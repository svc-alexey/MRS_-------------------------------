	ПЛ_Запрос.УстановитьПараметр("Ссылка", ДокументВыпускБлюд.Ссылка);
	
	ПЛ_ВтЗапроса = ПЛ_Запрос.ВыполнитьПакетСПромежуточнымиДанными();
