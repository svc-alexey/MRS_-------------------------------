		Если ТекРежимЗаписиДвижениеПродукции <> РежимЗаписиДокумента.ОтменаПроведения И НЕ СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
			ЗаполнитьСерииТиповогоДокумента(ТекДокументПеремещения, ДокументВыпускБлюд, 1);
		КонецЕсли;
		//-Серии
		
		//+ОтложенноеПроведение
		Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
			ИсходныйРежимЗаписиДвижениеПродукции	= ТекРежимЗаписиДвижениеПродукции;
			ТекРежимЗаписиДвижениеПродукции			= РежимЗаписиДокумента.Запись;
		КонецЕсли;
		//-ОтложенноеПроведение
		
		Попытка
			ТекДокументПеремещения.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
			Если ЗначениеЗаполнено(ДокументВыпускБлюд.ДокументОснование) И ТипЗнч(ДокументВыпускБлюд.ДокументОснование) = Тип("ДокументСсылка.питПланМеню") Тогда
				ТекДокументПеремещения.ДополнительныеСвойства.Вставить("питДокументОбщепитРаспределениеЗапасов", ДокументВыпускБлюд);
			КонецЕсли;
			ТекДокументПеремещения.Записать(ТекРежимЗаписиДвижениеПродукции);
		Исключение
			ТекстОшибки = ТекстОшибки + "
			|Ошибка записи документа """ + ТекДокументПеремещения.Метаданные().Представление() + """
			| по документу Общепит """+ДокументВыпускБлюд+"""
			|по причине: <"+ОписаниеОшибки()+">";
			Возврат Ложь;
		КонецПопытки;
		
		//+ОтложенноеПроведение
		Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
			ТекДействие = ПолучитьТекущееДействиеПоРежимузаписиТиповогоДокумента(ИсходныйРежимЗаписиДвижениеПродукции);
			ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ТекДействие, ТекДокументПеремещения.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
			СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
			Если НЕ ВсеОк Тогда 
				Возврат ВсеОк;
			КонецЕсли;
			ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.УстановитьСинхронизациюТиповогоДокумента, ТекДокументПеремещения.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
			СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
			Если НЕ ВсеОк Тогда 
				Возврат ВсеОк;
			КонецЕсли;
		КонецЕсли;
		//-ОтложенноеПроведение
		
		//+ОтложенноеПроведение
		ТекСинхронизирован = ?(СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд, Ложь, Истина);
		//-ОтложенноеПроведение
		
		// Добавление записи в результирующую таблицу в случае успешной записи документов.
		ДобавитьНовуюЗапись(ДокументВыпускБлюд, ТекДокументПеремещения, тблСозданныеДокументы, 1, ТекСинхронизирован);
		
	КонецЕсли;
	
	// Если документ найден, то получаем объект иначе создаем новый.
	ТекДокументПеремещения = Неопределено;
	Если НЕ ВыборкаДокПеремещения = Неопределено И ВыборкаДокПеремещения.Следующий() Тогда
		ТекДокументПеремещения = ВыборкаДокПеремещения.ТиповойДокумент.ПолучитьОбъект();
		
		
		// Определение параметров записи.
		ПараметрыЗаписиДокПеремещения = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокументВыпускБлюд.Проведен,ДокументВыпускБлюд.ПометкаУдаления,
		ТекДокументПеремещения.Проведен,ТекДокументПеремещения.ПометкаУдаления, Новый Структура);
		
		// Определение режима записи
		ТекРежимЗаписиДвижениеПродукции = ПараметрыЗаписиДокПеремещения.РежимЗаписи;
		
		Если ПараметрыЗаписиДокПеремещения.НужнаУстановкаПометкиУдаления Тогда
			
			//+ОтложенноеПроведение
			Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
				ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ПолучитьТекущееДействиеПоПометкеУдаленияТиповогоДокумента(ПараметрыЗаписи.ПометкаУдаления), ТекДокументПеремещения.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
				СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
				Если НЕ ВсеОк Тогда 
					Возврат ВсеОк;
				КонецЕсли;
				ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.УстановитьСинхронизациюТиповогоДокумента, ТекДокументПеремещения.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
				СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
				Если НЕ ВсеОк Тогда 
					Возврат ВсеОк;
				КонецЕсли;
			Иначе
			//-ОтложенноеПроведение
				
				Попытка
					ТекДокументПеремещения.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
					Если ЗначениеЗаполнено(ДокументВыпускБлюд.ДокументОснование) И ТипЗнч(ДокументВыпускБлюд.ДокументОснование) = Тип("ДокументСсылка.питПланМеню") Тогда
						ТекДокументПеремещения.ДополнительныеСвойства.Вставить("питДокументОбщепитРаспределениеЗапасов", ДокументВыпускБлюд);
					КонецЕсли;
					ТекДокументПеремещения.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
				Исключение
					ТекстОшибки = ТекстОшибки + "
					|Ошибка при установке пометки удаления """ + ТекДокументПеремещения.Метаданные().Представление() + """
					| по документу Общепит """+ДокументВыпускБлюд+"""
					|по причине: <"+ОписаниеОшибки()+">";
					Возврат Ложь;
				КонецПопытки;
				
			КонецЕсли;
			
		КонецЕсли;
		
		//+ОтложенноеПроведение
		ТекСинхронизирован = ?(СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд, Ложь, Истина);
		//-ОтложенноеПроведение
		
		// Добавление записи в результирующую таблицу в случае успешной записи документов.
		ДобавитьНовуюЗапись(ДокументВыпускБлюд, ТекДокументПеремещения, тблСозданныеДокументы, 1,ТекСинхронизирован);
		
	КонецЕсли;
	//-ДВИЖЕНИЕ ПРОДУКЦИИ И МАТЕРИАЛОВ 22
	
	/////////////////////////////////////////////////////////
	// ЗАПИСЬ ДОКУМЕНТА
	
	Если НЕ(ТекРежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения И ПустаяСтрока(ТекДокументОбъект.ВерсияДанных)) Тогда
		
		//+Серии
		Если ТекРежимЗаписи <> РежимЗаписиДокумента.ОтменаПроведения И НЕ СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
			ПараметрыУказанияСерий = Новый ФиксированнаяСтруктура(НоменклатураСервер.ПараметрыУказанияСерий(ТекДокументОбъект, Документы.РеализацияТоваровУслуг));
			ЗаполнитьСерииТиповогоДокумента(ТекДокументОбъект, ДокументВыпускБлюд);
		КонецЕсли;
		//-Серии
		
		//+ОтложенноеПроведение
		Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
			ИсходныйРежимЗаписи	= ТекРежимЗаписи;
			ТекРежимЗаписи		= РежимЗаписиДокумента.Запись;
		КонецЕсли;
		//-ОтложенноеПроведение
		
		Попытка
			//ТекДокументОбъект.ЗаполнитьЭтапыГрафикаОплаты();
			ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
			ТекДокументОбъект.Записать(ТекРежимЗаписи);
		Исключение
			ТекстОшибки = ТекстОшибки + "
			|Ошибка записи документа """ + ТекДокументОбъект.Метаданные().Представление() + """
			| по документу Общепит """+ДокументВыпускБлюд+"""
			|по причине: <"+ОписаниеОшибки()+">";
			Возврат Ложь;
		КонецПопытки;
		
		//+ОтложенноеПроведение
		Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
			ТекДействие = ПолучитьТекущееДействиеПоРежимузаписиТиповогоДокумента(ИсходныйРежимЗаписи);
			ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ТекДействие, ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
			СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
			Если НЕ ВсеОк Тогда 
				Возврат ВсеОк;
			КонецЕсли;
			ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.УстановитьСинхронизациюТиповогоДокумента, ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
			СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
			Если НЕ ВсеОк Тогда 
				Возврат ВсеОк;
			КонецЕсли;
		КонецЕсли;
		//-ОтложенноеПроведение
		
		//+ОтложенноеПроведение
		ТекСинхронизирован = ?(СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд, Ложь, Истина);
		//-ОтложенноеПроведение
		
		// Добавление записи в результирующую таблицу в случае успешной записи документов.
		ДобавитьНовуюЗапись(ДокументВыпускБлюд, ТекДокументОбъект, тблСозданныеДокументы,,ТекСинхронизирован);
		
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

// Функция формирует документ "Перемещение товаров" для выпуска с перемещением.
//
// Параметры:
//  ДокументВыпускБлюд		 - ДокументСсылка	 - Ссылка на документ "Выпуск блюд", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьПеремещениеТоваровПоВыпускуБлюд(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки)
	
	//Возврат Истина; // {debug}
	
	//+БазовоеСмещение
	Если НЕ СтруктураПараметров.Свойство("питСмещатьДатыТиповыхДокументов") Тогда
		СтруктураПараметров.Вставить("питСмещатьДатыТиповыхДокументов", питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питСмещатьДатыТиповыхДокументов"));
	КонецЕсли;
	БазовоеСмещение = 0;
	Если СтруктураПараметров.питСмещатьДатыТиповыхДокументов Тогда
		СтрокиСмещение = СтруктураПараметров.ТаблицаПорядокПроведенияТиповыхДокументовВыпускаБлюд.НайтиСтроки(
		Новый Структура("ИмяТиповогоДокумента,ПричинаТиповогоДокумента", "ПеремещениеТоваров", 0));
		Если СтрокиСмещение.Количество() Тогда
			БазовоеСмещение = СтрокиСмещение[0].БазовоеСмещение;
		КонецЕсли;
	КонецЕсли;
	//-БазовоеСмещение
	
	Запрос = Новый Запрос;
	
	// Поиск существующего документа "Отчет о розничных продажах",
	// связанного с текущим "Выпуском блюд".
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питТиповыеДокументы.ТиповойДокумент
	|ПОМЕСТИТЬ втДокументыВыпускПродукции
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|	И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.ПеремещениеТоваров
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втДокументыВыпускПродукции.ТиповойДокумент
	|ИЗ
	|	втДокументыВыпускПродукции КАК втДокументыВыпускПродукции
	|";
	Запрос.УстановитьПараметр("Документпит",				ДокументВыпускБлюд);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	// Если документ найден, то получаем объект иначе создаем новый.
	Если Выборка.Следующий() Тогда
		ТекДокументОбъект = Выборка.ТиповойДокумент.ПолучитьОбъект();
	Иначе
		ТекДокументОбъект = Документы.ПеремещениеТоваров.СоздатьДокумент();
	КонецЕсли;
	
	// Определение параметров записи.
	ПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокументВыпускБлюд.Проведен,ДокументВыпускБлюд.ПометкаУдаления,
		ТекДокументОбъект.Проведен,ТекДокументОбъект.ПометкаУдаления,СтруктураПараметров);
	
	// Определение режима записи
	ТекРежимЗаписи = ПараметрыЗаписи.РежимЗаписи;
	
	Если ПараметрыЗаписи.НужнаУстановкаПометкиУдаления Тогда
		
		//+ОтложенноеПроведение
		Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
			ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ПолучитьТекущееДействиеПоПометкеУдаленияТиповогоДокумента(ПараметрыЗаписи.ПометкаУдаления), ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
			СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
			Если НЕ ВсеОк Тогда 
				Возврат ВсеОк;
			КонецЕсли;
		Иначе
		//-ОтложенноеПроведение
			
			Попытка
				ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
				Если ЗначениеЗаполнено(ДокументВыпускБлюд.ДокументОснование) И ТипЗнч(ДокументВыпускБлюд.ДокументОснование) = Тип("ДокументСсылка.питПланМеню") Тогда
					ТекДокументОбъект.ДополнительныеСвойства.Вставить("питДокументОбщепитРаспределениеЗапасов", ДокументВыпускБлюд);
				КонецЕсли;
				ТекДокументОбъект.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
			Исключение
				ТекстОшибки = ТекстОшибки + "
				|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
				| по документу Общепит """+ДокументВыпускБлюд+"""
				|по причине: <"+ОписаниеОшибки()+">";
				Возврат Ложь;
			КонецПопытки;
			
		КонецЕсли;
		
	КонецЕсли;
	
	///////////////////////////
	// ЗАПОЛНЕНИЕ ШАПКИ
	ЗаполнитьШапкуПеремещенияТоваровПоВыпускуБлюд(ТекДокументОбъект, ДокументВыпускБлюд, СтруктураПараметров, БазовоеСмещение);
	ОчиститьТабличныеЧастиПеремещенияТоваров(ТекДокументОбъект);
	
	// Получение данных по табличной части "Ингредиенты" отраслевого документа "Выпуск блюд".
	Запрос = Новый Запрос;
	
	//>>Швецов. 19.12.2024. Розничные продажи алкоголя
	//Запрос.Текст = "ВЫБРАТЬ
	//|	питВыпускБлюдТовары.Номенклатура,
	//|	питВыпускБлюдТовары.Характеристика,
	//|	ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка) КАК Серия, // Будем по FEFO определять дальше
	//|	питВыпускБлюдТовары.Назначение,
	//|	питВыпускБлюдТовары.Упаковка,
	//|	питВыпускБлюдТовары.Количество,
	//|	питВыпускБлюдТовары.КоличествоУпаковок
	//|ИЗ
	//|	Документ.питВыпускБлюд.Товары КАК питВыпускБлюдТовары
	//|ГДЕ
	//|	питВыпускБлюдТовары.Ссылка = &Ссылка
	//|	И питВыпускБлюдТовары.Номенклатура.ТипНоменклатуры В (&СкладскиеТипыНоменклатуры)";
	
	Запрос.Текст = "ВЫБРАТЬ
		|	питВыпускБлюдТовары.Номенклатура КАК Номенклатура,
		|	питВыпускБлюдТовары.Характеристика КАК Характеристика,
		|	ВЫБОР
		|		КОГДА питВыпускБлюдТовары.Номенклатура.АлкогольнаяПродукция
		|				И НЕ питВыпускБлюдТовары.Номенклатура.АлкогольнаяПродукцияВоВскрытойТаре
		|			ТОГДА питВыпускБлюдТовары.Серия
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)
		|	КОНЕЦ КАК Серия,
		|	питВыпускБлюдТовары.Назначение КАК Назначение,
		|	питВыпускБлюдТовары.Упаковка КАК Упаковка,
		|	питВыпускБлюдТовары.Количество КАК Количество,
		|	питВыпускБлюдТовары.КоличествоУпаковок КАК КоличествоУпаковок
		|ИЗ
		|	Документ.питВыпускБлюд.Товары КАК питВыпускБлюдТовары
		|ГДЕ
		|	питВыпускБлюдТовары.Ссылка = &Ссылка
		|	И питВыпускБлюдТовары.Номенклатура.ТипНоменклатуры В(&СкладскиеТипыНоменклатуры)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	питВыпускБлюдТоварыСерии.Серия КАК Серия,
		|	питВыпускБлюдТоварыСерии.Количество КАК Количество,
		|	питВыпускБлюдТоварыСерии.Номенклатура КАК Номенклатура,
		|	питВыпускБлюдТоварыСерии.Характеристика КАК Характеристика,
		|	питВыпускБлюдТоварыСерии.Назначение КАК Назначение
		|ИЗ
		|	Документ.питВыпускБлюд.ТоварыСерии КАК питВыпускБлюдТоварыСерии
		|ГДЕ
		|	питВыпускБлюдТоварыСерии.Ссылка = &Ссылка
		|	И питВыпускБлюдТоварыСерии.Номенклатура.ТипНоменклатуры В(&СкладскиеТипыНоменклатуры)
		|;";
	
	Запрос.УстановитьПараметр("Ссылка", ДокументВыпускБлюд.Ссылка);
	
	СкладскиеТипыНоменклатуры = питОбщегоНазначения.ПолучитьСкладскиеТипыНоменклатуры();
	Запрос.УстановитьПараметр("СкладскиеТипыНоменклатуры", СкладскиеТипыНоменклатуры);
	
	// Обход таб. части и заполнение таб. частей "Товары" документа "Передача материалов в производство".
	//Выборка = Запрос.Выполнить().Выбрать();
	
	Пакет = Запрос.ВыполнитьПакет();
	ВыборкаТовары = Пакет[0].Выбрать();
	ВыборкаСерии = Пакет[1].Выбрать();
	
	Пока ВыборкаТовары.Следующий() Цикл
		
		НовСтрока						= ТекДокументОбъект.Товары.Добавить();
		НовСтрока.Номенклатура			= ВыборкаТовары.Номенклатура;
		НовСтрока.Характеристика		= ВыборкаТовары.Характеристика;
		НовСтрока.Серия					= ВыборкаТовары.Серия;
		НовСтрока.Назначение			= ВыборкаТовары.Назначение;
		НовСтрока.Упаковка				= ВыборкаТовары.Упаковка;
		НовСтрока.КоличествоУпаковок	= ВыборкаТовары.КоличествоУпаковок;
		НовСтрока.Количество			= ВыборкаТовары.Количество;
		
	КонецЦикла;
	
	Если ВыборкаСерии.Количество() <> 0 Тогда
		Пока ВыборкаСерии.Следующий() Цикл
			
			НовСтрокаСерии						= ТекДокументОбъект.Серии.Добавить();
			НовСтрокаСерии.Номенклатура			= ВыборкаСерии.Номенклатура;
			НовСтрокаСерии.Характеристика		= ВыборкаСерии.Характеристика;
			НовСтрокаСерии.Серия				= ВыборкаСерии.Серия;
			НовСтрокаСерии.Назначение			= ВыборкаСерии.Назначение;
			НовСтрокаСерии.Количество			= ВыборкаСерии.Количество;
			
		КонецЦикла;
	КонецЕсли;		
	//<<Швецов. 19.12.2024. Розничные продажи алкоголя

	/////////////////////////////////////////////////////////
	// ЗАПИСЬ ДОКУМЕНТА
	
	//+ОтложенноеПроведение
	Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
		ИсходныйРежимЗаписи	= ТекРежимЗаписи;
		ТекРежимЗаписи		= РежимЗаписиДокумента.Запись;
	КонецЕсли;
	//-ОтложенноеПроведение
	
	Попытка
		
		//+Серии
		Если ТекРежимЗаписи <> РежимЗаписиДокумента.ОтменаПроведения И НЕ СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
			ЗаполнитьСерииТиповогоДокумента(ТекДокументОбъект, ДокументВыпускБлюд);
		КонецЕсли;
		//-Серии
		
		ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
		Если ЗначениеЗаполнено(ДокументВыпускБлюд.ДокументОснование) И ТипЗнч(ДокументВыпускБлюд.ДокументОснование) = Тип("ДокументСсылка.питПланМеню") Тогда
			ТекДокументОбъект.ДополнительныеСвойства.Вставить("питДокументОбщепитРаспределениеЗапасов", ДокументВыпускБлюд);
		КонецЕсли;
		ТекДокументОбъект.Записать(ТекРежимЗаписи);
	Исключение
		ТекстОшибки = ТекстОшибки + "
		|Ошибка записи документа """ + ТекДокументОбъект.Метаданные().Представление() + """
		| по документу Общепит """+ДокументВыпускБлюд+"""
		|по причине: <"+ОписаниеОшибки()+">";
		Возврат Ложь;
	КонецПопытки;
	
	//+ОтложенноеПроведение
	Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
		ТекДействие = ПолучитьТекущееДействиеПоРежимузаписиТиповогоДокумента(ИсходныйРежимЗаписи);
		ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ТекДействие, ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
		СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
		ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.УстановитьСинхронизациюТиповогоДокумента, ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
		СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
	КонецЕсли;
	//-ОтложенноеПроведение
	
	//+ОтложенноеПроведение
	ТекСинхронизирован = ?(СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд, Ложь, Истина);
	//-ОтложенноеПроведение
	
	// Добавление записи в результирующую таблицу в случае успешной записи документов.
	ДобавитьНовуюЗапись(ДокументВыпускБлюд, ТекДокументОбъект, тблСозданныеДокументы,,ТекСинхронизирован);
	
	Возврат Истина;
	
КонецФункции

// Функция формирует документ "Перемещение товаров" для выпуска с перемещением.
//
// Параметры:
//  ДокументВыпускБлюд		 - ДокументСсылка	 - Ссылка на документ "Выпуск блюд", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьПеремещениеИзКладовойПоВыпускуБлюд(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки)
	
	//Возврат Истина; // {debug}
	
	//+БазовоеСмещение
	Если НЕ СтруктураПараметров.Свойство("питСмещатьДатыТиповыхДокументов") Тогда
		СтруктураПараметров.Вставить("питСмещатьДатыТиповыхДокументов", питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питСмещатьДатыТиповыхДокументов"));
	КонецЕсли;
	БазовоеСмещение = 0;
	Если СтруктураПараметров.питСмещатьДатыТиповыхДокументов Тогда
		СтрокиСмещение = СтруктураПараметров.ТаблицаПорядокПроведенияТиповыхДокументовВыпускаБлюд.НайтиСтроки(
		Новый Структура("ИмяТиповогоДокумента,ПричинаТиповогоДокумента", "ДвижениеПродукцииИМатериалов", 3));
		Если СтрокиСмещение.Количество() Тогда
			БазовоеСмещение = СтрокиСмещение[0].БазовоеСмещение;
		КонецЕсли;
	КонецЕсли;
	//-БазовоеСмещение
	
	Запрос = Новый Запрос;
	
	// Поиск существующего документа,
	// связанного с текущим "Выпуском блюд".
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питТиповыеДокументы.ТиповойДокумент
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|	И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.ДвижениеПродукцииИМатериалов
	|	И питТиповыеДокументы.ПричинаТиповогоДокумента = 3
	|";
	Запрос.УстановитьПараметр("Документпит",				ДокументВыпускБлюд);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	// Если документ найден, то получаем объект иначе создаем новый.
	Если Выборка.Следующий() Тогда
		ТекДокументОбъект = Выборка.ТиповойДокумент.ПолучитьОбъект();
	Иначе
		ТекДокументОбъект = Документы.ДвижениеПродукцииИМатериалов.СоздатьДокумент();
	КонецЕсли;
	
	// Определение параметров записи.
	ПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокументВыпускБлюд.Проведен,ДокументВыпускБлюд.ПометкаУдаления,
		ТекДокументОбъект.Проведен,ТекДокументОбъект.ПометкаУдаления,СтруктураПараметров);
	
	// Определение режима записи
	ТекРежимЗаписи = ПараметрыЗаписи.РежимЗаписи;
	
	Если ПараметрыЗаписи.НужнаУстановкаПометкиУдаления Тогда
		
		//+ОтложенноеПроведение
		Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
			ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ПолучитьТекущееДействиеПоПометкеУдаленияТиповогоДокумента(ПараметрыЗаписи.ПометкаУдаления), ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
			СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
			Если НЕ ВсеОк Тогда 
				Возврат ВсеОк;
			КонецЕсли;
		Иначе
		//-ОтложенноеПроведение
			
			Попытка
				ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
				Если ЗначениеЗаполнено(ДокументВыпускБлюд.ДокументОснование) И ТипЗнч(ДокументВыпускБлюд.ДокументОснование) = Тип("ДокументСсылка.питПланМеню") Тогда
					ТекДокументОбъект.ДополнительныеСвойства.Вставить("питДокументОбщепитРаспределениеЗапасов", ДокументВыпускБлюд);
				КонецЕсли;
				ТекДокументОбъект.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
			Исключение
				ТекстОшибки = ТекстОшибки + "
				|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
				| по документу Общепит """+ДокументВыпускБлюд+"""
				|по причине: <"+ОписаниеОшибки()+">";
				Возврат Ложь;
			КонецПопытки;
			
		КонецЕсли;
		
	КонецЕсли;
	
	/////////////////////////////////
	// ЗАПОЛНЕНИЕ ШАПКИ.
	ТекДокументОбъект.Дата							= ДокументВыпускБлюд.Дата 
	+ ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0)
	- БазовоеСмещение;
	ТекДокументОбъект.Организация					= ДокументВыпускБлюд.Организация;
	ТекДокументОбъект.Отправитель					= ДокументВыпускБлюд.Склад;
	ТекДокументОбъект.Получатель					= ДокументВыпускБлюд.СкладПолучатель;
	ТекДокументОбъект.Ответственный					= ДокументВыпускБлюд.Ответственный;
	ТекДокументОбъект.Комментарий					= ДокументВыпускБлюд.Комментарий;
	ТекДокументОбъект.Статус						= Перечисления.СтатусыДвиженияПродукцииИМатериалов.Принято;
	ТекДокументОбъект.ХозяйственнаяОперация			= Перечисления.ХозяйственныеОперации.ПередачаПродукцииИзКладовой;
	ТекДокументОбъект.НаправлениеДеятельности		= ДокументВыпускБлюд.НаправлениеДеятельности;
	//+25
	ТекДокументОбъект.Валюта						= ?(ЗначениеЗаполнено(ДокументВыпускБлюд.Валюта), ДокументВыпускБлюд.Валюта, Константы.ВалютаРегламентированногоУчета.Получить());
	ТекДокументОбъект.ВариантПриемкиТоваров			= Перечисления.ВариантыПриемкиТоваров.РазделенаТолькоПоНакладным;
	//-25
	
	// Автоопределение значения налогообложения НДС.
	ТекДокументОбъект.НалогообложениеНДС	= ?(СтруктураПараметров.Свойство("НалогообложениеНДС"), СтруктураПараметров.НалогообложениеНДС, Неопределено);
	
	// Очистка табличных частей для избежания дублирования информации.
	ТекДокументОбъект.Товары.Очистить();
	ТекДокументОбъект.Серии.Очистить();
	ТекДокументОбъект.ВидыЗапасов.Очистить();
	ТекДокументОбъект.ДополнительныеРеквизиты.Очистить();
	
	// Получение данных по табличной части "Ингредиенты" отраслевого документа "Выпуск блюд".
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	питВыпускБлюдТовары.Номенклатура,
	|	питВыпускБлюдТовары.Характеристика,
	|	ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка) КАК Серия, // Будем по FEFO определять дальше
	|	питВыпускБлюдТовары.Назначение,
	|	питВыпускБлюдТовары.Упаковка,
	|	питВыпускБлюдТовары.Количество,
	|	питВыпускБлюдТовары.КоличествоУпаковок
	|ИЗ
	|	Документ.питВыпускБлюд.Товары КАК питВыпускБлюдТовары
	|ГДЕ
	|	питВыпускБлюдТовары.Ссылка = &Ссылка
	|	И питВыпускБлюдТовары.Номенклатура.ТипНоменклатуры В (&СкладскиеТипыНоменклатуры)";
	Запрос.УстановитьПараметр("Ссылка", ДокументВыпускБлюд.Ссылка);
	
	СкладскиеТипыНоменклатуры = питОбщегоНазначения.ПолучитьСкладскиеТипыНоменклатуры();
	Запрос.УстановитьПараметр("СкладскиеТипыНоменклатуры", СкладскиеТипыНоменклатуры);
	
	// Обход таб. части и заполнение таб. частей "Товары" документа "Передача материалов в производство".
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		НовСтрока						= ТекДокументОбъект.Товары.Добавить();
		НовСтрока.Номенклатура			= Выборка.Номенклатура;
		НовСтрока.Характеристика		= Выборка.Характеристика;
		НовСтрока.Серия					= Справочники.СерииНоменклатуры.ПустаяСсылка(); // Серии заполнятся по FEFO позже
		НовСтрока.Назначение			= Выборка.Назначение;
		НовСтрока.НазначениеОтправителя	= Выборка.Назначение;
		НовСтрока.Упаковка				= Выборка.Упаковка;
		НовСтрока.КоличествоУпаковок	= Выборка.КоличествоУпаковок;
		НовСтрока.Количество			= Выборка.Количество;    
		НовСтрока.ИдентификаторСтроки	= Новый УникальныйИдентификатор;
		
	КонецЦикла;
	
	/////////////////////////////////////////////////////////
	// ЗАПИСЬ ДОКУМЕНТА
	
	//+ОтложенноеПроведение
	Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
		ИсходныйРежимЗаписи	= ТекРежимЗаписи;
		ТекРежимЗаписи		= РежимЗаписиДокумента.Запись;
	КонецЕсли;
	//-ОтложенноеПроведение
	
	Попытка
		
		//+Серии
		Если ТекРежимЗаписи <> РежимЗаписиДокумента.ОтменаПроведения И НЕ СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
			ЗаполнитьСерииТиповогоДокумента(ТекДокументОбъект, ДокументВыпускБлюд, 3);
		КонецЕсли;
		//-Серии
		
		ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
		Если ЗначениеЗаполнено(ДокументВыпускБлюд.ДокументОснование) И ТипЗнч(ДокументВыпускБлюд.ДокументОснование) = Тип("ДокументСсылка.питПланМеню") Тогда
			ТекДокументОбъект.ДополнительныеСвойства.Вставить("питДокументОбщепитРаспределениеЗапасов", ДокументВыпускБлюд);
		КонецЕсли;
		ТекДокументОбъект.Записать(ТекРежимЗаписи);
	Исключение
		ТекстОшибки = ТекстОшибки + "
		|Ошибка записи документа """ + ТекДокументОбъект.Метаданные().Представление() + """
		| по документу Общепит """+ДокументВыпускБлюд+"""
		|по причине: <"+ОписаниеОшибки()+">";
		Возврат Ложь;
	КонецПопытки;
	
	//+ОтложенноеПроведение
	Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
		ТекДействие = ПолучитьТекущееДействиеПоРежимузаписиТиповогоДокумента(ИсходныйРежимЗаписи);
		ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ТекДействие, ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
		СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
		ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.УстановитьСинхронизациюТиповогоДокумента, ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
		СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
	КонецЕсли;
	//-ОтложенноеПроведение
	
	//+ОтложенноеПроведение
	ТекСинхронизирован = ?(СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд, Ложь, Истина);
	//-ОтложенноеПроведение
	
	// Добавление записи в результирующую таблицу в случае успешной записи документов.
	ДобавитьНовуюЗапись(ДокументВыпускБлюд, ТекДокументОбъект, тблСозданныеДокументы, 3, ТекСинхронизирован);
	
	Возврат Истина;
	
КонецФункции

// Функция формирует документ "Отчет о розничных продажах" для выпуска с розничной реализацией.
//
// Параметры:
//  ДокументВыпускБлюд		 - ДокументСсылка	 - Ссылка на документ "Выпуск блюд", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьВнутреннееПотреблениеТоваровПоВыпускуБлюд(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки)
	
	ИмяДокументаВнутреннееПотребление = питОбратнаяСовместимостьПовтИсп.ИмяДокументаВнутреннееПотребление();
	
	//+БазовоеСмещение
	Если НЕ СтруктураПараметров.Свойство("питСмещатьДатыТиповыхДокументов") Тогда
		СтруктураПараметров.Вставить("питСмещатьДатыТиповыхДокументов", питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питСмещатьДатыТиповыхДокументов"));
	КонецЕсли;
	БазовоеСмещение = 0;
	Если СтруктураПараметров.питСмещатьДатыТиповыхДокументов Тогда
		СтрокиСмещение = СтруктураПараметров.ТаблицаПорядокПроведенияТиповыхДокументовВыпускаБлюд.НайтиСтроки(
		Новый Структура("ИмяТиповогоДокумента,ПричинаТиповогоДокумента", ИмяДокументаВнутреннееПотребление, 0));
		Если СтрокиСмещение.Количество() Тогда
			БазовоеСмещение = СтрокиСмещение[0].БазовоеСмещение;
		КонецЕсли;
	КонецЕсли;
	//-БазовоеСмещение
	
	Запрос = Новый Запрос;
	
	// Поиск существующего документа "Списание недостач товаров",
	// связанного с текущим "Выпуском блюд".
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питТиповыеДокументы.ТиповойДокумент
	|ПОМЕСТИТЬ втДокументыВыпускПродукции
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|	И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.ВнутреннееПотребление
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втДокументыВыпускПродукции.ТиповойДокумент
	|ИЗ
	|	втДокументыВыпускПродукции КАК втДокументыВыпускПродукции";
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "Документ.ВнутреннееПотребление", СтрШаблон("Документ.%1", ИмяДокументаВнутреннееПотребление));
	Запрос.УстановитьПараметр("Документпит",				ДокументВыпускБлюд);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	// Если документ найден, то получаем объект иначе создаем новый.
	Если Выборка.Следующий() Тогда
		ТекДокументОбъект = Выборка.ТиповойДокумент.ПолучитьОбъект();
		ЭтоНовый = Ложь;
	Иначе
		ЭтоНовый = Истина;
		ТекДокументОбъект = Документы[ИмяДокументаВнутреннееПотребление].СоздатьДокумент();
	КонецЕсли;
	
	// Определение параметров записи.
	ПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокументВыпускБлюд.Проведен,ДокументВыпускБлюд.ПометкаУдаления,
		ТекДокументОбъект.Проведен,ТекДокументОбъект.ПометкаУдаления,СтруктураПараметров);
	
	// Определение режима записи
	ТекРежимЗаписи = ПараметрыЗаписи.РежимЗаписи;
	
	// Для нового дока отменять проведения не требуется.
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения
		И ЭтоНовый Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ПараметрыЗаписи.НужнаУстановкаПометкиУдаления Тогда
		
		//+ОтложенноеПроведение
		Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
			ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ПолучитьТекущееДействиеПоПометкеУдаленияТиповогоДокумента(ПараметрыЗаписи.ПометкаУдаления), ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
			СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
			Если НЕ ВсеОк Тогда 
				Возврат ВсеОк;
			КонецЕсли;
		Иначе
		//-ОтложенноеПроведение
			
			Попытка
				ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
				ТекДокументОбъект.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
			Исключение
				ТекстОшибки = ТекстОшибки + "
				|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
				| по документу Общепит """+ДокументВыпускБлюд+"""
				|по причине: <"+ОписаниеОшибки()+">";
				Возврат Ложь;
			КонецПопытки;
			
		КонецЕсли;
		
	КонецЕсли;
	
	/////////////////////////////////
	// ЗАПОЛНЕНИЕ ШАПКИ.
	ТекДокументОбъект.Дата								= ДокументВыпускБлюд.Дата 
	+ ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0)
	- БазовоеСмещение;
	ТекДокументОбъект.Организация						= ДокументВыпускБлюд.Организация;
	ТекДокументОбъект.Склад								= ДокументВыпускБлюд.Склад;
	ТекДокументОбъект.Подразделение						= ДокументВыпускБлюд.Подразделение;
	ТекДокументОбъект.Ответственный						= ДокументВыпускБлюд.Ответственный;
	ТекДокументОбъект.Комментарий						= ДокументВыпускБлюд.Комментарий;
	//+25
	//ТекДокументОбъект.ДатаРаспоряжения					= КонецДня(ДокументВыпускБлюд.Дата);
	//-25
	ТекДокументОбъект.ВидЦены							= ДокументВыпускБлюд.ТипЦен;
	ТекДокументОбъект.ХозяйственнаяОперация				= Перечисления.ХозяйственныеОперации.СписаниеТоваровПоТребованию;
	ТекДокументОбъект.НаправлениеДеятельности			= ДокументВыпускБлюд.НаправлениеДеятельности;
	
	// Очистка табличных частей, т.к. будет их перезаполнение.
	ТекДокументОбъект.Товары.Очистить();
	ТекДокументОбъект.Серии.Очистить();
	ТекДокументОбъект.ВидыЗапасов.Очистить();
	ТекДокументОбъект.ДополнительныеРеквизиты.Очистить(); 
	
	// << MRS #VINE-142 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 15.07.25, (Заполнение алкогольной лицензии по умолчанию)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	алкЛицензии.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.алкЛицензии КАК алкЛицензии
		|ГДЕ
		|	&ДатаДокумента МЕЖДУ алкЛицензии.ДатаНачалаСрокаДействия И алкЛицензии.ДатаОкончанияСрокаДействия
		|	И алкЛицензии.Владелец = &Владелец";
	
	Запрос.УстановитьПараметр("Владелец", ТекДокументОбъект.Организация);
	Запрос.УстановитьПараметр("ДатаДокумента", ТекДокументОбъект.Дата);

	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		ТекДокументОбъект.алкЛицензияОрганизации = ВыборкаДетальныеЗаписи.Ссылка;
	КонецЕсли;
	// >> MRS #VINE-142 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 15.07.25, (Заполнение алкогольной лицензии по умолчанию)
	
	// Получение данных по табличной части "Товары" отраслевого документа "Выпуск блюд".
	Запрос = Новый Запрос;
	
	//>>Швецов. 19.12.2024. Розничные продажи алкоголя
	//Запрос.Текст = "ВЫБРАТЬ
	//|	питВыпускБлюдТовары.Номенклатура,
	//|	питВыпускБлюдТовары.Характеристика,
	//|	питВыпускБлюдТовары.Серия КАК Серия,
	//|	питВыпускБлюдТовары.Назначение,
	//|	питВыпускБлюдТовары.Упаковка,
	//|	питВыпускБлюдТовары.КоличествоУпаковок,
	//|	питВыпускБлюдТовары.Количество
	//|ИЗ
	//|	Документ.питВыпускБлюд.Товары КАК питВыпускБлюдТовары
	//|ГДЕ
	//|	питВыпускБлюдТовары.Ссылка = &Ссылка
	//|	И питВыпускБлюдТовары.Номенклатура.ТипНоменклатуры В (&СкладскиеТипыНоменклатуры)";
	
	Запрос.Текст = "ВЫБРАТЬ
		|	питВыпускБлюдТовары.Номенклатура КАК Номенклатура,
		|	питВыпускБлюдТовары.Характеристика КАК Характеристика,
		|	ВЫБОР
		|		КОГДА питВыпускБлюдТовары.Номенклатура.АлкогольнаяПродукция
		|				И НЕ питВыпускБлюдТовары.Номенклатура.АлкогольнаяПродукцияВоВскрытойТаре
		|			ТОГДА питВыпускБлюдТовары.Серия
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)
		|	КОНЕЦ КАК Серия,
		|	питВыпускБлюдТовары.Назначение КАК Назначение,
		|	питВыпускБлюдТовары.Упаковка КАК Упаковка,
		|	питВыпускБлюдТовары.Количество КАК Количество,
		|	питВыпускБлюдТовары.КоличествоУпаковок КАК КоличествоУпаковок
		|ИЗ
		|	Документ.питВыпускБлюд.Товары КАК питВыпускБлюдТовары
		|ГДЕ
		|	питВыпускБлюдТовары.Ссылка = &Ссылка
		|	И питВыпускБлюдТовары.Номенклатура.ТипНоменклатуры В(&СкладскиеТипыНоменклатуры)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	питВыпускБлюдТоварыСерии.Серия КАК Серия,
		|	питВыпускБлюдТоварыСерии.Количество КАК Количество,
		|	питВыпускБлюдТоварыСерии.Номенклатура КАК Номенклатура,
		|	питВыпускБлюдТоварыСерии.Характеристика КАК Характеристика,
		|	питВыпускБлюдТоварыСерии.Назначение КАК Назначение
		|ИЗ
		|	Документ.питВыпускБлюд.ТоварыСерии КАК питВыпускБлюдТоварыСерии
		|ГДЕ
		|	питВыпускБлюдТоварыСерии.Ссылка = &Ссылка
		|	И питВыпускБлюдТоварыСерии.Номенклатура.ТипНоменклатуры В(&СкладскиеТипыНоменклатуры)
		|;";
	
	Запрос.УстановитьПараметр("Ссылка", ДокументВыпускБлюд.Ссылка);
	
	СкладскиеТипыНоменклатуры = питОбщегоНазначения.ПолучитьСкладскиеТипыНоменклатуры();
	Запрос.УстановитьПараметр("СкладскиеТипыНоменклатуры", СкладскиеТипыНоменклатуры);
	
	// Обход таб. части и заполнение таб. частей "Товары" документа "Передача материалов в производство".
	//Выборка = Запрос.Выполнить().Выбрать();
	
	Пакет = Запрос.ВыполнитьПакет();
	ВыборкаТовары = Пакет[0].Выбрать();
	ВыборкаСерии = Пакет[1].Выбрать();
	
	// << MRS #ERP-5519 ДенисламовАД <Adel.Denislamov@mriyaresort.com> 20.11.25, ()
	ПричинаСписания = Справочники.MRS_ПричиныСписания.ПустаяСсылка();
	//Если ДокументВыпускБлюд.ПЛ_ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.питХозяйственныеОперации.ПЛ_ЗаборныйЛист") Тогда
		ПричинаСписания = MRS_СлужебныеПараметрыПовтИсп.ПолучитьЗначение("ПричинаСписанияДляСозданияВП_из_ЗаборногоЛиста","Значение");
	//КонецЕсли;
	// >> MRS #ERP-5519 ДенисламовАД <Adel.Denislamov@mriyaresort.com> 20.11.25, ()

	Пока ВыборкаТовары.Следующий() Цикл
		
		НовСтрока						= ТекДокументОбъект.Товары.Добавить();
		НовСтрока.Номенклатура			= ВыборкаТовары.Номенклатура;
		НовСтрока.Характеристика		= ВыборкаТовары.Характеристика;
		НовСтрока.Серия					= ВыборкаТовары.Серия;
		НовСтрока.Назначение			= ВыборкаТовары.Назначение;
		НовСтрока.Упаковка				= ВыборкаТовары.Упаковка;
		НовСтрока.КоличествоУпаковок	= ВыборкаТовары.КоличествоУпаковок;
		НовСтрока.Количество			= ВыборкаТовары.Количество;
		НовСтрока.СтатьяРасходов		= ДокументВыпускБлюд.СтатьяРасходов;
		// << MRS #ERP-5519 ДенисламовАД <Adel.Denislamov@mriyaresort.com> 20.11.25, ()
		НовСтрока.MRS_ПричиныСписания = ПричинаСписания;
		// >> MRS #ERP-5519 ДенисламовАД <Adel.Denislamov@mriyaresort.com> 20.11.25, ()
	КонецЦикла;
	
	Если ВыборкаСерии.Количество() <> 0 Тогда 
		Пока ВыборкаСерии.Следующий() Цикл
			
			НовСтрокаСерии						= ТекДокументОбъект.Серии.Добавить();
			НовСтрокаСерии.Номенклатура			= ВыборкаСерии.Номенклатура;
			НовСтрокаСерии.Характеристика		= ВыборкаСерии.Характеристика;
			НовСтрокаСерии.Серия				= ВыборкаСерии.Серия;
			НовСтрокаСерии.Назначение			= ВыборкаСерии.Назначение;
			НовСтрокаСерии.Количество			= ВыборкаСерии.Количество;
			
		КонецЦикла;
	КонецЕсли;	
	//<<Швецов. 19.12.2024. Розничные продажи алкоголя
	
	/////////////////////////////////////////////////////////
	// ЗАПИСЬ ДОКУМЕНТА
	
	//+ОтложенноеПроведение
	Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
		ИсходныйРежимЗаписи	= ТекРежимЗаписи;
		ТекРежимЗаписи		= РежимЗаписиДокумента.Запись;
	КонецЕсли;
	//-ОтложенноеПроведение
	
	Попытка
		
		//+Серии
		Если ТекРежимЗаписи <> РежимЗаписиДокумента.ОтменаПроведения И НЕ СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
			ЗаполнитьСерииТиповогоДокумента(ТекДокументОбъект, ДокументВыпускБлюд);
		КонецЕсли;
		//-Серии
		
		ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
		ТекДокументОбъект.Записать(ТекРежимЗаписи);
	Исключение
		ТекстОшибки = ТекстОшибки + "
		|Ошибка записи документа """ + ТекДокументОбъект.Метаданные().Представление() + """
		| по документу Общепит """+ДокументВыпускБлюд+"""
		|по причине: <"+ОписаниеОшибки()+">";
		Возврат Ложь;
	КонецПопытки;
	
	//+ОтложенноеПроведение
	Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
		ТекДействие = ПолучитьТекущееДействиеПоРежимузаписиТиповогоДокумента(ИсходныйРежимЗаписи);
		ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ТекДействие, ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
		СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
		ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.УстановитьСинхронизациюТиповогоДокумента, ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
		СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
	КонецЕсли;
	//-ОтложенноеПроведение
	
	//+ОтложенноеПроведение
	ТекСинхронизирован = ?(СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд, Ложь, Истина);
	//-ОтложенноеПроведение
	
	// Добавление записи в результирующую таблицу в случае успешной записи документов.
	ДобавитьНовуюЗапись(ДокументВыпускБлюд, ТекДокументОбъект, тблСозданныеДокументы,,ТекСинхронизирован);
	
	Возврат Истина;
	
КонецФункции

// Функция формирует документ "Корректировка остатков ИС" для выпуска блюд.
//
// Параметры:
//  ДокументВыпускБлюд		 - ДокументСсылка	 - Ссылка на документ "Выпуск блюд", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьКорректировкуОстатковИСПоВыпускуБлюд(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки)
	
	ДокументВыпускБлюдСсылка = ДокументВыпускБлюд;
	Если ТипЗнч(ДокументВыпускБлюд) = Тип("ДокументОбъект.питВыпускБлюд") Тогда
		ДокументВыпускБлюдСсылка = ДокументВыпускБлюд.Ссылка;
	КонецЕсли; 
	
	Запрос = Новый Запрос;
	
	// Поиск существующего документа 
	// связанного с текущим "Выпуском блюд".
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питТиповыеДокументы.ТиповойДокумент КАК ТиповойДокумент
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|	И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.питКорректировкаОстатковИС";
	Запрос.УстановитьПараметр("Документпит", ДокументВыпускБлюдСсылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	// Если документ найден, то получаем объект иначе создаем новый.
	Если Выборка.Следующий() Тогда
		ТекДокументОбъект = Выборка.ТиповойДокумент.ПолучитьОбъект();
	Иначе
		// для реализаций создаем только для модификаторов бизнес-ланчей
		ТекДокументОбъект = Документы.питКорректировкаОстатковИС.СоздатьДокумент();
		ТекДокументОбъект.Заполнить(Неопределено);
	КонецЕсли;
	
	// Определение параметров записи.
	ПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(
		ДокументВыпускБлюд.Проведен, 
		ДокументВыпускБлюд.ПометкаУдаления,
		ТекДокументОбъект.Проведен,
		ТекДокументОбъект.ПометкаУдаления,
		СтруктураПараметров);
		
	// Определение режима записи
	ТекРежимЗаписи = ПараметрыЗаписи.РежимЗаписи;
	
	// Возможно изменили политику списания, тогда документ более не актуальный.
	СпособСписанияМарок = Константы.питСписаниеМарокИСПриПроизводстве.Получить();
	Если НЕ ЗначениеЗаполнено(СпособСписанияМарок)
		ИЛИ СпособСписанияМарок = Перечисления.питСпособыСписанияМарокИСПриПроизводстве.НеИспользовать
		ИЛИ СпособСписанияМарок = Перечисления.питСпособыСписанияМарокИСПриПроизводстве.ИсключатьЦелевыеДокументы
		И РегистрыСведений.питУчетДанныхПродаж.ЭтоЦелевойДокумент(ДокументВыпускБлюдСсылка) Тогда
		
		Если НЕ ТекДокументОбъект.ЭтоНовый() Тогда
			
			//+ОтложенноеПроведение
			Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
				ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, 
				ПолучитьТекущееДействиеПоПометкеУдаленияТиповогоДокумента(ПараметрыЗаписи.ПометкаУдаления), 
					ТекДокументОбъект.Ссылка, 
					СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,
					ТекстОшибки);
				СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = 
					СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
				Если НЕ ВсеОк Тогда 
					Возврат ВсеОк;
				КонецЕсли;
			Иначе
			//-ОтложенноеПроведение
				Попытка
					ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
					ТекДокументОбъект.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
				Исключение
					ТекстОшибки = ТекстОшибки + "
					|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
					| по документу Общепит """+ДокументВыпускБлюдСсылка+"""
					|по причине: <"+ОписаниеОшибки()+">";
					Возврат Ложь;
				КонецПопытки;
			КонецЕсли;
			
		КонецЕсли;
		
		Возврат Истина;
	КонецЕсли;
	
	//УстановкаПометкиУдаления
	Если ПараметрыЗаписи.НужнаУстановкаПометкиУдаления Тогда
		
		Если НЕ ТекДокументОбъект.ЭтоНовый() Тогда
		
			//+ОтложенноеПроведение
			Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
				ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, 
					ПолучитьТекущееДействиеПоПометкеУдаленияТиповогоДокумента(ПараметрыЗаписи.ПометкаУдаления), 
					ТекДокументОбъект.Ссылка, 
					СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,
					ТекстОшибки);
				СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = 
					СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
				Если НЕ ВсеОк Тогда 
					Возврат ВсеОк;
				КонецЕсли;
			Иначе
			//-ОтложенноеПроведение
				Попытка
					ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
					ТекДокументОбъект.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
				Исключение
					ТекстОшибки = ТекстОшибки + "
					|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
					| по документу Общепит """+ДокументВыпускБлюд+"""
					|по причине: <"+ОписаниеОшибки()+">";
					Возврат Ложь;
				КонецПопытки;
			КонецЕсли;
		
		КонецЕсли;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питВыпускБлюд.Дата КАК Дата,
	|	питВыпускБлюд.Ответственный КАК Автор,
	|	питВыпускБлюд.Организация КАК Организация,
	|	питВыпускБлюд.Подразделение КАК Подразделение,
	|	питВыпускБлюд.Склад КАК Склад,
	|	питВыпускБлюд.Комментарий КАК Комментарий,
	|	ЕСТЬNULL(питПараметрыСкладовОбщепита.КонтролироватьОстаткиМарокИСПриПроведении, ЛОЖЬ) КАК КонтролироватьОстаткиМарокИСПриПроведении
	|ИЗ
	|	Документ.питВыпускБлюд КАК питВыпускБлюд
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.питПараметрыСкладовОбщепита КАК питПараметрыСкладовОбщепита
	|		ПО питВыпускБлюд.Склад = питПараметрыСкладовОбщепита.Склад
	|ГДЕ
	|	питВыпускБлюд.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", ДокументВыпускБлюдСсылка);
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	ДокументВыпускБлюдДанные = РезультатЗапроса[0].Выбрать();
	ДокументВыпускБлюдДанные.Следующий();
	
	/////////////////////////////////
	// ЗАПОЛНЕНИЕ ШАПКИ.
	ТекДокументОбъект.Дата = ДокументВыпускБлюдДанные.Дата + 
		?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0);
	ТекДокументОбъект.Организация = ДокументВыпускБлюдДанные.Организация;
	ТекДокументОбъект.Склад = ДокументВыпускБлюдДанные.Склад;
	ТекДокументОбъект.ДокументОснование = ДокументВыпускБлюдСсылка;
	ТекДокументОбъект.Комментарий = ДокументВыпускБлюдДанные.Комментарий;
	ТекДокументОбъект.Автор = ДокументВыпускБлюдДанные.Автор;
	ТекДокументОбъект.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.КорректировкаОстатковИСПриготовление;
	ТекДокументОбъект.Подразделение = ДокументВыпускБлюдДанные.Подразделение;
	
	Если Константы.питИспользоватьМаркиИСКассовыхСистемПриПроизводстве.Получить() Тогда
		ДоступныеМестаПечати = Справочники.питМестаПечати.МестаПечатиПоСтруктурнойЕдинице(ТекДокументОбъект.Склад);
	Иначе
		ДоступныеМестаПечати = Новый Массив;
	КонецЕсли;
	ДоступныеМестаПечати.Добавить(ТекДокументОбъект.Склад);
	
	Запрос = Новый Запрос;
	ТекстЗапроса ="ВЫБРАТЬ
	              |	втИнгредиенты.Ингредиент КАК Номенклатура,
	              |	втИнгредиенты.ИдентификаторБлюда КАК ИдентификаторБлюда,
	              |	СУММА(втИнгредиенты.КоличествоИнгредиентаФакт) КАК Количество,
	              |	втИнгредиенты.УпаковкаИнгредиента КАК УпаковкаИнгредиента
	              |ПОМЕСТИТЬ ВТ_Производство
	              |ИЗ
	              |	Документ.питВыпускБлюд.Ингредиенты КАК втИнгредиенты
	              |ГДЕ
	              |	втИнгредиенты.Ссылка = &ДокументВыпуска
	              |	И НЕ втИнгредиенты.ИзАвтопеределов
	              |	И НЕ втИнгредиенты.Ингредиент.питВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.питВидыНоменклатуры.ТехнологическийИнгредиент)
	              |	И втИнгредиенты.Ингредиент.ТипНоменклатуры В(&СкладскиеТипыНоменклатуры)
	              |
	              |СГРУППИРОВАТЬ ПО
	              |	втИнгредиенты.Ингредиент,
	              |	втИнгредиенты.ИдентификаторБлюда,
	              |	втИнгредиенты.УпаковкаИнгредиента
	              |;
	              |
	              |////////////////////////////////////////////////////////////////////////////////
	              |ВЫБРАТЬ
	              |	ВТ_Производство.Номенклатура КАК Номенклатура,
	              |	СУММА(ВТ_Производство.Количество) КАК Количество,
	              |	ВТ_Производство.УпаковкаИнгредиента КАК УпаковкаИнгредиента
	              |ПОМЕСТИТЬ ВТ_МаркируемыеТовары
	              |ИЗ
	              |	ВТ_Производство КАК ВТ_Производство
	              |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНоменклатура
	              |		ПО ВТ_Производство.Номенклатура = СпрНоменклатура.Ссылка
	              |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.питВыпускБлюд.Блюда КАК ТЧПродукция
	              |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНоменклатураБлюда
	              |			ПО ТЧПродукция.Номенклатура = СпрНоменклатураБлюда.Ссылка
	              |		ПО (ТЧПродукция.Ссылка = &ДокументВыпуска)
	              |			И ВТ_Производство.ИдентификаторБлюда = ТЧПродукция.ИдентификаторСтроки
	              |ГДЕ
	              |	СпрНоменклатура.ОсобенностьУчета В(&ОсобенностиУчетаДоступныеДляОтраженияОстатковИС)
	              |	И НЕ ЕСТЬNULL(СпрНоменклатураБлюда.питПродажаВРозлив, ИСТИНА)
	              |	И ТЧПродукция.Ссылка = &ДокументВыпуска
	              |
	              |СГРУППИРОВАТЬ ПО
	              |	ВТ_Производство.Номенклатура,
	              |	ВТ_Производство.УпаковкаИнгредиента
	              |;
	              |
	              |////////////////////////////////////////////////////////////////////////////////
	              |ВЫБРАТЬ
	              |	МАКСИМУМ(ОстаткиМарокИС.Период) КАК Период,
	              |	ОстаткиМарокИС.Организация КАК Организация,
	              |	ОстаткиМарокИС.МестоПечати КАК МестоПечати,
	              |	ОстаткиМарокИС.Номенклатура КАК Номенклатура,
	              |	ВТ_МаркируемыеТовары.УпаковкаИнгредиента КАК УпаковкаИнгредиента
	              |ПОМЕСТИТЬ ВТ_ПоследниеМарки
	              |ИЗ
	              |	ВТ_МаркируемыеТовары КАК ВТ_МаркируемыеТовары
	              |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.питОстаткиМарокИС КАК ОстаткиМарокИС
	              |		ПО ВТ_МаркируемыеТовары.Номенклатура = ОстаткиМарокИС.Номенклатура
	              |ГДЕ
	              |	НЕ &КонтролироватьОстаткиМарокИС
	              |	И ОстаткиМарокИС.Период <= &Период
	              |	И ОстаткиМарокИС.Период >= &НачалоПериода
	              |	И ОстаткиМарокИС.Организация = &Организация
	              |	И ОстаткиМарокИС.МестоПечати В(&МестаПечати)
	              |
	              |СГРУППИРОВАТЬ ПО
	              |	ОстаткиМарокИС.Организация,
	              |	ОстаткиМарокИС.МестоПечати,
	              |	ОстаткиМарокИС.Номенклатура,
	              |	ВТ_МаркируемыеТовары.УпаковкаИнгредиента
	              |;
	              |
	              |////////////////////////////////////////////////////////////////////////////////
	              |ВЫБРАТЬ
	              |	ОстаткиМарокИСОстатки.Организация КАК Организация,
	              |	ОстаткиМарокИСОстатки.МестоПечати КАК МестоПечати,
	              |	ОстаткиМарокИСОстатки.Номенклатура КАК Номенклатура,
	              |	ОстаткиМарокИСОстатки.Штрихкод КАК Штрихкод,
	              |	ОстаткиМарокИСОстатки.КоличествоОстаток КАК КоличествоОстаток,
	              |	0 КАК Приоритет
	              |ПОМЕСТИТЬ ВТ_ДоступныеМарки
	              |ИЗ
	              |	РегистрНакопления.питОстаткиМарокИС.Остатки(
	              |			&МоментКонтроля,
	              |			Организация = &Организация
	              |				И МестоПечати В (&МестаПечати)
	              |				И Номенклатура В
	              |					(ВЫБРАТЬ
	              |						ВТ_МаркируемыеТовары.Номенклатура КАК Номенклатура
	              |					ИЗ
	              |						ВТ_МаркируемыеТовары КАК ВТ_МаркируемыеТовары)) КАК ОстаткиМарокИСОстатки
	              |ГДЕ
	              |	ОстаткиМарокИСОстатки.КоличествоОстаток > 0
	              |
	              |ОБЪЕДИНИТЬ ВСЕ
	              |
	              |ВЫБРАТЬ
	              |	ВТ_ПоследниеМарки.Организация,
	              |	ВТ_ПоследниеМарки.МестоПечати,
	              |	ВТ_ПоследниеМарки.Номенклатура,
	              |	МАКСИМУМ(ОстаткиМарокИС.Штрихкод),
	              |	0,
	              |	1
	              |ИЗ
	              |	ВТ_ПоследниеМарки КАК ВТ_ПоследниеМарки
	              |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.питОстаткиМарокИС КАК ОстаткиМарокИС
	              |		ПО ВТ_ПоследниеМарки.Период = ОстаткиМарокИС.Период
	              |			И ВТ_ПоследниеМарки.Организация = ОстаткиМарокИС.Организация
	              |			И ВТ_ПоследниеМарки.МестоПечати = ОстаткиМарокИС.МестоПечати
	              |			И ВТ_ПоследниеМарки.Номенклатура = ОстаткиМарокИС.Номенклатура
	              |
	              |СГРУППИРОВАТЬ ПО
	              |	ВТ_ПоследниеМарки.Организация,
	              |	ВТ_ПоследниеМарки.МестоПечати,
	              |	ВТ_ПоследниеМарки.Номенклатура
	              |
	              |ОБЪЕДИНИТЬ ВСЕ
	              |
	              |ВЫБРАТЬ
	              |	ОстаткиМарокИС.Организация,
	              |	ОстаткиМарокИС.МестоПечати,
	              |	ОстаткиМарокИС.Номенклатура,
	              |	ОстаткиМарокИС.Штрихкод,
	              |	ВЫБОР
	              |		КОГДА ОстаткиМарокИС.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	              |			ТОГДА ОстаткиМарокИС.Количество
	              |		ИНАЧЕ -ОстаткиМарокИС.Количество
	              |	КОНЕЦ,
	              |	0
	              |ИЗ
	              |	РегистрНакопления.питОстаткиМарокИС КАК ОстаткиМарокИС
	              |ГДЕ
	              |	ОстаткиМарокИС.Регистратор = &ДокументКорректировки
	              |	И ОстаткиМарокИС.Период <= &Период
	              |;
	              |
	              |////////////////////////////////////////////////////////////////////////////////
	              |ВЫБРАТЬ
	              |	ВТ_ИтоговаяТаблица.Организация КАК Организация,
	              |	ВТ_ИтоговаяТаблица.МестоПечати КАК МестоПечати,
	              |	ВТ_ИтоговаяТаблица.Номенклатура КАК Номенклатура,
	              |	ВТ_ИтоговаяТаблица.Штрихкод КАК Штрихкод,
	              |	СУММА(ВТ_ИтоговаяТаблица.КоличествоОстаток) КАК КоличествоОстаток,
	              |	ВТ_ИтоговаяТаблица.Приоритет КАК Приоритет
	              |ПОМЕСТИТЬ ВТ_ИтоговаяТаблица
	              |ИЗ
	              |	ВТ_ДоступныеМарки КАК ВТ_ИтоговаяТаблица
	              |
	              |СГРУППИРОВАТЬ ПО
	              |	ВТ_ИтоговаяТаблица.Организация,
	              |	ВТ_ИтоговаяТаблица.МестоПечати,
	              |	ВТ_ИтоговаяТаблица.Номенклатура,
	              |	ВТ_ИтоговаяТаблица.Штрихкод,
	              |	ВТ_ИтоговаяТаблица.Приоритет
	              |
	              |ИМЕЮЩИЕ
	              |	СУММА(ВТ_ИтоговаяТаблица.КоличествоОстаток) > 0
	              |;
	              |
	              |////////////////////////////////////////////////////////////////////////////////
	              |ВЫБРАТЬ
	              |	ЕСТЬNULL(ВТ_ИтоговаяТаблица.МестоПечати, &СтруктурнаяЕдиница) КАК МестоПечати,
	              |	ВТ_МаркируемыеТовары.Номенклатура КАК Номенклатура,
	              |	ВТ_МаркируемыеТовары.Количество КАК Количество,
	              |	ЕСТЬNULL(ВТ_ИтоговаяТаблица.Штрихкод, НЕОПРЕДЕЛЕНО) КАК ШтрихкодУпаковки,
	              |	ЕСТЬNULL(ВТ_ИтоговаяТаблица.КоличествоОстаток, 0) КАК КоличествоОстаток,
	              |	ЕСТЬNULL(ВТ_ИтоговаяТаблица.Приоритет, 0) КАК Приоритет,
	              |	ВЫБОР
	              |		КОГДА ЕСТЬNULL(ВТ_ИтоговаяТаблица.МестоПечати, &СтруктурнаяЕдиница) = &СтруктурнаяЕдиница
	              |			ТОГДА 0
	              |		ИНАЧЕ 1
	              |	КОНЕЦ КАК ПриоритетПоМестуПечати,
	              |	ВТ_МаркируемыеТовары.УпаковкаИнгредиента КАК УпаковкаИнгредиента
	              |ИЗ
	              |	ВТ_МаркируемыеТовары КАК ВТ_МаркируемыеТовары
	              |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ИтоговаяТаблица КАК ВТ_ИтоговаяТаблица
	              |		ПО ВТ_МаркируемыеТовары.Номенклатура = ВТ_ИтоговаяТаблица.Номенклатура
	              |
	              |УПОРЯДОЧИТЬ ПО
	              |	Номенклатура,
	              |	ПриоритетПоМестуПечати,
	              |	Приоритет,
	              |	КоличествоОстаток
	              |ИТОГИ
	              |	МАКСИМУМ(Количество)
	              |ПО
	              |	Номенклатура";
	
	Запрос.Текст = ТекстЗапроса;
	
	СкладскиеТипыНоменклатуры = питОбщегоНазначения.ПолучитьСкладскиеТипыНоменклатуры();
	Запрос.УстановитьПараметр("СкладскиеТипыНоменклатуры", СкладскиеТипыНоменклатуры);
	Запрос.УстановитьПараметр("ОсобенностиУчетаДоступныеДляОтраженияОстатковИС", 
		РегистрыНакопления.питОстаткиМарокИС.ОсобенностиУчетаДоступныеДляОтраженияОстатковИС());
	Запрос.УстановитьПараметр("ДокументВыпуска", ДокументВыпускБлюдСсылка);
	Запрос.УстановитьПараметр("Период", ТекДокументОбъект.Дата);
	Запрос.УстановитьПараметр("МоментКонтроля", Новый Граница(Новый МоментВремени(ТекДокументОбъект.Дата, ТекДокументОбъект.Ссылка),
		ВидГраницы.Включая));
	// Рассматривать отрицательный остаток будет за последние 2 недели.
	Запрос.УстановитьПараметр("НачалоПериода", ТекДокументОбъект.Дата - 86400*14);
	КонтролироватьОстаткиМарокИС = ДокументВыпускБлюдДанные.КонтролироватьОстаткиМарокИСПриПроведении;
	Запрос.УстановитьПараметр("КонтролироватьОстаткиМарокИС", КонтролироватьОстаткиМарокИС);
	Запрос.УстановитьПараметр("ДокументКорректировки", ТекДокументОбъект.Ссылка);
	Запрос.УстановитьПараметр("МестаПечати", ДоступныеМестаПечати);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", ТекДокументОбъект.Склад);
	Запрос.УстановитьПараметр("Организация", ТекДокументОбъект.Организация);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ИндексПоследнегоПакета = РезультатЗапроса.ВГраница();
	Если РезультатЗапроса[ИндексПоследнегоПакета].Пустой() Тогда
		
		Если НЕ ЗначениеЗаполнено(ТекДокументОбъект.Ссылка) Тогда
			Возврат Истина;
		КонецЕсли;
		
		//+ОтложенноеПроведение
		Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
			ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, 
				ПолучитьТекущееДействиеПоПометкеУдаленияТиповогоДокумента(ПараметрыЗаписи.ПометкаУдаления), 
				ТекДокументОбъект.Ссылка, 
				СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,
				ТекстОшибки);
			СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = 
				СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
			Если НЕ ВсеОк Тогда 
				Возврат ВсеОк;
			КонецЕсли;
		Иначе
		//-ОтложенноеПроведение
			Попытка
				ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
				ТекДокументОбъект.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
			Исключение
				ТекстОшибки = ТекстОшибки + "
				|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
				| по документу Общепит """+ДокументВыпускБлюд+"""
				|по причине: <"+ОписаниеОшибки()+">";
				Возврат Ложь;
			КонецПопытки;
		КонецЕсли;
		
		Возврат Истина;
	КонецЕсли;
	
	// Очистка табличных частей, т.к. будет их перезаполнение.
	ТекДокументОбъект.Запасы.Очистить();
	
	СтруктураПоследнейСтроки = питОбщегоНазначения.ПустаяСтруктураПоРезультатуЗапроса(
		РезультатЗапроса[ИндексПоследнегоПакета]);
	
   	ВыборкаНоменклатуры = РезультатЗапроса[ИндексПоследнегоПакета].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаНоменклатуры.Следующий() Цикл
		
		////упаковка ингридиента из выборки
		//КоличествоТребуетсяВМЛ = питОбщегоНазначения.ПеревестиОбъемВМиллилитры(
		//	ВыборкаНоменклатуры.Номенклатура,,
		//	ВыборкаНоменклатуры.Количество);
		//КоличествоОсталось = КоличествоТребуетсяВМЛ;
		
		НоваяСтрока = Неопределено;
		ВыборкаОстатков = ВыборкаНоменклатуры.Выбрать(); 
		
		Пока ВыборкаОстатков.Следующий() Цикл
			
			//КоличествоОсталось = ВыборкаОстатков.Количество;
			
			КоличествоТребуетсяВМЛ = питОбщегоНазначения.ПеревестиОбъемВМиллилитры(
									ВыборкаОстатков.Номенклатура,
									ВыборкаОстатков.УпаковкаИнгредиента,
									ВыборкаОстатков.Количество);
		
			КоличествоОсталось = ОКР(КоличествоТребуетсяВМЛ);
			
			Если КоличествоОсталось <= 0 Тогда
				Прервать;
			КонецЕсли;
			
			Если НоваяСтрока = Неопределено Тогда
				ЗаполнитьЗначенияСвойств(СтруктураПоследнейСтроки, ВыборкаОстатков);
			КонецЕсли;
			
			Если ВыборкаОстатков.Приоритет = 1 Тогда
				КоличествоКСписанию = КоличествоОсталось;
			Иначе
				КоличествоКСписанию = Мин(КоличествоОсталось, ВыборкаОстатков.КоличествоОстаток);
			КонецЕсли;
			
			Если КоличествоКСписанию = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			НоваяСтрока = ТекДокументОбъект.Запасы.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаОстатков);
			
			НоваяСтрока.Количество = -КоличествоКСписанию;
			
			КоличествоОсталось = КоличествоОсталось - КоличествоКСписанию;
		
		КонецЦикла;
		
		Если КоличествоОсталось = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Если НоваяСтрока = Неопределено
			И НЕ КонтролироватьОстаткиМарокИС Тогда
			Продолжить;
		ИначеЕсли НоваяСтрока = Неопределено Тогда
			НоваяСтрока = ТекДокументОбъект.Запасы.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтруктураПоследнейСтроки);
			НоваяСтрока.Количество = -КоличествоОсталось;
		Иначе
			НоваяСтрока.Количество = НоваяСтрока.Количество - КоличествоОсталось;
		КонецЕсли;
		
	КонецЦикла;
	
	
	
	
	/////////////////////////////////////////////////////////
	// ЗАПИСЬ ДОКУМЕНТА
	
	//+ОтложенноеПроведение
	Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
		ИсходныйРежимЗаписи	= ТекРежимЗаписи;
		ТекРежимЗаписи		= РежимЗаписиДокумента.Запись;
	КонецЕсли;
	//-ОтложенноеПроведение
	
	Попытка
		ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
		ТекДокументОбъект.ДополнительныеСвойства.Вставить("КонтролироватьОстаткиМарокИС", КонтролироватьОстаткиМарокИС);
		ТекДокументОбъект.Записать(ТекРежимЗаписи);
	Исключение
		ТекстОшибки = ТекстОшибки + "
		|Ошибка записи документа """ + ТекДокументОбъект.Метаданные().Представление() + """
		| по документу Общепит """+ДокументВыпускБлюдСсылка+"""
		|по причине: <"+ОписаниеОшибки()+">";
		Возврат Ложь;
	КонецПопытки;
	
	//+ОтложенноеПроведение
	Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
		ТекДействие = ПолучитьТекущееДействиеПоРежимузаписиТиповогоДокумента(ИсходныйРежимЗаписи);
		ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ТекДействие, ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
		СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
		ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.УстановитьСинхронизациюТиповогоДокумента, ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
		СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
	КонецЕсли;
	//-ОтложенноеПроведение
	
	//+ОтложенноеПроведение
	ТекСинхронизирован = ?(СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд, Ложь, Истина);
	//-ОтложенноеПроведение
	
	// Добавление записи в результирующую таблицу в случае успешной записи документов.
	ДобавитьНовуюЗапись(ДокументВыпускБлюд, ТекДокументОбъект, тблСозданныеДокументы, , ТекСинхронизирован);
	
	Возврат Истина;
	
КонецФункции


//>> Швецов. 29.05.2025. 
//Функция формирует документ "Корректировка остатков ИС" для по маркам ингридиентов из производтсва.
//
// Параметры:
//  ДокументВыпускБлюд		 - ДокументСсылка	 - Ссылка на документ "Выпуск блюд", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция MRS_СформироватьКорректировкуОстатковИСПоПроизводству(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки)
	
	ДокументВыпускБлюдСсылка = ДокументВыпускБлюд;
	Если ТипЗнч(ДокументВыпускБлюд) = Тип("ДокументОбъект.питВыпускБлюд") Тогда
		ДокументВыпускБлюдСсылка = ДокументВыпускБлюд.Ссылка;
	КонецЕсли; 
	
	Запрос = Новый Запрос;
	
	// Поиск существующего документа 
	// связанного с текущим "Выпуском блюд".
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питТиповыеДокументы.ТиповойДокумент КАК ТиповойДокумент
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|	И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.питКорректировкаОстатковИС";
	Запрос.УстановитьПараметр("Документпит", ДокументВыпускБлюдСсылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	// Если документ найден, то получаем объект иначе создаем новый.
	Если Выборка.Следующий() Тогда
		ТекДокументОбъект = Выборка.ТиповойДокумент.ПолучитьОбъект();
	Иначе
		// для реализаций создаем только для модификаторов бизнес-ланчей
		ТекДокументОбъект = Документы.питКорректировкаОстатковИС.СоздатьДокумент();
		ТекДокументОбъект.Заполнить(Неопределено);
	КонецЕсли;
	
	// Определение параметров записи.
	ПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(
		ДокументВыпускБлюд.Проведен, 
		ДокументВыпускБлюд.ПометкаУдаления,
		ТекДокументОбъект.Проведен,
		ТекДокументОбъект.ПометкаУдаления,
		СтруктураПараметров);
		
	// Определение режима записи
	ТекРежимЗаписи = ПараметрыЗаписи.РежимЗаписи;
		
	//УстановкаПометкиУдаления
	Если ПараметрыЗаписи.НужнаУстановкаПометкиУдаления Тогда
		
		Если НЕ ТекДокументОбъект.ЭтоНовый() Тогда
		
			//+ОтложенноеПроведение
			Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
				ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, 
					ПолучитьТекущееДействиеПоПометкеУдаленияТиповогоДокумента(ПараметрыЗаписи.ПометкаУдаления), 
					ТекДокументОбъект.Ссылка, 
					СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,
					ТекстОшибки);
				СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = 
					СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
				Если НЕ ВсеОк Тогда 
					Возврат ВсеОк;
				КонецЕсли;
			Иначе
			//-ОтложенноеПроведение
				Попытка
					ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
					ТекДокументОбъект.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
				Исключение
					ТекстОшибки = ТекстОшибки + "
					|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
					| по документу Общепит """+ДокументВыпускБлюд+"""
					|по причине: <"+ОписаниеОшибки()+">";
					Возврат Ложь;
				КонецПопытки;
			КонецЕсли;
		
		КонецЕсли;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питВыпускБлюд.Дата КАК Дата,
	|	питВыпускБлюд.Ответственный КАК Автор,
	|	питВыпускБлюд.Организация КАК Организация,
	|	питВыпускБлюд.Подразделение КАК Подразделение,
	|	питВыпускБлюд.Склад КАК Склад,
	|	питВыпускБлюд.Комментарий КАК Комментарий,
	|	ЕСТЬNULL(питПараметрыСкладовОбщепита.КонтролироватьОстаткиМарокИСПриПроведении, ЛОЖЬ) КАК КонтролироватьОстаткиМарокИСПриПроведении
	|ИЗ
	|	Документ.питВыпускБлюд КАК питВыпускБлюд
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.питПараметрыСкладовОбщепита КАК питПараметрыСкладовОбщепита
	|		ПО питВыпускБлюд.Склад = питПараметрыСкладовОбщепита.Склад
	|ГДЕ
	|	питВыпускБлюд.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", ДокументВыпускБлюдСсылка);
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	ДокументВыпускБлюдДанные = РезультатЗапроса[0].Выбрать();
	ДокументВыпускБлюдДанные.Следующий();
	
	/////////////////////////////////
	// ЗАПОЛНЕНИЕ ШАПКИ.
	ТекДокументОбъект.Дата = ДокументВыпускБлюдДанные.Дата + 
		?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0);
	ТекДокументОбъект.Организация = ДокументВыпускБлюдДанные.Организация;
	ТекДокументОбъект.Склад = ДокументВыпускБлюдДанные.Склад;
	ТекДокументОбъект.ДокументОснование = ДокументВыпускБлюдСсылка;
	ТекДокументОбъект.Комментарий = ДокументВыпускБлюдДанные.Комментарий;
	ТекДокументОбъект.Автор = ДокументВыпускБлюдДанные.Автор;
	ТекДокументОбъект.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.КорректировкаОстатковИСКорректировкаОстатков;
	ТекДокументОбъект.Подразделение = ДокументВыпускБлюдДанные.Подразделение;
	// Создаем массив документов "Производство без заказа"
	МассивДокументов = Новый Массив;
	Для Каждого Строка Из тблСозданныеДокументы Цикл
		Если ТипЗнч(Строка.ТиповойДокумент) = Тип("ДокументСсылка.ПроизводствоБезЗаказа") Тогда
			МассивДокументов.Добавить(Строка.ТиповойДокумент);
		КонецЕсли;
	КонецЦикла;
	
	// Создаем запрос для получения данных из табличной части
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ПроизводствоБезЗаказаМатериалыИРаботы.Номенклатура КАК Номенклатура,
	|	ПроизводствоБезЗаказаМатериалыИРаботы.Количество * 1000 КАК Количество,
	|	ПроизводствоБезЗаказаМатериалыИРаботы.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ПроизводствоБезЗаказаМатериалыИРаботы.Склад КАК МестоПечати,
	|	ШтрихкодыУпаковокТоваров.Ссылка КАК ШтрихкодУпаковки
	|ИЗ
	|	Документ.ПроизводствоБезЗаказа.МатериалыИРаботы КАК ПроизводствоБезЗаказаМатериалыИРаботы
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
	|		ПО ПроизводствоБезЗаказаМатериалыИРаботы.Серия.Номер = ШтрихкодыУпаковокТоваров.ЗначениеШтрихкода
	|ГДЕ
	|	ПроизводствоБезЗаказаМатериалыИРаботы.Ссылка В(&МассивДокументов)
	|	И ПроизводствоБезЗаказаМатериалыИРаботы.Номенклатура.АлкогольнаяПродукция
	|	И ПроизводствоБезЗаказаМатериалыИРаботы.Серия <> ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)";
	
	Запрос.УстановитьПараметр("МассивДокументов", МассивДокументов);
	
	РезультатЗапроса = Запрос.Выполнить();
		
 	Если РезультатЗапроса.Пустой() Тогда
		
		Если НЕ ЗначениеЗаполнено(ТекДокументОбъект.Ссылка) Тогда
			Возврат Истина;
		КонецЕсли;
		
		//+ОтложенноеПроведение
		Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
			ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, 
				ПолучитьТекущееДействиеПоПометкеУдаленияТиповогоДокумента(ПараметрыЗаписи.ПометкаУдаления), 
				ТекДокументОбъект.Ссылка, 
				СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,
				ТекстОшибки);
			СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = 
				СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
			Если НЕ ВсеОк Тогда 
				Возврат ВсеОк;
			КонецЕсли;
		Иначе
		//-ОтложенноеПроведение
			Попытка
				ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
				ТекДокументОбъект.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
			Исключение
				ТекстОшибки = ТекстОшибки + "
				|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
				| по документу Общепит """+ДокументВыпускБлюд+"""
				|по причине: <"+ОписаниеОшибки()+">";
				Возврат Ложь;
			КонецПопытки;
		КонецЕсли;
		
		Возврат Истина;
	КонецЕсли;
	
	// Очистка табличных частей, т.к. будет их перезаполнение.
	ТекДокументОбъект.Запасы.Очистить();
		
   	ВыборкаНоменклатуры = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаНоменклатуры.Следующий() Цикл
		
		НоваяСтрока = Неопределено;
		
		//КоличествоМЛ = питОбщегоНазначения.ПеревестиОбъемВМиллилитры(ВыборкаНоменклатуры.Номенклатура,
		//	ВыборкаНоменклатуры.ЕдиницаИзмерения, 
		//	ВыборкаНоменклатуры.Количество);
			
		НоваяСтрока = ТекДокументОбъект.Запасы.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаНоменклатуры);
		//НоваяСтрока.Количество = КоличествоМЛ;
					
	КонецЦикла;
	
	/////////////////////////////////////////////////////////
	// ЗАПИСЬ ДОКУМЕНТА
	
	//+ОтложенноеПроведение
	Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
		ИсходныйРежимЗаписи	= ТекРежимЗаписи;
		ТекРежимЗаписи		= РежимЗаписиДокумента.Запись;
	КонецЕсли;
	//-ОтложенноеПроведение
	
	Попытка
		ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина); 
		ТекДокументОбъект.Записать(ТекРежимЗаписи);
	Исключение
		ТекстОшибки = ТекстОшибки + "
		|Ошибка записи документа """ + ТекДокументОбъект.Метаданные().Представление() + """
		| по документу Общепит """+ДокументВыпускБлюдСсылка+"""
		|по причине: <"+ОписаниеОшибки()+">";
		Возврат Ложь;
	КонецПопытки;
	
	//+ОтложенноеПроведение
	Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
		ТекДействие = ПолучитьТекущееДействиеПоРежимузаписиТиповогоДокумента(ИсходныйРежимЗаписи);
		ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ТекДействие, ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
		СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
		ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.УстановитьСинхронизациюТиповогоДокумента, ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
		СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
	КонецЕсли;
	//-ОтложенноеПроведение
	
	//+ОтложенноеПроведение
	ТекСинхронизирован = ?(СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд, Ложь, Истина);
	//-ОтложенноеПроведение
	
	// Добавление записи в результирующую таблицу в случае успешной записи документов.
	ДобавитьНовуюЗапись(ДокументВыпускБлюд, ТекДокументОбъект, тблСозданныеДокументы, , ТекСинхронизирован);
	
	Возврат Истина;
	
КонецФункции
//<< Швецов. 29.05.2025.

// Функция помечает на удаление неиспользуемые комплексные документы выпуска блюд в зависимости от текущего режима
//
// Параметры:
//  ДокВыпускБлюд		 - ДокументСсылка	 - Ссылка на документ "Выпуск блюд", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция ПометитьНаУдалениеНеиспользуемыеКомплексныеДокументыВыпускаБлюд(ДокВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки = "")
	
	ИмяДокументаВнутреннееПотребление = питОбратнаяСовместимостьПовтИсп.ИмяДокументаВнутреннееПотребление();
	
	ВсеОк = Истина;

	ФормироватьДокументыПроизводства22 = Константы.питФормироватьДокументыПроизводства22.Получить();

	Запрос = Новый Запрос;
	ТекстЗапросаШаблон = "ВЫБРАТЬ
	|	питТиповыеДокументыВсе.ТиповойДокумент,
	|	ВЫРАЗИТЬ(питТиповыеДокументыВсе.ДокументОбщепит КАК Документ.питВыпускБлюд) КАК ДокументВыпускБлюд,
	|	питТиповыеДокументыВсе.ПричинаТиповогоДокумента
	|ПОМЕСТИТЬ втТиповыеДокументыВсе
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументыВсе
	|ГДЕ
	|	питТиповыеДокументыВсе.ДокументОбщепит = &Документпит
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	питТиповыеДокументы.ТиповойДокумент,
	|	питТиповыеДокументы.ДокументВыпускБлюд,
	|	питТиповыеДокументы.ПричинаТиповогоДокумента
	|ИЗ
	|	втТиповыеДокументыВсе КАК питТиповыеДокументы
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.питВыпускБлюд КАК питВыпускБлюд
	|		ПО питТиповыеДокументы.ДокументВыпускБлюд = питВыпускБлюд.Ссылка
	|ГДЕ
	|	(%ТекстУсловие%) 
	|
	|УПОРЯДОЧИТЬ ПО
	|	питТиповыеДокументы.ТиповойДокумент.МоментВремени";
	ТекстЗапроса = "";
	ТекстЗапросаУсловие = "";
	ТекстЗапросаШаблонУсловие = " питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.%ИмяДокумента% ";

	Если НЕ ДокВыпускБлюд.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.ВыпускПродукцииСПеремещением Тогда
		ОбъединитьВсе = ?(ПустаяСтрока(ТекстЗапросаУсловие),""," ИЛИ ");
		ТекстЗапросаУсловие = ТекстЗапросаУсловие + ОбъединитьВсе 
				+ " (" 
				+ СтрЗаменить(ТекстЗапросаШаблонУсловие,"%ИмяДокумента%","ПеремещениеТоваров")
				+ " И питТиповыеДокументы.ПричинаТиповогоДокумента = 3"
				+ ") ";
		
		Если ФормироватьДокументыПроизводства22 Тогда
			ОбъединитьВсе = ?(ПустаяСтрока(ТекстЗапросаУсловие),""," ИЛИ ");
			ТекстЗапросаУсловие = ТекстЗапросаУсловие + ОбъединитьВсе 
			+ " (" 
			+ СтрЗаменить(ТекстЗапросаШаблонУсловие,"%ИмяДокумента%","ДвижениеПродукцииИМатериалов")
			+ " И питТиповыеДокументы.ПричинаТиповогоДокумента = 3"
			+ ") ";
		КонецЕсли;

	КонецЕсли;
	
	Если НЕ ДокВыпускБлюд.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.ВыпускПродукцииСоСписанием Тогда
		ОбъединитьВсе = ?(ПустаяСтрока(ТекстЗапросаУсловие),""," ИЛИ ");
		ТекстЗапросаУсловие = ТекстЗапросаУсловие + ОбъединитьВсе + СтрЗаменить(ТекстЗапросаШаблонУсловие,"%ИмяДокумента%",ИмяДокументаВнутреннееПотребление);
	КонецЕсли;
	
	Если НЕ ДокВыпускБлюд.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.ВыпускПродукцииСРозничнойРеализацией Тогда
		ОбъединитьВсе = ?(ПустаяСтрока(ТекстЗапросаУсловие),""," ИЛИ ");
		ТекстЗапросаУсловие = ТекстЗапросаУсловие + ОбъединитьВсе + СтрЗаменить(ТекстЗапросаШаблонУсловие,"%ИмяДокумента%","ОтчетОРозничныхПродажах");

		Если ФормироватьДокументыПроизводства22 Тогда
			ОбъединитьВсе = ?(ПустаяСтрока(ТекстЗапросаУсловие),""," ИЛИ ");
			ТекстЗапросаУсловие = ТекстЗапросаУсловие + ОбъединитьВсе 
			+ " (" 
			+ СтрЗаменить(ТекстЗапросаШаблонУсловие,"%ИмяДокумента%","ДвижениеПродукцииИМатериалов")
			+ " И питТиповыеДокументы.ПричинаТиповогоДокумента = 1 И ВЫРАЗИТЬ(питТиповыеДокументы.ТиповойДокумент КАК Документ.ДвижениеПродукцииИМатериалов).Получатель <> питВыпускБлюд.Склад"
			+ ") ";
		КонецЕсли;

		Если ФормироватьДокументыПроизводства22 Тогда
			// перемещение на склад реализации
			ОбъединитьВсе = ?(ПустаяСтрока(ТекстЗапросаУсловие),""," ИЛИ ");
			ТекстЗапросаУсловие = ТекстЗапросаУсловие + ОбъединитьВсе 
			+ " (" 
			+ СтрЗаменить(ТекстЗапросаШаблонУсловие,"%ИмяДокумента%","ПеремещениеТоваров")
			+ " И питТиповыеДокументы.ПричинаТиповогоДокумента = 1"
			+ ") ";
		КонецЕсли;

	КонецЕсли;

	Если НЕ ДокВыпускБлюд.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.ВыпускПродукцииСРеализацией Тогда
		ОбъединитьВсе = ?(ПустаяСтрока(ТекстЗапросаУсловие),""," ИЛИ ");
		ТекстЗапросаУсловие = ТекстЗапросаУсловие + ОбъединитьВсе + СтрЗаменить(ТекстЗапросаШаблонУсловие,"%ИмяДокумента%","РеализацияТоваровУслуг");

		Если ФормироватьДокументыПроизводства22 Тогда
			ОбъединитьВсе = ?(ПустаяСтрока(ТекстЗапросаУсловие),""," ИЛИ ");
			ТекстЗапросаУсловие = ТекстЗапросаУсловие + ОбъединитьВсе 
			+ " (" 
			+ СтрЗаменить(ТекстЗапросаШаблонУсловие,"%ИмяДокумента%","ДвижениеПродукцииИМатериалов")
			+ " И питТиповыеДокументы.ПричинаТиповогоДокумента = 1 И ВЫРАЗИТЬ(питТиповыеДокументы.ТиповойДокумент КАК Документ.ДвижениеПродукцииИМатериалов).Получатель <> питВыпускБлюд.Склад"
			+ ") ";
		КонецЕсли;

		Если ФормироватьДокументыПроизводства22 Тогда
			// перемещение на склад реализации
			ОбъединитьВсе = ?(ПустаяСтрока(ТекстЗапросаУсловие),""," ИЛИ ");
			ТекстЗапросаУсловие = ТекстЗапросаУсловие + ОбъединитьВсе 
			+ " (" 
			+ СтрЗаменить(ТекстЗапросаШаблонУсловие,"%ИмяДокумента%","ПеремещениеТоваров")
			+ " И питТиповыеДокументы.ПричинаТиповогоДокумента = 1"
			+ ") ";
		КонецЕсли;

	КонецЕсли;

	ТекстЗапроса = СтрЗаменить(ТекстЗапросаШаблон,"%ТекстУсловие%", ТекстЗапросаУсловие);

	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("Документпит", ДокВыпускБлюд);
	Выборка = Запрос.Выполнить().Выбрать();

	Пока Выборка.Следующий() Цикл

		ДокОбъект = Выборка.ТиповойДокумент.ПолучитьОбъект();

		//+ОтложенноеПроведение
		Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
			ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокВыпускБлюд, ПолучитьТекущееДействиеПоПометкеУдаленияТиповогоДокумента(Истина), ДокОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
			СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
			Если НЕ ВсеОк Тогда 
				Возврат ВсеОк;
			КонецЕсли;
			ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.УстановитьСинхронизациюТиповогоДокумента, ДокОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
			СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
			Если НЕ ВсеОк Тогда 
				Возврат ВсеОк;
			КонецЕсли;
		Иначе
			//-ОтложенноеПроведение

			// Неактуальные для данного типа разделки доки, помечаем на удаление.
			Попытка
				ДокОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
				ДокОбъект.УстановитьПометкуУдаления(Истина);
			Исключение
				ТекстОшибки = ТекстОшибки + "
				|Ошибка при установке пометки удаления """ + ДокОбъект.Метаданные().Представление() + """
				| по документу Общепит """+ДокВыпускБлюд+"""
				|по причине: <"+ОписаниеОшибки()+">";
				Возврат Ложь;
			КонецПопытки;

		КонецЕсли;

		//+ОтложенноеПроведение
		ТекСинхронизирован = ?(СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд, Ложь, Истина);
		//-ОтложенноеПроведение

		// Добавление записи в результирующую таблицу в случае успешной записи документов.
		ДобавитьНовуюЗапись(ДокВыпускБлюд, ДокОбъект, тблСозданныеДокументы, Выборка.ПричинаТиповогоДокумента, ТекСинхронизирован);

	КонецЦикла;

	Возврат ВсеОк;

КонецФункции

//>>Швецов. 26.12.2024. Розничные продажи алкоголя
Функция СоздатьДокументАктСписанияЕГАИС(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы)
	
	// << MRS #VINE-129 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 16.06.25, (на основании непроведенного документа ничего формировать не нужно)
	Если СтруктураПараметров.РежимЗаписи <> РежимЗаписиДокумента.Проведение Тогда
		Возврат Истина;
	КонецЕсли;
	// >> MRS #VINE-129 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 16.06.25, (на основании непроведенного документа ничего формировать не нужно)
	
	СтруктураВозврата = MRS_ЗагрузкаЕГАИСФронт.ПолучитьОстаткиМарокДляПроизводства(ДокументВыпускБлюд, тблСозданныеДокументы);
	
	Если НЕ СтруктураВозврата.Свойство("Шапка") Тогда
		Возврат Истина;
	КонецЕсли;
	
	//Условия по акту списания ЕГАИС
	ДопСоединение = "ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АктСписанияЕГАИС КАК АктСписанияЕГАИСРегистр1
			|		ПО питТиповыеДокументы.ТиповойДокумент = АктСписанияЕГАИСРегистр1.Ссылка
			|			И (АктСписанияЕГАИСРегистр1.ВидДокумента = &ВидОперацииАктСписанияЕГАИСРегистр1)
			|			И (АктСписанияЕГАИСРегистр1.ПричинаСписания = ЗНАЧЕНИЕ(Перечисление.ПричиныСписанийЕГАИС.питПриготовление))
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыДокументовЕГАИС КАК СтатусыДокументовЕГАИС
			|		ПО (АктСписанияЕГАИСРегистр1.Ссылка = СтатусыДокументовЕГАИС.Документ)
			|";    
	// << MRS #VINE-267 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 08.04.26, (Задвоение актов на списание ЕГАИС_V2 если отправлен то ничего не делаем)
	//ДопОтбор = "И СтатусыДокументовЕГАИС.Статус = &СтатусЧерновикАктСписанияЕГАИС
	//|	И СтатусыДокументовЕГАИС.ДальнейшееДействие1 = &ДальнейшееДействиеЕГАИС";
	ДопОтбор = "";
	// >> MRS #VINE-267 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 08.04.26, (Задвоение актов на списание ЕГАИС_V2)
	
	// Поиск существующего документа "Акт списания ЕГАИС",
	// связанного с текущим "Выпуском блюд". 
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ                              
	// << MRS #VINE-267 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 08.04.26, (Задвоение актов на списание ЕГАИС_V2)
	|	СтатусыДокументовЕГАИС.ДальнейшееДействие1,
	|	СтатусыДокументовЕГАИС.Статус КАК Статус,
	// >> MRS #VINE-267 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 08.04.26, (Задвоение актов на списание ЕГАИС_V2)
	|	питТиповыеДокументы.ТиповойДокумент
	|ПОМЕСТИТЬ втДокументыВыпускПродукции
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|	&ДопСоединение
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &ДокументПит
	|	И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.АктСписанияЕГАИС
	|	&ДопОтбор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	// << MRS #VINE-267 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 08.04.26, (Задвоение актов на списание ЕГАИС_V2)
	|	втДокументыВыпускПродукции.ДальнейшееДействие1,
	|	втДокументыВыпускПродукции.Статус КАК Статус,
	// >> MRS #VINE-267 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 08.04.26, (Задвоение актов на списание ЕГАИС_V2)	
	|	втДокументыВыпускПродукции.ТиповойДокумент
	|ИЗ
	|	втДокументыВыпускПродукции КАК втДокументыВыпускПродукции
	|";
		
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ДопОтбор", ДопОтбор);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ДопСоединение", ДопСоединение);

	Запрос.УстановитьПараметр("ДокументПит", ДокументВыпускБлюд);
	
	Запрос.УстановитьПараметр("СтатусЧерновикАктСписанияЕГАИС", Перечисления.СтатусыОбработкиАктаСписанияЕГАИС.Черновик);
	Запрос.УстановитьПараметр("ДальнейшееДействиеЕГАИС", Перечисления.ДальнейшиеДействияПоВзаимодействиюЕГАИС.ПередайтеДанные);
	Запрос.УстановитьПараметр("ВидОперацииАктСписанияЕГАИСРегистр1", Перечисления.ВидыДокументовЕГАИС.АктСписанияИзРегистра1);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	// Если документ найден, то получаем объект иначе создаем новый.
	Если Выборка.Следующий() Тогда 
		// << MRS #VINE-267 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 08.04.26, (Задвоение актов на списание ЕГАИС_V2) Если отправлен то ничего не делаем
		//ТекДокументОбъект = Выборка.ТиповойДокумент.ПолучитьОбъект();
		//ЭтоНовый = Ложь;  
		Если Выборка.Статус = Перечисления.СтатусыОбработкиАктаСписанияЕГАИС.Черновик 
			И Выборка.ДальнейшееДействие1 = Перечисления.ДальнейшиеДействияПоВзаимодействиюЕГАИС.ПередайтеДанные Тогда

			ТекДокументОбъект = Выборка.ТиповойДокумент.ПолучитьОбъект();
			ЭтоНовый = Ложь;
		Иначе 
			Возврат Истина;	
		КонецЕсли;
		// >> MRS #VINE-267 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 08.04.26, (Задвоение актов на списание ЕГАИС_V2)	
	Иначе
		ТекДокументОбъект = Документы.АктСписанияЕГАИС.СоздатьДокумент();
		ЭтоНовый = Истина;
	КонецЕсли;            
		
	ПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокументВыпускБлюд.Проведен, ДокументВыпускБлюд.ПометкаУдаления,
		ТекДокументОбъект.Проведен, ТекДокументОбъект.ПометкаУдаления, Новый Структура);
		
	ТекРежимЗаписиДок = ПараметрыЗаписи.РежимЗаписи;	
	
	Если ПараметрыЗаписи.НужнаУстановкаПометкиУдаления И НЕ ЭтоНовый Тогда
	
		Попытка
			ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
			ТекДокументОбъект.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
			Возврат Истина;
		Исключение
			ТекстОшибки = ТекстОшибки + "
			|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
			| по документу Общепит """+ДокументВыпускБлюд+"""
			|по причине: <"+ОписаниеОшибки()+">";
			Возврат Ложь;
		КонецПопытки;
					
	КонецЕсли;
	
	// Товары
	ТекДокументОбъект.Товары.Очистить();
	ТекДокументОбъект.АкцизныеМарки.Очистить();
	ТекДокументОбъект.Комментарий = СтрШаблон("Создан по данным документа общепита: %1",ДокументВыпускБлюд);
	
	Для Каждого ЭлементСтруктуры ИЗ СтруктураВозврата Цикл
		
		Если ЭлементСтруктуры.Ключ = "Шапка" Тогда
			
			ОрганизацияЕГАИС = ЭлементСтруктуры.Значение;

		ИначеЕсли ЭлементСтруктуры.Ключ = "ДанныеСерииТовара" Тогда
			
			Для Каждого СтрокаТЧ из ЭлементСтруктуры.Значение Цикл
				
				НоваяСтрока = ТекДокументОбъект.Товары.Добавить();
				НоваяСтрока.АлкогольнаяПродукция    = СтрокаТЧ.АлкогольнаяПродукция;
				НоваяСтрока.Номенклатура            = СтрокаТЧ.Номенклатура;
				НоваяСтрока.Справка2                = СтрокаТЧ.Справка2;
				НоваяСтрока.Количество              = СтрокаТЧ.Количество;
				НоваяСтрока.КоличествоУпаковок 		= СтрокаТЧ.Количество;
								
			    НоваяСтрокаАМ = ТекДокументОбъект.АкцизныеМарки.Добавить();
			    НоваяСтрокаАМ.ШтрихкодУпаковки 				= СтрокаТЧ.АкцизнаяМарка;
		        НоваяСтрокаАМ.АкцизнаяМарка 				= СтрокаТЧ.АкцизнаяМарка;
			    НоваяСтрокаАМ.Справка2 						= СтрокаТЧ.Справка2;
				НоваяСтрокаАМ.Количество                    = СтрокаТЧ.Количество;
				НоваяСтрокаАМ.ВыбытиеБутылки				= Истина;
				
			КонецЦикла;
			
		КонецЕсли;
	
	КонецЦикла;
	
	// << MRS #VINE-41 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 25.03.25, (Свертка товаров при автоматическом формировании акта списания ЕГАИС)
	ТекДокументОбъект.Товары.Свернуть("АлкогольнаяПродукция, Номенклатура, Характеристика, Серия, Упаковка, Справка2, ИдентификаторСтроки, СтатусУказанияСерий", "Цена, НС_КоличествоДАЛ, Количество, КоличествоУпаковок, Сумма");
	
	//Для Каждого ТекСтрока Из ТекДокументОбъект.Товары Цикл
		//Если ТекСтрока.Количество <> 0 Тогда
		//	ТекСтрока.Цена = ТекСтрока.Сумма / ТекСтрока.Количество;
		//Иначе                                      
		//	ТекСтрока.Цена = ТекСтрока.Сумма / ТекСтрока.КоличествоУпаковок;
		//КонецЕсли;
		
	//КонецЦикла;
	// >> MRS #VINE-41 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 25.03.25, (Свертка товаров при автоматическом формировании акта списания ЕГАИС)
				
	// Дата документа
	Если НЕ ЗначениеЗаполнено(ТекДокументОбъект.Дата) Тогда
		ТекДокументОбъект.Дата = ДокументВыпускБлюд.Дата;
	КонецЕсли;
	
	ТекДокументОбъект.ВидДокумента = Перечисления.ВидыДокументовЕГАИС.АктСписанияИзРегистра1;
	ТекДокументОбъект.ПричинаСписания = Перечисления.ПричиныСписанийЕГАИС.питПриготовление;
	
	ТекДокументОбъект.ОрганизацияЕГАИС = ОрганизацияЕГАИС;
	
	Если НЕ ЗначениеЗаполнено(ТекДокументОбъект.Номер) Тогда
		ТекДокументОбъект.УстановитьНовыйНомер();
	КонецЕсли;
	
	ТекДокументОбъект.Ответственный = ДокументВыпускБлюд.Ответственный;
	
	Попытка
		
		ТекДокументОбъект.Записать(ТекРежимЗаписиДок);
		
	Исключение
		ТекстОшибки = Строка(ТекстОшибки) + "
		|Ошибка записи документа " + ТекДокументОбъект.Метаданные().Представление() + "
		| по документу Общепит " + ДокументВыпускБлюд + "
		|по причине: <" + ОписаниеОшибки()  +">";
		Возврат Ложь;
	КонецПопытки;
	
	// Добавление записи в результирующую таблицу в случае успешной записи документов.
	ДобавитьНовуюЗапись(ДокументВыпускБлюд, ТекДокументОбъект, тблСозданныеДокументы, 0);
	
	Возврат Истина;
	

КонецФункции


#КонецОбласти

#КонецОбласти

#Область ФормированиеТиповыхДокументовПоРазделке

// Процедура формирования типовых документов по переданному выпуску блюд.
//
// Параметры:
//  ДокРазделкапит		 - ДокументСсылка	 - Ссылка на документ "Разделка", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьТиповыеДокументыПоРазделке(ДокРазделкапит, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки = "")
	
	ВсеОк = Истина;
	
	Если СтруктураПараметров.Свойство("ФормироватьДокументыПроизводства22") Тогда
		ФормироватьДокументыПроизводства22 = СтруктураПараметров.ФормироватьДокументыПроизводства22;
	Иначе
		ФормироватьДокументыПроизводства22 = Константы.питФормироватьДокументыПроизводства22.Получить();
	КонецЕсли;
	
	ТиповыеДокументы = ПолучитьТиповыеДокументыДляДокументаПитПоРежимуПроизводства(ДокРазделкапит, ?(ФормироватьДокументыПроизводства22,"2.1","2.2"));
	Если ТиповыеДокументы.Количество() Тогда
		
		УдалятьДокументыСтаройСхемыПроведения = Истина;
		Если СтруктураПараметров.Свойство("УдалятьДокументыСтаройСхемыПроведения") Тогда
			УдалятьДокументыСтаройСхемыПроведения = СтруктураПараметров.УдалятьДокументыСтаройСхемыПроведения;
		КонецЕсли;
		
		Если УдалятьДокументыСтаройСхемыПроведения Тогда
			
			Если СтруктураПараметров.Свойство("РежимЗаписи") И СтруктураПараметров.РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
				// Для документов общепит при перепроведении выполняется сначала отмена проведения явным образом, 
				// чтобы отменить проведение всех типовых документов.
				// В этот момент, мы отменим проведение документов старой схемы.
				ФормироватьДокументыПроизводства22 = НЕ ФормироватьДокументыПроизводства22;
			Иначе
				
				// "Обрываем" связь документов старой схемы производства!
				ВсеОк = ПометитьНаУдалениеИОтвязатьТиповыеДокументы(ДокРазделкапит, ТиповыеДокументы, СтруктураПараметров, ТекстОшибки);
				
			КонецЕсли;
			
		Иначе
			
			ТекстОшибки = ТекстОшибки + "
			| Не выполнено формирование типовых документов производства "+?(ФормироватьДокументыПроизводства22,"2.2","2.1")+" по документу общепит <"+ДокРазделкапит+"> !!
			| По данному документу уже созданы документы производства "+?(ФормироватьДокументыПроизводства22,"2.1","2.2")+"!";
			Возврат Ложь;
			
		КонецЕсли;
	КонецЕсли;
	
	ПоФиксированнойСтоимости = ФормироватьДокументыПоРазделкеПоФиксированнойСтоимости(ДокРазделкапит);
	
	Если ФормироватьДокументыПроизводства22 Тогда
		
		// ДОКУМЕНТЫ 2.2
		
		Если ПоФиксированнойСтоимости Тогда
			
			// Заглушка, все удаляем
			ТиповыеДокументыРазделки = ПолучитьТиповыеДокументыДляДокументаПитПоРежимуПроизводства(ДокРазделкапит, "2.2");
			Для каждого ТиповойДокумент Из ТиповыеДокументыРазделки Цикл
				
				Попытка
					ДокОбъект = ТиповойДокумент.ПолучитьОбъект();
					ДокОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
					ДокОбъект.УстановитьПометкуУдаления(Истина);
				Исключение
					ТекстОшибки = ТекстОшибки + "
					|Ошибка при установке пометки удаления """ + ДокОбъект.Метаданные().Представление() + """
					| по документу Общепит """+ДокРазделкапит+"""
					|по причине: <"+ОписаниеОшибки()+">";
					Возврат Ложь;
				КонецПопытки;
				
			КонецЦикла;
			
		Иначе
			
			// По долям себестоимости, будут созданы "Производство без заказа"
			ВсеОК = СформироватьТиповыеДокументыПоРазделкеПоДолямСебестоимости22(ДокРазделкапит, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
			
		КонецЕсли;
		
	Иначе // Документы 2.1
		
		Если СтруктураПараметров.Свойство("ПроизводственныйПуть") Тогда
			СтруктураПараметров.ПроизводственныйПуть = ПоФиксированнойСтоимости;
		Иначе
			СтруктураПараметров.Вставить("ПроизводственныйПуть", ПоФиксированнойСтоимости);
		КонецЕсли;
		
		ВсеОк = ПометитьНаУдалениеНеиспользуемыеТиповыеДокументыРазделки(ДокРазделкапит, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
		
		Если ПоФиксированнойСтоимости И ВсеОк Тогда
			////////////////////////////////////////////////////////////////////////////////////////////////////
			// ВАРИАНТ С ФОРМИРОВАНИЕМ ПРОИЗВОДСТВЕННЫХ ТИПОВЫХ ДОКУМЕНТОВ ПО ДОКУМЕНТУ Общепит "РАЗДЕЛКА"
			//
			ВсеОК = СформироватьТиповыеДокументыПоРазделкеПроизводственныйПуть(ДокРазделкапит, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
		Иначе
			////////////////////////////////////////////////////////////////////////////////////////////////////
			// ВАРИАНТ С ФОРМИРОВАНИЕМ ТИПОВЫХ ДОКУМЕНТОВ "РАЗБОРКА" ПО ДОКУМЕНТУ Общепит "РАЗДЕЛКА"
			//
			ВсеОК = СформироватьТиповыеДокументыПоРазделкеСборкаРазборкаТоваров(ДокРазделкапит, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ВсеОк;
	
КонецФункции

// Функция определяет, нужно ли формировать производственные документы по переданному документу пит "Разделка".
//
// Параметры:
//  ДокРазделкапит	 - ДокументСсылка.питРазделка - Ссылка на проверяемый документ.
// 
// Возвращаемое значение:
//  Булево - Флаг необходимости формирования производственных документов.
//
Функция ФормироватьДокументыПоРазделкеПоФиксированнойСтоимости(ДокРазделкапит)
	
	Возврат Ложь;
	
	Результат = Ложь;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	питРазделкаТовары.ПроцентСебестоимости
	|ИЗ
	|	Документ.питРазделка.Товары КАК питРазделкаТовары
	|ГДЕ
	|	питРазделкаТовары.Ссылка = &ДокументРазделка
	|	И питРазделкаТовары.ПроцентСебестоимости = 0";
	Запрос.УстановитьПараметр("ДокументРазделка", ДокРазделкапит);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Результат = Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#Область ФормированиеТиповыхПроизводственныхДокументовПоРазделке

// Процедура формирования типовых документов по переданному выпуску блюд.
//
// Параметры:
//  ДокРазделкапит		 - ДокументСсылка	 - Ссылка на документ "Разделка", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьТиповыеДокументыПоРазделкеПроизводственныйПуть(ДокРазделкапит, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки = "")
	
	ВсеОк = Истина;
	
	///////////////////////////////////////////////////
	// ФОРМИРОВАНИЕ ПЕРЕДАЧИ МАТЕРИАЛОВ В ПРОИЗВОДСТВО
	ВсеОк = СформироватьПередачуМатериаловПоРазделке(ДокРазделкапит, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
	Если НЕ ВсеОк Тогда 
		Возврат ВсеОк;
	КонецЕсли;
	
	//////////////////////////////////
	// ФОРМИРОВАНИЕ ВЫПУСКОВ ПРОДУКЦИИ
	//
	
	// Получение документов-объектов "Выпуск продукции" с направлением "На склад" и "В подразделение".
	ДокВыпускПродукцииНаСклад	= Неопределено;
	ПолучитьВыпускиПродукцииДляРазделки(ДокРазделкапит, ДокВыпускПродукцииНаСклад);
	
	// Определение параметров записи.
	ПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокРазделкапит.Проведен,ДокРазделкапит.ПометкаУдаления,
		ДокВыпускПродукцииНаСклад.Проведен,ДокВыпускПродукцииНаСклад.ПометкаУдаления,СтруктураПараметров);
	
	// Определение режима записи
	ТекРежимЗаписи = ПараметрыЗаписи.РежимЗаписи;
	
	//!!!!!!!!!!
	// Если документы "Выпуск продукции" проведены, то будет происходить перепроведение или отмена проведения.
	// Для этого необходимо сначала отменить проведение списаний затарат в производство, т.к.
	// в них есть ссылки на строки ТЧ "Товары" типовых документов "Выпуск продукции".
	Если ДокВыпускПродукцииНаСклад.Проведен 
		И НЕ ОтменитьПроведениеТиповогоДокументаПоДокументупит(ДокРазделкапит, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки, "СписаниеЗатратНаВыпуск") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ПараметрыЗаписи.НужнаУстановкаПометкиУдаления Тогда
		
		Попытка
			ДокВыпускПродукцииНаСклад.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
			ДокВыпускПродукцииНаСклад.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
		Исключение
			ТекстОшибки = ТекстОшибки + "
			|Ошибка при установке пометки удаления """ + ДокВыпускПродукцииНаСклад.Метаданные().Представление() + """(на склад)
			| по документу Общепит """+ДокРазделкапит+"""
			|по причине: <"+ОписаниеОшибки()+">";
			Возврат Ложь;
		КонецПопытки;
		
	КонецЕсли;
		
	// Заполнение общих реквизитов
	//ЗаполнитьОбщиеРеквизиты(ДокументВыпускБлюд,ДокВыпускПродукцииНаСклад);
	
	/////////////////////////////////
	// ЗАПОЛНЕНИЕ ШАПКИ.
	
	// Выпуск на склад
	ДокВыпускПродукцииНаСклад.Дата						= ДокРазделкапит.Дата + ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0);
	ДокВыпускПродукцииНаСклад.Организация				= ДокРазделкапит.Организация;
	ДокВыпускПродукцииНаСклад.Подразделение				= ДокРазделкапит.Подразделение;
	ДокВыпускПродукцииНаСклад.Склад						= ДокРазделкапит.Склад;
	ДокВыпускПродукцииНаСклад.ВидЦены					= ДокРазделкапит.ТипЦен;
	ДокВыпускПродукцииНаСклад.Ответственный				= ДокРазделкапит.Ответственный;
	ДокВыпускПродукцииНаСклад.Комментарий				= ДокРазделкапит.Комментарий;
	ДокВыпускПродукцииНаСклад.ВыпускПоРаспоряжениям		= Ложь;
	ДокВыпускПродукцииНаСклад.НаправлениеВыпуска		= Перечисления.ХозяйственныеОперации.ВыпускПродукцииНаСклад;
	
	// Автоопределение значения налогообложения НДС.
	ДокВыпускПродукцииНаСклад.ВыпускПодДеятельность = Неопределено;
	ПараметрыЗаполнения = Документы.ВыпускПродукции.ПараметрыЗаполненияВидаДеятельностиНДС(ДокВыпускПродукцииНаСклад);
	УчетНДСУП.ЗаполнитьВидДеятельностиНДС(ДокВыпускПродукцииНаСклад.ВыпускПодДеятельность, ПараметрыЗаполнения);
	
	мМетаданныеДокументапит	= ДокРазделкапит.Метаданные();
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Валюта", мМетаданныеДокументапит) Тогда
		ДокВыпускПродукцииНаСклад.Валюта				= ДокРазделкапит.Валюта;
	ИначеЕсли ОбщегоНазначения.ЕстьРеквизитОбъекта("ВалютаДокумента", мМетаданныеДокументапит) Тогда
		ДокВыпускПродукцииНаСклад.Валюта				= ДокРазделкапит.ВалютаДокумента;
	КонецЕсли;
	//ДокВыпускПродукцииНаСклад.НаправлениеДеятельности	= ДокРазделкапит.;
	
	// Очистка табличных частей, т.к. будет их перезаполнение.
	ДокВыпускПродукцииНаСклад.Товары.Очистить();
	ДокВыпускПродукцииНаСклад.Серии.Очистить();
	ДокВыпускПродукцииНаСклад.ДополнительныеРеквизиты.Очистить();
	
	// Получение данных по табличной части "Производство" отраслевого документа "Выпуск блюд".
	Запрос = Новый Запрос;
	ТекстЗапроса=
	"ВЫБРАТЬ
	|	питРазделкаТовары.Номенклатура КАК Номенклатура,
	|	питРазделкаТовары.Характеристика КАК Характеристика,
	|	питРазделкаТовары.КоличествоУпаковок КАК КоличествоУпаковокНоменклатуры,
	|	питРазделкаТовары.Упаковка КАК УпаковкаНоменклатуры,
	|	питРазделкаТовары.Количество КАК КоличествоНоменклатуры,
	|	питРазделкаТовары.ПроцентСебестоимости
	|ИЗ
	|	Документ.питРазделка.Товары КАК питРазделкаТовары
	|ГДЕ
	|	питРазделкаТовары.Ссылка = &Ссылка
	|	И НЕ питРазделкаТовары.Номенклатура.питВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.питВидыНоменклатуры.ТехнологическийИнгредиент)";
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("Ссылка", ДокРазделкапит.Ссылка);
	
	// Обход таб. части и заполнение таб. частей "Товары" документов "Выпуск продукции".
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		НовСтрока = ДокВыпускПродукцииНаСклад.Товары.Добавить();
		НовСтрока.Подразделение			= Справочники.СтруктураПредприятия.ПустаяСсылка(); // Для данного направления выпуска не заполнен.
		НовСтрока.Склад					= ДокРазделкапит.Склад; // Дублируем из шапки.
		
		НовСтрока.Номенклатура			= Выборка.Номенклатура;
		НовСтрока.Характеристика		= Выборка.Характеристика;
		НовСтрока.Упаковка				= Выборка.УпаковкаНоменклатуры;
		НовСтрока.КоличествоУпаковок	= Выборка.КоличествоУпаковокНоменклатуры;
		НовСтрока.Количество			= Выборка.КоличествоНоменклатуры;
		Если Выборка.ПроцентСебестоимости = 0 Тогда
			НовСтрока.ТипСтоимости			= Перечисления.ТипыСтоимостиВыходныхИзделий.Фиксированная;
			//НовСтрока.Цена					= Выборка.Цена;
			//НовСтрока.Сумма					= Выборка.Сумма;
		Иначе
			НовСтрока.ТипСтоимости			= Перечисления.ТипыСтоимостиВыходныхИзделий.Рассчитывается;
		КонецЕсли;
		
		//НовСтрока.Серия				= Выборка.;
		//НовСтрока.СтатьяРасходов		= Выборка.; // Необходимо добавить в выпуск.
		//НовСтрока.СписатьНаРасходы	= ; // Только если будет выпуск со списанием.
		//НовСтрока.Склад				= ; // .
		
	КонецЦикла;
	
	//////////////////////////////////
	// ЗАПИСЬ ВЫПУСКОВ ПРОДУКЦИИ
	
	Попытка
		ДокВыпускПродукцииНаСклад.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
		ДокВыпускПродукцииНаСклад.Записать(ТекРежимЗаписи);
	Исключение
		ТекстОшибки = ТекстОшибки + "
		|Ошибка записи документа """ + ДокВыпускПродукцииНаСклад.Метаданные().Представление() + """(на склад)
		| по документу Общепит """+ДокРазделкапит+"""
		|по причине: <"+ОписаниеОшибки()+">";
		Возврат Ложь;
	КонецПопытки;
	
	// Добавление записи в результирующую таблицу в случае успешной записи документов.
	ДобавитьНовуюЗапись(ДокРазделкапит, ДокВыпускПродукцииНаСклад, тблСозданныеДокументы);
	
	// Массив обновленных выпусков продукции, на которых будут ссылаться
	// документы "Списание затрат на выпуск".
	ДокументыВыпускаПродукции = Новый Массив;
	ДокументыВыпускаПродукции.Добавить(ДокВыпускПродукцииНаСклад.Ссылка);
	СтруктураПараметров.Вставить("ДокументыВыпускаПродукции", ДокументыВыпускаПродукции);
	
	/////////////////////////////////////
	// ФОРМИРОВАНИЕ СПИСАНИЙ ЗАТРАТ НА ВЫПУСК
	ВсеОк = СформироватьСписанияЗатратПоРазделке(ДокРазделкапит, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
	
	Возврат ВсеОк;
	
КонецФункции

// Процедура по переданной ссылке на разделку ищет типовые документы "Выпуск продукции" с хоз. операцией
//  "В подразделение" или "На склад" возвращая ДокОбъект. Если не находит, то создает для них пустой объект.
//
// Параметры:
//  ДокументВыпускБлюд			 - ДокументСсылка	 - Ссылка на документ, для которого ищем "Выпуски продукции".
//  выхДокВыпускПродукцииНаСклад - ДокументОбъект	 - Документ "Выпуск продукции"(на склад).
//
Процедура ПолучитьВыпускиПродукцииДляРазделки(ДокументВыпускБлюд, выхДокВыпускПродукцииНаСклад = Неопределено, выхДокВыпускПродукцииВПодр = Неопределено)
	
	Запрос = Новый Запрос;
	
	// Поиск всех выпусков продукции "В подразделение" или "На склад", 
	// связанных с текущим выпуском блюд.
	Запрос.Текст = 
	"ВЫБРАТЬ 
	|	питТиповыеДокументы.ТиповойДокумент
	|ПОМЕСТИТЬ втДокументыВыпускПродукции
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|	И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.ВыпускПродукции
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ 
	|	ВыпускПродукции.НаправлениеВыпуска,
	|	втДокументыВыпускПродукции.ТиповойДокумент КАК ВыпускПродукции
	|ИЗ
	|	втДокументыВыпускПродукции КАК втДокументыВыпускПродукции
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВыпускПродукции КАК ВыпускПродукции
	|		ПО (втДокументыВыпускПродукции.ТиповойДокумент = ВыпускПродукции.Ссылка)
	|ГДЕ
	|	ВыпускПродукции.НаправлениеВыпуска В(&НеобходимыеНаправленияВыпуска)";
	
	// Список хоз. операций, поиск будет производиться только для них.
	НаправленияВыпуска = Новый СписокЗначений;
	НаправленияВыпуска.Добавить(Перечисления.ХозяйственныеОперации.ВыпускПродукцииНаСклад);
	
	Запрос.УстановитьПараметр("Документпит",				ДокументВыпускБлюд);
	Запрос.УстановитьПараметр("НеобходимыеНаправленияВыпуска",	НаправленияВыпуска);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	// Если документы найдены, то инициализируем соответствующие переменные.
	Пока Выборка.Следующий() Цикл
		Если Выборка.НаправлениеВыпуска = Перечисления.ХозяйственныеОперации.ВыпускПродукцииНаСклад Тогда
			Если выхДокВыпускПродукцииНаСклад = Неопределено Тогда
				выхДокВыпускПродукцииНаСклад = Выборка.ВыпускПродукции.ПолучитьОбъект();
			Иначе
				// Случай, когда С "Выпуском блюд" связано более 1го "Выпуск продукции"(На склад).
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	// Если переменные не инициализированны, значит документы не были найдены
	// и необходимо создать пустые документы-объекты, которые далее будут заполняться.
	Если выхДокВыпускПродукцииНаСклад = Неопределено Тогда
		выхДокВыпускПродукцииНаСклад = Документы["ВыпускПродукции"].СоздатьДокумент();
	КонецЕсли;
	
КонецПроцедуры

// Функция формирует документ "Передача материалов в производство" для всех ингредиентов не из автопеределов
//  в ТЧ "Ингредиенты" переданного документа "Выпуск блюд" или обновляет существующие.
//
// Параметры:
//  ДокументРазделка		 - ДокументСсылка	 - Ссылка на документ "Разделка", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьПередачуМатериаловПоРазделке(ДокументРазделка, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки)
	
	Запрос = Новый Запрос;
	
	// Поиск существующего документа "Передача материалов в производство",
	// связанного с текущим "Выпуском блюд".
	Запрос.Текст = 
	"ВЫБРАТЬ 
	|	питТиповыеДокументы.ТиповойДокумент
	|ПОМЕСТИТЬ втДокументыВыпускПродукции
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|	И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.ПередачаМатериаловВПроизводство
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ 
	|	втДокументыВыпускПродукции.ТиповойДокумент
	|ИЗ
	|	втДокументыВыпускПродукции КАК втДокументыВыпускПродукции
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПередачаМатериаловВПроизводство КАК ПередачаМатериаловВПроизводство
	|		ПО (втДокументыВыпускПродукции.ТиповойДокумент = ПередачаМатериаловВПроизводство.Ссылка)
	|";
	Запрос.УстановитьПараметр("Документпит",				ДокументРазделка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	// Если документ найден, то получаем объект иначе создаем новый.
	Если Выборка.Следующий() Тогда
		ТекДокументОбъект = Выборка.ТиповойДокумент.ПолучитьОбъект();
	Иначе
		ТекДокументОбъект = Документы["ПередачаМатериаловВПроизводство"].СоздатьДокумент();
	КонецЕсли;
	
	// Определение параметров записи.
	ПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокументРазделка.Проведен,ДокументРазделка.ПометкаУдаления,
		ТекДокументОбъект.Проведен,ТекДокументОбъект.ПометкаУдаления,СтруктураПараметров);
	
	// Определение режима записи
	ТекРежимЗаписи = ПараметрыЗаписи.РежимЗаписи;
	
	Если ПараметрыЗаписи.НужнаУстановкаПометкиУдаления Тогда
		
		Попытка
			ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
			ТекДокументОбъект.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
		Исключение
			ТекстОшибки = ТекстОшибки + "
			|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
			| по документу Общепит """+ДокументРазделка+"""
			|по причине: <"+ОписаниеОшибки()+">";
			Возврат Ложь;
		КонецПопытки;
		
	КонецЕсли;
	
	/////////////////////////////////
	// ЗАПОЛНЕНИЕ ШАПКИ.
	
	ТекДокументОбъект.Дата					= ДокументРазделка.Дата + ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0);
	ТекДокументОбъект.Организация			= ДокументРазделка.Организация;
	ТекДокументОбъект.Склад					= ДокументРазделка.Склад;
	ТекДокументОбъект.Подразделение			= ДокументРазделка.Подразделение;
	ТекДокументОбъект.Ответственный			= ДокументРазделка.Ответственный;
	ТекДокументОбъект.Комментарий			= ДокументРазделка.Комментарий;
	ТекДокументОбъект.ХозяйственнаяОперация	= Перечисления.ХозяйственныеОперации.ПередачаВПроизводство;
	ТекДокументОбъект.Статус				= Перечисления.СтатусыПередачМатериаловВПроизводство.Принято;
	
	// Очистка табличных частей, т.к. будет их перезаполнение.
	ТекДокументОбъект.Товары.Очистить();
	ТекДокументОбъект.ВидыЗапасов.Очистить();
	ТекДокументОбъект.Серии.Очистить();
	ТекДокументОбъект.ДополнительныеРеквизиты.Очистить();
	
	НовСтрока						= ТекДокументОбъект.Товары.Добавить();
	НовСтрока.Номенклатура			= ДокументРазделка.Номенклатура;
	НовСтрока.Упаковка				= ДокументРазделка.Упаковка;
	НовСтрока.КоличествоУпаковок	= ДокументРазделка.КоличествоУпаковок;
	НовСтрока.Количество			= ДокументРазделка.Количество;
	
	/////////////////////////////////////////////////////////
	// ЗАПИСЬ ДОКУМЕНТА "ПЕРЕДАЧА МАТЕРИАЛОВ В ПРОИЗВОДСТВО"
	
	Попытка
		ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
		ТекДокументОбъект.Записать(ТекРежимЗаписи);
	Исключение
		ПодробноеПредставлениеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ТекстОшибки = ТекстОшибки + "
		|Ошибка записи документа """ + ТекДокументОбъект.Метаданные().Представление() + """
		| по документу Общепит """+ДокументРазделка+"""
		|по причине: <"+ОписаниеОшибки()+">";
		Возврат Ложь;
	КонецПопытки;
	
	// Добавление записи в результирующую таблицу в случае успешной записи документов.
	ДобавитьНовуюЗапись(ДокументРазделка, ТекДокументОбъект, тблСозданныеДокументы);
	
	Возврат Истина;
	
КонецФункции

// Функция формирует документы "Списание затрат на выпуск" для каждой номенклатурной позиции
//  в ТЧ "Товары" переданного документа "Разделка" или обновляет существующие.
//
// Параметры:
//  ДокументРазделка		 - ДокументСсылка	 - Ссылка на документ "Разделка", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьСписанияЗатратПоРазделке(ДокументРазделка, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки = "")
	
	// Запрос:
	// 1. Получение ВТ с реквизитами шапки документа "Выпуск блюд".
	// 2. Выбор в ВТ всех "Списаний затрат на выпуск", связанных с переданным выпуском блюд.
	// 3. Выбор в ВТ необходимых реквизитов ТЧ Производство док. "Выпуск блюд" + реквизитов шапки из (1).
	// 4. Выбор номенклатуры и флагов проведения из документов "Списание затрат...", связанных с "Выпуск блюд"(2).
	// 5. Выбор данных из вт(3) с итогом по номенклатуре.
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питРазделка.Ссылка,
	|	питРазделка.ПометкаУдаления,
	|	питРазделка.Проведен,
	|	питРазделка.Организация,
	|	питРазделка.Номенклатура,
	|	питРазделка.Количество,
	|	питРазделка.КоличествоУпаковок,
	|	питРазделка.Упаковка,
	|	питРазделка.Ответственный,
	|	питРазделка.Комментарий,
	|	питРазделка.Подразделение,
	|	питРазделка.Дата,
	|	питРазделка.СтатьяКалькуляции,
	|	питРазделка.СуммарнаяДоляВыхода
	|ПОМЕСТИТЬ втШапкаРазделки
	|ИЗ
	|	Документ.питРазделка КАК питРазделка
	|ГДЕ
	|	питРазделка.Ссылка = &Документпит
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	питТиповыеДокументы.ТиповойДокумент
	|ПОМЕСТИТЬ втДокументыСписаниеЗатрат
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|	И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.СписаниеЗатратНаВыпуск
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВыпускПродукции.Ссылка,
	|	ВЫБОР
	|		КОГДА ВыпускПродукции.НаправлениеВыпуска = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВыпускПродукцииВПодразделение)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Автопередел
	|ПОМЕСТИТЬ втВыпускиПродукцииАвтопередел
	|ИЗ
	|	Документ.ВыпускПродукции КАК ВыпускПродукции
	|ГДЕ
	|	ВыпускПродукции.Ссылка В(&ДокументыВыпускаПродукции)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВыпускПродукцииТовары.Ссылка КАК Распоряжение,
	|	ВыпускПродукцииТовары.Номенклатура,
	|	ВыпускПродукцииТовары.КодСтроки,
	|	втВыпускиПродукцииАвтопередел.Автопередел
	|ПОМЕСТИТЬ втРаспоряжения
	|ИЗ
	|	Документ.ВыпускПродукции.Товары КАК ВыпускПродукцииТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ втВыпускиПродукцииАвтопередел КАК втВыпускиПродукцииАвтопередел
	|		ПО ВыпускПродукцииТовары.Ссылка = втВыпускиПродукцииАвтопередел.Ссылка
	|ГДЕ
	|	ВыпускПродукцииТовары.Ссылка В(&ДокументыВыпускаПродукции)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	питРазделкаТовары.Ссылка,
	|	питРазделкаТовары.Номенклатура,
	|	ЛОЖЬ КАК Автопередел,
	|	питРазделкаТовары.КоличествоУпаковок КАК КоличествоУпаковокНоменклатуры,
	|	питРазделкаТовары.Упаковка КАК УпаковкаНоменклатуры,
	|	питРазделкаТовары.Количество КАК КоличествоНоменклатуры,
	|	питРазделкаТовары.ПроцентВыхода КАК КоэффициентСписываемойНоменклатуры
	|ПОМЕСТИТЬ втПроизводство
	|ИЗ
	|	Документ.питРазделка.Товары КАК питРазделкаТовары
	|ГДЕ
	|	питРазделкаТовары.Ссылка = &Документпит
	|	И НЕ питРазделкаТовары.Номенклатура.питВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.питВидыНоменклатуры.ТехнологическийИнгредиент)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втПроизводство.Ссылка,
	|	втПроизводство.Номенклатура,
	|	втПроизводство.Автопередел,
	|	втПроизводство.КоличествоУпаковокНоменклатуры,
	|	втПроизводство.УпаковкаНоменклатуры,
	|	втПроизводство.КоличествоНоменклатуры,
	|	втПроизводство.КоэффициентСписываемойНоменклатуры
	|ПОМЕСТИТЬ втПроизводствоВсе
	|ИЗ
	|	втПроизводство КАК втПроизводство
	|ГДЕ
	|	втПроизводство.Ссылка = &Документпит
	|
	|СГРУППИРОВАТЬ ПО
	|	втПроизводство.КоличествоНоменклатуры,
	|	втПроизводство.КоличествоУпаковокНоменклатуры,
	|	втПроизводство.Ссылка,
	|	втПроизводство.Номенклатура,
	|	втПроизводство.Автопередел,
	|	втПроизводство.УпаковкаНоменклатуры,
	|	втПроизводство.КоэффициентСписываемойНоменклатуры
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втПроизводствоВсе.Номенклатура,
	|	втПроизводствоВсе.Ссылка КАК ДокументВыпускБлюд,
	|	втПроизводствоВсе.КоличествоНоменклатуры,
	|	втПроизводствоВсе.УпаковкаНоменклатуры,
	|	втПроизводствоВсе.КоличествоУпаковокНоменклатуры,
	|	втШапкаРазделки.Номенклатура КАК Ингредиент,
	|	втШапкаРазделки.Упаковка КАК УпаковкаИнгредиента,
	|	втШапкаРазделки.Количество КАК КоличествоИнгредиентаФакт,
	|	втШапкаРазделки.КоличествоУпаковок КАК КоличествоУпаковокИнгредиентаФакт,
	|	втШапкаРазделки.ПометкаУдаления,
	|	втШапкаРазделки.Проведен,
	|	втШапкаРазделки.Организация,
	|	втШапкаРазделки.Ответственный,
	|	втШапкаРазделки.Комментарий,
	|	втШапкаРазделки.Подразделение,
	|	втШапкаРазделки.Дата,
	|	втПроизводствоВсе.КоэффициентСписываемойНоменклатуры,
	|	втШапкаРазделки.СтатьяКалькуляции,
	|	ЕСТЬNULL(втРаспоряжения.Распоряжение, ЗНАЧЕНИЕ(Документ.ВыпускПродукции.ПустаяСсылка)) КАК Распоряжение,
	|	ЕСТЬNULL(втРаспоряжения.КодСтроки, 0) КАК КодСтроки,
	|	втПроизводствоВсе.Автопередел,
	|	ВЫБОР
	|		КОГДА втШапкаРазделки.СуммарнаяДоляВыхода = 0
	|			ТОГДА 1
	|		ИНАЧЕ втШапкаРазделки.СуммарнаяДоляВыхода
	|	КОНЕЦ КАК СуммарнаяДоляВыхода
	|ПОМЕСТИТЬ втНоменклатураВПроизводстве
	|ИЗ
	|	втШапкаРазделки КАК втШапкаРазделки
	|		ЛЕВОЕ СОЕДИНЕНИЕ втПроизводствоВсе КАК втПроизводствоВсе
	|			ЛЕВОЕ СОЕДИНЕНИЕ втРаспоряжения КАК втРаспоряжения
	|			ПО втПроизводствоВсе.Номенклатура = втРаспоряжения.Номенклатура
	|				И втПроизводствоВсе.Автопередел = втРаспоряжения.Автопередел
	|		ПО втШапкаРазделки.Ссылка = втПроизводствоВсе.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втДокументыСписаниеЗатрат.ТиповойДокумент КАК СписаниеЗатрат,
	|	СписаниеЗатратНаВыпуск.ПометкаУдаления,
	|	СписаниеЗатратНаВыпуск.Проведен
	|ИЗ
	|	втДокументыСписаниеЗатрат КАК втДокументыСписаниеЗатрат
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СписаниеЗатратНаВыпуск КАК СписаниеЗатратНаВыпуск
	|		ПО втДокументыСписаниеЗатрат.ТиповойДокумент = СписаниеЗатратНаВыпуск.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втНоменклатураВПроизводстве.Номенклатура КАК Номенклатура,
	|	втНоменклатураВПроизводстве.ДокументВыпускБлюд,
	|	втНоменклатураВПроизводстве.КоличествоНоменклатуры,
	|	втНоменклатураВПроизводстве.УпаковкаНоменклатуры,
	|	втНоменклатураВПроизводстве.КоличествоУпаковокНоменклатуры,
	|	втНоменклатураВПроизводстве.Ингредиент,
	|	втНоменклатураВПроизводстве.УпаковкаИнгредиента,
	|	втНоменклатураВПроизводстве.КоличествоИнгредиентаФакт,
	|	втНоменклатураВПроизводстве.КоличествоУпаковокИнгредиентаФакт,
	|	втНоменклатураВПроизводстве.ПометкаУдаления,
	|	втНоменклатураВПроизводстве.Проведен,
	|	втНоменклатураВПроизводстве.Организация,
	|	втНоменклатураВПроизводстве.Ответственный,
	|	втНоменклатураВПроизводстве.Комментарий,
	|	втНоменклатураВПроизводстве.Подразделение,
	|	втНоменклатураВПроизводстве.Дата,
	|	втНоменклатураВПроизводстве.КоэффициентСписываемойНоменклатуры,
	|	втНоменклатураВПроизводстве.СтатьяКалькуляции,
	|	втНоменклатураВПроизводстве.Распоряжение,
	|	втНоменклатураВПроизводстве.КодСтроки,
	|	втНоменклатураВПроизводстве.Автопередел КАК Автопередел,
	|	втНоменклатураВПроизводстве.СуммарнаяДоляВыхода КАК СуммарныйКоэффициент
	|ИЗ
	|	втНоменклатураВПроизводстве КАК втНоменклатураВПроизводстве
	|ИТОГИ ПО
	|	Номенклатура,
	|	Автопередел";
	
	// Если документы "Выпуск продукции" не заданы, то инициализируем их как пустой массив.
	Если СтруктураПараметров.Свойство("ДокументыВыпускаПродукции") И НЕ СтруктураПараметров.ДокументыВыпускаПродукции = Неопределено Тогда
		ДокументыВыпускаПродукции = СтруктураПараметров.ДокументыВыпускаПродукции;
	Иначе
		ДокументыВыпускаПродукции = Новый Массив;
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Документпит",				ДокументРазделка);
	Запрос.УстановитьПараметр("ДокументыВыпускаПродукции",	ДокументыВыпускаПродукции);
	
	// Выполнение запроса и получение 2х выборок:
	// - Основная выборка с данными по номенклатуре и ее ингридиентам
	// - Доп. выборка существующих документов "Списание затрат" по текущему документу "пит".
	РезультатПакет = Запрос.ВыполнитьПакет();
	Выборка								= РезультатПакет[8].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаСуществующиеСписания			= РезультатПакет[7].Выбрать();
	
	// Структура текущего "Списания затрат".
	ТекСписаниеЗатрат = Новый Структура("СписаниеЗатрат,ПометкаУдаления,Проведен");
	
	РаспределеноДолей = 0;
	РаспределеноКоличество = 0;
	РаспределеноКоличествоУпаковок = 0;
	
	// Обход основной выборки
	Пока Выборка.Следующий() Цикл
		
		ВыборкаАвтопередел = Выборка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаАвтопередел.Следующий() Цикл
			
			ВыборкаДетальная = ВыборкаАвтопередел.Выбрать();
			
			// Выборка по списаниям затрат.
			// Если документ существует, тогда заполняем его данными структуру тек. списания,
			// иначе - заполняем значениями по умолчанию.
			Если ВыборкаСуществующиеСписания.Следующий() Тогда
				ЗаполнитьЗначенияСвойств(ТекСписаниеЗатрат,ВыборкаСуществующиеСписания);
			Иначе
				ТекСписаниеЗатрат.СписаниеЗатрат = Документы["СписаниеЗатратНаВыпуск"].ПустаяСсылка();
				ТекСписаниеЗатрат.ПометкаУдаления = Ложь;
				ТекСписаниеЗатрат.Проведен = Ложь;
			КонецЕсли;
			
			// "Обнуление" переменной текущего объекта
			ТекДокументОбъект = Неопределено;
			
			ПерваяДетальнаяСтрока = Истина; // В момент обхода первой строки детальной выборки заполняем шапку.
			
			// Детальный обход основной выборки
			Пока ВыборкаДетальная.Следующий() Цикл
				
				Если ПерваяДетальнаяСтрока Тогда
					
					////////////////////////////
					// Определение режима записи
					ПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(ВыборкаДетальная.Проведен,ВыборкаДетальная.ПометкаУдаления
					,ТекСписаниеЗатрат.Проведен,ТекСписаниеЗатрат.ПометкаУдаления,СтруктураПараметров);
					ТекРежимЗаписи = ПараметрыЗаписи.РежимЗаписи;
					////////////////////////////
					
					// Если тек списание затрат не было найдено, то создаем новый объект.
					Если ТекСписаниеЗатрат.СписаниеЗатрат = Документы["СписаниеЗатратНаВыпуск"].ПустаяСсылка() Тогда
						ТекДокументОбъект = Документы["СписаниеЗатратНаВыпуск"].СоздатьДокумент();
					Иначе
						ТекДокументОбъект = ТекСписаниеЗатрат.СписаниеЗатрат.ПолучитьОбъект();
						
						// Если нужно установить пометку удаления, то перед синхронизацией сделаем это.
						Если ПараметрыЗаписи.НужнаУстановкаПометкиУдаления Тогда
							
							// Помечаем на удаление / снимаем пометку в док. "Списание затрат...".
							Попытка
								ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
								ТекДокументОбъект.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
							Исключение
								ТекстОшибки = ТекстОшибки + "
								|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
								| по документу Общепит """+ДокументРазделка+"""
								|по причине: <"+ОписаниеОшибки()+">";
								Возврат Ложь;
							КонецПопытки;
							
						КонецЕсли;
						
						// Очистка табличных частей для избежания дублирования информации.
						ТекДокументОбъект.ВыходныеИзделия.Очистить();
						ТекДокументОбъект.МатериалыИУслуги.Очистить();
						ТекДокументОбъект.ВозвратныеОтходы.Очистить();
						ТекДокументОбъект.Трудозатраты.Очистить();
						ТекДокументОбъект.Серии.Очистить();
						
					КонецЕсли;
					
					// Заполнение шапки.
					ТекДокументОбъект.Дата			= ВыборкаДетальная.Дата + ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0);
					ТекДокументОбъект.Организация	= ВыборкаДетальная.Организация;
					ТекДокументОбъект.Номенклатура	= ВыборкаДетальная.Номенклатура;
					ТекДокументОбъект.Ответственный	= ВыборкаДетальная.Ответственный;
					ТекДокументОбъект.Комментарий	= ВыборкаДетальная.Комментарий;
					ТекДокументОбъект.Количество	= ВыборкаДетальная.КоличествоНоменклатуры;
					ТекДокументОбъект.Подразделение	= ВыборкаДетальная.Подразделение;
					
					// Заполнение табличной части "Выходные изделия".
					НовСтрокаТЧ						= ТекДокументОбъект.ВыходныеИзделия.Добавить();
					НовСтрокаТЧ.Номенклатура		= ВыборкаДетальная.Номенклатура;
					НовСтрокаТЧ.КоличествоУпаковок	= ВыборкаДетальная.КоличествоУпаковокНоменклатуры;
					НовСтрокаТЧ.Количество			= ВыборкаДетальная.КоличествоНоменклатуры;
					НовСтрокаТЧ.Упаковка			= ВыборкаДетальная.УпаковкаНоменклатуры;
					НовСтрокаТЧ.Подразделение		= ВыборкаДетальная.Подразделение;
					НовСтрокаТЧ.Распоряжение		= ВыборкаДетальная.Распоряжение;
					НовСтрокаТЧ.КодСтроки			= ВыборкаДетальная.КодСтроки;
					
					ПерваяДетальнаяСтрока = Ложь;
				КонецЕсли;
				
				// Заполнение табличной части "Материалы и услуги".
				НовСтрокаТЧ							= ТекДокументОбъект.МатериалыИУслуги.Добавить();
				НовСтрокаТЧ.Номенклатура			= ВыборкаДетальная.Ингредиент;
				НовСтрокаТЧ.СтатьяКалькуляции		= ВыборкаДетальная.СтатьяКалькуляции;
				НовСтрокаТЧ.Количество				= Окр(ВыборкаДетальная.КоличествоИнгредиентаФакт * (ВыборкаДетальная.КоэффициентСписываемойНоменклатуры / ВыборкаДетальная.СуммарныйКоэффициент),3);
				НовСтрокаТЧ.Упаковка				= ВыборкаДетальная.УпаковкаИнгредиента;
				НовСтрокаТЧ.КоличествоУпаковок		= Окр(ВыборкаДетальная.КоличествоУпаковокИнгредиентаФакт * (ВыборкаДетальная.КоэффициентСписываемойНоменклатуры / ВыборкаДетальная.СуммарныйКоэффициент),3);
				НовСтрокаТЧ.Подразделение			= ВыборкаДетальная.Подразделение;
				
				//+Дораспределение
				// Если после долевого распределения осталось что-то нераспределенное, то допишем это в последнюю строку
				РаспределеноДолей = РаспределеноДолей + ВыборкаДетальная.КоэффициентСписываемойНоменклатуры;
				РаспределеноКоличество = РаспределеноКоличество + НовСтрокаТЧ.Количество;
				РаспределеноКоличествоУпаковок = РаспределеноКоличествоУпаковок + НовСтрокаТЧ.КоличествоУпаковок;
				Если РаспределеноДолей = ВыборкаДетальная.СуммарныйКоэффициент Тогда
					
					ДельтаКоличество = ВыборкаДетальная.КоличествоИнгредиентаФакт - РаспределеноКоличество;
					ДельтаКоличествоУпаковок = ВыборкаДетальная.КоличествоУпаковокИнгредиентаФакт - РаспределеноКоличествоУпаковок;
					
					Если ДельтаКоличество > 0 Тогда
						НовСтрокаТЧ.Количество = НовСтрокаТЧ.Количество + ДельтаКоличество;
					КонецЕсли;
					
					Если ДельтаКоличествоУпаковок > 0 Тогда
						НовСтрокаТЧ.КоличествоУпаковок = НовСтрокаТЧ.КоличествоУпаковок + ДельтаКоличествоУпаковок;
					КонецЕсли;
					
				КонецЕсли;
				//-Дораспределение
				
			КонецЦикла;
			
			Если НЕ ТекДокументОбъект = Неопределено Тогда
				
				// Запись заполненного документа "Списание затрат".
				Попытка
					ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
					ТекДокументОбъект.Записать(ТекРежимЗаписи);
				Исключение
					ТекстОшибки = ТекстОшибки + "
					|Ошибка записи документа """ + ТекДокументОбъект.Метаданные().Представление() + """
					| по документу Общепит """+ДокументРазделка+"""
					|по причине: <"+ОписаниеОшибки()+">";
					Возврат Ложь;
				КонецПопытки;
				
			КонецЕсли;
			
			// Добавление записи в результирующую таблицу в случае успешной записи документов.
			ДобавитьНовуюЗапись(ДокументРазделка, ТекДокументОбъект, тблСозданныеДокументы);
			
		КонецЦикла;
		
	КонецЦикла;
	
	// "Обнуление" переменной текущего объекта.
	ТекДокументОбъект = Неопределено;
	
	// Если остались лишние документы "Списания затрат", то нужно пометить их на удаление.
	Пока ВыборкаСуществующиеСписания.Следующий() Цикл
		
		ТекДокументОбъект = ВыборкаСуществующиеСписания.СписаниеЗатрат.ПолучитьОбъект();
		
		// Помечаем на удаление "Списание затрат...", если он еще не помечен.
		Если НЕ ВыборкаСуществующиеСписания.ПометкаУдаления Тогда
			Попытка
				ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
				ТекДокументОбъект.УстановитьПометкуУдаления(Истина);
			Исключение
				ТекстОшибки = ТекстОшибки + "
				|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
				| по документу Общепит """+ДокументРазделка+"""
				|по причине: <"+ОписаниеОшибки()+">";
				Возврат Ложь;
			КонецПопытки;
		КонецЕсли;
		
		// Добавление записи в результирующую таблицу.
		ДобавитьНовуюЗапись(ДокументРазделка, ТекДокументОбъект, тблСозданныеДокументы);
		
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции // СформироватьСписанияЗатратПоРазделке

#КонецОбласти

#Область ФормированиеТиповыхДокументовСборкаТоваровПоРазделке

// Процедура формирования типовых документов по переданному выпуску блюд.
//
// Параметры:
//  ДокРазделкапит		 - ДокументСсылка	 - Ссылка на документ "Разделка", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьТиповыеДокументыПоРазделкеСборкаРазборкаТоваров(ДокРазделкапит, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки = "")
	
	Перем ДокСборкаТоваров;
	ВсеОк = Истина;
	
	ПолучитьСборкуТоваровДляпитРазделки(ДокРазделкапит, ДокСборкаТоваров);
	Если ДокСборкаТоваров = Неопределено Тогда
		// Например исходный документ удален, а подкладных для удаления нет.
		Возврат Истина;
	КонецЕсли;
	 
	// Определение параметров записи.
	ПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокРазделкапит.Проведен,ДокРазделкапит.ПометкаУдаления,
		ДокСборкаТоваров.Проведен,ДокСборкаТоваров.ПометкаУдаления,СтруктураПараметров);
	
	// Определение режима записи
	ТекРежимЗаписи = ПараметрыЗаписи.РежимЗаписи;
	
	//!!!!!!!!
	// Если документы "Выпуск продукции" проведены, то будет происходить перепроведение или отмена проведения.
	// Для этого необходимо сначала отменить проведение списаний затарат в производство, т.к.
	// в них есть ссылки на строки ТЧ "Товары" типовых документов "Выпуск продукции".
	
	Если ПараметрыЗаписи.НужнаУстановкаПометкиУдаления Тогда
		
		Попытка
			ДокСборкаТоваров.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
			ДокСборкаТоваров.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
		Исключение
			ТекстОшибки = ТекстОшибки + "
			|Ошибка при установке пометки удаления """ + ДокСборкаТоваров.Метаданные().Представление() + """(в подр.)
			| по документу Общепит """+ДокРазделкапит+"""
			|по причине: <"+ОписаниеОшибки()+">";
			Возврат Ложь;
		КонецПопытки;
		
		
	КонецЕсли;
		
	/////////////////////////////////
	// ЗАПОЛНЕНИЕ ШАПКИ.
	
	МетаданныеСборкаТоваров = ДокСборкаТоваров.Метаданные();
	ДокСборкаТоваров.Дата	= ДокРазделкапит.Дата + ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0);
	
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("ТипОперации", МетаданныеСборкаТоваров) Тогда
		ДокСборкаТоваров.ТипОперации	= Перечисления.ТипыОперацийЗаказаНаСборку.РазборкаНаКомплектующие;
	КонецЕсли;
	
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("ХозяйственнаяОперация", МетаданныеСборкаТоваров) Тогда
		ДокСборкаТоваров.ХозяйственнаяОперация	= Перечисления.ХозяйственныеОперации.РазборкаТоваров;
	КонецЕсли;
	
	ДокСборкаТоваров.Количество         = ДокРазделкапит.Количество;
	ДокСборкаТоваров.КоличествоУпаковок = ДокРазделкапит.КоличествоУпаковок;
	ДокСборкаТоваров.Упаковка           = ДокРазделкапит.Упаковка;
	
	ДокСборкаТоваров.Комментарий = ДокРазделкапит.Комментарий;
	ДокСборкаТоваров.Номенклатура = ДокРазделкапит.Номенклатура;
	ДокСборкаТоваров.Организация = ДокРазделкапит.Организация;
	
	
	ДокСборкаТоваров.Склад = ДокРазделкапит.Склад;
	ДокСборкаТоваров.Подразделение = ДокРазделкапит.Подразделение;
	
	ДокСборкаТоваров.Статус = Перечисления.СтатусыСборокТоваров.СобраноРазобрано;
	
	
	
	ДокСборкаТоваров.СборкаПодДеятельность = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС; ///***--- НДС
	ДокСборкаТоваров.ВидыЗапасовУказаныВручную = Ложь;
	
	
	/// Сделка, ВариантКомплектации, СтатусУказанияСерий, ВидЗапасов,НомерГТД, Назначение, Ответственный
	// Серия - вроде обязательный
	//НоменклатураОсновногоКомпонента , 
	//АналитикаУчетаНоменклатуры АналитикаУчетаПартий
	//+25
	//ДокСборкаТоваров.ДатаРаспоряжения = ТекущаяДата();
	//-25
	
	// Очистка табличных частей, т.к. будет их перезаполнение.
	ДокСборкаТоваров.Товары.Очистить();
	Для Каждого Стр из ДокРазделкапит.Товары Цикл
		
		Если Стр.Номенклатура.питВидНоменклатуры = Перечисления.питВидыНоменклатуры.ТехнологическийИнгредиент Тогда
			Продолжить;
		КонецЕсли;
		
		НовСтр = ДокСборкаТоваров.товары.Добавить();
		НовСтр.Номенклатура = Стр.Номенклатура;
		
		НовСтр.Упаковка = Стр.Упаковка;
		НовСтр.КоличествоУпаковок = Стр.КоличествоУпаковок;
		НовСтр.Количество = Стр.Количество;
		
		НовСтр.ДоляСтоимости = Стр.ПроцентСебестоимости;
		
		//НовСтр. = Стр.;
		//НовСтр. = Стр.;
		//НовСтр. = Стр.;
		//НовСтр. = Стр.;
		//НовСтр. = Стр.;
		//НовСтр. = Стр.;
		//НовСтр. = Стр.;
		//НовСтр. = Стр.;
		//НовСтр. = Стр.;
		//НовСтр. = Стр.;

		
		//Обязательные
		//НовСтр.КодСтроки = Стр.;// Вроде обязательный, не понятно
		//НовСтр.Серия = 
		//
		//
		
		//Необязательн
		//НовСтр.СтатусУказанияСерий
		//НовСтр.ВидЗапасов
		//НовСтр.
		//НовСтр.Назначение 
		//       НомерГТД
		//   АналитикаУчетаПартий
		//   АналитикаУчетаНоменклатуры
		//
		

		
	КонецЦикла;
	
	
	Попытка
		ДокСборкаТоваров.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
		
		ДокСборкаТоваров.Записать(ТекРежимЗаписи);
	Исключение
		ТекстОшибки = ТекстОшибки + "
		|Ошибка записи документа """ + ДокСборкаТоваров.Метаданные().Представление() + """
		| по документу Общепит """+ДокРазделкапит+"""
		|по причине: <"+ОписаниеОшибки()+">";
		Возврат Ложь;
	КонецПопытки;
	
	// Добавление записи в результирующую таблицу в случае успешной записи документов.
	ДобавитьНовуюЗапись(ДокРазделкапит, ДокСборкаТоваров, тблСозданныеДокументы);
	
	Возврат ВсеОк;
	
КонецФункции

// Процедура по переданной ссылке на выпуск блюд ищет типовые документы "Выпуск продукции" с хоз. операцией
//  "В подразделение" или "На склад" возвращая ДокОбъект. Если не находит, то создает для них пустой объект.
//
// Параметры:
//  ДокументВыпускБлюд			 - ДокументСсылка	 - Ссылка на документ, для которого ищем "Выпуски продукции".
//  выхДокВыпускПродукцииНаСклад - ДокументОбъект	 - Документ "Выпуск продукции"(на склад).
//  выхДокВыпускПродукцииВПодр	 - ДокументОбъект	 - Документ "Выпуск продукции"(в подразделение).
//
Процедура ПолучитьСборкуТоваровДляпитРазделки(ДокументПланМеню, выхДокЗаказНаПередачуВПроизводство)
	
	Запрос = Новый Запрос;
	
	// Поиск всех выпусков продукции "В подразделение" или "На склад", 
	// связанных с текущим выпуском блюд.
	Запрос.Текст = 
	"ВЫБРАТЬ 
	|	питТиповыеДокументы.ТиповойДокумент
	|ПОМЕСТИТЬ втДокументыВыпускПродукции
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ 
	|	втДокументыВыпускПродукции.ТиповойДокумент КАК ДокументОбщепита
	|ИЗ
	|	втДокументыВыпускПродукции КАК втДокументыВыпускПродукции
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВыпускПродукции КАК ВыпускПродукции
	|		ПО (втДокументыВыпускПродукции.ТиповойДокумент = ВыпускПродукции.Ссылка)";
	
	Запрос.УстановитьПараметр("Документпит",				ДокументПланМеню);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	// Если документы найдены, то инициализируем соответствующие переменные.
	Пока Выборка.Следующий() Цикл
		
		Если ТипЗнч(Выборка.ДокументОбщепита) = Тип("ДокументСсылка.СборкаТоваров") Тогда
			выхДокЗаказНаПередачуВПроизводство = Выборка.ДокументОбщепита.ПолучитьОбъект();
		Иначе
			// возможно, производственные документы, игнорируем
		КонецЕсли;
		
	КонецЦикла;
	
	// Если переменные не инициализированны, значит документы не были найдены
	// и необходимо создать пустые документы-объекты, которые далее будут заполняться.
	Если (выхДокЗаказНаПередачуВПроизводство = Неопределено) И НЕ ДокументПланМеню.ПометкаУдаления Тогда
		выхДокЗаказНаПередачуВПроизводство = Документы.СборкаТоваров.СоздатьДокумент();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ФормированиеТиповыхДокументовПоРазделке22

// Процедура формирования типовых документов по переданному выпуску блюд.
//
// Параметры:
//  ДокРазделкапит		 - ДокументСсылка	 - Ссылка на документ "Разделка", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьТиповыеДокументыПоРазделкеПоДолямСебестоимости22(ДокРазделкапит, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки = "")
	
	Перем ДокПроизводствоБезЗаказа;
	ВсеОк = Истина;
	
	//+Получение данных разделки
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питРазделка.Ссылка КАК Ссылка,
	|	питРазделка.ПометкаУдаления КАК ПометкаУдаления,
	|	питРазделка.Номер КАК Номер,
	|	питРазделка.Дата КАК Дата,
	|	питРазделка.Проведен КАК Проведен,
	|	питРазделка.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
	|	питРазделка.Организация КАК Организация,
	|	питРазделка.Склад КАК Склад,
	|	питРазделка.Подразделение КАК Подразделение,
	|	питРазделка.ТипЦен КАК ТипЦен,
	|	питРазделка.СуммаДокумента КАК СуммаДокумента,
	|	питРазделка.ВалютаДокумента КАК ВалютаДокумента,
	|	питРазделка.Ответственный КАК Ответственный,
	|	питРазделка.Комментарий КАК Комментарий,
	|	питРазделка.Номенклатура КАК Номенклатура,
	|	питРазделка.Характеристика КАК Характеристика,
	|	ЕСТЬNULL(питРазделкаСерии.Серия, питРазделка.Серия) КАК Серия,
	|	питРазделка.Упаковка КАК Упаковка,
	|	ЕСТЬNULL(питРазделкаСерии.Количество, питРазделка.Количество) КАК Количество,
	|	питРазделка.Рецептура КАК Рецептура,
	|	питРазделка.СтатьяКалькуляции КАК СтатьяКалькуляции
	|ИЗ
	|	Документ.питРазделка КАК питРазделка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.питРазделка.Серии КАК питРазделкаСерии
	|		ПО (питРазделкаСерии.Ссылка = питРазделка.Ссылка)
	|			И (питРазделкаСерии.Номенклатура = питРазделка.Номенклатура)
	|			И (питРазделкаСерии.Характеристика = питРазделка.Характеристика)
	|			И (питРазделкаСерии.Назначение = питРазделка.Назначение)
	|ГДЕ
	|	питРазделка.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	питРазделкаТовары.Номенклатура КАК Номенклатура,
	|	питРазделкаТовары.Характеристика КАК Характеристика,
	|	питРазделкаТовары.Серия КАК Серия,
	|	питРазделкаТовары.СтатусУказанияСерий КАК СтатусУказанияСерий,
	|	питРазделкаТовары.Упаковка КАК Упаковка,
	|	питРазделкаТовары.КоличествоУпаковокНорма КАК КоличествоУпаковокНорма,
	|	питРазделкаТовары.КоличествоУпаковок КАК КоличествоУпаковок,
	|	питРазделкаТовары.КоличествоНорма КАК КоличествоНорма,
	|	питРазделкаТовары.Количество КАК Количество,
	|	питРазделкаТовары.СчетУчета КАК СчетУчета,
	|	питРазделкаТовары.ПроцентВыхода КАК ПроцентВыхода,
	|	питРазделкаТовары.ПроцентСебестоимости КАК ПроцентСебестоимости,
	|	питРазделкаТовары.СпособУчетаНДС КАК СпособУчетаНДС,
	|	питРазделкаТовары.СтатьяКалькуляции КАК СтатьяКалькуляции,
	|	питРазделкаТовары.НомерСтроки КАК НомерСтроки
	|ИЗ
	|	Документ.питРазделка.Товары КАК питРазделкаТовары
	|ГДЕ
	|	питРазделкаТовары.Ссылка = &Ссылка
	|	И НЕ питРазделкаТовары.Номенклатура.питВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.питВидыНоменклатуры.ТехнологическийИнгредиент)
	|ИТОГИ
	|	СУММА(ПроцентСебестоимости)
	|ПО
	|	ОБЩИЕ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	питРазделкаТоварыСерии.Серия КАК Серия,
	|	питРазделкаТоварыСерии.Номенклатура КАК Номенклатура,
	|	питРазделкаТоварыСерии.Характеристика КАК Характеристика,
	|	питРазделкаТоварыСерии.Назначение КАК Назначение,
	|	питРазделкаТоварыСерии.Количество КАК Количество,
	|	питРазделкаТоварыСерии.Ссылка.Склад КАК Получатель
	|ИЗ
	|	Документ.питРазделка.ТоварыСерии КАК питРазделкаТоварыСерии
	|ГДЕ
	|	питРазделкаТоварыСерии.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	питРазделкаПобочныеИзделия.Ссылка КАК Ссылка,
	|	питРазделкаПобочныеИзделия.НомерСтроки КАК НомерСтроки,
	|	питРазделкаПобочныеИзделия.Подразделение КАК Подразделение,
	|	питРазделкаПобочныеИзделия.Получатель КАК Получатель,
	|	питРазделкаПобочныеИзделия.Номенклатура КАК Номенклатура,
	|	питРазделкаПобочныеИзделия.Характеристика КАК Характеристика,
	|	питРазделкаПобочныеИзделия.Серия КАК Серия,
	|	питРазделкаПобочныеИзделия.СтатусУказанияСерий КАК СтатусУказанияСерий,
	|	питРазделкаПобочныеИзделия.КоличествоУпаковок КАК КоличествоУпаковок,
	|	питРазделкаПобочныеИзделия.Количество КАК Количество,
	|	питРазделкаПобочныеИзделия.Упаковка КАК Упаковка,
	|	питРазделкаПобочныеИзделия.Цена КАК Цена,
	|	питРазделкаПобочныеИзделия.Сумма КАК Сумма,
	|	питРазделкаПобочныеИзделия.СтатьяКалькуляции КАК СтатьяКалькуляции,
	|	питРазделкаПобочныеИзделия.Назначение КАК Назначение,
	|	питРазделкаПобочныеИзделия.КоличествоУпаковок КАК ОсталосьКоличестваУпаковок,
	|	питРазделкаПобочныеИзделия.Количество КАК ОсталосьКоличества
	|ИЗ
	|	Документ.питРазделка.ПобочныеИзделия КАК питРазделкаПобочныеИзделия
	|ГДЕ
	|	питРазделкаПобочныеИзделия.Ссылка = &Ссылка
	|";
	
	Запрос.УстановитьПараметр("Ссылка", ДокРазделкапит);
	
	РезультатЗапросаПакет = Запрос.ВыполнитьПакет();
	
	РезультатЗапроса = РезультатЗапросаПакет[0];
	
	ШапкаРазделки = РезультатЗапроса.Выбрать();
	ШапкаРазделки.Следующий();
	
	РезультатЗапроса = РезультатЗапросаПакет[1];
	ВыборкаДоляСС = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	СуммарнаяДоляСС = 1;
	Если ВыборкаДоляСС.Следующий() Тогда
		СуммарнаяДоляСС = ?(ВыборкаДоляСС.ПроцентСебестоимости = 0, 1, ВыборкаДоляСС.ПроцентСебестоимости);
	Иначе
		Возврат Истина;
	КонецЕсли;
	ВыборкаБлюда = ВыборкаДоляСС.Выбрать();
	
	РезультатЗапроса = РезультатЗапросаПакет[2];
	ТаблицаСерииТовары = РезультатЗапроса.Выгрузить();
	//-Получение данных разделки
	
	ПолучитьПроизводствоБезЗаказаДляпитРазделки(ДокРазделкапит, ДокПроизводствоБезЗаказа);
	Если ДокПроизводствоБезЗаказа = Неопределено Тогда
		// Например исходный документ удален, а подкладных для удаления нет.
		Возврат Истина;
	КонецЕсли;
	 
	// Определение параметров записи.
	ПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокРазделкапит.Проведен,ДокРазделкапит.ПометкаУдаления,
		ДокПроизводствоБезЗаказа.Проведен,ДокПроизводствоБезЗаказа.ПометкаУдаления,СтруктураПараметров);
	
	// Определение режима записи
	ТекРежимЗаписи = ПараметрыЗаписи.РежимЗаписи;
	
	//!!!!!!!!
	// Если документы "Выпуск продукции" проведены, то будет происходить перепроведение или отмена проведения.
	// Для этого необходимо сначала отменить проведение списаний затарат в производство, т.к.
	// в них есть ссылки на строки ТЧ "Товары" типовых документов "Выпуск продукции".
	
	Если ПараметрыЗаписи.НужнаУстановкаПометкиУдаления Тогда
		
		Попытка
			ДокПроизводствоБезЗаказа.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
			ДокПроизводствоБезЗаказа.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
		Исключение
			ТекстОшибки = ТекстОшибки + "
			|Ошибка при установке пометки удаления """ + ДокПроизводствоБезЗаказа.Метаданные().Представление() + """
			| по документу Общепит """+ДокРазделкапит+"""
			|по причине: <"+ОписаниеОшибки()+">";
			Возврат Ложь;
		КонецПопытки;
		
	КонецЕсли;
	
	/////////////////////////////////
	// ЗАПОЛНЕНИЕ ШАПКИ.
	
	МетаданныеСборкаТоваров = ДокПроизводствоБезЗаказа.Метаданные();
	
	///////////
	
	// Заполнение шапки.
	ДокПроизводствоБезЗаказа.Дата					= ШапкаРазделки.Дата + ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0);
	ДокПроизводствоБезЗаказа.Организация			= ШапкаРазделки.Организация;
	ДокПроизводствоБезЗаказа.Подразделение			= ШапкаРазделки.Подразделение;
	ДокПроизводствоБезЗаказа.ГруппировкаЗатрат		= Перечисления.ГруппировкиЗатратВПроизводствеБезЗаказа.ПоПродукции;
	ДокПроизводствоБезЗаказа.Ответственный			= ШапкаРазделки.Ответственный;
	ДокПроизводствоБезЗаказа.Валюта					= Константы.ВалютаРегламентированногоУчета.Получить();
	
	// Автоопределение значения налогообложения НДС.
	ДокПроизводствоБезЗаказа.ВыпускПодДеятельность	= Неопределено;
	ПараметрыЗаполнения = Документы.ПроизводствоБезЗаказа.ПараметрыЗаполненияВидаДеятельностиНДС(ДокПроизводствоБезЗаказа);
	УчетНДСУП.ЗаполнитьВидДеятельностиНДС(ДокПроизводствоБезЗаказа.ВыпускПодДеятельность, ПараметрыЗаполнения);
	
	// Очистка табличных частей для избежания дублирования информации.
	ДокПроизводствоБезЗаказа.ВыходныеИзделия.Очистить();
	ДокПроизводствоБезЗаказа.ВыходныеИзделияСерии.Очистить();
	ДокПроизводствоБезЗаказа.МатериалыИРаботы.Очистить();
	ДокПроизводствоБезЗаказа.Трудозатраты.Очистить();
	ДокПроизводствоБезЗаказа.ПобочныеИзделия.Очистить();
	ДокПроизводствоБезЗаказа.ПобочныеИзделияСерии.Очистить();
	
	ТекНомерГруппыЗатрат = 1; // номер, по которому сопоставляются ТЧ "ВыходныеИзделия" и ТЧ "МатериалыИРаботы".
	
	Коэф = питОбщегоНазначения.ПолучитьКоэффициентУпаковки(ШапкаРазделки.Номенклатура,ШапкаРазделки.Упаковка);
	Коэф = ?(Коэф = 0, 1, Коэф);
	ПараметрыУказанияСерий = Новый ФиксированнаяСтруктура(НоменклатураСервер.ПараметрыУказанияСерий(ДокПроизводствоБезЗаказа, Документы.ПроизводствоБезЗаказа));
	
	ТаблицаПобочныеИзделия = РезультатЗапросаПакет[3].Выгрузить();
	
	ШапкаРазделки.Сбросить();
	Пока ШапкаРазделки.Следующий() Цикл
		
		ОсталосьСписатьДоли = СуммарнаяДоляСС;
		ОсталосьКоличества = ШапкаРазделки.Количество;
		ШапкаКоличествоУпаковок = ШапкаРазделки.Количество / Коэф;
		ОсталосьКоличестваУпаковок = ШапкаКоличествоУпаковок;
		
		Пока ВыборкаБлюда.Следующий() И ОсталосьСписатьДоли > 0 Цикл
			
			КСписаниюДоли = Мин(ВыборкаБлюда.ПроцентСебестоимости, ОсталосьСписатьДоли);
			
			Если НЕ КСписаниюДоли = 0 Тогда
				
				НовСтрокаТЧ						= ДокПроизводствоБезЗаказа.МатериалыИРаботы.Добавить();
				НовСтрокаТЧ.Склад				= ШапкаРазделки.Склад;			// Отправитель всегда склад из шапки выпуска, потому что мы именно его обеспечиваем.
				НовСтрокаТЧ.Подразделение		= ШапкаРазделки.Подразделение;	// Отправитель всегда подразделение из шапки выпуска, потому что мы именно его обеспечиваем.
				НовСтрокаТЧ.Номенклатура		= ШапкаРазделки.Номенклатура;
				НовСтрокаТЧ.Характеристика		= ШапкаРазделки.Характеристика;
				НовСтрокаТЧ.Серия				= ШапкаРазделки.Серия;
				НовСтрокаТЧ.КоличествоУпаковок	= ?(ОсталосьСписатьДоли = КСписаниюДоли, ОсталосьКоличестваУпаковок, КСписаниюДоли/СуммарнаяДоляСС*ШапкаКоличествоУпаковок);
				НовСтрокаТЧ.Количество			= ?(ОсталосьСписатьДоли = КСписаниюДоли, ОсталосьКоличества, КСписаниюДоли/СуммарнаяДоляСС*ШапкаРазделки.Количество);
				НовСтрокаТЧ.Упаковка			= ШапкаРазделки.Упаковка;
				НовСтрокаТЧ.СтатьяКалькуляции	= ШапкаРазделки.СтатьяКалькуляции;
				//+25
				НовСтрокаТЧ.ИдентификаторСтроки	= Новый УникальныйИдентификатор;
				//-25
				
				// Побочные изделия.
				Для каждого ВыборкаПобочныеИзделия Из ТаблицаПобочныеИзделия Цикл
					НовСтрокаТЧПобочныеИзделия						= ДокПроизводствоБезЗаказа.ПобочныеИзделия.Добавить();
					ЗаполнитьЗначенияСвойств(НовСтрокаТЧПобочныеИзделия, ВыборкаПобочныеИзделия);
					НовСтрокаТЧПобочныеИзделия.НомерГруппыЗатрат	= ТекНомерГруппыЗатрат;
					НовСтрокаТЧПобочныеИзделия.НаправлениеВыпуска = Перечисления.ХозяйственныеОперации.ВыпускПродукцииНаСклад;
					НовСтрокаТЧПобочныеИзделия.ПодразделениеПолучатель = ВыборкаПобочныеИзделия.Подразделение;
					НовСтрокаТЧПобочныеИзделия.КоличествоУпаковок	= ?(ОсталосьСписатьДоли = КСписаниюДоли, ВыборкаПобочныеИзделия.ОсталосьКоличестваУпаковок, КСписаниюДоли/СуммарнаяДоляСС*ВыборкаПобочныеИзделия.КоличествоУпаковок);
					НовСтрокаТЧПобочныеИзделия.Количество			= ?(ОсталосьСписатьДоли = КСписаниюДоли, ВыборкаПобочныеИзделия.ОсталосьКоличества, КСписаниюДоли/СуммарнаяДоляСС*ВыборкаПобочныеИзделия.Количество);
					НовСтрокаТЧПобочныеИзделия.Сумма			= ?(ОсталосьСписатьДоли = КСписаниюДоли, ВыборкаПобочныеИзделия.Сумма, НовСтрокаТЧПобочныеИзделия.КоличествоУпаковок * НовСтрокаТЧПобочныеИзделия.Цена);
					//+25
					НовСтрокаТЧПобочныеИзделия.ИдентификаторСтроки	= Новый УникальныйИдентификатор;
					//-25
					ВыборкаПобочныеИзделия.Сумма = ВыборкаПобочныеИзделия.Сумма - НовСтрокаТЧПобочныеИзделия.Сумма;
					ВыборкаПобочныеИзделия.ОсталосьКоличества = ВыборкаПобочныеИзделия.ОсталосьКоличества - НовСтрокаТЧПобочныеИзделия.Количество;
					ВыборкаПобочныеИзделия.ОсталосьКоличестваУпаковок = ВыборкаПобочныеИзделия.ОсталосьКоличестваУпаковок - НовСтрокаТЧПобочныеИзделия.КоличествоУпаковок;
				КонецЦикла;
				
				ОсталосьСписатьДоли = ОсталосьСписатьДоли - КСписаниюДоли;
				ОсталосьКоличества = ОсталосьКоличества - НовСтрокаТЧ.Количество;
				ОсталосьКоличестваУпаковок = ОсталосьКоличестваУпаковок - НовСтрокаТЧ.КоличествоУпаковок;
				
			КонецЕсли;
			
			СПВыходныеИзделия = Новый Структура("Номенклатура, Характеристика, Серия");
			ЗаполнитьЗначенияСвойств(СПВыходныеИзделия, ВыборкаБлюда);
			НайденныеСтрокиВыхИзделия = ДокПроизводствоБезЗаказа.ВыходныеИзделия.НайтиСтроки(СПВыходныеИзделия);
			Если НайденныеСтрокиВыхИзделия.Количество() Тогда
				НовСтрокаТЧВыхИзделия = НайденныеСтрокиВыхИзделия[0];
			Иначе
				// Заполнение табличной части "Выходные изделия".
				НовСтрокаТЧВыхИзделия							= ДокПроизводствоБезЗаказа.ВыходныеИзделия.Добавить();
				НовСтрокаТЧВыхИзделия.НаправлениеВыпуска		= Перечисления.ХозяйственныеОперации.ВыпускПродукцииНаСклад;
				НовСтрокаТЧВыхИзделия.Получатель				= ШапкаРазделки.Склад;
				НовСтрокаТЧВыхИзделия.Номенклатура				= ВыборкаБлюда.Номенклатура;
				НовСтрокаТЧВыхИзделия.Характеристика			= ВыборкаБлюда.Характеристика;
				НовСтрокаТЧВыхИзделия.Серия						= ВыборкаБлюда.Серия;
				НовСтрокаТЧВыхИзделия.СтатусУказанияСерий		= ВыборкаБлюда.СтатусУказанияСерий;
				НовСтрокаТЧВыхИзделия.КоличествоУпаковок		= ВыборкаБлюда.КоличествоУпаковок;
				НовСтрокаТЧВыхИзделия.Количество				= ВыборкаБлюда.Количество;
				НовСтрокаТЧВыхИзделия.Упаковка					= ВыборкаБлюда.Упаковка;
				НовСтрокаТЧВыхИзделия.ИдентификаторСтроки		= Новый УникальныйИдентификатор;
				НовСтрокаТЧВыхИзделия.НомерГруппыЗатрат			= ТекНомерГруппыЗатрат;
				НовСтрокаТЧВыхИзделия.Подразделение				= ШапкаРазделки.Подразделение;
				//ВидЗапасов
				ТекНомерГруппыЗатрат = ТекНомерГруппыЗатрат + 1;
			КонецЕсли;
			
			Если НЕ КСписаниюДоли = 0 Тогда
				НовСтрокаТЧ.НомерГруппыЗатрат	= НовСтрокаТЧВыхИзделия.НомерГруппыЗатрат;
			КонецЕсли;
			
		КонецЦикла;
		ВыборкаБлюда.Сбросить();
		
	КонецЦикла;
	
	//+Серии
	ДокПроизводствоБезЗаказа.ВыходныеИзделияСерии.Загрузить(ТаблицаСерииТовары);
	
	// Пересчет статусов, которые могли поменяться.
	НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(ДокПроизводствоБезЗаказа, ПараметрыУказанияСерий["ВыходныеИзделия"]);
	НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(ДокПроизводствоБезЗаказа, ПараметрыУказанияСерий["МатериалыИРаботы"]);
	НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(ДокПроизводствоБезЗаказа, ПараметрыУказанияСерий["ПобочныеИзделия"]);
	//-Серии
	
	/////////////
	
	Попытка
		ДокПроизводствоБезЗаказа.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
		ДокПроизводствоБезЗаказа.Записать(ТекРежимЗаписи);
	Исключение
		ТекстОшибки = ТекстОшибки + "
		|Ошибка записи документа """ + ДокПроизводствоБезЗаказа.Метаданные().Представление() + """
		| по документу Общепит """+ДокРазделкапит+"""
		|по причине: <"+ОписаниеОшибки()+">";
		Возврат Ложь;
	КонецПопытки;
	
	// Добавление записи в результирующую таблицу в случае успешной записи документов.
	ДобавитьНовуюЗапись(ДокРазделкапит, ДокПроизводствоБезЗаказа, тблСозданныеДокументы);
	
	Возврат ВсеОк;
	
КонецФункции

// Процедура по переданной ссылке на разделку ищет типовые документы "Производство без заказа"
//  Если не находит, то создает для них пустой объект.
//
// Параметры:
//  ДокументРазделка			 - ДокументСсылка	 - Ссылка на документ, для которого ищем "Разделка".
//  выхДокПроизводствоБезЗаказа	 - ДокументОбъект	 - Документ "Производство без заказа"(в подразделение).
//
Процедура ПолучитьПроизводствоБезЗаказаДляпитРазделки(ДокументРазделка, выхДокПроизводствоБезЗаказа)
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = 
	"ВЫБРАТЬ 
	|	питТиповыеДокументы.ТиповойДокумент
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|";
	
	Запрос.УстановитьПараметр("Документпит",				ДокументРазделка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	// Если документы найдены, то инициализируем соответствующие переменные.
	Пока Выборка.Следующий() Цикл
		
		Если ТипЗнч(Выборка.ТиповойДокумент) = Тип("ДокументСсылка.ПроизводствоБезЗаказа") Тогда
			выхДокПроизводствоБезЗаказа = Выборка.ТиповойДокумент.ПолучитьОбъект();
		Иначе
			// возможно, производственные документы, игнорируем
		КонецЕсли;
		
	КонецЦикла;
	
	// Если переменные не инициализированны, значит документы не были найдены
	// и необходимо создать пустые документы-объекты, которые далее будут заполняться.
	Если (выхДокПроизводствоБезЗаказа = Неопределено) И НЕ ДокументРазделка.ПометкаУдаления Тогда
		выхДокПроизводствоБезЗаказа = Документы.ПроизводствоБезЗаказа.СоздатьДокумент();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

// Функция помечает на удаление неиспользуемые типовые документы разделки в зависимости от текущего режима
//
// Параметры:
//  ДокРазделкапит		 - ДокументСсылка	 - Ссылка на документ "Разделка", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция ПометитьНаУдалениеНеиспользуемыеТиповыеДокументыРазделки(ДокРазделкапит, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки = "")
	
	ВсеОк = Истина;
	
	ПроизводственныйПуть = Истина;
	Если СтруктураПараметров.Свойство("ПроизводственныйПуть") Тогда
		ПроизводственныйПуть = СтруктураПараметров.ПроизводственныйПуть;
	Иначе
		ПроизводственныйПуть = ФормироватьДокументыПоРазделкеПоФиксированнойСтоимости(ДокРазделкапит);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	
	// Поиск связанных с данной разделкой типовых документов.
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питТиповыеДокументы.ТиповойДокумент
	|ПОМЕСТИТЬ втДокументыСписание
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|	И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.СписаниеЗатратНаВыпуск
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	питТиповыеДокументы.ТиповойДокумент
	|ПОМЕСТИТЬ втДокументыВыпускПродукции
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|	И НЕ питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.СписаниеЗатратНаВыпуск
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втДокументыВыпускПродукции.ТиповойДокумент КАК ТиповойДокумент
	|ИЗ
	|	втДокументыВыпускПродукции КАК втДокументыВыпускПродукции
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВыпускПродукции КАК ВыпускПродукции
	|		ПО втДокументыВыпускПродукции.ТиповойДокумент = ВыпускПродукции.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втДокументыСписание.ТиповойДокумент КАК ТиповойДокумент
	|ИЗ
	|	втДокументыСписание КАК втДокументыСписание";
	
	Запрос.УстановитьПараметр("Документпит",				ДокРазделкапит);
	Результат =  Запрос.ВыполнитьПакет();
	
	Если НЕ ПроизводственныйПуть Тогда
		// Сначала помечаем списания.
		ВыбораСписанияЗатрат = Результат[3].Выбрать();
		Пока ВыбораСписанияЗатрат.Следующий() Цикл
			
			
			// Неактуальные для данного типа разделки доки, помечаем на удаление.
			Попытка
				ДокОбъект = ВыбораСписанияЗатрат.ТиповойДокумент.ПолучитьОбъект();
				ДокОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
				ДокОбъект.УстановитьПометкуУдаления(Истина);
			Исключение
				ТекстОшибки = ТекстОшибки + "
				|Ошибка при установке пометки удаления """ + ДокОбъект.Метаданные().Представление() + """
				| по документу Общепит """+ДокРазделкапит+"""
				|по причине: <"+ОписаниеОшибки()+">";
				Возврат Ложь;
			КонецПопытки;
			
			
			// Добавление записи в результирующую таблицу в случае успешной записи документов.
			ДобавитьНовуюЗапись(ДокРазделкапит, ДокОбъект, тблСозданныеДокументы);
			
		КонецЦикла;
	КонецЕсли;
	
	Выборка = Результат[2].Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Если (ТипЗнч(Выборка.ТиповойДокумент) = Тип("ДокументСсылка.СборкаТоваров") И ПроизводственныйПуть) 
			ИЛИ (НЕ ТипЗнч(Выборка.ТиповойДокумент) = Тип("ДокументСсылка.СборкаТоваров") И НЕ ПроизводственныйПуть) Тогда
			
			// Неактуальные для данного типа разделки доки, помечаем на удаление.
			Попытка
				ДокОбъект = Выборка.ТиповойДокумент.ПолучитьОбъект();
				ДокОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
				ДокОбъект.УстановитьПометкуУдаления(Истина);
			Исключение
				ТекстОшибки = ТекстОшибки + "
				|Ошибка при установке пометки удаления """ + ДокОбъект.Метаданные().Представление() + """
				| по документу Общепит """+ДокРазделкапит+"""
				|по причине: <"+ОписаниеОшибки()+">";
				Возврат Ложь;
			КонецПопытки;
			
			// Добавление записи в результирующую таблицу в случае успешной записи документов.
			ДобавитьНовуюЗапись(ДокРазделкапит, ДокОбъект, тблСозданныеДокументы);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ВсеОк;
	
КонецФункции

#КонецОбласти

#Область ФормированиеТиповыхДокументовПоПлануМеню

// Процедура формирования типовых документов по переданному выпуску блюд.
//
// Параметры:
//  ДокументВыпускБлюд		 - ДокументСсылка	 - Ссылка на документ "Выпуск блюд", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьТиповыеДокументыПоПлануМеню(ДокПланМеню, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки = "")
	Перем ВсеОк;
	ВсеОк = Истина;
	
	Если СтруктураПараметров.Свойство("ФормироватьДокументыПроизводства22") Тогда
		ФормироватьДокументыПроизводства22 = СтруктураПараметров.ФормироватьДокументыПроизводства22;
	Иначе
		ФормироватьДокументыПроизводства22 = Константы.питФормироватьДокументыПроизводства22.Получить();
		СтруктураПараметров.Вставить("ФормироватьДокументыПроизводства22", ФормироватьДокументыПроизводства22);
	КонецЕсли;
	
	ТиповыеДокументы = ПолучитьТиповыеДокументыДляДокументаПитПоРежимуПроизводства(ДокПланМеню, ?(ФормироватьДокументыПроизводства22,"2.1","2.2"));
	Если ТиповыеДокументы.Количество() Тогда
		
		УдалятьДокументыСтаройСхемыПроведения = Истина;
		Если СтруктураПараметров.Свойство("УдалятьДокументыСтаройСхемыПроведения") Тогда
			УдалятьДокументыСтаройСхемыПроведения = СтруктураПараметров.УдалятьДокументыСтаройСхемыПроведения;
		КонецЕсли;
		
		Если УдалятьДокументыСтаройСхемыПроведения Тогда
			
			Если СтруктураПараметров.Свойство("РежимЗаписи") И СтруктураПараметров.РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
				// Для документов общепит при перепроведении выполняется сначала отмена проведения явным образом, 
				// чтобы отменить проведение всех типовых документов.
				// В этот момент, мы отменим проведение документов старой схемы.
				ФормироватьДокументыПроизводства22 = НЕ ФормироватьДокументыПроизводства22;
			Иначе
				
				// "Обрываем" связь документов старой схемы производства!
				ВсеОк = ПометитьНаУдалениеИОтвязатьТиповыеДокументы(ДокПланМеню, ТиповыеДокументы, СтруктураПараметров, ТекстОшибки);
				
			КонецЕсли;
			
		Иначе
			
			ТекстОшибки = ТекстОшибки + "
			| Не выполнено формирование типовых документов производства "+?(ФормироватьДокументыПроизводства22,"2.2","2.1")+" по документу общепит <"+ДокПланМеню+"> !!
			| По данному документу уже созданы документы производства "+?(ФормироватьДокументыПроизводства22,"2.1","2.2")+"!";
			Возврат Ложь;
			
		КонецЕсли;
	КонецЕсли;
	
	Если ФормироватьДокументыПроизводства22 Тогда
		
		// ДОКУМЕНТЫ 2.2
		
	Иначе // Документы 2.1
		
	КонецЕсли;
	
	ЕстьИнгредиентыБезСхемыОбеспечения = Истина;
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЕСТЬNULL(питПланМенюИнгредиенты.ЕстьСхемаОбеспечения, ЛОЖЬ) КАК ЕстьСхемаОбеспечения
	|ПОМЕСТИТЬ втЕстьСхема
	|ИЗ
	|	Документ.питПланМеню.Ингредиенты КАК питПланМенюИнгредиенты
	|ГДЕ
	|	питПланМенюИнгредиенты.Ссылка = &Ссылка
	|	И НЕ питПланМенюИнгредиенты.Ингредиент.питВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.питВидыНоменклатуры.ТехнологическийИнгредиент)
	|	И питПланМенюИнгредиенты.ИзАвтопеределов = ЛОЖЬ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЕСТЬNULL(питПланМенюИнгредиенты.ЕстьСхемаОбеспечения, ЛОЖЬ)
	|ИЗ
	|	Документ.питПланМеню.Замены КАК питПланМенюИнгредиенты
	|ГДЕ
	|	питПланМенюИнгредиенты.Ссылка = &Ссылка
	|	И НЕ питПланМенюИнгредиенты.ИнгредиентЗамена.питВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.питВидыНоменклатуры.ТехнологическийИнгредиент)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(МИНИМУМ(втЕстьСхема.ЕстьСхемаОбеспечения), ЛОЖЬ) КАК ЕстьСхемаОбеспечения
	|ИЗ
	|	втЕстьСхема КАК втЕстьСхема";
	Запрос.УстановитьПараметр("Ссылка", ДокПланМеню);
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ЕстьИнгредиентыБезСхемыОбеспечения = ТипЗнч(ВыборкаДетальныеЗаписи.ЕстьСхемаОбеспечения) = Тип("Булево") И НЕ ВыборкаДетальныеЗаписи.ЕстьСхемаОбеспечения;
	КонецЦикла;
	
	СтруктураСкладовКладовая = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокПланМеню, "Склад, Склад.ЦеховаяКладовая, ЦеховаяКладовая, ЦеховаяКладовая.ЦеховаяКладовая");
	Если СтруктураСкладовКладовая.СкладЦеховаяКладовая = NULL Тогда
		СтруктураСкладовКладовая.СкладЦеховаяКладовая = Ложь;
	КонецЕсли;
	Если СтруктураСкладовКладовая.ЦеховаяКладоваяЦеховаяКладовая = NULL Тогда
		СтруктураСкладовКладовая.ЦеховаяКладоваяЦеховаяКладовая = Ложь;
	КонецЕсли;
	
	Если НЕ ЕстьИнгредиентыБезСхемыОбеспечения 
		ИЛИ СтруктураСкладовКладовая.Склад = СтруктураСкладовКладовая.ЦеховаяКладовая Тогда
		
		Если НЕ ОтменитьПроведениеТиповогоДокументаПоДокументупит(ДокПланМеню, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки, "ЗаказНаПеремещение",,Истина) Тогда
			Возврат Ложь;
		КонецЕсли;
		
		Если НЕ ОтменитьПроведениеТиповогоДокументаПоДокументупит(ДокПланМеню, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки, "ЗаказМатериаловВПроизводство",,Истина) Тогда
			Возврат Ложь;
		КонецЕсли;
		
	ИначеЕсли СтруктураСкладовКладовая.ЦеховаяКладоваяЦеховаяКладовая Тогда
		
		Если НЕ ОтменитьПроведениеТиповогоДокументаПоДокументупит(ДокПланМеню, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки, "ЗаказНаПеремещение",,Истина) Тогда
			Возврат Ложь;
		КонецЕсли;
		
		///////////////////////////////////////////////////
		// ЗАКАЗ МАТЕРИАЛОВ В ПРОИЗВОДСТВО
		ВсеОк = СформироватьЗаказМатериаловВПроизводствоПоПлануМеню(ДокПланМеню, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
		
	Иначе
		
		Если НЕ ОтменитьПроведениеТиповогоДокументаПоДокументупит(ДокПланМеню, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки, "ЗаказМатериаловВПроизводство",,Истина) Тогда
			Возврат Ложь;
		КонецЕсли;
		
		///////////////////////////////////////////////////
		// ЗАКАЗ НА ПЕРЕМЕЩЕНИЕ
		ВсеОк = СформироватьЗаказНаПеремещениеПоПлануМеню(ДокПланМеню, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ВсеОк;
	
КонецФункции

// Функция формирует документы "Заказ материалов в производство".
//
// Параметры:
//  ДокПланМеню		 - ДокументСсылка	 - Ссылка на документ "План-меню", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьЗаказМатериаловВПроизводствоПоПлануМеню(ДокПланМеню, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки)
	
	Перем ДатаФормированияПотребности, мМетаданныеТиповогоОбъекта, мМетаданныеТЧ, НовСтр, ПараметрыЗаписи, Стр, ТекРежимЗаписи;
	
	Если СтруктураПараметров.Свойство("ФормироватьДокументыПроизводства22") Тогда
		ФормироватьДокументыПроизводства22 = СтруктураПараметров.ФормироватьДокументыПроизводства22;
	Иначе
		ФормироватьДокументыПроизводства22 = Константы.питФормироватьДокументыПроизводства22.Получить();
		СтруктураПараметров.Вставить("ФормироватьДокументыПроизводства22", ФормироватьДокументыПроизводства22);
	КонецЕсли;
	
	ДокЗаказНаПередачуВПроизводство = Неопределено;
	ВсеОк = Истина;
	
	ПолучитьТиповойДокументДляПланаМеню(ДокПланМеню, ДокЗаказНаПередачуВПроизводство, "ЗаказМатериаловВПроизводство");
	Если ДокЗаказНаПередачуВПроизводство = Неопределено Тогда
		// Например изходный документ удален, а подкладных для удаления нет.
		Возврат Истина;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДокЗаказНаПередачуВПроизводство.ВерсияДанных) 
		И ДокЗаказНаПередачуВПроизводство.Статус <> Перечисления.СтатусыЗаказовМатериаловВПроизводство.КВыполнению Тогда
		// Статус был изменен пользователем, синхронизацию данных не проводим
		
		// Добавление записи в результирующую таблицу в случае успешной записи документов.
		ДобавитьНовуюЗапись(ДокПланМеню, ДокЗаказНаПередачуВПроизводство, тблСозданныеДокументы);
		
		Возврат Истина;
		
	КонецЕсли;
	
	// Запрос данных.
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питПланМеню.Дата КАК Дата,
	|	питПланМеню.Автор КАК Автор,
	|	питПланМеню.Организация КАК Организация,
	|	питПланМеню.Подразделение КАК Подразделение,
	|	питПланМеню.ЦеховаяКладовая КАК ЦеховаяКладовая,
	|	питПланМеню.Комментарий КАК Комментарий,
	|	питПланМеню.Склад КАК Склад,
	|	питПланМеню.ДатаПлан КАК ДатаПлан,
	|	питПланМеню.Ответственный КАК Ответственный,
	|	питПланМеню.Проведен КАК Проведен,
	|	питПланМеню.ПометкаУдаления КАК ПометкаУдаления
	|ИЗ
	|	Документ.питПланМеню КАК питПланМеню
	|ГДЕ
	|	питПланМеню.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	питПланМенюИнгредиенты.Ингредиент КАК Ингредиент,
	|	питПланМенюИнгредиенты.Характеристика КАК Характеристика,
	|	питПланМенюИнгредиенты.Назначение КАК Назначение,
	|	питПланМенюИнгредиенты.УпаковкаИнгредиента КАК УпаковкаИнгредиента,
	|	питПланМенюИнгредиенты.КоличествоУпаковокИнгредиентаНорма КАК КоличествоУпаковокИнгредиентаНорма,
	|	питПланМенюИнгредиенты.КоличествоИнгредиентаНорма КАК КоличествоИнгредиентаНорма,
	|	питПланМенюИнгредиенты.ИзАвтопеределов КАК ИзАвтопеределов,
	|	питПланМенюИнгредиенты.ЕстьСхемаОбеспечения КАК ЕстьСхемаОбеспечения,
	|	питПланМенюИнгредиенты.РецептураАвтопередела КАК РецептураАвтопередела
	|ПОМЕСТИТЬ втИнгредиенты
	|ИЗ
	|	Документ.питПланМеню.Ингредиенты КАК питПланМенюИнгредиенты
	|ГДЕ
	|	питПланМенюИнгредиенты.Ссылка = &Ссылка
	|	И НЕ питПланМенюИнгредиенты.Ингредиент.питВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.питВидыНоменклатуры.ТехнологическийИнгредиент)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	питПланМенюЗамены.ИнгредиентЗамена,
	|	питПланМенюЗамены.ХарактеристикаИнгредиентаЗамена,
	|	питПланМенюЗамены.НазначениеИнгредиентаЗамена,
	|	питПланМенюЗамены.УпаковкаИнгредиентаЗамена,
	|	питПланМенюЗамены.КоличествоУпаковокИнгредиентаЗамена,
	|	питПланМенюЗамены.КоличествоИнгредиентаЗамена,
	|	ЛОЖЬ,
	|	питПланМенюЗамены.ЕстьСхемаОбеспечения,
	|	ЗНАЧЕНИЕ(Документ.питРецептура.ПустаяСсылка)
	|ИЗ
	|	Документ.питПланМеню.Замены КАК питПланМенюЗамены
	|ГДЕ
	|	питПланМенюЗамены.Ссылка = &Ссылка
	|	И НЕ питПланМенюЗамены.ИнгредиентЗамена.питВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.питВидыНоменклатуры.ТехнологическийИнгредиент)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	питПланМенюИнгредиенты.Ингредиент КАК Ингредиент,
	|	питПланМенюИнгредиенты.Характеристика КАК Характеристика,
	|	питПланМенюИнгредиенты.Назначение КАК Назначение,
	|	питПланМенюИнгредиенты.УпаковкаИнгредиента КАК УпаковкаИнгредиента,
	|	СУММА(питПланМенюИнгредиенты.КоличествоУпаковокИнгредиентаНорма) КАК КоличествоУпаковокИнгредиентаНорма,
	|	СУММА(питПланМенюИнгредиенты.КоличествоИнгредиентаНорма) КАК КоличествоИнгредиентаНорма,
	|	питПланМенюИнгредиенты.ИзАвтопеределов КАК ИзАвтопеределов,
	|	питПланМенюИнгредиенты.ЕстьСхемаОбеспечения КАК ЕстьСхемаОбеспечения,
	|	питПланМенюИнгредиенты.РецептураАвтопередела КАК РецептураАвтопередела
	|ИЗ
	|	втИнгредиенты КАК питПланМенюИнгредиенты
	|
	|СГРУППИРОВАТЬ ПО
	|	питПланМенюИнгредиенты.УпаковкаИнгредиента,
	|	питПланМенюИнгредиенты.Ингредиент,
	|	питПланМенюИнгредиенты.Характеристика,
	|	питПланМенюИнгредиенты.Назначение,
	|	питПланМенюИнгредиенты.ИзАвтопеределов,
	|	питПланМенюИнгредиенты.ЕстьСхемаОбеспечения,
	|	питПланМенюИнгредиенты.РецептураАвтопередела";
	Запрос.УстановитьПараметр("Ссылка", ДокПланМеню);
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	ДокПланМенюДанные = РезультатЗапроса[0].Выбрать();
	ДокПланМенюДанные.Следующий();
	ДокПланМенюИнгредиенты = РезультатЗапроса[2].Выбрать();
	
	Если ДокПланМенюДанные.Склад = ДокПланМенюДанные.ЦеховаяКладовая Тогда
		
		// Если в плане меню склад производства = складу материалов, то подкладной документ "Заказ материалов в производство" создаваться не должен.
		ВсеОк = ОтменитьПроведениеТиповогоДокументаПоДокументупит(ДокПланМеню, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки, "ЗаказМатериаловВПроизводство");
		Возврат ВсеОк;
		
	КонецЕсли;
	
	// Определение параметров записи.
	ПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокПланМенюДанные.Проведен,ДокПланМенюДанные.ПометкаУдаления,
	ДокЗаказНаПередачуВПроизводство.Проведен,ДокЗаказНаПередачуВПроизводство.ПометкаУдаления,СтруктураПараметров);
	
	// Определение режима записи
	ТекРежимЗаписи = ПараметрыЗаписи.РежимЗаписи;
	
	//!!!!!!!!!!
	// Если документы "Выпуск продукции" проведены, то будет происходить перепроведение или отмена проведения.
	// Для этого необходимо сначала отменить проведение списаний затарат в производство, т.к.
	// в них есть ссылки на строки ТЧ "Товары" типовых документов "Выпуск продукции".
	
	Если ПараметрыЗаписи.НужнаУстановкаПометкиУдаления Тогда
		
		Попытка
			ДокЗаказНаПередачуВПроизводство.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
			ДокЗаказНаПередачуВПроизводство.ДополнительныеСвойства.Вставить("питДокументОбщепитРаспределениеЗапасов", ДокПланМеню);
			ДокЗаказНаПередачуВПроизводство.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
		Исключение
			ТекстОшибки = ТекстОшибки + "
			|Ошибка при установке пометки удаления """ + ДокЗаказНаПередачуВПроизводство.Метаданные().Представление() + """(в подр.)
			| по документу Общепит """+ДокПланМеню+"""
			|по причине: <"+ОписаниеОшибки()+">";
			Возврат Ложь;
		КонецПопытки;
		
		
	КонецЕсли;
	
	// В "План меню" был добавлен новый реквизит "Дата план", потребность формируем именно на дату плана.
	ДатаФормированияПотребности = ?(ЗначениеЗаполнено(ДокПланМенюДанные.ДатаПлан), ДокПланМенюДанные.ДатаПлан, ДокПланМенюДанные.Дата);
	
	мМетаданныеТиповогоОбъекта		= ДокЗаказНаПередачуВПроизводство.Метаданные();
	
	мМетаданныеТЧ = мМетаданныеТиповогоОбъекта.ТабличныеЧасти["Товары"];
	
	/////////////////////////////////
	// ЗАПОЛНЕНИЕ ШАПКИ.
	
	ДокЗаказНаПередачуВПроизводство.Дата	= ДокПланМенюДанные.Дата + ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0);
	ДокЗаказНаПередачуВПроизводство.МаксимальныйКодСтроки	= 0;
	
	ДокЗаказНаПередачуВПроизводство.Организация				= ДокПланМенюДанные.Организация;
	ДокЗаказНаПередачуВПроизводство.Подразделение			= ДокПланМенюДанные.Подразделение;
	ДокЗаказНаПередачуВПроизводство.Склад					= ДокПланМенюДанные.Склад;
	ДокЗаказНаПередачуВПроизводство.Приоритет = Справочники.Приоритеты.ПолучитьПриоритетПоУмолчанию(Неопределено);
	
	///***---Даты!!!!
	ДокЗаказНаПередачуВПроизводство.ДатаОтгрузки			= ДатаФормированияПотребности + ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0);
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("ЖелаемаяДатаОтгрузки", мМетаданныеТиповогоОбъекта) Тогда
		ДокЗаказНаПередачуВПроизводство.ЖелаемаяДатаОтгрузки	=ДатаФормированияПотребности + ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0);
	КонецЕсли;
	ДокЗаказНаПередачуВПроизводство.Статус = Перечисления.СтатусыЗаказовМатериаловВПроизводство.КВыполнению;///***---????
	
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("УправлениеПроизводством2_2", мМетаданныеТиповогоОбъекта) Тогда
		ДокЗаказНаПередачуВПроизводство.УправлениеПроизводством2_2 = ФормироватьДокументыПроизводства22;
	КонецЕсли;
	
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("ЦеховаяКладовая", мМетаданныеТиповогоОбъекта) Тогда
		ДокЗаказНаПередачуВПроизводство.ЦеховаяКладовая = ДокПланМенюДанные.ЦеховаяКладовая;
	КонецЕсли;
	
	Если ДокЗаказНаПередачуВПроизводство.УправлениеПроизводством2_2 Тогда
		ДокЗаказНаПередачуВПроизводство.ХозяйственнаяОперация	= Перечисления.ХозяйственныеОперации.ПередачаМатериаловВКладовую;
	Иначе
		ДокЗаказНаПередачуВПроизводство.ХозяйственнаяОперация	= Перечисления.ХозяйственныеОперации.ПередачаВПроизводство;
	КонецЕсли;
	
	//Если ФормироватьДокументыПроизводства22 Тогда
	
	ДокЗаказНаПередачуВПроизводство.НеОтгружатьЧастями		= Ложь; ///***---
	
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Ответственный", мМетаданныеТиповогоОбъекта) Тогда
		ДокЗаказНаПередачуВПроизводство.Ответственный = ДокПланМенюДанные.Ответственный;
	КонецЕсли;
	
	ДокЗаказНаПередачуВПроизводство.Комментарий					= ДокПланМенюДанные.Комментарий;
	
	// Очистка табличных частей, т.к. будет их перезаполнение.
	ДокЗаказНаПередачуВПроизводство.Товары.Очистить();
	Пока ДокПланМенюИнгредиенты.Следующий() Цикл
		
		Если ДокПланМенюИнгредиенты.ИзАвтопеределов ИЛИ (НЕ ДокПланМенюИнгредиенты.ИзАвтопеределов И ДокПланМенюИнгредиенты.ЕстьСхемаОбеспечения) Тогда 
			Продолжить;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(ДокПланМенюИнгредиенты.Ингредиент) Тогда
			Продолжить;
		КонецЕсли;
		
		НовСтр = ДокЗаказНаПередачуВПроизводство.товары.Добавить();
		НовСтр.Номенклатура = ДокПланМенюИнгредиенты.Ингредиент;
		НовСтр.Характеристика = ДокПланМенюИнгредиенты.Характеристика;
		НовСтр.Назначение = ДокПланМенюИнгредиенты.Назначение;
		НовСтр.Упаковка = ДокПланМенюИнгредиенты.УпаковкаИнгредиента;
		
		НовСтр.КоличествоУпаковок = ДокПланМенюИнгредиенты.КоличествоУпаковокИнгредиентаНорма;
		НовСтр.Количество = ДокПланМенюИнгредиенты.КоличествоИнгредиентаНорма;
		
		НовСтр.Отменено = Ложь;
		
		НовСтр.ВариантОбеспечения = Перечисления.ВариантыОбеспечения.КОбеспечению;///***---????
		
		Если ОбщегоНазначения.ЕстьРеквизитОбъекта("ДатаОтгрузки", мМетаданныеТЧ) Тогда
			НовСтр.ДатаОтгрузки = ДатаФормированияПотребности + ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0);
		ИначеЕсли ОбщегоНазначения.ЕстьРеквизитОбъекта("НачалоОтгрузки", мМетаданныеТЧ) Тогда
			НовСтр.НачалоОтгрузки = ДатаФормированияПотребности + ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0);
		КонецЕсли;
		
		
		//Обязательные
		//НовСтр.Серия = 
		
		//Необязательн
		//НовСтр.ГруппаПродукции
		//НовСтр.СтатусУказанияСерий
		
		//НовСтр.КодСтроки
		//НовСтр.Назначение = Стр.
		
	КонецЦикла;
	
	Если НЕ ДокЗаказНаПередачуВПроизводство.Товары.Количество() Тогда
		//  Если в плане меню склад производства <> складу материалов, но в
		//  него не попадает ни одна позиция (по всем позициям к обеспечению 
		//  настроено обеспечение потребностей). В таком случае пустой подкладной
		//  документ "Заказ материалов в производство" также создаваться не должен.
		ТекРежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения;
	КонецЕсли;
	Если ПустаяСтрока(ДокЗаказНаПередачуВПроизводство.ВерсияДанных) И ТекРежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
		// Новые документы нельзя отменить.
		Возврат ВсеОк;
	КонецЕсли;
	
	Попытка
		ДокЗаказНаПередачуВПроизводство.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
		ДокЗаказНаПередачуВПроизводство.ДополнительныеСвойства.Вставить("питДокументОбщепитРаспределениеЗапасов", ДокПланМеню);
		
		ДокЗаказНаПередачуВПроизводство.Записать(ТекРежимЗаписи);
	Исключение
		ТекстОшибки = ТекстОшибки + "
		|Ошибка записи документа """ + ДокЗаказНаПередачуВПроизводство.Метаданные().Представление() + """
		| по документу Общепит """+ДокПланМеню+"""
		|по причине: <"+ОписаниеОшибки()+">";
		Возврат Ложь;
	КонецПопытки;
	
	// Добавление записи в результирующую таблицу в случае успешной записи документов.
	ДобавитьНовуюЗапись(ДокПланМеню, ДокЗаказНаПередачуВПроизводство, тблСозданныеДокументы);
	
	Возврат ВсеОк;
	
КонецФункции


// Функция формирует документы "Заказ на перемещение".
//
// Параметры:
//  ДокПланМеню		 - ДокументСсылка	 - Ссылка на документ "План-меню", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьЗаказНаПеремещениеПоПлануМеню(ДокПланМеню, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки)
	
	Перем ДатаФормированияПотребности, мМетаданныеТиповогоОбъекта, мМетаданныеТЧ, НовСтр, ПараметрыЗаписи, Стр, ТекРежимЗаписи;
	
	ДокЗаказНаПеремещение = Неопределено;
	ВсеОк = Истина;
	
	ПолучитьТиповойДокументДляПланаМеню(ДокПланМеню, ДокЗаказНаПеремещение, "ЗаказНаПеремещение");
	Если ДокЗаказНаПеремещение = Неопределено Тогда
		// Например изходный документ удален, а подкладных для удаления нет.
		Возврат Истина;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДокЗаказНаПеремещение.ВерсияДанных) 
		И ДокЗаказНаПеремещение.Статус <> Перечисления.СтатусыВнутреннихЗаказов.КВыполнению Тогда
		// Статус был изменен пользователем, синхронизацию данных не проводим
		
		// Добавление записи в результирующую таблицу в случае успешной записи документов.
		ДобавитьНовуюЗапись(ДокПланМеню, ДокЗаказНаПеремещение, тблСозданныеДокументы);
		
		Возврат Истина;
		
	КонецЕсли;
	
	// Определение параметров записи.
	ПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокПланМеню.Проведен,ДокПланМеню.ПометкаУдаления,
	ДокЗаказНаПеремещение.Проведен,ДокЗаказНаПеремещение.ПометкаУдаления,СтруктураПараметров);
	
	// Определение режима записи
	ТекРежимЗаписи = ПараметрыЗаписи.РежимЗаписи;
	
	//УстановкаПометкиУдаления
	Если ПараметрыЗаписи.НужнаУстановкаПометкиУдаления Тогда
		Попытка
			ДокЗаказНаПеремещение.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
			ДокЗаказНаПеремещение.ДополнительныеСвойства.Вставить("питДокументОбщепитРаспределениеЗапасов", ДокПланМеню);
			ДокЗаказНаПеремещение.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
		Исключение
			ТекстОшибки = ТекстОшибки + "
			|Ошибка при установке пометки удаления """ + ДокЗаказНаПеремещение.Метаданные().Представление() + """(в подр.)
			| по документу Общепит """+ДокПланМеню+"""
			|по причине: <"+ОписаниеОшибки()+">";
			Возврат Ложь;
		КонецПопытки;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питПланМеню.Дата КАК Дата,
	|	питПланМеню.Автор КАК Автор,
	|	питПланМеню.Организация КАК Организация,
	|	питПланМеню.Подразделение КАК Подразделение,
	|	питПланМеню.ЦеховаяКладовая КАК ЦеховаяКладовая,
	|	питПланМеню.Комментарий КАК Комментарий,
	|	питПланМеню.Склад КАК Склад,
	|	питПланМеню.ДатаПлан КАК ДатаПлан,
	|	питПланМеню.Ответственный КАК Ответственный
	|ИЗ
	|	Документ.питПланМеню КАК питПланМеню
	|ГДЕ
	|	питПланМеню.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	питПланМенюИнгредиенты.Ингредиент КАК Ингредиент,
	|	питПланМенюИнгредиенты.Характеристика КАК Характеристика,
	|	питПланМенюИнгредиенты.Назначение КАК Назначение,
	|	питПланМенюИнгредиенты.УпаковкаИнгредиента КАК УпаковкаИнгредиента,
	|	питПланМенюИнгредиенты.КоличествоУпаковокИнгредиентаНорма КАК КоличествоУпаковокИнгредиентаНорма,
	|	питПланМенюИнгредиенты.КоличествоИнгредиентаНорма КАК КоличествоИнгредиентаНорма,
	|	питПланМенюИнгредиенты.ИзАвтопеределов КАК ИзАвтопеределов,
	|	питПланМенюИнгредиенты.ЕстьСхемаОбеспечения КАК ЕстьСхемаОбеспечения,
	|	питПланМенюИнгредиенты.РецептураАвтопередела КАК РецептураАвтопередела
	|ПОМЕСТИТЬ втИнгредиенты
	|ИЗ
	|	Документ.питПланМеню.Ингредиенты КАК питПланМенюИнгредиенты
	|ГДЕ
	|	питПланМенюИнгредиенты.Ссылка = &Ссылка
	|	И НЕ питПланМенюИнгредиенты.Ингредиент.питВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.питВидыНоменклатуры.ТехнологическийИнгредиент)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	питПланМенюЗамены.ИнгредиентЗамена,
	|	питПланМенюЗамены.ХарактеристикаИнгредиентаЗамена,
	|	питПланМенюЗамены.НазначениеИнгредиентаЗамена,
	|	питПланМенюЗамены.УпаковкаИнгредиентаЗамена,
	|	питПланМенюЗамены.КоличествоУпаковокИнгредиентаЗамена,
	|	питПланМенюЗамены.КоличествоИнгредиентаЗамена,
	|	ЛОЖЬ,
	|	питПланМенюЗамены.ЕстьСхемаОбеспечения,
	|	ЗНАЧЕНИЕ(Документ.питРецептура.ПустаяСсылка)
	|ИЗ
	|	Документ.питПланМеню.Замены КАК питПланМенюЗамены
	|ГДЕ
	|	питПланМенюЗамены.Ссылка = &Ссылка
	|	И НЕ питПланМенюЗамены.ИнгредиентЗамена.питВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.питВидыНоменклатуры.ТехнологическийИнгредиент)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	питПланМенюИнгредиенты.Ингредиент КАК Ингредиент,
	|	питПланМенюИнгредиенты.Характеристика КАК Характеристика,
	|	питПланМенюИнгредиенты.УпаковкаИнгредиента КАК УпаковкаИнгредиента,
	|	питПланМенюИнгредиенты.Назначение КАК Назначение,
	|	СУММА(питПланМенюИнгредиенты.КоличествоУпаковокИнгредиентаНорма) КАК КоличествоУпаковокИнгредиентаНорма,
	|	СУММА(питПланМенюИнгредиенты.КоличествоИнгредиентаНорма) КАК КоличествоИнгредиентаНорма,
	|	питПланМенюИнгредиенты.ИзАвтопеределов КАК ИзАвтопеределов,
	|	питПланМенюИнгредиенты.ЕстьСхемаОбеспечения КАК ЕстьСхемаОбеспечения,
	|	питПланМенюИнгредиенты.РецептураАвтопередела КАК РецептураАвтопередела
	|ИЗ
	|	втИнгредиенты КАК питПланМенюИнгредиенты
	|
	|СГРУППИРОВАТЬ ПО
	|	питПланМенюИнгредиенты.ИзАвтопеределов,
	|	питПланМенюИнгредиенты.Ингредиент,
	|	питПланМенюИнгредиенты.Характеристика,
	|	питПланМенюИнгредиенты.Назначение,
	|	питПланМенюИнгредиенты.РецептураАвтопередела,
	|	питПланМенюИнгредиенты.ЕстьСхемаОбеспечения,
	|	питПланМенюИнгредиенты.УпаковкаИнгредиента";
	Запрос.УстановитьПараметр("Ссылка", ДокПланМеню);
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	ДокПланМенюДанные = РезультатЗапроса[0].Выбрать();
	ДокПланМенюДанные.Следующий();
	ДокПланМенюИнгредиенты = РезультатЗапроса[2].Выбрать();
	
	// В "План меню" был добавлен новый реквизит "Дата план", потребность формируем именно на дату плана.
	ДатаФормированияПотребности = ?(ЗначениеЗаполнено(ДокПланМенюДанные.ДатаПлан), ДокПланМенюДанные.ДатаПлан, ДокПланМенюДанные.Дата);
	
	// Метаданные.
	мМетаданныеТиповогоОбъекта		= ДокЗаказНаПеремещение.Метаданные();
	мМетаданныеТЧ = мМетаданныеТиповогоОбъекта.ТабличныеЧасти["Товары"];
	
	/////////////////////////////////
	// ЗАПОЛНЕНИЕ ШАПКИ.
	ДокЗаказНаПеремещение.Дата								= ДокПланМенюДанные.Дата + ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0);
	ДокЗаказНаПеремещение.Организация						= ДокПланМенюДанные.Организация;
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Ответственный", мМетаданныеТиповогоОбъекта) Тогда
		ДокЗаказНаПеремещение.Ответственный					= ДокПланМенюДанные.Ответственный;
	КонецЕсли;
	ДокЗаказНаПеремещение.Подразделение						= ДокПланМенюДанные.Подразделение;
	ДокЗаказНаПеремещение.СкладОтправитель					= ДокПланМенюДанные.Склад;
	ДокЗаказНаПеремещение.СкладПолучатель					= ДокПланМенюДанные.ЦеховаяКладовая;
	ДокЗаказНаПеремещение.Статус							= Перечисления.СтатусыВнутреннихЗаказов.КВыполнению;
	ДокЗаказНаПеремещение.МаксимальныйКодСтроки				= 0;
	ДокЗаказНаПеремещение.ХозяйственнаяОперация				= Перечисления.ХозяйственныеОперации.ПеремещениеТоваров;
	ДокЗаказНаПеремещение.ЖелаемаяДатаПоступления			= ДатаФормированияПотребности + ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0);
	ДокЗаказНаПеремещение.Комментарий						= ДокПланМенюДанные.Комментарий;
	ДокЗаказНаПеремещение.СпособДоставки					= Перечисления.СпособыДоставки.Самовывоз;
	ДокЗаказНаПеремещение.ВариантПриемкиТоваров				= Перечисления.ВариантыПриемкиТоваров.РазделенаПоЗаказамИНакладным;
	
	// Очистка табличных частей, т.к. будет их перезаполнение.
	ДокЗаказНаПеремещение.Товары.Очистить();
	Пока ДокПланМенюИнгредиенты.Следующий() Цикл
		
		Если ДокПланМенюИнгредиенты.ИзАвтопеределов ИЛИ (НЕ ДокПланМенюИнгредиенты.ИзАвтопеределов И ДокПланМенюИнгредиенты.ЕстьСхемаОбеспечения) Тогда 
			Продолжить;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(ДокПланМенюИнгредиенты.Ингредиент) Тогда
			Продолжить;
		КонецЕсли;
		
		НовСтр = ДокЗаказНаПеремещение.товары.Добавить();
		НовСтр.НачалоОтгрузки				= ДатаФормированияПотребности + ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0);
		НовСтр.НачалоОтгрузки				= ДатаФормированияПотребности + ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0);
		НовСтр.КоличествоУпаковок			= ДокПланМенюИнгредиенты.КоличествоУпаковокИнгредиентаНорма;
		НовСтр.Количество					= ДокПланМенюИнгредиенты.КоличествоИнгредиентаНорма;
		НовСтр.Номенклатура					= ДокПланМенюИнгредиенты.Ингредиент;
		НовСтр.Характеристика				= ДокПланМенюИнгредиенты.Характеристика;
		НовСтр.Назначение					= ДокПланМенюИнгредиенты.Назначение;
		НовСтр.Упаковка						= ДокПланМенюИнгредиенты.УпаковкаИнгредиента;
		НовСтр.Отменено						= Ложь;
		НовСтр.ВариантОбеспечения			= Перечисления.ВариантыОбеспечения.КОбеспечению;
		
		//Обязательные
		//НовСтр.Серия = 
		//Необязательн
		//НовСтр.ГруппаПродукции
		//НовСтр.СтатусУказанияСерий
		//НовСтр.КодСтроки
		
	КонецЦикла;
	
	Попытка
		ДокЗаказНаПеремещение.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
		ДокЗаказНаПеремещение.ДополнительныеСвойства.Вставить("питДокументОбщепитРаспределениеЗапасов", ДокПланМеню);
		ДокЗаказНаПеремещение.Записать(ТекРежимЗаписи);
	Исключение
		ТекстОшибки = ТекстОшибки + "
		|Ошибка записи документа """ + ДокЗаказНаПеремещение.Метаданные().Представление() + """
		| по документу Общепит """+ДокПланМеню+"""
		|по причине: <"+ОписаниеОшибки()+">";
		Возврат Ложь;
	КонецПопытки;
	
	// Добавление записи в результирующую таблицу в случае успешной записи документов.
	ДобавитьНовуюЗапись(ДокПланМеню, ДокЗаказНаПеремещение, тблСозданныеДокументы);
	
	Возврат ВсеОк;
	
КонецФункции

// Процедура по переданной ссылке на план-меню ищет типовые документы. Если не находит, то создает для них пустой объект.
//
// Параметры:
//  ДокументВыпускБлюд			 - ДокументСсылка	 - Ссылка на документ, для которого ищем "Выпуски продукции".
//  выхДокВыпускПродукцииНаСклад - ДокументОбъект	 - Документ "Выпуск продукции"(на склад).
//  выхДокВыпускПродукцииВПодр	 - ДокументОбъект	 - Документ "Выпуск продукции"(в подразделение).
//
Процедура ПолучитьТиповойДокументДляПланаМеню(ДокументПланМеню, выхДокЗаказ, ИмяТиповогоДокумента)
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = 
	"ВЫБРАТЬ 
	|	питТиповыеДокументы.ТиповойДокумент КАК ДокументОбщепита
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|	И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ."+ИмяТиповогоДокумента+"
	|";
	
	Запрос.УстановитьПараметр("Документпит",				ДокументПланМеню);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	// Если документы найдены, то инициализируем соответствующие переменные.
	Пока Выборка.Следующий() Цикл
		
		выхДокЗаказ = Выборка.ДокументОбщепита.ПолучитьОбъект();
	КонецЦикла;
	
	// Если переменные не инициализированны, значит документы не были найдены
	// и необходимо создать пустые документы-объекты, которые далее будут заполняться.
	Если (выхДокЗаказ = Неопределено) И НЕ ДокументПланМеню.ПометкаУдаления Тогда
		выхДокЗаказ = Документы[ИмяТиповогоДокумента].СоздатьДокумент();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ФормированиеТиповыхДокументовПоРецептуре

// Процедура формирования типовых документов по переданному выпуску блюд.
//
// Параметры:
//  ДокРазделкапит		 - ДокументСсылка	 - Ссылка на документ "Разделка", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьТиповыеДокументыПоРецептуре(ДокРецептура, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки = "")
	
	ВсеОк = Истина;
	
	// В режиме синхронизации нет проверки статуса спецификации.
	Если СтруктураПараметров.Свойство("ЭтоРежимСинхронизации") Тогда
		ЭтоРежимСинхронизации = СтруктураПараметров.ЭтоРежимСинхронизации;
	Иначе
		ЭтоРежимСинхронизации = Ложь;
	КонецЕсли;
	
	//+питКА
	Если НЕ (питПроизводствоПовтИсп.ПолучитьИмяОсновнойКонфигурации() = "УправлениеПредприятием"
		ИЛИ питПроизводствоПовтИсп.ПолучитьИмяОсновнойКонфигурации() = "ERPWE") Тогда
		Возврат ВсеОк;
	КонецЕсли;
	//-питКА
	
	Если СтруктураПараметров.Свойство("ФормироватьДокументыПроизводства22") Тогда
		ФормироватьДокументыПроизводства22 = СтруктураПараметров.ФормироватьДокументыПроизводства22;
	Иначе
		ФормироватьДокументыПроизводства22 = Константы.питФормироватьДокументыПроизводства22.Получить();
	КонецЕсли;
	
	ТиповыеДокументы = ПолучитьТиповыеДокументыДляДокументаПитПоРежимуПроизводства(ДокРецептура, ?(ФормироватьДокументыПроизводства22,"2.1","2.2"));
	Если ТиповыеДокументы.Количество() Тогда
		
		УдалятьДокументыСтаройСхемыПроведения = Истина;
		Если СтруктураПараметров.Свойство("УдалятьДокументыСтаройСхемыПроведения") Тогда
			УдалятьДокументыСтаройСхемыПроведения = СтруктураПараметров.УдалятьДокументыСтаройСхемыПроведения;
		КонецЕсли;
		
		Если УдалятьДокументыСтаройСхемыПроведения Тогда
			
			Если СтруктураПараметров.Свойство("РежимЗаписи") И СтруктураПараметров.РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
				// Для документов общепит при перепроведении выполняется сначала отмена проведения явным образом, 
				// чтобы отменить проведение всех типовых документов.
				// В этот момент, мы отменим проведение документов старой схемы.
				ФормироватьДокументыПроизводства22 = НЕ ФормироватьДокументыПроизводства22;
			Иначе
				
				// "Обрываем" связь документов старой схемы производства!
				ВсеОк = ПометитьНаУдалениеИОтвязатьТиповыеДокументы(ДокРецептура, ТиповыеДокументы, СтруктураПараметров, ТекстОшибки);
				
			КонецЕсли;
			
		Иначе
			
			ТекстОшибки = ТекстОшибки + "
			| Не выполнено формирование типовых документов производства "+?(ФормироватьДокументыПроизводства22,"2.2","2.1")+" по документу общепит <"+ДокРецептура+"> !!
			| По данному документу уже созданы документы производства "+?(ФормироватьДокументыПроизводства22,"2.1","2.2")+"!";
			Возврат Ложь;
			
		КонецЕсли;
	КонецЕсли;
	
	// Ничего не формируем, если не стоит настройка. Но это не ошибка, поэтому возвращаем, что все ок.
	Если НЕ ЭтоРежимСинхронизации И (НЕ Константы.питФормироватьСпецификацииПоРецептурам.Получить()) Тогда
		//ИЛИ НЕ (ДокРецептура.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.РецептураПриготовление)) 
		Возврат ВсеОк;
	КонецЕсли;
	
	//////////////////////////////////
	// ФОРМИРОВАНИЕ СПЕЦИФИКАЦИЙ
	//
	
	// Получение документов-объектов "Выпуск продукции" с направлением "На склад" и "В подразделение".
	Спецификация	= Неопределено;
	ПолучитьСпецификациюПоРецептуре(ДокРецептура, Спецификация);
	
	ЭтоНоваяСпецификация = Спецификация.ЭтоНовый();
	
	// Для помеченый на удаление рецептур ничего не создаем, если раньше не было создано.
	Если ЭтоНоваяСпецификация И ДокРецептура.ПометкаУдаления Тогда
		Возврат ВсеОК;
	КонецЕсли;
	
	// Для существующих спецификаций, если изменился статус и уже не равен "В разработке",
	// то переформирования не происходит.
	Если НЕ ЭтоРежимСинхронизации И НЕ ЭтоНоваяСпецификация 
		И Спецификация.Статус <> Перечисления.СтатусыСпецификаций.ВРазработке Тогда
		
		ТекстРецептура = "Для рецептуры """+ДокРецептура.Ссылка+""" уже утверждена спецификация """+Спецификация.Ссылка+" #"+Спецификация.Код+""". 
		|Синхронизация данных рецептуры и связанной спецификации возможна только для спецификаций в статусе ""В разработке""";
		СтруктураПараметров.Вставить("питСообщениеПоРецептуре", ТекстРецептура);
		СтруктураПараметров.Вставить("питСсылкаНаСпецификацию", Спецификация.Ссылка);
		
		Возврат ВсеОк;
		
	Иначе
		
		ТекстРецептура = "";
		
	КонецЕсли;
	
	// Определение параметров записи.
	
	// Для справочника, коим является спецификация, не определяем режим записи.
	Если СтруктураПараметров.Свойство("ОпределятьРежимЗаписи") Тогда
		ОпределятьРежимЗаписи = Ложь;
	Иначе
		СтруктураПараметров.Вставить("ОпределятьРежимЗаписи", Ложь);
	КонецЕсли;
	
	ПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокРецептура.Проведен,ДокРецептура.ПометкаУдаления,
		,Спецификация.ПометкаУдаления,СтруктураПараметров);
	
	Если ПараметрыЗаписи.НужнаУстановкаПометкиУдаления Тогда
		
		Попытка
			Спецификация.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
			Спецификация.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
		Исключение
			ТекстОшибки = ТекстОшибки + "
			|Ошибка при установке пометки удаления """ + Спецификация.Метаданные().Представление() + "
			| по документу Общепит """+ДокРецептура+"""
			|по причине: <"+ОписаниеОшибки()+">";
			Возврат Ложь;
		КонецПопытки;
		
	КонецЕсли;
	
	/////////////////////////////////
	// ЗАПОЛНЕНИЕ ШАПКИ.
	
	мМетаданныеДокументапит			= ДокРецептура.Метаданные();
	мМетаданныеТиповогоОбъекта		= Спецификация.Метаданные();
	
	мМетаданныеТЧМатериалыИУслуги = мМетаданныеТиповогоОбъекта.ТабличныеЧасти["МатериалыИУслуги"];
	
	Если ЭтоНоваяСпецификация Тогда
		// В режиме синхронизации для не новых рецептур не меняем статус.
		// В остальных случаях перезаполняем ниже указанные реквизиты.
		
		Спецификация.Статус										= Перечисления.СтатусыСпецификаций.ВРазработке;
		Спецификация.МногоэтапныйПроизводственныйПроцесс		= Ложь;
		Спецификация.ОптимальноеКоличествоПередачиМеждуЭтапами	= 1;
		Спецификация.СпособРаспределенияЗатратНаВыходныеИзделия	= Перечисления.СпособыРаспределенияЗатратНаВыходныеИзделия.ПоДолямСтоимости;
		
		
	КонецЕсли;
	
	Спецификация.Наименование								= ДокРецептура.Наименование;
	Спецификация.НачалоДействия								= ДокРецептура.ДатаНачала;
	Спецификация.КонецДействия								= ДокРецептура.ДатаКонца;
	Спецификация.Ответственный								= ДокРецептура.Ответственный;
	Спецификация.Описание									= ДокРецептура.ТехнологияПриготовления;
	Если ДокРецептура.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.РецептураПриготовление Тогда
		Спецификация.ТипПроизводственногоПроцесса			= Перечисления.ТипыПроизводственныхПроцессов.Сборка;
	Иначе
		Спецификация.ТипПроизводственногоПроцесса			= Перечисления.ТипыПроизводственныхПроцессов.Разборка;
		//Спецификация.ОсновноеИзделиеВидНоменклатуры
		Спецификация.ОсновноеИзделиеНоменклатура			= ДокРецептура.Номенклатура;
		Спецификация.ОсновноеИзделиеХарактеристика			= ДокРецептура.Характеристика;
		Спецификация.ОсновноеИзделиеУпаковка				= ДокРецептура.Номенклатура;
		Спецификация.ОсновноеИзделиеКоличествоУпаковок		= ДокРецептура.КоличествоУпаковок;
	КонецЕсли;
	Спецификация.ВыходныеИзделия.Очистить();
	
	//+25
	Спецификация.ВариантПодбораВДокументы	= Перечисления.ВариантыПодбораСпецификацииВДокументы.Автоматически;
	Спецификация.ВариантНазначения			= Перечисления.ВариантыНазначенияСпецификации.Номенклатура;
	СтруктураДанных = Новый Структура("Номенклатура,Характеристика,Упаковка,КоличествоУпаковок");
	Для каждого КлючИЗначение Из СтруктураДанных Цикл
		РеквизитОбъекта = "ОсновноеИзделие"+КлючИЗначение.Ключ;
		Спецификация[РеквизитОбъекта] = ДокРецептура[КлючИЗначение.Ключ];
	КонецЦикла;
	Спецификация.ОсновноеИзделиеВидНоменклатуры = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокРецептура.Номенклатура, "ВидНоменклатуры");
	ПервыйЭтап    = Новый Структура("Ссылка");
	ПоследнийЭтап = Новый Структура("Ссылка");
	Справочники.РесурсныеСпецификации.ПолучитьПервыйИПоследнийЭтап(Спецификация.Ссылка, ПервыйЭтап, ПоследнийЭтап);
	Спецификация.ОсновноеИзделиеЭтап = ПервыйЭтап.Ссылка;
	Спецификация.ЗаполнитьСлужебныеРеквизитыПовтИсп();
	ПустойУИД = Новый УникальныйИдентификатор("00000000-0000-0000-0000-000000000000");
	//-25
	
	// Очистка табличных частей, т.к. будет их перезаполнение.
	//Спецификация.ВыходныеИзделия.Очистить();
	//Спецификация.МатериалыИУслуги.Очистить();
	//Спецификация.ВозвратныеОтходы.Очистить();
	//Спецификация.Трудозатраты.Очистить();
	
	// Получение данных по табличной части "Производство" отраслевого документа "Выпуск блюд".
	Запрос = Новый Запрос;
	ТекстЗапроса=
	"ВЫБРАТЬ
	|	питРецептураИнгридиенты.Номенклатура КАК Номенклатура,
	|	питРецептураИнгридиенты.Номенклатура.ВидНоменклатуры КАК ВидНоменклатуры,
	|	питРецептураИнгридиенты.Характеристика КАК Характеристика,
	|	питРецептураИнгридиенты.Упаковка КАК УпаковкаНоменклатуры,
	|	питРецептураИнгридиенты.КоличествоУпаковокБрутто КАК КоличествоУпаковокНоменклатуры,
	|	питРецептураИнгридиенты.КоличествоБрутто КАК КоличествоНоменклатуры,
	|	питРецептураИнгридиенты.ПроцентСебестоимости КАК ПроцентСебестоимости,
	|	питРецептураИнгридиенты.Рецептура КАК Рецептура,
	|	питРецептураИнгридиенты.СтатьяКалькуляции КАК СтатьяКалькуляции,
	|	питРецептураИнгридиенты.КлючСвязи КАК КлючСвязи,
	|	питРецептураИнгридиенты.АлгоритмРасчетаКоличества КАК АлгоритмРасчетаКоличества,
	|	питРецептураИнгридиенты.СпособАвтовыбораНоменклатуры КАК СпособАвтовыбораНоменклатуры,
	|	питРецептураИнгридиенты.СпособАвтовыбораХарактеристики КАК СпособАвтовыбораХарактеристики,
	|	питРецептураИнгридиенты.СвойствоСодержащееНоменклатуру КАК СвойствоСодержащееНоменклатуру,
	|	питРецептураИнгридиенты.АлгоритмАвтовыбораХарактеристики КАК АлгоритмАвтовыбораХарактеристики
	|ИЗ
	|	Документ.питРецептура.Ингредиенты КАК питРецептураИнгридиенты
	|ГДЕ
	|	питРецептураИнгридиенты.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	питРецептураТрудозатраты.ВидРабот КАК ВидРабот,
	|	питРецептураТрудозатраты.Количество КАК Количество,
	|	питРецептураТрудозатраты.НазначениеРабот КАК НазначениеРабот,
	|	питРецептураТрудозатраты.СтатьяКалькуляции КАК СтатьяКалькуляции
	|ИЗ
	|	Документ.питРецептура.Трудозатраты КАК питРецептураТрудозатраты
	|ГДЕ
	|	питРецептураТрудозатраты.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
