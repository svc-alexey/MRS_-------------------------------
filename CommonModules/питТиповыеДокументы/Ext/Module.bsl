#Область ФормированиеТиповыхДокументовПоВыпускуБлюд

// Процедура формирования типовых документов по переданному выпуску блюд.
//
// Параметры:
//  ДокументВыпускБлюд		 - ДокументСсылка	 - Ссылка на документ "Выпуск блюд", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьТиповыеДокументыПоВыпускуБлюд(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки = "")
	
	Если СтруктураПараметров.Свойство("ФормироватьДокументыПроизводства22") Тогда
		ФормироватьДокументыПроизводства22 = СтруктураПараметров.ФормироватьДокументыПроизводства22;
	Иначе
		ФормироватьДокументыПроизводства22 = Константы.питФормироватьДокументыПроизводства22.Получить();
	КонецЕсли;
	
	//+ОтложенноеПроведение
	Если НЕ СтруктураПараметров.Свойство("питИспользоватьОтложенноеПроведениеВыпускаБлюд") Тогда
		СтруктураПараметров.Вставить("питИспользоватьОтложенноеПроведениеВыпускаБлюд", питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питИспользоватьОтложенноеПроведениеВыпускаБлюд"));
	КонецЕсли;
	//+debug
	//СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд = Ложь;
	//-debug
	Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд
		И НЕ СтруктураПараметров.Свойство("питТекущийПриоритетДействияОтложенногоПроведения") Тогда
		СтруктураПараметров.Вставить("питТекущийПриоритетДействияОтложенногоПроведения", ПолучитьТекущийПриоритетДействияОтложенногоПроведения(ДокументВыпускБлюд));
	КонецЕсли;
	//-ОтложенноеПроведение
	
	Если НЕ СтруктураПараметров.Свойство("ТаблицаПорядокПроведенияТиповыхДокументовВыпускаБлюд") Тогда
		СтруктураПараметров.Вставить("ТаблицаПорядокПроведенияТиповыхДокументовВыпускаБлюд", ПолучитьТаблицуПорядокПроведенияТиповыхДокументовВыпускаБлюд(СтруктураПараметров, ДокументВыпускБлюд.Дата));
	КонецЕсли;
	
	ТиповыеДокументы = ПолучитьТиповыеДокументыДляДокументаПитПоРежимуПроизводства(ДокументВыпускБлюд, ?(ФормироватьДокументыПроизводства22,"2.1","2.2"));
	Если ТиповыеДокументы.Количество() Тогда
		
		УдалятьДокументыСтаройСхемыПроведения = Истина;
		Если СтруктураПараметров.Свойство("УдалятьДокументыСтаройСхемыПроведения") Тогда
			УдалятьДокументыСтаройСхемыПроведения = СтруктураПараметров.УдалятьДокументыСтаройСхемыПроведения;
		КонецЕсли;
		
		Если УдалятьДокументыСтаройСхемыПроведения Тогда
			
			//+ОтложенноеПроведение
			Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
				Для каждого ТекТиповойДокумент Из ТиповыеДокументы Цикл
					ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.ПометитьНаУдалениеТиповойДокумент	, ТекТиповойДокумент, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
					СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
					Если НЕ ВсеОк Тогда 
						Возврат ВсеОк;
					КонецЕсли;
					ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.ОтвязатьТиповойДокумент				, ТекТиповойДокумент, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
					СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
					Если НЕ ВсеОк Тогда 
						Возврат ВсеОк;
					КонецЕсли;
				КонецЦикла;
			Иначе
			//-ОтложенноеПроведение
				
				// "Обрываем" связь документов старой схемы производства!
				ВсеОк = ПометитьНаУдалениеИОтвязатьТиповыеДокументы(ДокументВыпускБлюд, ТиповыеДокументы, СтруктураПараметров, ТекстОшибки);
				
			КонецЕсли;
			
		Иначе
			
			ТекстОшибки = ТекстОшибки + "
			| Не выполнено формирование типовых документов производства "+?(ФормироватьДокументыПроизводства22,"2.2","2.1")+" по документу общепит <"+ДокументВыпускБлюд+"> !!
			| По данному документу уже созданы документы производства "+?(ФормироватьДокументыПроизводства22,"2.1","2.2")+"!";
			Возврат Ложь;
			
		КонецЕсли;
	КонецЕсли;
	
	//<<Загребалов И., Апрель-Софт, 28.11.2021.SD64997, Удаление документа выпуск
	// если удаляем выпуск блюд, удалим все связанные документы, если они остались
	Если ДокументВыпускБлюд.ПометкаУдаления Тогда
		ТиповыеДокументыДляПометки = Новый Массив;
		НайтиТиповойДокументДляДокументапит(ДокументВыпускБлюд, ТиповыеДокументыДляПометки, ТекстОшибки);
		
		//<<Загребалов И., Апрель-Софт, 02.12.2021.SD64997, Удаление документа выпуск
		Если ТипЗнч(ТиповыеДокументыДляПометки) <> Тип("Массив") Тогда
			МассивДокументов = Новый Массив;
			МассивДокументов.Добавить(ТиповыеДокументыДляПометки);
		Иначе
			МассивДокументов = ТиповыеДокументыДляПометки;
		КонецЕсли;
		//>>

		ВсеОк = ПометитьНаУдалениеТиповыеДокументы(ДокументВыпускБлюд, МассивДокументов, Неопределено , ТекстОшибки);
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
	КонецЕсли;
	//>>
	
	///////////////////////////////////////////////////
	// ОТМЕНА ПРОВЕДЕНИЯ ВСЕХ ПОДКЛАДНЫХ
	Если (НЕ ПараметрыСеанса.ПроводитьБезКонтроляОстатковТоваровОрганизаций 
		И Константы.КонтролироватьОстаткиТоваровОрганизаций.Получить())
		ИЛИ СтруктураПараметров.РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения
		ИЛИ Документы.питВыпускБлюд.СодержитСерийнуюНоменклатуруДляСписания(ДокументВыпускБлюд) Тогда
		// Если есть контроль остатков то выполнить отмену проведения существующих документов.
		// Или если это режим отмены проведения.
		ВсеОк = ОтменитьПроведениеТиповыхДокументовПоВыпускуБлюд(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
	КонецЕсли;
	
	// При отмене проведения больше никаких действий не требуется.
	Если СтруктураПараметров.РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
		Возврат ВсеОк;
	КонецЕсли;
	
	// НалогообложениеНДС в выпуске блюд.
	// Автоопределение значения налогообложения НДС.
	РеквизитыВыпуска = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументВыпускБлюд, "Организация, Дата, НаправлениеДеятельности");
	РеквизитыВыпускаКэш = Новый Структура("Организация, Дата, НаправлениеДеятельности");
	ЗаполнитьЗначенияСвойств(РеквизитыВыпускаКэш, РеквизитыВыпуска,,"НаправлениеДеятельности");
	ПараметрыЗаполненияВидаДеятельностиНДС = Документы.ПроизводствоБезЗаказа.ПараметрыЗаполненияВидаДеятельностиНДС(РеквизитыВыпуска);
	СтарыеПараметрыЗаполненияВидаДеятельностиНДС = Новый Структура("ПараметрыЗаполненияВидаДеятельностиНДС", Документы.ПроизводствоБезЗаказа.ПараметрыЗаполненияВидаДеятельностиНДС(РеквизитыВыпускаКэш));
	НайденноеНалогообложениеНДС = Неопределено;
	УчетНДСУП.ЗаполнитьВидДеятельностиНДС(НайденноеНалогообложениеНДС, ПараметрыЗаполненияВидаДеятельностиНДС, СтарыеПараметрыЗаполненияВидаДеятельностиНДС);
	СтруктураПараметров.Вставить("НалогообложениеНДС", НайденноеНалогообложениеНДС);
	
	// 1
	Если ФормироватьДокументыПроизводства22 Тогда
		
		///////////////////////////////////////////////////
		// ФОРМИРОВАНИЕ ПЕРЕМЕЩЕНИЙ С РАЗРЕШЕННЫХ КЛАДОВЫХ
		ВсеОк = СформироватьДвижениеПродукцииИзРазрешенныхКладовыхПоВыпускуБлюд22(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
		
	КонецЕсли;
	
	// 2
	///////////////////////////////////////////////////
	// ФОРМИРОВАНИЕ ОПРИХОДОВАНИЯ ИЗЛИШКОВ
	ВсеОк = СформироватьОприходованиеИзлишковПоВыпускуБлюд(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
	Если НЕ ВсеОк Тогда 
		Возврат ВсеОк;
	КонецЕсли;
	
	///////////////////////////////////////////////////////////////
	// ПОМЕТКА УДАЛЕНИЯ НЕАКТУАЛЬНЫХ КОМПЛЕКСНЫХ ТИПОВЫХ ДОКУМЕНТОВ
	ВсеОк = ПометитьНаУдалениеНеиспользуемыеКомплексныеДокументыВыпускаБлюд(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
	Если НЕ ВсеОк Тогда 
		Возврат ВсеОк;
	КонецЕсли;
	
	//22
	Если ФормироватьДокументыПроизводства22 Тогда
		
		///////////////////////////////////////////////////
		// ФОРМИРОВАНИЕ ПЕРЕДАЧИ МАТЕРИАЛОВ В ПРОИЗВОДСТВО
		ВсеОк = СформироватьПроизводствоБезЗаказа22ПоВыпускуБлюд(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
		
	Иначе
		
		///////////////////////////////////////////////////
		// ФОРМИРОВАНИЕ ПЕРЕДАЧИ МАТЕРИАЛОВ В ПРОИЗВОДСТВО
		ВсеОк = СформироватьПередачуМатериаловПоВыпускуБлюд(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
		
		//////////////////////////////////
		// ФОРМИРОВАНИЕ ВЫПУСКОВ ПРОДУКЦИИ
		//
		ВсеОк = СформироватьВыпускПродукцииПоВыпускуБлюд(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
		Если НЕ ВсеОк Тогда
			Возврат ВсеОк;
		КонецЕсли;
		
		//////////////////////////////////////////////////////////////////////////////
		// ФОРМИРОВАНИЕ СПИСАНИЙ ЗАТРАТ НА ВЫПУСК
		ВсеОк = СформироватьСписанияЗатратПоВыпускуБлюд(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
		Если НЕ ВсеОк Тогда
			Возврат ВсеОк;
		КонецЕсли;
		
	КонецЕсли; // Если формировать по версии 2.2
	
	///////////////////////////////////////////////////////////////////////////////////////
	// ДОКУМЕНТЫ ПО КОМПЛЕКСНЫМ ВЫПУСКАМ БЛЮД
	//
	
	Если ДокументВыпускБлюд.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.ВыпускПродукцииСРозничнойРеализацией Тогда
		
		///////////////////////////////////////////////////////////////////////////////////////
		// ФОРМИРОВАНИЕ "ОТЧЕТА О РОЗНИЧНЫХ ПРОДАЖАХ" ДЛЯ ВЫПУСКА С РОЗНИЧНОЙ РЕАЛИЗАЦИЕЙ
		ВсеОк = СформироватьОтчетОРозничныхПродажахПоВыпускуБлюд(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
		
	ИначеЕсли ДокументВыпускБлюд.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.ВыпускПродукцииСРеализацией Тогда
		
		///////////////////////////////////////////////////////////////////////////////////////
		// ФОРМИРОВАНИЕ "РЕАЛИЗАЦИИ ТОВАРОВ УСЛУГ" ДЛЯ ВЫПУСКА С РЕАЛИЗАЦИЕЙ
		ВсеОк = СформироватьРеализациюТоваровУслугПоВыпускуБлюд(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
		
	ИначеЕсли ДокументВыпускБлюд.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.ВыпускПродукцииСПеремещением Тогда
		
		// Если исходный склад является цеховой кладовой, то создаем движение продукции и материалов с операцией "перемещение из кладовой"
		Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументВыпускБлюд, "Склад.ЦеховаяКладовая") Тогда
			
			///////////////////////////////////////////////////////////////////////////////////////
			// ФОРМИРОВАНИЕ ДОКУМЕНТА "ДВИЖЕНИЕ ПРОДУКЦИИ И МАТЕРИАЛОВ" ДЛЯ ВЫПУСКА С ПЕРЕМЕЩЕНИЕМ
			ВсеОк = СформироватьПеремещениеИзКладовойПоВыпускуБлюд(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
			
		Иначе
			
			///////////////////////////////////////////////////////////////////////////////////////
			// ФОРМИРОВАНИЕ ДОКУМЕНТА "ПЕРЕМЕЩЕНИЕ ТОВАРОВ" ДЛЯ ВЫПУСКА С РОЗНИЧНОЙ РЕАЛИЗАЦИЕЙ
			ВсеОк = СформироватьПеремещениеТоваровПоВыпускуБлюд(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
			
		КонецЕсли;
		
	ИначеЕсли ДокументВыпускБлюд.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.ВыпускПродукцииСоСписанием Тогда
		
		///////////////////////////////////////////////////////////////////////////////////////
		// ФОРМИРОВАНИЕ ДОКУМЕНТА "СПИСАНИЕ НЕДОСТАЧ ТОВАРОВ" ДЛЯ ВЫПУСКА СО СПИСАНИЕМ
		ВсеОк = СформироватьВнутреннееПотреблениеТоваровПоВыпускуБлюд(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
						
	ИначеЕсли ДокументВыпускБлюд.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.ВыпускПродукции Тогда
	КонецЕсли;
	
	///////////////////////////////////////////////////////////
	// Отложенное формирование типовых документов
	
	ФормироватьОтложенноОприходованияИзлишков = Ложь;
	Если СтруктураПараметров.Свойство("ОтложитьФормированиеОприходованияИзлишков", ФормироватьОтложенноОприходованияИзлишков) 
		И ФормироватьОтложенноОприходованияИзлишков Тогда
		
		///////////////////////////////////////////////////
		// ФОРМИРОВАНИЕ ОПРИХОДОВАНИЯ ИЗЛИШКОВ
		ВсеОк = СформироватьОприходованиеИзлишковПоВыпускуБлюд(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки, Истина);
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
		
	КонецЕсли;
	
	//22
	Если ФормироватьДокументыПроизводства22 Тогда
		
		ФормироватьОтложенноДвижениеПродукцииИзРазрешенныхКладовых = Ложь;
		Если СтруктураПараметров.Свойство("ОтложитьФормированиеДвиженияПродукцииИзРазрешенныхКладовых", ФормироватьОтложенноДвижениеПродукцииИзРазрешенныхКладовых) 
			И ФормироватьОтложенноДвижениеПродукцииИзРазрешенныхКладовых Тогда
			
			///////////////////////////////////////////////////
			// ФОРМИРОВАНИЕ ОПРИХОДОВАНИЯ ИЗЛИШКОВ
			ВсеОк = СформироватьДвижениеПродукцииИзРазрешенныхКладовыхПоВыпускуБлюд22(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки, Истина);
			Если НЕ ВсеОк Тогда 
				Возврат ВсеОк;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	//>>Швецов. 10.01.2025. Розничные продажи алкоголя
	///////////////////////////////////////////////////
	// ФОРМИРОВАНИЕ ОПРИХОДОВАНИЯ ИЗЛИШКОВ
	//ВсеОк = СформироватьКорректировкуОстатковИСПоВыпускуБлюд(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
	//Если НЕ ВсеОк Тогда 
	//	Возврат ВсеОк;
	//КонецЕсли;
	//<<Швецов. 10.01.2025. Розничные продажи алкоголя
	
	//>>Швецов. 29.05.2025 Создаем корректировку остатка вскрытого алкоголя по ингридиентам в производстве
	СоздатьДокументАктСписанияЕГАИС(ДокументВыпускБлюд,СтруктураПараметров, тблСозданныеДокументы);
	ВсеОк = MRS_СформироватьКорректировкуОстатковИСПоПроизводству(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
	Если НЕ ВсеОк Тогда 
		Возврат ВсеОк;
	КонецЕсли;	
	//<<Швецов
	Возврат ВсеОк;
	
КонецФункции

Функция СформироватьВыпускПродукцииПоВыпускуБлюд(Знач ДокументВыпускБлюд, Знач СтруктураПараметров, Знач тблСозданныеДокументы, ТекстОшибки)
	
	// Получение документов-объектов "Выпуск продукции" с направлением "На склад" и "В подразделение".
	ДокВыпускПродукцииНаСклад	= Неопределено;
	ДокВыпускПродукцииВПодр		= Неопределено;
