	ПЛ_Номенклатура = ДокументВыпускБлюд.ПЛ_Номенклатура;
	Если ЗначениеЗаполнено(ПЛ_Номенклатура) И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПЛ_Номенклатура, "питПродажаПоСвободнойЦене") Тогда
		ПЛ_Номенклатура = Неопределено;
	КонецЕсли; 
	//>> Портал-Юг, Баринов, 2019.11.28
	
	//>>Швецов.11.02.2025. Розничные продажи алкоголя. 
	//По заборному листу разбиваем серийный алкоголь и все остальное на ОРП и ВН "списание на расходы"
	MRS_ТЧАлкоголь = ПЛ_ВтЗапроса[4].Выбрать();
	MRS_ТЧСерииАлкоголь = ПЛ_ВтЗапроса[5].Выбрать();
	//<<Швецов.11.02.2025. Розничные продажи алкоголя.	
	
	Пока Выборка.Следующий() Цикл
		
		//>>Швецов.11.02.2025. Розничные продажи алкоголя. 
		//По заборному листу разбиваем серийный алкоголь и все остальное на ОРП и ВН "списание на расходы"
		СерийныйАлкоголь = Выборка.Номенклатура.АлкогольнаяПродукция И НЕ Выборка.Номенклатура.АлкогольнаяПродукцияВоВскрытойТаре;
		
		Если СерийныйАлкоголь И MRS_ЗаборныйЛист Тогда
			
