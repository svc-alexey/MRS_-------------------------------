		Запрос.УстановитьПараметр("ПодразделениеРецептуры", ?(питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питПодразделениеПроизводстваПолуфабрикатов") = Перечисления.питПодразделенияПроизводстваПолуфабрикатов.ПодразделениеРецептуры, Истина, Ложь));
		
		ТаблицаДокументов = Новый ТаблицаЗначений;
