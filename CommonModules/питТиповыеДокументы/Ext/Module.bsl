	//ПЛ_ПакетРезультат.Колонки[25].Псевдоним = "ПЛ_КоличествоУпаковокИнгредиента";
	ПЛ_ПакетРезультат.Колонки[ПЛ_ПакетРезультат.Колонки.Количество() - 1].Псевдоним = "ПЛ_КоличествоУпаковокИнгредиента";
	//>> Портал-Юг, Гребенюк, 29.05.2023

	ПЛ_ОператорыПакетРезультат.ВыбираемыеПоля.Добавить("ВЫРАЗИТЬ(СУММА(ВЫБОР
	|			КОГДА НЕ втПроизводство.Автопередел
	|				ТОГДА ПЛ_ВтТовары.Количество
	|			ИНАЧЕ втПроизводство.КоличествоНоменклатуры
	|		КОНЕЦ) КАК ЧИСЛО (15,3))");
	
	//<< Портал-Юг, Гребенюк, 29.05.2023, [Обновление 2.5, изменилось количество пакетов]
	//ПЛ_ПакетРезультат.Колонки[26].Псевдоним = "ПЛ_КоличествоНоменклатуры";
	ПЛ_ПакетРезультат.Колонки[ПЛ_ПакетРезультат.Колонки.Количество() - 1].Псевдоним = "ПЛ_КоличествоНоменклатуры";
	//>> Портал-Юг, Гребенюк, 29.05.2023
	
	ПЛ_ОператорыПакетРезультат.ВыбираемыеПоля.Добавить("ВЫБОР
	|		КОГДА НЕ втПроизводство.Автопередел
	|			ТОГДА ПЛ_ВтТовары.Количество / втПроизводство.КоличествоНоменклатуры * СУММА(втПроизводство.КоличествоИнгредиентаФакт)
	|		ИНАЧЕ втПроизводство.КоличествоИнгредиентаФакт
	|	КОНЕЦ ");
	
	//<< Портал-Юг, Гребенюк, 29.05.2023, [Обновление 2.5, изменилось количество пакетов]	
	//ПЛ_ПакетРезультат.Колонки[27].Псевдоним = "ПЛ_КоличествоИнгредиента";  
	ПЛ_ПакетРезультат.Колонки[ПЛ_ПакетРезультат.Колонки.Количество() - 1].Псевдоним = "ПЛ_КоличествоИнгредиента";
    //>> Портал-Юг, Гребенюк, 29.05.2023
	
	//<< Портал-Юг, Баринов, 2019.08.13 [6.2.9 Изменения правил выгрузки данных для БП]
	//ПЛ_ОператорыПакетРезультат.ВыбираемыеПоля.Добавить("ЕСТЬNULL(ВЫРАЗИТЬ(ПЛ_ВтТовары.ПЛ_ДоговорПЛ_ЗначениеАналитикиПродаж КАК Справочник.ГруппыФинансовогоУчетаНоменклатуры), ЗНАЧЕНИЕ(Справочник.ГруппыФинансовогоУчетаНоменклатуры.ПустаяСсылка))");
	//<< Портал-Юг, Баринов, 2019.10.03 [6.2.10 Отражение производства услуг по СКЛ]
	//ПЛ_ОператорыПакетРезультат.ВыбираемыеПоля.Добавить("ЕСТЬNULL(ВЫРАЗИТЬ(ПЛ_ВтТовары.ПЛ_ДоговорПЛ_ЗначениеАналитикиПродаж КАК Справочник.ГруппыФинансовогоУчетаНоменклатуры), ПЛ_ВтТовары.Номенклатура.ГруппаФинансовогоУчета)");
	ПЛ_ОператорыПакетРезультат.ВыбираемыеПоля.Добавить("ПЛ_ВтТовары.ГруппаФинансовогоУчета");
	//>> Портал-Юг, Баринов, 2019.10.03
	//>> Портал-Юг, Баринов, 2019.08.13
	//<< Портал-Юг, Гребенюк, 29.05.2023, [Обновление 2.5, изменилось количество пакетов]
	//ПЛ_ПакетРезультат.Колонки[28].Псевдоним = "ПЛ_ЗначениеАналитикиПродаж"; 
	ПЛ_ПакетРезультат.Колонки[ПЛ_ПакетРезультат.Колонки.Количество() - 1].Псевдоним = "ПЛ_ЗначениеАналитикиПродаж";
	//>> Портал-Юг, Гребенюк, 29.05.2023
	
	// добавление соединения с таблицей ПЛ_ВтТовары
	ПЛ_ИсточникВтПроизводство = ПЛ_ОператорыПакетРезультат.Источники[0];
	ПЛ_ИсточникВтПроизводство.Соединения.Добавить("ПЛ_ВтТовары", "втПроизводство.Номенклатура = ПЛ_ВтТовары.Номенклатура");
	ПЛ_ИсточникВтПроизводство.Соединения.Добавить("ПЛ_ВтТовары", "втПроизводство.Характеристика = ПЛ_ВтТовары.Характеристика");
	ПЛ_ИсточникВтПроизводство.Соединения.Добавить("ПЛ_ВтТовары", "втПроизводство.Серия = ПЛ_ВтТовары.Серия");
	ПЛ_ИсточникВтПроизводство.Соединения.Добавить("ПЛ_ВтТовары", "втПроизводство.Назначение = ПЛ_ВтТовары.Назначение");
	ПЛ_ИсточникВтПроизводство.Соединения.Добавить("ПЛ_ВтТовары", "НЕ втПроизводство.Автопередел");
	
	// добавление группировочных полей в итогах
	ПЛ_ИтогГруппаФинУчета = ПЛ_ПакетРезультат.КонтрольныеТочкиИтогов.Добавить("ПЛ_ЗначениеАналитикиПродаж");
	
	// добавление итоговых полей
	ПЛ_ПакетРезультат.ВыраженияИтогов.Добавить("МАКСИМУМ(ПЛ_КоличествоУпаковокНоменклатуры)");
	ПЛ_ПакетРезультат.ВыраженияИтогов.Добавить("МАКСИМУМ(ПЛ_КоличествоНоменклатуры)");
	ПЛ_ПакетРезультат.ВыраженияИтогов.Добавить("МАКСИМУМ(ПЛ_КоличествоИнгредиента)");
	ПЛ_ПакетРезультат.ВыраженияИтогов.Добавить("МАКСИМУМ(ПЛ_КоличествоУпаковокИнгредиента)");
	
	//<< Портал-Юг, Гребенюк, 29.05.2023, [Обновление 2.5, изменилось количество пакетов]
	//ПЛ_ПакетРезультат.Операторы[0].ВыбираемыеПоля.Удалить(15);
	//ПЛ_ПакетРезультат.Операторы[0].ВыбираемыеПоля.Удалить(14);
	ПЛ_ПакетРезультат.Операторы[0].ВыбираемыеПоля.Удалить(16);
	ПЛ_ПакетРезультат.Операторы[0].ВыбираемыеПоля.Удалить(15);
	//>> Портал-Юг, Гребенюк, 29.05.2023
	ПЛ_ПакетРезультат.Операторы[0].ВыбираемыеПоля.Добавить("втПроизводство.КоличествоУпаковокИнгредиентаФакт");
	ПЛ_ПакетРезультат.Операторы[0].ВыбираемыеПоля.Добавить("втПроизводство.КоличествоИнгредиентаФакт");
	//>>Портал-Юг, Давиденко 2019.03.16
	
	Запрос.Текст = ПЛ_СхемаЗапроса.ПолучитьТекстЗапроса();
	//>>Портал-Юг, Давиденко 2019.03.11
	
	Запрос.УстановитьПараметр("Документпит", ДокументВыпускБлюд);
	Запрос.УстановитьПараметр("ПодразделениеПроизводстваПолуфабрикатов", ПодразделениеПроизводстваПолуфабрикатов);
	
	РезультатЗапросаПакет = Запрос.ВыполнитьПакет();
	//<<Портал-Юг, Давиденко 2019.03.16 [6.2.10 Отражение производства услуг по СКЛ]
	// после редактирования запроса пакеты смещены
	
	//РезультатЗапроса								= РезультатЗапросаПакет[3];
	//РезультатЗапросаТиповыеДокументы				= РезультатЗапросаПакет[6];
	//РезультатЗапросаШапкаВыпуска					= РезультатЗапросаПакет[7];
	//РезультатЗапросаДвижениеПродукцииИМатериалов	= РезультатЗапросаПакет[9];
	//РезультатЗапросаТрудозатраты					= РезультатЗапросаПакет[10];
	//РезультатЗапросаПобочныеИзделия					= РезультатЗапросаПакет[11];

	РезультатЗапроса								= РезультатЗапросаПакет[4];
	РезультатЗапросаТиповыеДокументы				= РезультатЗапросаПакет[7];
	РезультатЗапросаШапкаВыпуска					= РезультатЗапросаПакет[8];
	РезультатЗапросаДвижениеПродукцииИМатериалов	= РезультатЗапросаПакет[10];
	РезультатЗапросаТрудозатраты					= РезультатЗапросаПакет[11];
	РезультатЗапросаПобочныеИзделия					= РезультатЗапросаПакет[12];
	//>>Портал-Юг, Давиденко 2019.03.16 	
	
	// Получение данных шапки.
	ШапкаВыпуска = РезультатЗапросаШапкаВыпуска.Выбрать();
	ШапкаВыпуска.Следующий();
	
	// Существующие выпуски без заказа.
	ВыборкаСуществующиеПроизводстваБезЗаказа = РезультатЗапросаТиповыеДокументы.Выбрать();
	
	// Существующие движения продукции и материалов.
	ВыборкаСуществующиеДвиженияПродукцииИМатериалов = РезультатЗапросаДвижениеПродукцииИМатериалов.Выбрать();
	
	//<<Портал-Юг, Давиденко 2019.03.23 [6.2.10 Отражение производства услуг по СКЛ]
	// таблица для расчета отклонения в количестве ингредиентов
	ПЛ_ТЗДляКонтроляКоличества = Новый ТаблицаЗначений;
	
	ПЛ_ТЗДляКонтроляКоличества.Колонки.Добавить("Номенклатура");
	ПЛ_ТЗДляКонтроляКоличества.Колонки.Добавить("Ингредиент");
	ПЛ_ТЗДляКонтроляКоличества.Колонки.Добавить("Количество", Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(15,3, ДопустимыйЗнак.Любой)));
	ПЛ_ТЗДляКонтроляКоличества.Колонки.Добавить("КоличествоУпаковок", Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(15,3, ДопустимыйЗнак.Любой)));
	ПЛ_ТЗДляКонтроляКоличества.Колонки.Добавить("ГруппаФинансовогоУчета");
	ПЛ_ТЗДляКонтроляКоличества.Колонки.Добавить("КоличествоКонтроль", Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(15,3, ДопустимыйЗнак.Любой)));
	ПЛ_ТЗДляКонтроляКоличества.Колонки.Добавить("КоличествоУпаковокКонтроль", Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(15,3, ДопустимыйЗнак.Любой)));
	ПЛ_ТЗДляКонтроляКоличества.Колонки.Добавить("Характеристика");
	ПЛ_ТЗДляКонтроляКоличества.Колонки.Добавить("Серия");
	ПЛ_ТЗДляКонтроляКоличества.Колонки.Добавить("Назначение");
	ПЛ_ТЗДляКонтроляКоличества.Колонки.Добавить("РецептураБлюда");
	ПЛ_ТЗДляКонтроляКоличества.Колонки.Добавить("ХарактеристикаИнгредиента");
	ПЛ_ТЗДляКонтроляКоличества.Колонки.Добавить("СерияИнгредиента");
	//>>Портал-Юг, Давиденко 2019.03.23	
	// Нет производственной части.
	Если НЕ РезультатЗапроса.Пустой() Тогда
		
		ВыборкаПорядок = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		ВыборкаТрудозатраты = РезультатЗапросаТрудозатраты.Выбрать();
		ПоискПоТрудозатратам = Новый Структура("ИдентификаторБлюда");
		
		ВыборкаПобочныеИзделия = РезультатЗапросаПобочныеИзделия.Выбрать();
		ПоискПоПобочнымИзделиям = Новый Структура("ИдентификаторБлюда");
		
		// Структура текущего "Производство без заказа".
		ТекПроизводствоБезЗаказа = Новый Структура("ПроизводствоБезЗаказа,ПометкаУдаления,Проведен");
		
		// Структура текущего "Производство без заказа".
		ТекДвижениеПродукцииИМатериалов = Новый Структура("ДокументСсылка,ПометкаУдаления,Проведен");
		МассивТекДокументовДвижениеПродукции = Новый Массив;
		
		Пока ВыборкаПорядок.Следующий() Цикл 
			// Выборка по полю "Порядок".
			
			Выборка = ВыборкаПорядок.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока Выборка.Следующий() Цикл
				// Выборка по полю "Подразделение производства", для каждого порядка и подразделения свой док. "Производство без заказа".
				
				ТекДокументОбъект = Неопределено;
				
				// Выборка производствам без заказа.
				// Если документ существует, тогда заполняем его данными структуру,
				// иначе - заполняем значениями по умолчанию.
				Если ВыборкаСуществующиеПроизводстваБезЗаказа.Следующий() Тогда
					ЗаполнитьЗначенияСвойств(ТекПроизводствоБезЗаказа,ВыборкаСуществующиеПроизводстваБезЗаказа);
				Иначе
					ТекПроизводствоБезЗаказа.ПроизводствоБезЗаказа = Документы.ПроизводствоБезЗаказа.ПустаяСсылка();
					ТекПроизводствоБезЗаказа.ПометкаУдаления = Ложь;
					ТекПроизводствоБезЗаказа.Проведен = Ложь;
				КонецЕсли;
				
				////////////////////////////
				// Определение режима записи
				ПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокументВыпускБлюд.Проведен,ДокументВыпускБлюд.ПометкаУдаления
				,ТекПроизводствоБезЗаказа.Проведен,ТекПроизводствоБезЗаказа.ПометкаУдаления,СтруктураПараметров);
				ТекРежимЗаписи = ПараметрыЗаписи.РежимЗаписи;
				////////////////////////////
				
				// Если тек списание затрат не было найдено, то создаем новый объект.
				Если ТекПроизводствоБезЗаказа.ПроизводствоБезЗаказа = Документы.ПроизводствоБезЗаказа.ПустаяСсылка() Тогда
					ТекДокументОбъект = Документы.ПроизводствоБезЗаказа.СоздатьДокумент();
				Иначе
					ТекДокументОбъект = ТекПроизводствоБезЗаказа.ПроизводствоБезЗаказа.ПолучитьОбъект();
					
					// Если нужно установить пометку удаления, то перед синхронизацией сделаем это.
					Если ПараметрыЗаписи.НужнаУстановкаПометкиУдаления Тогда
						
						//+ОтложенноеПроведение
						Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
							ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ПолучитьТекущееДействиеПоПометкеУдаленияТиповогоДокумента(ПараметрыЗаписи.ПометкаУдаления), ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
							СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
							Если НЕ ВсеОк Тогда 
								Возврат ВсеОк;
							КонецЕсли;
						Иначе
						//-ОтложенноеПроведение
							
							Попытка
								ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
								Если ЗначениеЗаполнено(ШапкаВыпуска.ДокументОснование) И ТипЗнч(ШапкаВыпуска.ДокументОснование) = Тип("ДокументСсылка.питПланМеню") Тогда
									ТекДокументОбъект.ДополнительныеСвойства.Вставить("питДокументОбщепитРаспределениеЗапасов", ДокументВыпускБлюд);
								КонецЕсли;
								ТекДокументОбъект.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
							Исключение
								ТекстОшибки = ТекстОшибки + "
								|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
								| по документу Общепит """+ДокументВыпускБлюд+"""
								|по причине: <"+ОписаниеОшибки()+">";
								Возврат Ложь;
							КонецПопытки;
							
						КонецЕсли;
						
					КонецЕсли;
					
					// Очистка табличных частей для избежания дублирования информации.
					ТекДокументОбъект.ВыходныеИзделия.Очистить();
					ТекДокументОбъект.МатериалыИРаботы.Очистить();
					ТекДокументОбъект.Трудозатраты.Очистить();
					ТекДокументОбъект.ПобочныеИзделия.Очистить();
					ТекДокументОбъект.ВыходныеИзделияСерии.Очистить();
					ТекДокументОбъект.ПобочныеИзделияСерии.Очистить();
					
				КонецЕсли;
				
				// Заполнение шапки.
				ТекДокументОбъект.Дата					= ШапкаВыпуска.Дата 
				+ ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0)
				- БазовоеСмещениеПроизводстваБезЗаказов;
				ТекДокументОбъект.Организация			= ШапкаВыпуска.Организация;
				ТекДокументОбъект.Подразделение			= Выборка.ПодразделениеПроизводства;
				ТекДокументОбъект.ГруппировкаЗатрат		= Перечисления.ГруппировкиЗатратВПроизводствеБезЗаказа.ПоПродукции;
				ТекДокументОбъект.Ответственный			= ШапкаВыпуска.Ответственный;
				ТекДокументОбъект.Комментарий			= ШапкаВыпуска.Комментарий;
				ТекДокументОбъект.Валюта				= ШапкаВыпуска.Валюта;
				ТекДокументОбъект.НаправлениеДеятельности	= ШапкаВыпуска.НаправлениеДеятельности;
				// Автоопределение значения налогообложения НДС.
				ТекДокументОбъект.ВыпускПодДеятельность	= ?(СтруктураПараметров.Свойство("НалогообложениеНДС"), СтруктураПараметров.НалогообложениеНДС, Неопределено);
				
				//+ДВИЖЕНИЕ ПРОДУКЦИИ И МАТЕРИАЛОВ В ОСНОВНОЙ ЦЕХ
				МассивТекДокументовДвижениеПродукции.Очистить();
				//-ДВИЖЕНИЕ ПРОДУКЦИИ И МАТЕРИАЛОВ В ОСНОВНОЙ ЦЕХ
				
				ТекНомерГруппыЗатрат = 1; // номер, по которому сопоставляются ТЧ "ВыходныеИзделия" и ТЧ "МатериалыИРаботы"в док "Производство без заказа"
				
				ВыборкаПоЦехам = Выборка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаПоЦехам.Следующий() Цикл
					
					
					//+ДВИЖЕНИЕ ПРОДУКЦИИ И МАТЕРИАЛОВ В ОСНОВНОЙ ЦЕХ
					
					ТекДокументОбъектДвижениеПродукцииИМатериалов = Неопределено;
					Если ВыборкаПоЦехам.ЦеховаяКладовая <> ШапкаВыпуска.Склад Тогда
						
						// Выборка по движениям продукции и материалов.
						// Если документ существует, тогда заполняем его данными структуру,
						// иначе - заполняем значениями по умолчанию.
						Если ВыборкаСуществующиеДвиженияПродукцииИМатериалов.Следующий() Тогда
							ЗаполнитьЗначенияСвойств(ТекДвижениеПродукцииИМатериалов,ВыборкаСуществующиеДвиженияПродукцииИМатериалов);
						Иначе
							ТекДвижениеПродукцииИМатериалов.ДокументСсылка = Документы.ДвижениеПродукцииИМатериалов.ПустаяСсылка();
							ТекДвижениеПродукцииИМатериалов.ПометкаУдаления = Ложь;
							ТекДвижениеПродукцииИМатериалов.Проведен = Ложь;
						КонецЕсли;
						
						////////////////////////////
						// Определение режима записи
						ПараметрыЗаписиДвижениеПродукцииИМатериалов = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокументВыпускБлюд.Проведен,ДокументВыпускБлюд.ПометкаУдаления
						,ТекДвижениеПродукцииИМатериалов.Проведен,ТекДвижениеПродукцииИМатериалов.ПометкаУдаления,Новый Структура);
						ТекРежимЗаписиДвижениеПродукцииИМатериалов = ПараметрыЗаписиДвижениеПродукцииИМатериалов.РежимЗаписи;
						////////////////////////////
						
						// Если тек списание затрат не было найдено, то создаем новый объект.
						Если ТекДвижениеПродукцииИМатериалов.ДокументСсылка = Документы.ДвижениеПродукцииИМатериалов.ПустаяСсылка() Тогда
							ТекДокументОбъектДвижениеПродукцииИМатериалов = Документы.ДвижениеПродукцииИМатериалов.СоздатьДокумент();
						Иначе
							ТекДокументОбъектДвижениеПродукцииИМатериалов = ТекДвижениеПродукцииИМатериалов.ДокументСсылка.ПолучитьОбъект();
							
							// Если нужно установить пометку удаления, то перед синхронизацией сделаем это.
							Если ПараметрыЗаписиДвижениеПродукцииИМатериалов.НужнаУстановкаПометкиУдаления Тогда
								
								//+ОтложенноеПроведение
								Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
									ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ПолучитьТекущееДействиеПоПометкеУдаленияТиповогоДокумента(ПараметрыЗаписиДвижениеПродукцииИМатериалов.ПометкаУдаления), ТекДокументОбъектДвижениеПродукцииИМатериалов.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
									СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
									Если НЕ ВсеОк Тогда 
										Возврат ВсеОк;
									КонецЕсли;
								Иначе
								//-ОтложенноеПроведение
									
									Попытка
										ТекДокументОбъектДвижениеПродукцииИМатериалов.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
										ТекДокументОбъектДвижениеПродукцииИМатериалов.УстановитьПометкуУдаления(ПараметрыЗаписиДвижениеПродукцииИМатериалов.ПометкаУдаления);
									Исключение
										ТекстОшибки = ТекстОшибки + "
										|Ошибка при установке пометки удаления """ + ТекДокументОбъектДвижениеПродукцииИМатериалов.Метаданные().Представление() + """
										| по документу Общепит """+ДокументВыпускБлюд+"""
										|по причине: <"+ОписаниеОшибки()+">";
										Возврат Ложь;
									КонецПопытки;
									
								КонецЕсли;
								
							КонецЕсли;
							
							// Очистка табличных частей для избежания дублирования информации.
							ТекДокументОбъектДвижениеПродукцииИМатериалов.Товары.Очистить();
							ТекДокументОбъектДвижениеПродукцииИМатериалов.Серии.Очистить();
							ТекДокументОбъектДвижениеПродукцииИМатериалов.ВидыЗапасов.Очистить();
							ТекДокументОбъектДвижениеПродукцииИМатериалов.ДополнительныеРеквизиты.Очистить();
							
						КонецЕсли;
						
						// Заполнение шапки.
						ТекДокументОбъектДвижениеПродукцииИМатериалов.Дата					= ШапкаВыпуска.Дата 
						+ ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0)
						- БазовоеСмещениеДвиженияПродукцииИМатериалов;
						ТекДокументОбъектДвижениеПродукцииИМатериалов.Организация			= ШапкаВыпуска.Организация;
						ТекДокументОбъектДвижениеПродукцииИМатериалов.Отправитель			= ВыборкаПоЦехам.ЦеховаяКладовая;
						ТекДокументОбъектДвижениеПродукцииИМатериалов.Получатель			= ШапкаВыпуска.Склад;
						ТекДокументОбъектДвижениеПродукцииИМатериалов.Ответственный			= ШапкаВыпуска.Ответственный;
						ТекДокументОбъектДвижениеПродукцииИМатериалов.Комментарий			= ШапкаВыпуска.Комментарий;
						ТекДокументОбъектДвижениеПродукцииИМатериалов.ХозяйственнаяОперация	= Перечисления.ХозяйственныеОперации.ПередачаПродукцииИзКладовой;
						ТекДокументОбъектДвижениеПродукцииИМатериалов.Статус				= Перечисления.СтатусыДвиженияПродукцииИМатериалов.Принято;
						ПараметрыУчетаПоОрганизации = УчетНДСУП.ПараметрыУчетаПоОрганизации(ТекДокументОбъектДвижениеПродукцииИМатериалов.Организация, 
							ТекДокументОбъектДвижениеПродукцииИМатериалов.Дата,
							ТекДокументОбъектДвижениеПродукцииИМатериалов.Отправитель);
						ТекДокументОбъектДвижениеПродукцииИМатериалов.НаправлениеДеятельности = ШапкаВыпуска.НаправлениеДеятельности;
						// Автоопределение значения налогообложения НДС.
						ТекДокументОбъектДвижениеПродукцииИМатериалов.НалогообложениеНДС	= ?(СтруктураПараметров.Свойство("НалогообложениеНДС"), СтруктураПараметров.НалогообложениеНДС, Неопределено);
						//+25
						ТекДокументОбъектДвижениеПродукцииИМатериалов.Валюта				= ?(ЗначениеЗаполнено(ШапкаВыпуска.Валюта), ШапкаВыпуска.Валюта, Константы.ВалютаРегламентированногоУчета.Получить());
						ТекДокументОбъектДвижениеПродукцииИМатериалов.ВариантПриемкиТоваров	= Перечисления.ВариантыПриемкиТоваров.РазделенаТолькоПоНакладным;
						//-25
					КонецЕсли;
					
					//-ДВИЖЕНИЕ ПРОДУКЦИИ И МАТЕРИАЛОВ В ОСНОВНОЙ ЦЕХ
					
					ВыборкаБлюдаБезХарактеристик = ВыборкаПоЦехам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					
					Пока ВыборкаБлюдаБезХарактеристик.Следующий() Цикл
					ВыборкаБлюдаБезУпаковок = ВыборкаБлюдаБезХарактеристик.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					Пока ВыборкаБлюдаБезУпаковок.Следующий() Цикл
					ВыборкаБлюда = ВыборкаБлюдаБезУпаковок.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					Пока ВыборкаБлюда.Следующий() Цикл
						
						// Выборка по полю "Номенклатура", заполняются выходные изделия(Блюда).
						
						Если ВыборкаБлюда.КоличествоНоменклатуры = 0 Тогда
							// Возможно меняли количество в режиме по факту и получилась нулевая строка, не добавляем.
							Продолжить;
						КонецЕсли;
						
						
						//+ДВИЖЕНИЕ ПРОДУКЦИИ И МАТЕРИАЛОВ В ОСНОВНОЙ ЦЕХ
						Если НЕ ТекДокументОбъектДвижениеПродукцииИМатериалов = Неопределено Тогда
							НовСтрокаДвижениеПродукцииИМатериалов = ТекДокументОбъектДвижениеПродукцииИМатериалов.Товары.Добавить();
							НовСтрокаДвижениеПродукцииИМатериалов.Номенклатура				= ВыборкаБлюда.Номенклатура;
							НовСтрокаДвижениеПродукцииИМатериалов.Характеристика			= ВыборкаБлюда.Характеристика;
							НовСтрокаДвижениеПродукцииИМатериалов.Серия						= ВыборкаБлюда.Серия;
							НовСтрокаДвижениеПродукцииИМатериалов.Назначение				= ВыборкаБлюда.Назначение;
							НовСтрокаДвижениеПродукцииИМатериалов.НазначениеОтправителя		= ВыборкаБлюда.Назначение;
							НовСтрокаДвижениеПродукцииИМатериалов.КоличествоУпаковок		= ВыборкаБлюда.КоличествоУпаковокНоменклатуры;
							НовСтрокаДвижениеПродукцииИМатериалов.Количество				= ВыборкаБлюда.КоличествоНоменклатуры;
							НовСтрокаДвижениеПродукцииИМатериалов.Упаковка					= ВыборкаБлюда.УпаковкаНоменклатуры;
							НовСтрокаДвижениеПродукцииИМатериалов.ИдентификаторСтроки		= Новый УникальныйИдентификатор;
							НовСтрокаДвижениеПродукцииИМатериалов.ГруппаПродукции			= ВыборкаБлюда.ГруппаАналитическогоУчета;
							
							Если НЕ ЗначениеЗаполнено(ВыборкаПоЦехам.ЦеховаяКладовая) Тогда
								ТекстОшибки = ТекстОшибки + "
								| Не удалось определить цеховую кладовую производства полуфабриката <"+ВыборкаБлюда.Номенклатура+"> по рецептуре <"+ВыборкаБлюда.РецептураБлюда+">!
								| Необходимо заполнить реквизит ""Цеховая кладовая"" в вышеуказанной рецептуре!";
								Возврат Ложь;
							КонецЕсли;
							
						КонецЕсли;
						//-ДВИЖЕНИЕ ПРОДУКЦИИ И МАТЕРИАЛОВ В ОСНОВНОЙ ЦЕХ
						
						//<<Портал-Юг, Давиденко 2019.03.15 [6.2.10 Отражение производства услуг по СКЛ]
							// сохранение выборки для верхнего уровня цикла
							ПЛ_ВыборкаБлюда = ВыборкаБлюда;
							
							ВыборкаБлюда = ВыборкаБлюда.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
							Пока ВыборкаБлюда.Следующий() Цикл
						//>>Портал-Юг, Давиденко 2019.03.15
							
						// Заполнение табличной части "Выходные изделия".
						НовСтрокаТЧ							= ТекДокументОбъект.ВыходныеИзделия.Добавить();
						НовСтрокаТЧ.НаправлениеВыпуска		= Перечисления.ХозяйственныеОперации.ВыпускПродукцииНаСклад;
						НовСтрокаТЧ.Получатель				= ВыборкаБлюда.ЦеховаяКладовая; // получатель - кладовая цеха подразделения из шапки(берется либо из рецептуры либо из выпуска в запросе выше).
						//<<Портал-Юг, Давиденко 2019.03.11 [4.2.11 Использование услуг и работ в документе «Выпуск блюд»]
							Если ВыборкаБлюда.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Работа Тогда
								НовСтрокаТЧ.НаправлениеВыпуска	= ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ВыпускПродукцииВПодразделение");
								НовСтрокаТЧ.Получатель 			= ВыборкаБлюда.ПодразделениеПроизводства;
							КонецЕсли;
							//>>Портал-Юг, Давиденко 2019.03.11
						НовСтрокаТЧ.Номенклатура			= ВыборкаБлюда.Номенклатура;
						НовСтрокаТЧ.Характеристика			= ВыборкаБлюда.Характеристика;
						НовСтрокаТЧ.Серия					= ВыборкаБлюда.Серия;
						НовСтрокаТЧ.Назначение				= ВыборкаБлюда.Назначение;
						НовСтрокаТЧ.КоличествоУпаковок		= ВыборкаБлюда.КоличествоУпаковокНоменклатуры;
						НовСтрокаТЧ.Количество				= ВыборкаБлюда.КоличествоНоменклатуры;
						//<<Портал-Юг, Давиденко 2019.03.15 [6.2.10 Отражение производства услуг по СКЛ]
						НовСтрокаТЧ.КоличествоУпаковок		= ВыборкаБлюда.ПЛ_КоличествоУпаковокНоменклатуры;
						НовСтрокаТЧ.Количество				= ВыборкаБлюда.ПЛ_КоличествоНоменклатуры;
						//>>Портал-Юг, Давиденко 2019.03.15
						НовСтрокаТЧ.Упаковка				= ВыборкаБлюда.УпаковкаНоменклатуры;
						НовСтрокаТЧ.ИдентификаторСтроки		= Новый УникальныйИдентификатор;
						НовСтрокаТЧ.НомерГруппыЗатрат		= ТекНомерГруппыЗатрат;
						НовСтрокаТЧ.Подразделение			= ВыборкаБлюда.ПодразделениеПроизводства;
						
						//<<Портал-Юг, Давиденко 2019.03.15 [6.2.10 Отражение производства услуг по СКЛ]
						НовСтрокаТЧ.ПЛ_ГруппаФинансовогоУчетаНоменклатуры			= ВыборкаБлюда.ПЛ_ЗначениеАналитикиПродаж;
						//>>Портал-Юг, Давиденко 2019.03.15
							
						//ВидЗапасов
						
						ВыборкаДетальная = ВыборкаБлюда.Выбрать();
						Пока ВыборкаДетальная.Следующий() Цикл
							// Детальная выборка, заполнение ТЧ "МатериалыИРаботы".
							
							Если ВыборкаДетальная.КоличествоИнгредиентаФакт < 0.001 Тогда
								// Ситуация, когда затраченного ингредиента оказалось менее 0,001.
								// Такая строка в ТЧ не добавляется.
								Продолжить;
							КонецЕсли;
							
							Если ВыборкаДетальная.питВидНоменклатурыИнгредиента = Перечисления.питВидыНоменклатуры.ТехнологическийИнгредиент Тогда
								// Технологические ингредиенты в производство не добавляем.
								Продолжить;
							КонецЕсли;
							
							НовСтрокаТЧ						= ТекДокументОбъект.МатериалыИРаботы.Добавить();
							НовСтрокаТЧ.Склад				= ШапкаВыпуска.Склад;			// Отправитель всегда склад из шапки выпуска, потому что мы именно его обеспечиваем.
							НовСтрокаТЧ.Подразделение		= ШапкаВыпуска.Подразделение;	// Отправитель всегда подразделение из шапки выпуска, потому что мы именно его обеспечиваем.
							НовСтрокаТЧ.Номенклатура		= ВыборкаДетальная.Ингредиент;
							НовСтрокаТЧ.Характеристика		= ВыборкаДетальная.ХарактеристикаИнгредиента;
							НовСтрокаТЧ.Назначение			= ВыборкаДетальная.НазначениеИнгредиента;
							//НовСтрокаТЧ.Серия				= ВыборкаДетальная.СерияИнгредиента;
							НовСтрокаТЧ.КоличествоУпаковок	= ВыборкаДетальная.КоличествоУпаковокИнгредиентаФакт;
							НовСтрокаТЧ.Количество			= ВыборкаДетальная.КоличествоИнгредиентаФакт;
							//<<Портал-Юг, Давиденко 2019.03.15 [6.2.10 Отражение производства услуг по СКЛ]   
							НовСтрокаТЧ.КоличествоУпаковок	= ВыборкаДетальная.ПЛ_КоличествоУпаковокИнгредиента;
							НовСтрокаТЧ.Количество			= ВыборкаДетальная.ПЛ_КоличествоИнгредиента;
							//>>Портал-Юг, Давиденко 2019.03.15
							НовСтрокаТЧ.Упаковка			= ВыборкаДетальная.УпаковкаИнгредиента;
							НовСтрокаТЧ.СтатьяКалькуляции	= ?(ЗначениеЗаполнено(ВыборкаДетальная.СтатьяКалькуляции), ВыборкаДетальная.СтатьяКалькуляции,ШапкаВыпуска.СтатьяКалькуляции);
							НовСтрокаТЧ.НомерГруппыЗатрат	= ТекНомерГруппыЗатрат;
							//+25
							НовСтрокаТЧ.ИдентификаторСтроки	= Новый УникальныйИдентификатор;
							//-25
							//<<Портал-Юг, Давиденко 2019.03.24 [6.2.10 Отражение производства услуг по СКЛ]
								// наполнение таблицы всеми ингредиентами 
								ПЛ_НоваяСтрокаТЗ = ПЛ_ТЗДляКонтроляКоличества.Добавить();
								ЗаполнитьЗначенияСвойств(ПЛ_НоваяСтрокаТЗ, ВыборкаДетальная);
								
								ПЛ_НоваяСтрокаТЗ.ГруппаФинансовогоУчета = ВыборкаДетальная.ПЛ_ЗначениеАналитикиПродаж;
								ПЛ_НоваяСтрокаТЗ.Серия = ВыборкаДетальная.Серия;
								ПЛ_НоваяСтрокаТЗ.Количество = ВыборкаДетальная.КоличествоИнгредиентаФакт;
								ПЛ_НоваяСтрокаТЗ.КоличествоУпаковок = ВыборкаДетальная.КоличествоУпаковокИнгредиентаФакт;
								ПЛ_НоваяСтрокаТЗ.КоличествоКонтроль = ВыборкаДетальная.ПЛ_КоличествоИнгредиента;
								ПЛ_НоваяСтрокаТЗ.КоличествоУпаковокКонтроль = ВыборкаДетальная.ПЛ_КоличествоУпаковокИнгредиента;
								//>>Портал-Юг, Давиденко 2019.03.24							
						КонецЦикла;
						
						// ТРУДОЗАТРАТЫ
						ПоискПоТрудозатратам.ИдентификаторБлюда = ВыборкаБлюда.ИдентификаторСтроки;
						Пока ВыборкаТрудозатраты.НайтиСледующий(ПоискПоТрудозатратам) Цикл
							
							ТекДокументОбъект.РаспоряжениеДляТрудозатрат = ЗначениеЗаполнено(ШапкаВыпуска.ИсполнительТрудозатрат);
							
							// Заполнение ТЧ "Трудозатраты".
							НовСтрокаТЧ						= ТекДокументОбъект.Трудозатраты.Добавить();
							НовСтрокаТЧ.Подразделение		= ВыборкаТрудозатраты.Подразделение;
							НовСтрокаТЧ.ВидРабот			= ВыборкаТрудозатраты.ВидРабот;
							НовСтрокаТЧ.Количество			= ВыборкаТрудозатраты.Количество;
							НовСтрокаТЧ.СтатьяКалькуляции	= ВыборкаТрудозатраты.СтатьяКалькуляции;
							НовСтрокаТЧ.НомерГруппыЗатрат	= ТекНомерГруппыЗатрат;
							НовСтрокаТЧ.Исполнитель			= ШапкаВыпуска.ИсполнительТрудозатрат;
							
						КонецЦикла;
						ВыборкаТрудозатраты.Сбросить();
						
						// Побочные изделия
						ПоискПоПобочнымИзделиям.ИдентификаторБлюда = ВыборкаБлюда.ИдентификаторСтроки;
						Пока ВыборкаПобочныеИзделия.НайтиСледующий(ПоискПоПобочнымИзделиям) Цикл
							
							// Заполнение ТЧ "Трудозатраты".
							НовСтрокаТЧ						= ТекДокументОбъект.ПобочныеИзделия.Добавить();
							ЗаполнитьЗначенияСвойств(НовСтрокаТЧ, ВыборкаПобочныеИзделия);
							НовСтрокаТЧ.НомерГруппыЗатрат	= ТекНомерГруппыЗатрат;
							НовСтрокаТЧ.НаправлениеВыпуска = Перечисления.ХозяйственныеОперации.ВыпускПродукцииНаСклад;
							НовСтрокаТЧ.ПодразделениеПолучатель = ВыборкаПобочныеИзделия.Подразделение;
							//+25
							НовСтрокаТЧ.ИдентификаторСтроки	= Новый УникальныйИдентификатор;
							//-25
							
						КонецЦикла;
						ВыборкаПобочныеИзделия.Сбросить();
						
						ТекНомерГруппыЗатрат = ТекНомерГруппыЗатрат + 1;
						
						//<<Портал-Юг, Давиденко 2019.03.15 [6.2.10 Отражение производства услуг по СКЛ]
						КонецЦикла;
						ВыборкаБлюда = ПЛ_ВыборкаБлюда;
						//>>Портал-Юг, Давиденко 2019.03.15
						
					КонецЦикла;
					КонецЦикла;
					КонецЦикла;
					
					//+ДВИЖЕНИЕ ПРОДУКЦИИ И МАТЕРИАЛОВ В ОСНОВНОЙ ЦЕХ
					Если НЕ ТекДокументОбъектДвижениеПродукцииИМатериалов = Неопределено Тогда
						МассивТекДокументовДвижениеПродукции.Добавить(Новый Структура("ТекДокументОбъектДвижениеПродукцииИМатериалов,ТекРежимЗаписиДвижениеПродукцииИМатериалов"
						,ТекДокументОбъектДвижениеПродукцииИМатериалов,ТекРежимЗаписиДвижениеПродукцииИМатериалов));
					КонецЕсли;
					//-ДВИЖЕНИЕ ПРОДУКЦИИ И МАТЕРИАЛОВ В ОСНОВНОЙ ЦЕХ
					
				КонецЦикла;
				
				Если НЕ ТекДокументОбъект = Неопределено Тогда
					
					//<<Портал-Юг, Давиденко 2019.03.24 [6.2.10 Отражение производства услуг по СКЛ]
				ПЛ_ТЗСАналитикой = ПЛ_ТЗДляКонтроляКоличества.Скопировать();
				Если НЕ ТекДокументОбъект = Неопределено Тогда
					// сохраним ТЗ отдельно для поиска аналитики по полной таблице
					
					ПЛ_ТЗДляКонтроляКоличества.Свернуть("Номенклатура, Характеристика, Серия, Назначение, Ингредиент, РецептураБлюда, ХарактеристикаИнгредиента, СерияИнгредиента, Количество, КоличествоУпаковок", "КоличествоКонтроль, КоличествоУпаковокКонтроль"); 
					
					ПЛ_СтруктураПоиска = Новый Структура;
					
					Для Каждого ПЛ_СтрокаТЗ Из ПЛ_ТЗДляКонтроляКоличества Цикл
						
						Если ПЛ_СтрокаТЗ.Количество - ПЛ_СтрокаТЗ.КоличествоКонтроль = 0
							И ПЛ_СтрокаТЗ.КоличествоУпаковок - ПЛ_СтрокаТЗ.КоличествоУпаковокКонтроль = 0 Тогда
							Продолжить;
						КонецЕсли;
						
						ПЛ_СтруктураПоиска.Вставить("Номенклатура", ПЛ_СтрокаТЗ.Номенклатура);
						ПЛ_СтруктураПоиска.Вставить("Ингредиент", ПЛ_СтрокаТЗ.Ингредиент);
						ПЛ_СтруктураПоиска.Вставить("Характеристика", ПЛ_СтрокаТЗ.Характеристика);
						ПЛ_СтруктураПоиска.Вставить("Серия", ПЛ_СтрокаТЗ.Серия);
						ПЛ_СтруктураПоиска.Вставить("Назначение", ПЛ_СтрокаТЗ.Назначение);
						ПЛ_СтруктураПоиска.Вставить("РецептураБлюда", ПЛ_СтрокаТЗ.РецептураБлюда);
						ПЛ_СтруктураПоиска.Вставить("ХарактеристикаИнгредиента", ПЛ_СтрокаТЗ.ХарактеристикаИнгредиента);
						ПЛ_СтруктураПоиска.Вставить("СерияИнгредиента", ПЛ_СтрокаТЗ.СерияИнгредиента);
						
						// поиск аналитики по ключам из таблицы с отклонением количества
						ПЛ_СтрокиСАналитикой = ПЛ_ТЗСАналитикой.НайтиСтроки(ПЛ_СтруктураПоиска);
						
						Если ПЛ_СтрокиСАналитикой.Количество() > 0 Тогда
							ПЛ_СтруктураПоиска.Вставить("ПЛ_ГруппаФинансовогоУчетаНоменклатуры", ПЛ_СтрокиСАналитикой[0].ГруппаФинансовогоУчета);
						КонецЕсли;
						
						ПЛ_СтруктураПоиска.Номенклатура = ПЛ_СтруктураПоиска.Ингредиент;
						ПЛ_СтруктураПоиска.Удалить("Ингредиент");
						ПЛ_СтруктураПоиска.Удалить("РецептураБлюда");
						ПЛ_СтруктураПоиска.Удалить("ХарактеристикаИнгредиента");
						ПЛ_СтруктураПоиска.Удалить("СерияИнгредиента");
						// поиск в документе строки, которую необходимо скорректировать
						ПЛ_СтрокиДляКорректировки = ТекДокументОбъект.МатериалыИРаботы.НайтиСтроки(ПЛ_СтруктураПоиска);
						
						// корректируем количество в документе на разницу между итоговым количеством ингридиента по блюду и количеством после деления по аналитикам
						Если ПЛ_СтрокиДляКорректировки.Количество() > 0 Тогда
							ПЛ_СтрокиДляКорректировки[0].Количество = ПЛ_СтрокиДляКорректировки[0].Количество + ПЛ_СтрокаТЗ.Количество - ПЛ_СтрокаТЗ.КоличествоКонтроль;
							ПЛ_СтрокиДляКорректировки[0].КоличествоУпаковок = ПЛ_СтрокиДляКорректировки[0].КоличествоУпаковок + ПЛ_СтрокаТЗ.КоличествоУпаковок - ПЛ_СтрокаТЗ.КоличествоУпаковокКонтроль;
						КонецЕсли;
						ПЛ_СтруктураПоиска.Очистить();
					КонецЦикла;
				КонецЕсли;
				ПЛ_ТЗСАналитикой.Очистить();
				
				ПЛ_ТЗДляКонтроляКоличества.Очистить();
				ПЛ_ТЗДляКонтроляКоличества = ПЛ_ТЗСАналитикой.Скопировать();
				//>>Портал-Юг, Давиденко 2019.03.24
				
					//+Серии
					Если ТекРежимЗаписи <> РежимЗаписиДокумента.ОтменаПроведения И НЕ СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
						ЗаполнитьСерииТиповогоДокумента(ТекДокументОбъект, ДокументВыпускБлюд , тблСозданныеДокументы);
					КонецЕсли;
					//-Серии
					
					//+ОтложенноеПроведение
					Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
						ИсходныйРежимЗаписи	= ТекРежимЗаписи;
						ТекРежимЗаписи		= РежимЗаписиДокумента.Запись;
					КонецЕсли;
					//-ОтложенноеПроведение
					
					// Запись заполненного документа "Производство без заказа".
					Попытка
						Если НЕ ТекРежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения // Отмена проведения произошла ранее
							И НЕ (ТекДокументОбъект.ЭтоНовый() И НЕ ТекДокументОбъект.ВыходныеИзделия.Количество()) Тогда // Пустой новый документ не записываем.
							ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
							Если ЗначениеЗаполнено(ШапкаВыпуска.ДокументОснование) И ТипЗнч(ШапкаВыпуска.ДокументОснование) = Тип("ДокументСсылка.питПланМеню") Тогда
								ТекДокументОбъект.ДополнительныеСвойства.Вставить("питДокументОбщепитРаспределениеЗапасов", ДокументВыпускБлюд);
							КонецЕсли;
							ТекДокументОбъект.Записать(ТекРежимЗаписи);
						КонецЕсли;
					Исключение
						ТекстОшибки = ТекстОшибки + "
						|Ошибка записи документа """ + ТекДокументОбъект.Метаданные().Представление() + """
						| по документу Общепит """+ДокументВыпускБлюд+"""
						|по причине: <"+ОписаниеОшибки()+">";
						Возврат Ложь;
					КонецПопытки;
					
					//+ОтложенноеПроведение
					Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
						ТекДействие = ПолучитьТекущееДействиеПоРежимузаписиТиповогоДокумента(ИсходныйРежимЗаписи);
						ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ТекДействие, ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
						СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
						Если НЕ ВсеОк Тогда 
							Возврат ВсеОк;
						КонецЕсли;
						ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.УстановитьСинхронизациюТиповогоДокумента, ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
						СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
						Если НЕ ВсеОк Тогда 
							Возврат ВсеОк;
						КонецЕсли;
					КонецЕсли;
					//-ОтложенноеПроведение
					
				КонецЕсли;
				
				//+ОтложенноеПроведение
				ТекСинхронизирован = ?(СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд, Ложь, Истина);
				//-ОтложенноеПроведение
				
				// Добавление записи в результирующую таблицу в случае успешной записи документов.
				ДобавитьНовуюЗапись(ДокументВыпускБлюд, ТекДокументОбъект, тблСозданныеДокументы,,ТекСинхронизирован);
				
				//+ДВИЖЕНИЕ ПРОДУКЦИИ И МАТЕРИАЛОВ В ОСНОВНОЙ ЦЕХ
				
				Для каждого ТекДокументДвижениеПродукции Из МассивТекДокументовДвижениеПродукции Цикл
					
					ТекДокДвижениеПродукции = ТекДокументДвижениеПродукции.ТекДокументОбъектДвижениеПродукцииИМатериалов;
					ТекРежимЗаписиДвижениеПродукции = ТекДокументДвижениеПродукции.ТекРежимЗаписиДвижениеПродукцииИМатериалов;
					
					Если НЕ ТекДокДвижениеПродукции = Неопределено Тогда
						//И Не ПустаяСтрока(ТекДокДвижениеПродукции.ВерсияДанных)
						
						//+Серии
						Если НЕ СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
							ЗаполнитьСерииТиповогоДокумента(ТекДокДвижениеПродукции, ДокументВыпускБлюд, 0);
						КонецЕсли;
						//-Серии
						
						//+ОтложенноеПроведение
						Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
							ИсходныйРежимЗаписиДвижениеПродукции	= ТекРежимЗаписиДвижениеПродукции;
							ТекРежимЗаписиДвижениеПродукции			= РежимЗаписиДокумента.Запись;
						КонецЕсли;
						//-ОтложенноеПроведение
						
						Попытка
							ТекДокДвижениеПродукции.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
							ТекДокДвижениеПродукции.Записать(ТекРежимЗаписиДвижениеПродукции);
						Исключение
							ТекстОшибки = ТекстОшибки + "
							|Ошибка записи документа """ + ТекДокДвижениеПродукции.Метаданные().Представление() + """
							| по документу Общепит """+ДокументВыпускБлюд+"""
							|по причине: <"+ОписаниеОшибки()+">";
							Возврат Ложь;
						КонецПопытки;
						
						//+ОтложенноеПроведение
						Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
							ТекДействие = ПолучитьТекущееДействиеПоРежимузаписиТиповогоДокумента(ИсходныйРежимЗаписиДвижениеПродукции);
							ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ТекДействие, ТекДокДвижениеПродукции.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
							СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
							Если НЕ ВсеОк Тогда 
								Возврат ВсеОк;
							КонецЕсли;
							ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.УстановитьСинхронизациюТиповогоДокумента, ТекДокДвижениеПродукции.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
							СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
							Если НЕ ВсеОк Тогда 
								Возврат ВсеОк;
							КонецЕсли;
						КонецЕсли;
						//-ОтложенноеПроведение
						
					КонецЕсли;
					
					//+ОтложенноеПроведение
					ТекСинхронизирован = ?(СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд, Ложь, Истина);
					//-ОтложенноеПроведение
					
					// Добавление записи в результирующую таблицу в случае успешной записи документов.
					ДобавитьНовуюЗапись(ДокументВыпускБлюд, ТекДокДвижениеПродукции, тблСозданныеДокументы,,ТекСинхронизирован);
					
				КонецЦикла;
				
				//-ДВИЖЕНИЕ ПРОДУКЦИИ И МАТЕРИАЛОВ В ОСНОВНОЙ ЦЕХ
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЕсли; // Если НЕ РезультатЗапроса.Пустой() Тогда
	
	// "Обнуление" переменной текущего объекта.
	ТекДокументОбъект = Неопределено;
	
	// Если остались лишние типовые документы, то нужно пометить их на удаление.
	Пока ВыборкаСуществующиеПроизводстваБезЗаказа.Следующий() Цикл
		
		ТекДокументОбъект = ВыборкаСуществующиеПроизводстваБезЗаказа.ПроизводствоБезЗаказа.ПолучитьОбъект();
		
		//+ОтложенноеПроведение
		Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
			ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ПолучитьТекущееДействиеПоПометкеУдаленияТиповогоДокумента(Истина), ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
			СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
			Если НЕ ВсеОк Тогда 
				Возврат ВсеОк;
			КонецЕсли;
			ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.УстановитьСинхронизациюТиповогоДокумента, ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
			СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
			Если НЕ ВсеОк Тогда 
				Возврат ВсеОк;
			КонецЕсли;
		Иначе
		//-ОтложенноеПроведение
			
			Если НЕ ВыборкаСуществующиеПроизводстваБезЗаказа.ПометкаУдаления Тогда
				Попытка
					ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
					Если ЗначениеЗаполнено(ШапкаВыпуска.ДокументОснование) И ТипЗнч(ШапкаВыпуска.ДокументОснование) = Тип("ДокументСсылка.питПланМеню") Тогда
						ТекДокументОбъект.ДополнительныеСвойства.Вставить("питДокументОбщепитРаспределениеЗапасов", ДокументВыпускБлюд);
					КонецЕсли;
					ТекДокументОбъект.УстановитьПометкуУдаления(Истина);
				Исключение
					ТекстОшибки = ТекстОшибки + "
					|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
					| по документу Общепит """+ДокументВыпускБлюд+"""
					|по причине: <"+ОписаниеОшибки()+">";
					Возврат Ложь;
				КонецПопытки;
			КонецЕсли;
			
		КонецЕсли;
		
		//+ОтложенноеПроведение
		ТекСинхронизирован = ?(СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд, Ложь, Истина);
		//-ОтложенноеПроведение
		
		// Добавление записи в результирующую таблицу.
		ДобавитьНовуюЗапись(ДокументВыпускБлюд, ТекДокументОбъект, тблСозданныеДокументы,,ТекСинхронизирован);
		
	КонецЦикла;
	
	//+ДВИЖЕНИЕ ПРОДУКЦИИ И МАТЕРИАЛОВ В ОСНОВНОЙ ЦЕХ
	
	// "Обнуление" переменной .
	ТекДокументДвижениеПродукции = Неопределено;
	
	// Если остались лишние типовые документы, то нужно пометить их на удаление.
	Пока ВыборкаСуществующиеДвиженияПродукцииИМатериалов.Следующий() Цикл
		
		ТекДокументДвижениеПродукции = ВыборкаСуществующиеДвиженияПродукцииИМатериалов.ДокументСсылка.ПолучитьОбъект();
		
		//+ОтложенноеПроведение
		Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
			ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ПолучитьТекущееДействиеПоПометкеУдаленияТиповогоДокумента(Истина), ТекДокументДвижениеПродукции.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
			СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
			Если НЕ ВсеОк Тогда 
				Возврат ВсеОк;
			КонецЕсли;
			ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.УстановитьСинхронизациюТиповогоДокумента, ТекДокументДвижениеПродукции.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
			СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
			Если НЕ ВсеОк Тогда 
				Возврат ВсеОк;
			КонецЕсли;
		Иначе
		//-ОтложенноеПроведение
			Если НЕ ВыборкаСуществующиеДвиженияПродукцииИМатериалов.ПометкаУдаления Тогда
				Попытка
					ТекДокументДвижениеПродукции.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
					ТекДокументДвижениеПродукции.УстановитьПометкуУдаления(Истина);
				Исключение
					ТекстОшибки = ТекстОшибки + "
					|Ошибка при установке пометки удаления """ + ТекДокументДвижениеПродукции.Метаданные().Представление() + """
					| по документу Общепит """+ДокументВыпускБлюд+"""
					|по причине: <"+ОписаниеОшибки()+">";
					Возврат Ложь;
				КонецПопытки;
			КонецЕсли;
			
		КонецЕсли;
		
		//+ОтложенноеПроведение
		ТекСинхронизирован = ?(СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд, Ложь, Истина);
		//-ОтложенноеПроведение
		
		// Добавление записи в результирующую таблицу.
		ДобавитьНовуюЗапись(ДокументВыпускБлюд, ТекДокументДвижениеПродукции, тблСозданныеДокументы,,ТекСинхронизирован);
		
	КонецЦикла;
	
	//-ДВИЖЕНИЕ ПРОДУКЦИИ И МАТЕРИАЛОВ В ОСНОВНОЙ ЦЕХ
	
	
	Возврат Истина;
	
КонецФункции // СформироватьПроизводствоБезЗаказа22ПоВыпускуБлюд()

// Функция формирует документ "Передача материалов в производство" для всех ингредиентов не из автопеределов
//  в ТЧ "Ингредиенты" переданного документа "Выпуск блюд" или обновляет существующие.
//
// Параметры:
//  ДокументВыпускБлюд		 - ДокументСсылка	 - Ссылка на документ "Выпуск блюд", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьПередачуМатериаловПоВыпускуБлюд(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки)
	
	Запрос = Новый Запрос;
	
	// Поиск существующего документа "Передача материалов в производство",
	// связанного с текущим "Выпуском блюд".
	Запрос.Текст = 
	"ВЫБРАТЬ 
	|	питТиповыеДокументы.ТиповойДокумент
	|ПОМЕСТИТЬ втДокументыВыпускПродукции
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|	И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.ПередачаМатериаловВПроизводство
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ 
	|	втДокументыВыпускПродукции.ТиповойДокумент
	|ИЗ
	|	втДокументыВыпускПродукции КАК втДокументыВыпускПродукции
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПередачаМатериаловВПроизводство КАК ПередачаМатериаловВПроизводство
	|		ПО (втДокументыВыпускПродукции.ТиповойДокумент = ПередачаМатериаловВПроизводство.Ссылка)
	|";
	Запрос.УстановитьПараметр("Документпит",				ДокументВыпускБлюд);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	// Если документ найден, то получаем объект иначе создаем новый.
	Если Выборка.Следующий() Тогда
		ТекДокументОбъект = Выборка.ТиповойДокумент.ПолучитьОбъект();
	Иначе
		ТекДокументОбъект = Документы["ПередачаМатериаловВПроизводство"].СоздатьДокумент();
	КонецЕсли;
	
	// Определение параметров записи.
	ПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокументВыпускБлюд.Проведен,ДокументВыпускБлюд.ПометкаУдаления,
		ТекДокументОбъект.Проведен,ТекДокументОбъект.ПометкаУдаления,СтруктураПараметров);
	
	// Определение режима записи
	ТекРежимЗаписи = ПараметрыЗаписи.РежимЗаписи;
	
	Если ПараметрыЗаписи.НужнаУстановкаПометкиУдаления Тогда
		
		//+ОтложенноеПроведение
		Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
			ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ПолучитьТекущееДействиеПоПометкеУдаленияТиповогоДокумента(ПараметрыЗаписи.ПометкаУдаления), ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
			СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
			Если НЕ ВсеОк Тогда 
				Возврат ВсеОк;
			КонецЕсли;
		Иначе
		//-ОтложенноеПроведение
			
			Попытка
				ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
				ТекДокументОбъект.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
			Исключение
				ТекстОшибки = ТекстОшибки + "
				|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
				| по документу Общепит """+ДокументВыпускБлюд+"""
				|по причине: <"+ОписаниеОшибки()+">";
				Возврат Ложь;
			КонецПопытки;
			
		КонецЕсли;
		
	КонецЕсли;
	
	/////////////////////////////////
	// ЗАПОЛНЕНИЕ ШАПКИ.
	
	ТекДокументОбъект.Дата					= ДокументВыпускБлюд.Дата + ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0);
	ТекДокументОбъект.Организация			= ДокументВыпускБлюд.Организация;
	ТекДокументОбъект.Склад					= ДокументВыпускБлюд.Склад;
	ТекДокументОбъект.Подразделение			= ДокументВыпускБлюд.Подразделение;
	ТекДокументОбъект.Ответственный			= ДокументВыпускБлюд.Ответственный;
	ТекДокументОбъект.Комментарий			= ДокументВыпускБлюд.Комментарий;
	ТекДокументОбъект.ХозяйственнаяОперация	= Перечисления.ХозяйственныеОперации.ПередачаВПроизводство;
	ТекДокументОбъект.Статус				= Перечисления.СтатусыПередачМатериаловВПроизводство.Принято;
	
	// Очистка табличных частей, т.к. будет их перезаполнение.
	ТекДокументОбъект.Товары.Очистить();
	ТекДокументОбъект.ВидыЗапасов.Очистить();
	ТекДокументОбъект.Серии.Очистить();
	ТекДокументОбъект.ДополнительныеРеквизиты.Очистить();
	
	// Получение данных по табличной части "Ингредиенты" отраслевого документа "Выпуск блюд".
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	питВыпускБлюдИнгредиенты.Ингредиент,
	|	питВыпускБлюдИнгредиенты.УпаковкаИнгредиента,
	|	питВыпускБлюдИнгредиенты.КоличествоУпаковокИнгредиентаФакт КАК КоличествоУпаковокИнгредиентаФакт,
	|	питВыпускБлюдИнгредиенты.КоличествоИнгредиентаФакт КАК КоличествоИнгредиентаФакт
	|ПОМЕСТИТЬ втИнгредиенты
	|ИЗ
	|	Документ.питВыпускБлюд.Ингредиенты КАК питВыпускБлюдИнгредиенты
	|ГДЕ
	|	питВыпускБлюдИнгредиенты.Ссылка = &Ссылка
	|	И питВыпускБлюдИнгредиенты.ИзАвтопеределов = ЛОЖЬ
	|	И НЕ питВыпускБлюдИнгредиенты.КоличествоИнгредиентаФакт = 0
	|	И НЕ питВыпускБлюдИнгредиенты.Ингредиент.питВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.питВидыНоменклатуры.ТехнологическийИнгредиент)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	питВыпускБлюдЗамены.ИнгредиентЗамена,
	|	питВыпускБлюдЗамены.УпаковкаИнгредиентаЗамена,
	|	питВыпускБлюдЗамены.КоличествоУпаковокИнгредиентаЗамена,
	|	питВыпускБлюдЗамены.КоличествоИнгредиентаЗамена
	|ИЗ
	|	Документ.питВыпускБлюд.Замены КАК питВыпускБлюдЗамены
	|ГДЕ
	|	питВыпускБлюдЗамены.Ссылка = &Ссылка
	|	И НЕ питВыпускБлюдЗамены.ИнгредиентЗамена.питВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.питВидыНоменклатуры.ТехнологическийИнгредиент)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втИнгредиенты.Ингредиент,
	|	втИнгредиенты.УпаковкаИнгредиента,
	|	СУММА(втИнгредиенты.КоличествоУпаковокИнгредиентаФакт) КАК КоличествоУпаковокИнгредиентаФакт,
	|	СУММА(втИнгредиенты.КоличествоИнгредиентаФакт) КАК КоличествоИнгредиентаФакт
	|ИЗ
	|	втИнгредиенты КАК втИнгредиенты
	|
	|СГРУППИРОВАТЬ ПО
	|	втИнгредиенты.Ингредиент,
	|	втИнгредиенты.УпаковкаИнгредиента";
	Запрос.УстановитьПараметр("Ссылка", ДокументВыпускБлюд.Ссылка);
	
	// Обход таб. части и заполнение таб. частей "Товары" документа "Передача материалов в производство".
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		НовСтрока						= ТекДокументОбъект.Товары.Добавить();
		НовСтрока.Номенклатура			= Выборка.Ингредиент;
		НовСтрока.Упаковка				= Выборка.УпаковкаИнгредиента;
		НовСтрока.КоличествоУпаковок	= Выборка.КоличествоУпаковокИнгредиентаФакт;
		НовСтрока.Количество			= Выборка.КоличествоИнгредиентаФакт;
		
	КонецЦикла;
	
	////////////////////////////////////////////////////////
	// Если выпуск блюд создан на основании плана меню, то ищем связанный с планом меню
	// заказ материалов в производство и пытаемся его связать построчно с текущим создаваемым\обновляемым
	// документом "Передача материалов в производство".
	ОснованиеВыпуска = ДокументВыпускБлюд.ДокументОснование;
	Если НЕ ОснованиеВыпуска = Неопределено
		И ЗначениеЗаполнено(ОснованиеВыпуска) 
		И ТипЗнч(ОснованиеВыпуска) = Тип("ДокументСсылка.питПланМеню") Тогда
		
		// Пишем параметры записи текущего синхронизируемого документа "Передача метариалов в производство" в структуру параметров.
		Если НЕ СтруктураПараметров.Свойство("ПараметрыЗаписиПередачаМатериалов") Тогда
			СтруктураПараметров.Вставить("ПараметрыЗаписиПередачаМатериалов", ПараметрыЗаписи);
		КонецЕсли;
		
		// Попытка выполнить привязку/отвязку "Передачи материалов в производство" и "Заказа материалов в производство" - подкладного 
		// документа от "План меню", на основании которого создан текущий выпуск продукции.
		ВсеОк = СвязатьОтвязатьПередачуВПроизводствоСЗаказомНаПроизводство(ТекДокументОбъект, ОснованиеВыпуска, СтруктураПараметров, ТекстОшибки);
		Если НЕ ВсеОк Тогда
			// Что-то пошло не так.
			Возврат Ложь;
		КонецЕсли;
		
	КонецЕсли;
	
	/////////////////////////////////////////////////////////
	// ЗАПИСЬ ДОКУМЕНТА "ПЕРЕДАЧА МАТЕРИАЛОВ В ПРОИЗВОДСТВО"
	
	//+ОтложенноеПроведение
	Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
		ИсходныйРежимЗаписи	= ТекРежимЗаписи;
		ТекРежимЗаписи		= РежимЗаписиДокумента.Запись;
	КонецЕсли;
	//-ОтложенноеПроведение
	
	Попытка
		ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
		ТекДокументОбъект.Записать(ТекРежимЗаписи);
	Исключение
		ТекстОшибки = ТекстОшибки + "
		|Ошибка записи документа """ + ТекДокументОбъект.Метаданные().Представление() + """
		| по документу Общепит """+ДокументВыпускБлюд+"""
		|по причине: <"+ОписаниеОшибки()+">";
		Возврат Ложь;
	КонецПопытки;
	
	//+ОтложенноеПроведение
	Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
		ТекДействие = ПолучитьТекущееДействиеПоРежимузаписиТиповогоДокумента(ИсходныйРежимЗаписи);
		ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ТекДействие, ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
		СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
		ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.УстановитьСинхронизациюТиповогоДокумента, ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
		СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
	КонецЕсли;
	//-ОтложенноеПроведение
	
	// Если была произведена отвязка "Передачи материалов в производство" от "Заказа материалов в производство", то
	// будет инициализирован флаг "Дописать заказ", который означает, что необходимо провести ИЗМЕНЕННЫЙ документ заказа после записи
	// документа передачи материалов.
	ДозаписатьЗаказ = Ложь;
	Если СтруктураПараметров.Свойство("ДозаписатьЗаказ") Тогда
		ДозаписатьЗаказ = СтруктураПараметров.ДозаписатьЗаказ;
	КонецЕсли;
	
	Если ДозаписатьЗаказ Тогда
		
		// Получаем объект измененного документа заказа материалов в производство.
		ДокЗаказОбъект = Неопределено;
		Если СтруктураПараметров.Свойство("ДокЗаказОбъект") Тогда
			ДокЗаказОбъект = СтруктураПараметров.ДокЗаказОбъект;
		КонецЕсли;
		
		Если ДокЗаказОбъект = Неопределено Тогда
			// Не нашли документ заказ.
			ТекстОшибки = ТекстОшибки + "
			|Ошибка записи документа """ + ТекДокументОбъект.Метаданные().Представление() + """
			| по документу Общепит """+ДокументВыпускБлюд+"""
			|по причине: <Не удалось отвязать документ ""Заказ материалов в производство"" от записываемого документа ""Передача материалов в производство"">";
			Возврат Ложь;
		КонецЕсли;
		
		//+ОтложенноеПроведение
		Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
			ИсходныйРежимЗаписиЗаказ	= РежимЗаписиДокумента.Проведение;
			ТекРежимЗаписиЗаказ			= РежимЗаписиДокумента.Запись;
		КонецЕсли;
		//-ОтложенноеПроведение
		
		// Проведение документа заказ.
		Попытка
			ДокЗаказОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
			ДокЗаказОбъект.Записать(ТекРежимЗаписиЗаказ);
		Исключение
			ТекстОшибки = ТекстОшибки + "
			|Ошибка записи документа """ + ТекДокументОбъект.Метаданные().Представление() + """
			| по документу Общепит """+ДокументВыпускБлюд+"""
			|по причине: <Не удалось отвязать документ ""Заказ материалов в производство"" от записываемого документа ""Передача материалов в производство"">";
			Возврат Ложь;
		КонецПопытки;
		
		//+ОтложенноеПроведение
		Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
			ТекДействие = ПолучитьТекущееДействиеПоРежимузаписиТиповогоДокумента(ИсходныйРежимЗаписиЗаказ);
			ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ТекДействие, ДокЗаказОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
			СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
			Если НЕ ВсеОк Тогда 
				Возврат ВсеОк;
			КонецЕсли;
			ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.УстановитьСинхронизациюТиповогоДокумента, ДокЗаказОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
			СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
			Если НЕ ВсеОк Тогда 
				Возврат ВсеОк;
			КонецЕсли;
		КонецЕсли;
		//-ОтложенноеПроведение
		
	КонецЕсли;
	
	//+ОтложенноеПроведение
	ТекСинхронизирован = ?(СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд, Ложь, Истина);
	//-ОтложенноеПроведение
	
	// Добавление записи в результирующую таблицу в случае успешной записи документов.
	ДобавитьНовуюЗапись(ДокументВыпускБлюд, ТекДокументОбъект, тблСозданныеДокументы,,ТекСинхронизирован);
	
	Возврат Истина;
	
КонецФункции

// Функция формирует документ "Оприходование излишков товаров" или обновляет существующие.
//
// Параметры:
//  ДокументВыпускБлюд		 - ДокументСсылка	 - Ссылка на документ "Выпуск блюд", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьОприходованиеИзлишковПоВыпускуБлюд(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки, ОтложенноеФормирование = Ложь)
	
	Если НЕ СтруктураПараметров.Свойство("ФормироватьИзлишки") Тогда
		ФормироватьИзлишки = Константы.питФормироватьОприходованиеИзлишковПоВыпускуБлюд.Получить();
		СтруктураПараметров.Вставить("ФормироватьИзлишки", ФормироватьИзлишки);
	Иначе
		ФормироватьИзлишки = СтруктураПараметров.ФормироватьИзлишки;
	КонецЕсли;
	
	//+БазовоеСмещение
	Если НЕ СтруктураПараметров.Свойство("питСмещатьДатыТиповыхДокументов") Тогда
		СтруктураПараметров.Вставить("питСмещатьДатыТиповыхДокументов", питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питСмещатьДатыТиповыхДокументов"));
	КонецЕсли;
	БазовоеСмещение = 0;
	Если СтруктураПараметров.питСмещатьДатыТиповыхДокументов Тогда
		СтрокиСмещение = СтруктураПараметров.ТаблицаПорядокПроведенияТиповыхДокументовВыпускаБлюд.НайтиСтроки(
		Новый Структура("ИмяТиповогоДокумента,ПричинаТиповогоДокумента", "ОприходованиеИзлишковТоваров", 0));
		Если СтрокиСмещение.Количество() Тогда
			БазовоеСмещение = СтрокиСмещение[0].БазовоеСмещение;
		КонецЕсли;
	КонецЕсли;
	//-БазовоеСмещение
	
	НовыйДокументИзлишков = Ложь;
	
	Если СтруктураПараметров.Свойство("ДокументОбъектИзлишков") Тогда
		
		// Уже ранее получали документ излишков и запомнили его, чтобы не делать еще раз запрос.
		ТекДокументОбъект = СтруктураПараметров.ДокументОбъектИзлишков;
		
	Иначе
		
		Запрос = Новый Запрос;
		
		// Поиск существующего документа "Оприходование излишков товаров",
		// связанного с текущим "Выпуском блюд".
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	питТиповыеДокументы.ТиповойДокумент
		|ПОМЕСТИТЬ втДокументыВыпускПродукции
		|ИЗ
		|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
		|ГДЕ
		|	питТиповыеДокументы.ДокументОбщепит = &Документпит
		|	И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.ОприходованиеИзлишковТоваров
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	втДокументыВыпускПродукции.ТиповойДокумент
		|ИЗ
		|	втДокументыВыпускПродукции КАК втДокументыВыпускПродукции
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОприходованиеИзлишковТоваров КАК ОприходованиеИзлишковТоваров
		|		ПО втДокументыВыпускПродукции.ТиповойДокумент = ОприходованиеИзлишковТоваров.Ссылка";
		Запрос.УстановитьПараметр("Документпит",				ДокументВыпускБлюд);
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Если ФормироватьИзлишки Тогда
			// Если документ найден, то получаем объект иначе создаем новый.
			Если Выборка.Следующий() Тогда
				ТекДокументОбъект = Выборка.ТиповойДокумент.ПолучитьОбъект();
			ИначеЕсли НЕ ДокументВыпускБлюд.Проведен Тогда
				Возврат Истина; // Для непроведенного выпуска, если раньше не было оприходования, то не создаем.
			Иначе
				ТекДокументОбъект = Документы.ОприходованиеИзлишковТоваров.СоздатьДокумент();
				НовыйДокументИзлишков = Истина;
			КонецЕсли;
		Иначе
			Если Выборка.Следующий() Тогда
				// Сейчас не формируем излишки, но уже ранее был создан такой документ
				ТекДокументСсылка = Выборка.ТиповойДокумент;
				
				//+ОтложенноеПроведение
				Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
					ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.ОтвязатьТиповойДокумент, ТекДокументСсылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
					СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
					Возврат ВсеОк;
				Иначе
				//-ОтложенноеПроведение
					Возврат УдалитьСвязьТиповогоДокументаСДокументомПит(ТекДокументСсылка, ДокументВыпускБлюд, ТекстОшибки);
				КонецЕсли;
				
			Иначе
				Возврат Истина;
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	// Определение параметров записи.
	ПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокументВыпускБлюд.Проведен,ДокументВыпускБлюд.ПометкаУдаления,
		ТекДокументОбъект.Проведен,ТекДокументОбъект.ПометкаУдаления,СтруктураПараметров);
	
	// Определение режима записи
	ТекРежимЗаписи = ПараметрыЗаписи.РежимЗаписи;
	
	Если НЕ ОтложенноеФормирование И ТекРежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
		Если НЕ НовыйДокументИзлишков Тогда
			// В случае отмены проведения оприходованием занимаемся позже, в самую последнюю очередь, 
			// т.к. он делаем движения в плюс по свободным остаткам и отменять их нужно после отмены всех остальных типовых документов.
			СтруктураПараметров.Вставить("ОтложитьФормированиеОприходованияИзлишков", Истина); 
			// Запоминаем, чтобы потом второй раз не получать
			СтруктураПараметров.Вставить("ДокументОбъектИзлишков", ТекДокументОбъект); 
		КонецЕсли;
		Возврат Истина;
	КонецЕсли;
	
	Если ПараметрыЗаписи.НужнаУстановкаПометкиУдаления И НЕ НовыйДокументИзлишков Тогда
		
		//+ОтложенноеПроведение
		Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
			ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ПолучитьТекущееДействиеПоПометкеУдаленияТиповогоДокумента(ПараметрыЗаписи.ПометкаУдаления), ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
			СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
			Если НЕ ВсеОк Тогда 
				Возврат ВсеОк;
			КонецЕсли;
		Иначе
		//-ОтложенноеПроведение
			
			Попытка
				ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
				ТекДокументОбъект.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
			Исключение
				ТекстОшибки = ТекстОшибки + "
				|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
				| по документу Общепит """+ДокументВыпускБлюд+"""
				|по причине: <"+ОписаниеОшибки()+">";
				Возврат Ложь;
			КонецПопытки;
			
		КонецЕсли;
		
	КонецЕсли;
	
	// Получение данных по табличной части "Ингредиенты" отраслевого документа "Выпуск блюд".
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	втИнгредиенты.Ингредиент КАК Номенклатура,
	|	втИнгредиенты.Характеристика КАК Характеристика,
	|	втИнгредиенты.Назначение КАК Назначение,
	|	ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка) КАК Серия,
	|	СУММА(втИнгредиенты.КоличествоИнгредиентаФакт) КАК КоличествоИнгредиентаФакт
	|ПОМЕСТИТЬ втТовары
	|ИЗ
	|	Документ.питВыпускБлюд.Ингредиенты КАК втИнгредиенты
	|ГДЕ
	|	втИнгредиенты.Ссылка = &Ссылка
	|	И НЕ втИнгредиенты.ИзАвтопеределов
	|	И НЕ втИнгредиенты.Ингредиент.питВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.питВидыНоменклатуры.ТехнологическийИнгредиент)
	|	И втИнгредиенты.Ингредиент.ТипНоменклатуры В (&СкладскиеТипыНоменклатуры)
	|
	|СГРУППИРОВАТЬ ПО
	|	втИнгредиенты.Ингредиент,
	|	втИнгредиенты.Характеристика,
	|	втИнгредиенты.Назначение
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	питВыпускБлюдТовары.Номенклатура,
	|	питВыпускБлюдТовары.Характеристика,
	|	питВыпускБлюдТовары.Назначение,
	|	ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка),
	|	СУММА(питВыпускБлюдТовары.Количество)
	|ИЗ
	|	Документ.питВыпускБлюд.Товары КАК питВыпускБлюдТовары
	|ГДЕ
	|	питВыпускБлюдТовары.Ссылка = &Ссылка
	|	И (питВыпускБлюдТовары.ПриготовлениеЗапрещено = ИСТИНА
	|	ИЛИ питВыпускБлюдТовары.Рецептура = ЗНАЧЕНИЕ(Документ.питРецептура.ПустаяСсылка))
	|	И НЕ питВыпускБлюдТовары.Номенклатура.питВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.питВидыНоменклатуры.БизнесЛанч)
	|	И питВыпускБлюдТовары.Номенклатура.ТипНоменклатуры В (&СкладскиеТипыНоменклатуры)
	|
	|СГРУППИРОВАТЬ ПО
	|питВыпускБлюдТовары.Номенклатура,
	|питВыпускБлюдТовары.Характеристика,
	|питВыпускБлюдТовары.Назначение
	|;
	|"+питОбщегоНазначенияСервер.ПолучитьТекстЗапросаДляВычетаДвиженийРегистратора()+"
	|;
	|"+питОбщегоНазначенияСервер.ПолучитьТекстЗапросаСвободныеОстатки("втТовары","втОстаткиБезВычета")+"
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	питТиповыеДокументы.ТиповойДокумент КАК ТиповойДокумент
	|ПОМЕСТИТЬ втДокументыТиповые
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &ДокументОбщепит
	|	И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.ДвижениеПродукцииИМатериалов
	|	И питТиповыеДокументы.ПричинаТиповогоДокумента = 2
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДвижениеПродукцииИМатериаловТовары.Номенклатура КАК Номенклатура,
	|	ДвижениеПродукцииИМатериаловТовары.Характеристика КАК Характеристика,
	|	ДвижениеПродукцииИМатериаловТовары.Назначение КАК Назначение,
	|	&Склад КАК Склад,
	|	ДвижениеПродукцииИМатериаловТовары.Серия КАК Серия,
	|	ДвижениеПродукцииИМатериаловТовары.Количество КАК Количество
	|ПОМЕСТИТЬ втОстаткиБезГруппировки
	|ИЗ
	|	втДокументыТиповые КАК втДокументыТиповые
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ДвижениеПродукцииИМатериалов.Товары КАК ДвижениеПродукцииИМатериаловТовары
	|		ПО втДокументыТиповые.ТиповойДокумент = ДвижениеПродукцииИМатериаловТовары.Ссылка
	|ГДЕ
	|	ДвижениеПродукцииИМатериаловТовары.Ссылка.Проведен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	втОстаткиБезВычета.Номенклатура КАК Номенклатура,
	|	втОстаткиБезВычета.Характеристика КАК Характеристика,
	|	втОстаткиБезВычета.Назначение КАК Назначение,
	|	втОстаткиБезВычета.Склад КАК Склад,
	|	втОстаткиБезВычета.Серия КАК Серия,
	|	втОстаткиБезВычета.Количество КАК Количество
	|ИЗ
	|	втОстаткиБезВычета КАК втОстаткиБезВычета
	|;
	|
	|//////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втОстаткиБезГруппировки.Номенклатура КАК Номенклатура,
	|	втОстаткиБезГруппировки.Характеристика КАК Характеристика,
	|	втОстаткиБезГруппировки.Назначение КАК Назначение,
	|	втОстаткиБезГруппировки.Склад КАК Склад,
	|	втОстаткиБезГруппировки.Серия КАК Серия,
	|	СУММА(втОстаткиБезГруппировки.Количество) КАК Количество
	|ПОМЕСТИТЬ втОстатки
	|ИЗ
	|	втОстаткиБезГруппировки КАК втОстаткиБезГруппировки
	|СГРУППИРОВАТЬ ПО
	|	втОстаткиБезГруппировки.Номенклатура,
	|	втОстаткиБезГруппировки.Характеристика,
	|	втОстаткиБезГруппировки.Назначение,
	|	втОстаткиБезГруппировки.Склад,
	|	втОстаткиБезГруппировки.Серия
	|;
	|
	|//////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втТовары.Номенклатура КАК Ингредиент,
	|	втТовары.Характеристика КАК Характеристика,
	|	втТовары.Назначение КАК Назначение,
	|	(втТовары.КоличествоИнгредиентаФакт - isnull(втОстатки.Количество,0)) КАК Количество
	|ИЗ 
	|	втТовары ЛЕВОЕ СОЕДИНЕНИЕ втОстатки 
	|		ПО втТовары.Номенклатура = втОстатки.Номенклатура
	|			И втТовары.Характеристика = втОстатки.Характеристика
	|			И втТовары.Назначение = втОстатки.Назначение
	|ГДЕ isnull(втОстатки.Количество,0) < втТовары.КоличествоИнгредиентаФакт
	|";
	
	Запрос.УстановитьПараметр("ДокументОбщепит", ДокументВыпускБлюд.Ссылка);
	Запрос.УстановитьПараметр("Ссылка", ДокументВыпускБлюд.Ссылка);
	Запрос.УстановитьПараметр("НаДату", КонецМесяца(ДокументВыпускБлюд.Дата));
	Запрос.УстановитьПараметр("НаДатуДата", КонецМесяца(ДокументВыпускБлюд.Дата));
	Запрос.УстановитьПараметр("Склад", ДокументВыпускБлюд.Склад);
	
	СкладскиеТипыНоменклатуры = питОбщегоНазначения.ПолучитьСкладскиеТипыНоменклатуры();
	Запрос.УстановитьПараметр("СкладскиеТипыНоменклатуры", СкладскиеТипыНоменклатуры);
	
	Если ЗначениеЗаполнено(ДокументВыпускБлюд.Склад) Тогда
		ОрдерПоИзлишкам = питОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументВыпускБлюд.Склад,"ИспользоватьОрдернуюСхемуПриОтраженииИзлишковНедостач");
	Иначе
		ОрдерПоИзлишкам = Ложь; // По умолчанию
	КонецЕсли;
	
	// Обход таб. части и заполнение таб. частей "Товары".
	Если НЕ ОрдерПоИзлишкам Тогда
		РезультатЗапроса = Запрос.Выполнить();
	Иначе
		РезультатЗапроса = Неопределено;
	КонецЕсли;
	
	Если ОрдерПоИзлишкам ИЛИ РезультатЗапроса.Пустой() Тогда
		
		// Нечего оприходовать, всего хватает. Документ не нужен! Существующий пометим на удаление
		Если НЕ ПустаяСтрока(ТекДокументОбъект.ВерсияДанных) Тогда
			
			//+ОтложенноеПроведение
			Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
				ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ПолучитьТекущееДействиеПоПометкеУдаленияТиповогоДокумента(Истина), ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
				СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
				Если НЕ ВсеОк Тогда 
					Возврат ВсеОк;
				КонецЕсли;
				ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.УстановитьСинхронизациюТиповогоДокумента, ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
				СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
				Если НЕ ВсеОк Тогда 
					Возврат ВсеОк;
				КонецЕсли;
			Иначе
			//-ОтложенноеПроведение
				
				Попытка
					ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
					ТекДокументОбъект.УстановитьПометкуУдаления(Истина);
				Исключение
					ТекстОшибки = ТекстОшибки + "
					|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
					| по документу Общепит """+ДокументВыпускБлюд+"""
					|по причине: <"+ОписаниеОшибки()+">";
					Возврат Ложь;
				КонецПопытки;
				
			КонецЕсли;
			
			//+ОтложенноеПроведение
			ТекСинхронизирован = ?(СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд, Ложь, Истина);
			//-ОтложенноеПроведение
			
			// Добавление записи в результирующую таблицу в случае успешной записи документов.
			ДобавитьНовуюЗапись(ДокументВыпускБлюд, ТекДокументОбъект, тблСозданныеДокументы,,ТекСинхронизирован);
			
		КонецЕсли;
		
		Возврат Истина;
		
	КонецЕсли;
	
	/////////////////////////////////
	// ЗАПОЛНЕНИЕ ШАПКИ.
	
	ТекДокументОбъект.Дата					= ДокументВыпускБлюд.Дата + ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0) - БазовоеСмещение;
	ТекДокументОбъект.Ответственный			= ДокументВыпускБлюд.Ответственный;
	ТекДокументОбъект.Комментарий			= ДокументВыпускБлюд.Комментарий;
	ТекДокументОбъект.Организация			= ДокументВыпускБлюд.Организация;
	ТекДокументОбъект.Ответственный			= ДокументВыпускБлюд.Ответственный;
	ТекДокументОбъект.Подразделение			= ДокументВыпускБлюд.Подразделение;
	ТекДокументОбъект.Склад					= ДокументВыпускБлюд.Склад;
	ТекДокументОбъект.ВидЦены				= питОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументВыпускБлюд.Склад,"УчетныйВидЦены");
	ТекДокументОбъект.СтатьяДоходов			= питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питСтатьяОприходованияИзлишков");
	ТекДокументОбъект.Валюта = ДоходыИРасходыСервер.ПолучитьВалютуУправленческогоУчета(
		Справочники.ВидыЦен.ПолучитьРеквизитыВидаЦены(ТекДокументОбъект.ВидЦены).ВалютаЦены);
	ТекДокументОбъект.НаправлениеДеятельности = ДокументВыпускБлюд.НаправлениеДеятельности;
	
	// Очистка табличных частей, т.к. будет их перезаполнение.
	ТекДокументОбъект.Товары.Очистить();
	ТекДокументОбъект.ДополнительныеРеквизиты.Очистить();
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		// Для того, чтобы случайно не оприходовать нулевое количество
		Если Окр(Выборка.Количество, 3) = 0 Тогда 
			Продолжить;
		КонецЕсли;
		
		НовСтрока						= ТекДокументОбъект.Товары.Добавить();
		НовСтрока.Номенклатура			= Выборка.Ингредиент;
		НовСтрока.Характеристика		= Выборка.Характеристика;
		НовСтрока.Назначение			= Выборка.Назначение;
		НовСтрока.Количество			= Выборка.Количество;
		
	КонецЦикла;
	
	// Заполнение ЦЕН
	Если ЗначениеЗаполнено(ТекДокументОбъект.ВидЦены) Тогда
		СтруктураДействий = Новый Структура;
		СтруктураДействий.Вставить("ПересчитатьСумму", "Количество");
		КолонкиПоЗначению = Новый Структура("Упаковка", Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка());
		ПараметрыЗаполнения = Новый Структура;
		ПараметрыЗаполнения.Вставить("Дата", ТекДокументОбъект.Дата);
		ПараметрыЗаполнения.Вставить("Организация", ТекДокументОбъект.Организация);
		ПараметрыЗаполнения.Вставить("Валюта", Константы.ВалютаРегламентированногоУчета.Получить());
		ПараметрыЗаполнения.Вставить("ВидЦены", ТекДокументОбъект.ВидЦены);
		ПараметрыЗаполнения.Вставить("КолонкиПоЗначению", КолонкиПоЗначению);
		ЦеныПредприятияЗаполнениеСервер.ЗаполнитьЦены(
			ТекДокументОбъект.Товары, // Табличная часть
			, // Выделенные строки (заполнять во всех строках)
			ПараметрыЗаполнения,
			СтруктураДействий);
		
		// Если цена заполнилась, а сумма меньше 1 копейки, тогда количество подгоняем под 1 копейку.
		Для каждого ТекСтрокаТовары Из ТекДокументОбъект.Товары Цикл
			Если ТекСтрокаТовары.Цена <> 0 И ТекСтрокаТовары.Сумма = 0 Тогда
				МинимальноМожноОприходовать = 0.01 / ТекСтрокаТовары.Цена;
				СтоимостьМинимальноОприходованного = 0.01;
				Если МинимальноМожноОприходовать < 0.001 Тогда
					СтоимостьМинимальноОприходованного = 0.001 * 0.01 / МинимальноМожноОприходовать;
					МинимальноМожноОприходовать = 0.001;
				КонецЕсли;
				ТекСтрокаТовары.Количество	= МинимальноМожноОприходовать;
				ТекСтрокаТовары.Сумма		= СтоимостьМинимальноОприходованного;
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
	// Проверка на заполненность цен, отсутствие цен критично и это ошибка!
	ТоварыСНезаполненнымиЦенами = Новый Массив;
	Для каждого ТекСтрокаТовары Из ТекДокументОбъект.Товары Цикл
		Если ТекСтрокаТовары.Цена = 0 ИЛИ ТекСтрокаТовары.Сумма = 0 Тогда
			ТоварыСНезаполненнымиЦенами.Добавить(ТекСтрокаТовары.Номенклатура);
		КонецЕсли;
	КонецЦикла;
	Если ТоварыСНезаполненнымиЦенами.Количество() Тогда
		
		ТекстОшибки = ТекстОшибки + "
		|Ошибка заполнения документа """ + ТекДокументОбъект.Метаданные().Представление() + """
		| по документу Общепит """+ДокументВыпускБлюд+"""
		|по причине: Не заполнены цены по виду цен <"+ТекДокументОбъект.ВидЦены+"> для следующих номенклатурных позиций:
		|";
		Для Сч = 0 По ТоварыСНезаполненнымиЦенами.Количество()-1 Цикл
			ТекстОшибки = ТекстОшибки + ?(Сч=0,"",",")+"<"+ТоварыСНезаполненнымиЦенами[Сч]+">";
		КонецЦикла;
		
		Возврат Ложь;
		
	КонецЕсли;
	
	/////////////////////////////////////////////////////////
	// ЗАПИСЬ ТИПОВОГО ДОКУМЕНТА 
	
	//+ОтложенноеПроведение
	Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
		ИсходныйРежимЗаписи	= ТекРежимЗаписи;
		ТекРежимЗаписи		= РежимЗаписиДокумента.Запись;
	КонецЕсли;
	//-ОтложенноеПроведение
	
	Попытка
		ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
		ТекДокументОбъект.Записать(ТекРежимЗаписи);
	Исключение
		ТекстОшибки = ТекстОшибки + "
		|Ошибка записи документа """ + ТекДокументОбъект.Метаданные().Представление() + """
		| по документу Общепит """+ДокументВыпускБлюд+"""
		|по причине: <"+ОписаниеОшибки()+">";
		Возврат Ложь;
	КонецПопытки;
	
	//+ОтложенноеПроведение
	Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
		ТекДействие = ПолучитьТекущееДействиеПоРежимузаписиТиповогоДокумента(ИсходныйРежимЗаписи);
		ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ТекДействие, ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
		СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
		ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.УстановитьСинхронизациюТиповогоДокумента, ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
		СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
	КонецЕсли;
	//-ОтложенноеПроведение
	
	//+ОтложенноеПроведение
	ТекСинхронизирован = ?(СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд, Ложь, Истина);
	//-ОтложенноеПроведение
	
	// Добавление записи в результирующую таблицу в случае успешной записи документов.
	ДобавитьНовуюЗапись(ДокументВыпускБлюд, ТекДокументОбъект, тблСозданныеДокументы,,ТекСинхронизирован);
	
	Возврат Истина;
	
КонецФункции

// Функция связывает или отвязывает переданный документ "Передача материалов в производство" 
//  с документом "Заказ материалов в производство", созданным как подкладной у переданного док. "План меню".
//
// Параметры:
//  ДокПередачаМатериаловОбъект	 - ДокОбъект.ПередачаМатериаловВПроизводство - Текущий обновляемый/создаваемый документ.
//  ДокПланМенюСсылка			 - ДокСсылка.питПланМеню - Ссылка на план меню, на основании которого был создан выпуск блюд.
//  СтруктураПараметров			 - Структура - Параметры.
//  ТекстОшибки					 - Строка - Текст ошибки.
// 
// Возвращаемое значение:
//  Булево - Успешность выполнения.
//
Функция СвязатьОтвязатьПередачуВПроизводствоСЗаказомНаПроизводство(ДокПередачаМатериаловОбъект, ДокПланМенюСсылка, СтруктураПараметров, ТекстОшибки = "")
	
	ДокЗаказ = Неопределено;
	
	// Получение парметров записи.
	Если НЕ СтруктураПараметров.Свойство("ПараметрыЗаписиПередачаМатериалов") Тогда
		ТекстОшибки = ТекстОшибки + "Ошибка при попытке связать передачу материалов в производство с заказом в производство. 
		| Не определены параметры записи типового документа!";
		Возврат Ложь;
	КонецЕсли;
	ПараметрыЗаписи = СтруктураПараметров.ПараметрыЗаписиПередачаМатериалов;
	
	// Признак того, какую операцию необходимо выполнить: связать заказ с передачей или отвязать.
	// Зависит от режима записи документа, связывание происходит только в момент проведения.
	Связать = ?(ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение, Истина, Ложь);
	
	// Поиск связанного с планом меню заказа материалов в производство, при этом связанный документ должен быть проведен.
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	питТиповыеДокументы.ТиповойДокумент
	|ПОМЕСТИТЬ втСвязанныйЗаказ
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|	И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.ЗаказМатериаловВПроизводство
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втСвязанныйЗаказ.ТиповойДокумент
	|ИЗ
	|	втСвязанныйЗаказ КАК втСвязанныйЗаказ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказМатериаловВПроизводство КАК ЗаказМатериаловВПроизводство
	|		ПО втСвязанныйЗаказ.ТиповойДокумент = ЗаказМатериаловВПроизводство.Ссылка
	|ГДЕ
	|	ЗаказМатериаловВПроизводство.Проведен";
	Запрос.УстановитьПараметр("Документпит", ДокПланМенюСсылка);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		// Связанный заказ найден.
		ДокЗаказ = Выборка.ТиповойДокумент;
		
		// Получение объекта заказа.
		ДокЗаказОбъект = ДокЗаказ.ПолучитьОбъект();
		
		// Выборка табличной части "Товары" документов "Заказ материалов в производство" и "Передача материалов в производство"
		// В "Товары заказа" добавляется пустая колонка "Количество отгрузить"(сколько товара нужно поставить "к отгрузке") 
		// и "Код строки"(код строки отгружаемого товара для связи с передачей материалов в производство). 
		// В "Товары передачи" добавляется колонка "Есть заказ" - признак того, что по данной товарной позиции есть строка 
		// в "Заказ материалов в производство", а также колонка "Код строки" для построчной связи с товарными позициями в заказе.
		// Данные колонки будут инициализированы далее по алгоритму.
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		|	ТоварыПередача.Номенклатура,
		|	ТоварыПередача.Количество
		|ПОМЕСТИТЬ втТоварыПередача
		|ИЗ
		|	&ТоварыПередача КАК ТоварыПередача
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	тчТоварыЗаказ.Номенклатура,
		|	тчТоварыЗаказ.Количество
		|ПОМЕСТИТЬ втТоварыЗаказ
		|ИЗ
		|	&тчТоварыЗаказ КАК тчТоварыЗаказ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	втТоварыПередача.Номенклатура,
		|	СУММА(втТоварыПередача.Количество) КАК Количество,
		|	МИНИМУМ(ЛОЖЬ) КАК ЕстьЗаказ,
		|	0 КАК КодСтроки
		|ИЗ
		|	втТоварыПередача КАК втТоварыПередача
		|
		|СГРУППИРОВАТЬ ПО
		|	втТоварыПередача.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	втТоварыЗаказ.Номенклатура,
		|	СУММА(втТоварыЗаказ.Количество) КАК Количество,
		|	СУММА(0) КАК КоличествоОтгрузить,
		|	0 КАК КодСтроки
		|ИЗ
		|	втТоварыЗаказ КАК втТоварыЗаказ
		|
		|СГРУППИРОВАТЬ ПО
		|	втТоварыЗаказ.Номенклатура";
		
		Запрос.УстановитьПараметр("ТоварыПередача", ДокПередачаМатериаловОбъект.Товары.Выгрузить());
		Запрос.УстановитьПараметр("тчТоварыЗаказ", ДокЗаказОбъект.Товары.Выгрузить());
		Результат = Запрос.ВыполнитьПакет();
		
		// Получаем таблицы "Товаров заказа" и "Товаров передачи".
		ТоварыДляПередачи	= Результат[2].Выгрузить();
		ТоварыЗаказа		= Результат[3].Выгрузить();
		
		// Строки заказа будут перезаполнены, лишние в последствии будут удалены.
		МассивСтрокДляУдаления = Новый Массив;
		
		Если Связать Тогда
			
			// Операция связывания строк заказа и передечи в производство.
			
			// Поиск номенклатуры из товаров передачи в товарах заказа и заполнение количества 
			// "для отгрузки" и признака того, что товар есть в заказе.
			Для каждого ТоварДляПередачи Из ТоварыДляПередачи Цикл
				
				НайденныйТоварЗаказа = ТоварыЗаказа.Найти(ТоварДляПередачи.Номенклатура, "Номенклатура");
				Если НЕ НайденныйТоварЗаказа = Неопределено Тогда
					// Если передаем в производство столько сколько в заказе или больше, 
					//то "к отгрузке" в заказе все количество, иначе столько, сколько передаем.
					НайденныйТоварЗаказа.КоличествоОтгрузить = ?(ТоварДляПередачи.Количество >= НайденныйТоварЗаказа.Количество, НайденныйТоварЗаказа.Количество, ТоварДляПередачи.Количество);
					ТоварДляПередачи.ЕстьЗаказ = Истина;
				КонецЕсли;
				
			КонецЦикла;
			
			/////////////////////////////////////////////////////////////////
			// Изменение данных объекта "Заказ материалов в производство"
			
			// Смена статуса с "К обеспечению" на "К выполнению".
			ДокЗаказОбъект.Статус = Перечисления.СтатусыЗаказовМатериаловВПроизводство.КВыполнению;
			
			МассивСтрокДляУдаления.Очистить();
			
			// Обход таблицы товаров заказа
			Для каждого ТоварЗаказа Из ТоварыЗаказа Цикл
				
				// Ищем номенклатуру в таб. части товаров заказа
				СтрокиЗаказа = ДокЗаказОбъект.Товары.НайтиСтроки(Новый Структура("Номенклатура",ТоварЗаказа.Номенклатура));
				
				Если СтрокиЗаказа.Количество() Тогда
					
					// Номенклатура найдена.
					// Итак, есть ТЗ "ТоварыЗаказа", в которой для каждой позиции номенклатуры написано "Количество" и "Количество отгрузить"
					// и есть табличная часть "Товары" документа заказа, в которой есть все эти номенклатурные позиции, но вероятно не сгруппированные.
					
					ИспСтрок = 1; // Сколько строк используется в ТЧ "Товары" для каждой номенклатуры из ТЗ "ТоварыЗаказа".
					
					Если ТоварЗаказа.Количество <= ТоварЗаказа.КоличествоОтгрузить Тогда
						// Случай, когда отгружаем все количество.
						// То есть в найденной строке тч "Товары" устанавливаем вариант обеспечения "Отгрузить" и все количество для отгрузки.
						// также запоминаем код строки в ТЗ "ТоварыЗаказа"(понадобится для построчной связи заказа и передачи).
						ТекСтрока = СтрокиЗаказа[0];
						ТекСтрока.ВариантОбеспечения = Перечисления.ВариантыОбеспечения.Отгрузить;
						ТекСтрока.Количество = ТоварЗаказа.Количество;
						Коэф = питОбщегоНазначения.ПолучитьКоэффициентУпаковки(ТекСтрока.Номенклатура,ТекСтрока.Упаковка);
						Коэф = ?(Коэф = 0, 1, Коэф);
						ТекСтрока.КоличествоУпаковок = ТекСтрока.Количество / Коэф;
						ТоварЗаказа.КодСтроки = ТекСтрока.КодСтроки;
						
					ИначеЕсли ТоварЗаказа.КоличествоОтгрузить = 0 Тогда
						
						// Случай, когда не надо ничего отгружать, в найденной строке тч "Товары" 
						// устанавливаем вариант обеспечения "Требуется" и общее количество товара.
						ТекСтрока = СтрокиЗаказа[0];
						ТекСтрока.ВариантОбеспечения = Перечисления.ВариантыОбеспечения.КОбеспечению;
						ТекСтрока.Количество = ТоварЗаказа.Количество;
						Коэф = питОбщегоНазначения.ПолучитьКоэффициентУпаковки(ТекСтрока.Номенклатура,ТекСтрока.Упаковка);
						Коэф = ?(Коэф = 0, 1, Коэф);
						ТекСтрока.КоличествоУпаковок = ТекСтрока.Количество / Коэф;
						
					Иначе
						
						// Случай, когда передаем в производство меньше, чем указано в заказе.
						// Поэтому часть товара необходимо отгрузить, а часть - оставить в статусе "Требуется".
						// Для этого будем для данной номенклатуры использовать две строки в ТЧ "Товары".
						ИспСтрок = 2;
						ТекСтрока = СтрокиЗаказа[0];
						ТекСтрока.ВариантОбеспечения = Перечисления.ВариантыОбеспечения.КОбеспечению;
						ТекСтрока.Количество = ТоварЗаказа.Количество - ТоварЗаказа.КоличествоОтгрузить;
						Коэф = питОбщегоНазначения.ПолучитьКоэффициентУпаковки(ТекСтрока.Номенклатура,ТекСтрока.Упаковка);
						Коэф = ?(Коэф = 0, 1, Коэф);
						ТекСтрока.КоличествоУпаковок = ТекСтрока.Количество / Коэф;
						
						// Если второй строки нет, то создаем ее копированием.
						Если СтрокиЗаказа.Количество() > 1 Тогда
							ТекСтрока2 = СтрокиЗаказа[1];
						Иначе
							ТекСтрока2 = ДокЗаказОбъект.Товары.Добавить();
							ЗаполнитьЗначенияСвойств(ТекСтрока2, ТекСтрока);
						КонецЕсли;
						
						// Устанавливаем статус отгрузки.
						ТекСтрока2.ВариантОбеспечения = Перечисления.ВариантыОбеспечения.Отгрузить;
						ТекСтрока2.Количество = ТоварЗаказа.КоличествоОтгрузить;
						Коэф = питОбщегоНазначения.ПолучитьКоэффициентУпаковки(ТекСтрока2.Номенклатура,ТекСтрока2.Упаковка);
						Коэф = ?(Коэф = 0, 1, Коэф);
						ТекСтрока2.КоличествоУпаковок = ТекСтрока2.Количество / Коэф;
						
						// Запоминаем код строки отгружаемого товара.
						ТоварЗаказа.КодСтроки = ТекСтрока2.КодСтроки;
						
					КонецЕсли;
					
				КонецЕсли;
				
				// Лишние найденные строки ТЧ "Товары" записываем в массив для удаления.
				Для Сч = ИспСтрок По СтрокиЗаказа.Количество()-1 Цикл
					МассивСтрокДляУдаления.Добавить(СтрокиЗаказа[Сч]);
				КонецЦикла;
				
			КонецЦикла; // ТоварыЗаказа
			
			// Удаляем накопленные строки для удаления
			Для каждого СтрокаДляУдаления Из МассивСтрокДляУдаления Цикл
				ДокЗаказОбъект.Товары.Удалить(СтрокаДляУдаления);
			КонецЦикла;
			
			// Связываем код строки товаров для передачи и товаров заказа.
			Для каждого ТоварДляПередачи Из ТоварыДляПередачи Цикл
				
				НайденныйТоварЗаказа = ТоварыЗаказа.Найти(ТоварДляПередачи.Номенклатура, "Номенклатура");
				Если НЕ НайденныйТоварЗаказа = Неопределено Тогда
					ТоварДляПередачи.КодСтроки = НайденныйТоварЗаказа.КодСтроки;
				КонецЕсли;
				
			КонецЦикла;
			
			// Записываем измененный документ заказа.
			Попытка
				
				Если ДокПередачаМатериаловОбъект.Проведен Тогда
					ДокПередачаМатериаловОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
					ДокПередачаМатериаловОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
				КонецЕсли;
				
				ДокЗаказОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
				ДокЗаказОбъект.Записать(РежимЗаписиДокумента.Проведение); // ?Режим записи?
			Исключение
				ТекстОшибки = ТекстОшибки + "
				|Ошибка связи документа """ + ДокПередачаМатериаловОбъект.Метаданные().Представление() + """
				| с документом """+ДокЗаказОбъект.Метаданные().Представление()+"""
				|по причине: <"+ОписаниеОшибки()+">";
				Возврат Ложь;
			КонецПопытки;
			
			/////////////////////////////////////////////////////////////////
			// Изменение данных объекта "Передача материалов в производство"
			
			// Флаг передачи по распоряжению(распоряжением является заказ материалов в производство, 
			// который мы только что подготовили для связи).
			ДокПередачаМатериаловОбъект.ПередачаПоРаспоряжениям = Истина;
			ДокПередачаМатериаловОбъект.Распоряжение = ДокЗаказОбъект.Ссылка;
			
			// Обходим ТЧ "Товары" и связываем код строки товара, если товара нет в заказе, то код строки - 0.
			// Также устанавливается ссылка на распоряжение.
			Для каждого ТекСтрокаПередача Из ДокПередачаМатериаловОбъект.Товары Цикл
				
				СтрокиДляПередачи = ТоварыДляПередачи.НайтиСтроки(Новый Структура("Номенклатура, ЕстьЗаказ",ТекСтрокаПередача.Номенклатура, Истина));
				Если СтрокиДляПередачи.Количество() Тогда
					ТекСтрокаПередача.КодСтроки = СтрокиДляПередачи[0].КодСтроки;
				Иначе
					ТекСтрокаПередача.КодСтроки = 0;
				КонецЕсли;
				
				ТекСтрокаПередача.Распоряжение = ДокЗаказОбъект.Ссылка;
				
			КонецЦикла; // Все. Документ "Передача материалов в производство" связан и готов к записи.
			
		Иначе // Отвязать
			
			/////////////////////////////////////////////////////////////////
			// Изменение данных объекта "Передача материалов в производство"
			
			// Убираем передачу по распоряжениям.
			ДокПередачаМатериаловОбъект.ПередачаПоРаспоряжениям = Ложь;
			ДокПередачаМатериаловОбъект.Распоряжение = Неопределено;
			
			// Обнуляем код строки и ссылку на распоряжение.
			Для каждого ТекСтрокаПередача Из ДокПередачаМатериаловОбъект.Товары Цикл
				
				ТекСтрокаПередача.КодСтроки = 0;
				ТекСтрокаПередача.Распоряжение = Неопределено;
				
			КонецЦикла;
			
			/////////////////////////////////////////////////////////////////
			// Изменение данных объекта "Заказ материалов в производство"
			
			МассивСтрокДляУдаления.Очистить();
			
			// Статус возвращаем на "К обеспечению"
			ДокЗаказОбъект.Статус = Перечисления.СтатусыЗаказовМатериаловВПроизводство.КВыполнению;
			
			// Обходим таблицу товаров заказа, ищем номенклатуру в ТЧ.
			Для каждого ТоварЗаказа Из ТоварыЗаказа Цикл
				
				СтрокиЗаказа = ДокЗаказОбъект.Товары.НайтиСтроки(Новый Структура("Номенклатура",ТоварЗаказа.Номенклатура));
				Если СтрокиЗаказа.Количество() Тогда
					
					// Нменклатура найдена. Модифицируем первую найденную строку, устанавливая статус "К обеспечению"
					// и общее количество, остальные строки по данной номенклатурной позиции добавляем в массив для удаления.
					ТекСтрока = СтрокиЗаказа[0];
					ТекСтрока.ВариантОбеспечения = Перечисления.ВариантыОбеспечения.КОбеспечению;
					ТекСтрока.Количество = ТоварЗаказа.Количество;
					Коэф = питОбщегоНазначения.ПолучитьКоэффициентУпаковки(ТекСтрока.Номенклатура,ТекСтрока.Упаковка);
					Коэф = ?(Коэф = 0, 1, Коэф);
					ТекСтрока.КоличествоУпаковок = ТекСтрока.Количество / Коэф;
					
					Для Сч = 1 По СтрокиЗаказа.Количество()-1 Цикл
						МассивСтрокДляУдаления.Добавить(СтрокиЗаказа[Сч]);
					КонецЦикла;
					
				КонецЕсли;
				
			КонецЦикла;
			
			// Удаляем ненужные строки.
			Для каждого СтрокаДляУдаления Из МассивСтрокДляУдаления Цикл
				ДокЗаказОбъект.Товары.Удалить(СтрокаДляУдаления);
			КонецЦикла;
			
			// Все, документ заказ готов к записи.
			// Но в случае с отвязыванием нам необходимо проводить его только после записи 
			// передачи материалов в производство. 
			// Поэтому пишем объект в структуру и далее по коду не забываем его записать.
			СтруктураПараметров.Вставить("ДокЗаказОбъект", ДокЗаказОбъект);
			СтруктураПараметров.Вставить("ДозаписатьЗаказ", Истина);
			
		КонецЕсли;
		
	Иначе
		// Значит по плану меню нет проведенного "Заказа на производство", значит и связь никакую не делаем
		Возврат Истина;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции // СвязатьОтвязатьПередачуВПроизводствоСЗаказомНаПроизводство()

// Функция формирует документ "Движение продукции и материалов" из разрешенных цеховых кладовых или обновляет существующие.
//
// Параметры:
//  ДокументВыпускБлюд		 - ДокументСсылка	 - Ссылка на документ "Выпуск блюд", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьДвижениеПродукцииИзРазрешенныхКладовыхПоВыпускуБлюд22(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки, ОтложенноеФормирование = Ложь)
	
	//Возврат Истина;
	
	ФормироватьДвижениеПродукции = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питПеремещатьБлюдаСРазрешенныхКладовых");
	
	НовыйДокументДвижениеПродукции = Ложь;
	
	//+БазовоеСмещение
	Если НЕ СтруктураПараметров.Свойство("питСмещатьДатыТиповыхДокументов") Тогда
		СтруктураПараметров.Вставить("питСмещатьДатыТиповыхДокументов", питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питСмещатьДатыТиповыхДокументов"));
	КонецЕсли;
	БазовоеСмещение = 0;
	Если СтруктураПараметров.питСмещатьДатыТиповыхДокументов Тогда
		СтрокиСмещение = СтруктураПараметров.ТаблицаПорядокПроведенияТиповыхДокументовВыпускаБлюд.НайтиСтроки(
		Новый Структура("ИмяТиповогоДокумента,ПричинаТиповогоДокумента", "ДвижениеПродукцииИМатериалов", 2));
		Если СтрокиСмещение.Количество() Тогда
			БазовоеСмещение = СтрокиСмещение[0].БазовоеСмещение;
		КонецЕсли;
	КонецЕсли;
	//-БазовоеСмещение
	
	Если СтруктураПараметров.Свойство("ДокументыОбъектыДвижениеИзРазрешенныхЦехов") Тогда
		
		// Уже ранее получали документ излишков и запомнили его, чтобы не делать еще раз запрос.
		ТекДокументыОбъекты = СтруктураПараметров.ДокументыОбъектыДвижениеИзРазрешенныхЦехов;
		
	Иначе
		
		Запрос = Новый Запрос;
		
		// Поиск существующих документов "Движение продукции и материалов", предназначенных для перемещения с разрешенных цехов(индекс - 2),
		// связанных с текущим "Выпуском блюд".
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	питТиповыеДокументы.ТиповойДокумент
		|ПОМЕСТИТЬ втДокументыВыпускПродукции
		|ИЗ
		|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
		|ГДЕ
		|	питТиповыеДокументы.ДокументОбщепит = &Документпит
		|	И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.ДвижениеПродукцииИМатериалов
		|	И питТиповыеДокументы.ПричинаТиповогоДокумента = 2
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	втДокументыВыпускПродукции.ТиповойДокумент
		|ИЗ
		|	втДокументыВыпускПродукции КАК втДокументыВыпускПродукции
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ДвижениеПродукцииИМатериалов КАК ДвижениеПродукцииИМатериалов
		|		ПО втДокументыВыпускПродукции.ТиповойДокумент = ДвижениеПродукцииИМатериалов.Ссылка
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДвижениеПродукцииИМатериалов.ПометкаУдаления";
		Запрос.УстановитьПараметр("Документпит",				ДокументВыпускБлюд);
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		ТекДокументыОбъекты = Новый Массив;
		ТекДокументОбъект = Неопределено;
		
		Если ФормироватьДвижениеПродукции Тогда
			// Если документ найден, то получаем объект иначе создаем новый.
			Если Выборка.Количество() Тогда
				Пока Выборка.Следующий() Цикл
					ТекДокументОбъект = Выборка.ТиповойДокумент.ПолучитьОбъект();
					ТекДокументыОбъекты.Добавить(ТекДокументОбъект);
				КонецЦикла;
			Иначе
				ТекДокументОбъект = Документы.ДвижениеПродукцииИМатериалов.СоздатьДокумент();
				ТекДокументыОбъекты.Добавить(ТекДокументОбъект);
				НовыйДокументДвижениеПродукции = Истина;
			КонецЕсли;
		Иначе
			Если Выборка.Количество() Тогда
				Пока Выборка.Следующий() Цикл
					// Сейчас не формируем излишки, но уже ранее был создан такой документ
					ТекДокументСсылка = Выборка.ТиповойДокумент;
					
					//+ОтложенноеПроведение
					Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
						ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.ОтвязатьТиповойДокумент				, ТекДокументСсылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
						СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
						Если НЕ ВсеОк Тогда 
							Возврат ВсеОк;
						КонецЕсли;
					Иначе
					//-ОтложенноеПроведение
						
						Если НЕ УдалитьСвязьТиповогоДокументаСДокументомПит(ТекДокументСсылка, ДокументВыпускБлюд, ТекстОшибки) Тогда
							Возврат Ложь;
						КонецЕсли;
						
					КонецЕсли;
					
				КонецЦикла;
			КонецЕсли;
			Возврат Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	ТекДокументОбъект = ТекДокументыОбъекты[0];
	
	// Определение параметров записи.
	ПараметрыЗаписи0 = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокументВыпускБлюд.Проведен,ДокументВыпускБлюд.ПометкаУдаления,
		ТекДокументОбъект.Проведен,ТекДокументОбъект.ПометкаУдаления,СтруктураПараметров);
	
	// Определение режима записи
	ТекРежимЗаписи0 = ПараметрыЗаписи0.РежимЗаписи;
	
	Если НЕ ОтложенноеФормирование И ТекРежимЗаписи0 = РежимЗаписиДокумента.ОтменаПроведения Тогда
		Если НЕ НовыйДокументДвижениеПродукции Тогда
			// В случае отмены проведения оприходованием занимаемся позже, в самую последнюю очередь, 
			// т.к. он делаем движения в плюс по свободным остаткам и отменять их нужно после отмены всех остальных типовых документов.
			СтруктураПараметров.Вставить("ОтложитьФормированиеДвиженияПродукцииИзРазрешенныхКладовых", Истина); 
			// Запоминаем, чтобы потом второй раз не получать
			СтруктураПараметров.Вставить("ДокументыОбъектыДвижениеИзРазрешенныхЦехов", ТекДокументыОбъекты); 
		КонецЕсли;
		Возврат Истина;
	КонецЕсли;
	
	Для каждого ТекДок Из ТекДокументыОбъекты Цикл
		
		// Определение параметров записи.
		ТекДокПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокументВыпускБлюд.Проведен,ДокументВыпускБлюд.ПометкаУдаления,
		ТекДок.Проведен,ТекДок.ПометкаУдаления,СтруктураПараметров);
		
		// Определение режима записи
		ТекДокТекРежимЗаписи = ТекДокПараметрыЗаписи.РежимЗаписи;
		
		Если ТекДокПараметрыЗаписи.НужнаУстановкаПометкиУдаления И НЕ НовыйДокументДвижениеПродукции Тогда
			
			//+ОтложенноеПроведение
			Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
				ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ПолучитьТекущееДействиеПоПометкеУдаленияТиповогоДокумента(ТекДокПараметрыЗаписи.ПометкаУдаления), ТекДок.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
				СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
				Если НЕ ВсеОк Тогда 
					Возврат ВсеОк;
				КонецЕсли;
			Иначе
			//-ОтложенноеПроведение
				
				Попытка
					ТекДок.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
					ТекДок.УстановитьПометкуУдаления(ТекДокПараметрыЗаписи.ПометкаУдаления);
				Исключение
					ТекстОшибки = ТекстОшибки + "
					|Ошибка при установке пометки удаления """ + ТекДок.Метаданные().Представление() + """
					| по документу Общепит """+ДокументВыпускБлюд+"""
					|по причине: <"+ОписаниеОшибки()+">";
					Возврат Ложь;
				КонецПопытки;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	ТекущийИндексТиповогоДокумента = 0;
	
	///
	// ПОЛУЧАЕМ МЕСТА, ОТКУДА МОЖНО БЫЛО БЫ ПЕРЕМЕСТИТЬ НОМЕНКЛАТУРУ.
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питВыпускБлюдТовары.Номенклатура КАК Номенклатура,
	|	питВыпускБлюдТовары.Характеристика КАК Характеристика,
	|	питВыпускБлюдТовары.Серия КАК Серия,
	|	питВыпускБлюдТовары.Назначение КАК Назначение,
	|	питВыпускБлюдТовары.Упаковка КАК Упаковка,
	|	питВыпускБлюдТовары.Количество КАК Количество,
	|	питВыпускБлюдТовары.КоличествоУпаковок КАК КоличествоУпаковок,
	|	питВыпускБлюдТовары.Рецептура КАК Рецептура
	|ПОМЕСТИТЬ втТовары
	|ИЗ
	|	Документ.питВыпускБлюд.Товары КАК питВыпускБлюдТовары
	|ГДЕ
	|	питВыпускБлюдТовары.Ссылка = &Ссылка
	|	И питВыпускБлюдТовары.ПриготовлениеЗапрещено = ИСТИНА
	|	И питВыпускБлюдТовары.Номенклатура.ТипНоменклатуры В (&СкладскиеТипыНоменклатуры)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	питВыпускБлюдИнгредиенты.Ингредиент,
	|	питВыпускБлюдИнгредиенты.Характеристика,
	|	питВыпускБлюдИнгредиенты.Серия,
	|	питВыпускБлюдИнгредиенты.Назначение КАК Назначение,
	|	питВыпускБлюдИнгредиенты.УпаковкаИнгредиента,
	|	питВыпускБлюдИнгредиенты.КоличествоИнгредиентаФакт,
	|	питВыпускБлюдИнгредиенты.КоличествоУпаковокИнгредиентаФакт,
	|	питВыпускБлюдИнгредиенты.РецептураАвтопередела
	|ИЗ
	|	Документ.питВыпускБлюд.Ингредиенты КАК питВыпускБлюдИнгредиенты
	|ГДЕ
	|	питВыпускБлюдИнгредиенты.Ссылка = &Ссылка
	|	И питВыпускБлюдИнгредиенты.ИзАвтопеределов = ЛОЖЬ
	|	И питВыпускБлюдИнгредиенты.РецептураАвтопередела <> ЗНАЧЕНИЕ(Документ.питРецептура.ПустаяСсылка)
