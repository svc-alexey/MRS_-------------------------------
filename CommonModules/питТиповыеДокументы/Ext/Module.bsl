	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	питРецептураСоответствиеСвойств.СвойствоМатериала КАК СвойствоМатериала,
	|	питРецептураСоответствиеСвойств.СвойствоПродукции КАК СвойствоПродукции,
	|	питРецептураСоответствиеСвойств.ЗначениеСвойства КАК ЗначениеСвойства,
	|	питРецептураСоответствиеСвойств.АлгоритмРасчетаЗначения КАК АлгоритмРасчетаЗначения,
	|	питРецептураСоответствиеСвойств.СпособПодбораЗначения КАК СпособПодбораЗначения,
	|	питРецептураСоответствиеСвойств.КлючСвязи КАК КлючСвязи
	|ИЗ
	|	Документ.питРецептура.СоответствиеСвойств КАК питРецептураСоответствиеСвойств
	|ГДЕ
	|	питРецептураСоответствиеСвойств.Ссылка = &Ссылка";
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("Ссылка", ДокРецептура.Ссылка);
	
	РезультатПакет = Запрос.ВыполнитьПакет();
	
	//+ПараметризацияРецептур
	ТаблицаСвойств = РезультатПакет[3].Выгрузить();
	ТаблицаСвойствПустая = ТаблицаСвойств.Количество() = 0;
	//-ПараметризацияРецептур
	
	//+АвтовыборНоменклатуры
	ТаблицаСвойствАвтовыбор			= РезультатПакет[4].Выгрузить();
	ТаблицаСвойствАвтовыборПустая	= ТаблицаСвойствАвтовыбор.Количество() = 0;
	//-АвтовыборНоменклатуры
	
	// Массив уже перезаполненных строк ТЧ.
	ПерезаполненныеСтроки = Новый Массив;
	ЭтоНоваяСтрока = Истина;
	
	// Обход таб. части и заполнение таб. частей спецификации.
	Выборка = РезультатПакет[0].Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Если ДокРецептура.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.РецептураРазделка Тогда
			НовСтрока = Спецификация.ВыходныеИзделия.Добавить();
			НовСтрока.Номенклатура			= Выборка.Номенклатура;
			НовСтрока.Характеристика		= Выборка.Характеристика;
			НовСтрока.Упаковка				= Выборка.УпаковкаНоменклатуры;
			НовСтрока.КоличествоУпаковок	= Выборка.КоличествоУпаковокНоменклатуры;
			//+25
			Если НовСтрока.КлючСвязи = ПустойУИД Тогда
				НовСтрока.КлючСвязи				= Новый УникальныйИдентификатор;
			КонецЕсли;
			НовСтрока.СпособАвтовыбораНоменклатуры		= Перечисления.СпособыАвтовыбораНоменклатуры.УказываетсяВНСИ;
			НовСтрока.СпособАвтовыбораХарактеристики	= Перечисления.СпособыАвтовыбораХарактеристики.УказываетсяВНСИ;
			НовСтрока.ВидНоменклатуры					= Выборка.ВидНоменклатуры;
			//-25
			НовСтрока.ДоляСтоимости			= Выборка.ПроцентСебестоимости;
			Продолжить;
		КонецЕсли;
		
		///////////////////////////////////////////////
		// +Поиск строки в ТЧ.
		ЭтоНоваяСтрока = Истина;
		Если НЕ ЭтоНоваяСпецификация Тогда
			// Поиск в существующей спецификации строки, соответствующей текущей строке рецептуры.
			//+ПараметризацияРецептур
			СП = Новый Структура("КлючСвязи");
			//-ПараметризацияРецептур
			ЗаполнитьЗначенияСвойств(СП, Выборка);
			НайденныеСтроки = Спецификация.МатериалыИУслуги.НайтиСтроки(СП);
			НайденныеСтрокиВрем = Новый Массив;
			Для Инд = 0 По НайденныеСтроки.Количество()-1 Цикл
				Если ПерезаполненныеСтроки.Найти(НайденныеСтроки[Инд]) = Неопределено Тогда
					НайденныеСтрокиВрем.Добавить(НайденныеСтроки[Инд]);
				КонецЕсли;
			КонецЦикла;
			НайденныеСтроки = НайденныеСтрокиВрем;
			
			КоличествоНайденных = НайденныеСтроки.Количество();
			Если КоличествоНайденных = 1 Тогда
				// Найдена одна строка, ее и перезаполняем.
				НовСтрока = НайденныеСтроки[0];
				ЭтоНоваяСтрока = Ложь;
			ИначеЕсли КоличествоНайденных > 1 Тогда
				// Найдено несколько строк
				НовСтрока = НайтиСтрокуСМинимальнымЭтапом(НайденныеСтроки);
				ЭтоНоваяСтрока = Ложь;
			Иначе
				// Ничего не найдено, добавить новую строку
				НовСтрока = Спецификация.МатериалыИУслуги.Добавить();
			КонецЕсли;
		Иначе
			// Ничего не найдено, добавить новую строку
			НовСтрока = Спецификация.МатериалыИУслуги.Добавить();
		КонецЕсли;
		// -Поиск строки в ТЧ.
		//////////////////////////////////////////////////////////////
		
		НовСтрока.Номенклатура			= Выборка.Номенклатура;
		НовСтрока.Характеристика		= Выборка.Характеристика;
		НовСтрока.Упаковка				= Выборка.УпаковкаНоменклатуры;
		НовСтрока.КоличествоУпаковок	= Выборка.КоличествоУпаковокНоменклатуры;
		//+25
		//НовСтрока.Количество			= Выборка.КоличествоНоменклатуры;
		//-25
		НовСтрока.СтатьяКалькуляции		= ?(ЗначениеЗаполнено(Выборка.СтатьяКалькуляции), Выборка.СтатьяКалькуляции,ДокРецептура.СтатьяКалькуляции);
		НовСтрока.АлгоритмРасчетаКоличества	= ?(ЗначениеЗаполнено(Выборка.АлгоритмРасчетаКоличества), Строка(Выборка.КоличествоУпаковокНоменклатуры), "");
		//+25
		НовСтрока.АлгоритмРасчетаКоличестваИсторияПереходаНаНовыеФормулы = НовСтрока.АлгоритмРасчетаКоличества;
		//-25
		//+АвтовыборНоменклатуры
		
		Если Не ЗначениеЗаполнено(Выборка.СпособАвтовыбораНоменклатуры) Тогда
			НовСтрока.СпособАвтовыбораНоменклатуры = Перечисления.СпособыАвтовыбораНоменклатуры.УказываетсяВНСИ;
		Иначе	
			НовСтрока.СпособАвтовыбораНоменклатуры		= Выборка.СпособАвтовыбораНоменклатуры; 
		КонецЕсли;
		Если Не ЗначениеЗаполнено(Выборка.СпособАвтовыбораХарактеристики) Тогда
			НовСтрока.СпособАвтовыбораХарактеристики = Перечисления.СпособыАвтовыбораХарактеристики.УказываетсяВНСИ;
		Иначе	
			НовСтрока.СпособАвтовыбораХарактеристики	= Выборка.СпособАвтовыбораХарактеристики;
		КонецЕсли;
		НовСтрока.СвойствоСодержащееНоменклатуру	= Выборка.СвойствоСодержащееНоменклатуру;
		НовСтрока.АлгоритмАвтовыбораХарактеристики	= Выборка.АлгоритмАвтовыбораХарактеристики;
		//-АвтовыборНоменклатуры
		Если ЭтоНоваяСтрока Тогда
			// Значения по умолчанию для реквизитов ТЧ.
			НовСтрока.КлючСвязи							= Выборка.КлючСвязи;
			НовСтрока.ПроизводитсяВПроцессе				= Ложь;
			Если ОбщегоНазначения.ЕстьРеквизитОбъекта("СпособПолученияМатериала", мМетаданныеТЧМатериалыИУслуги) Тогда
				НовСтрока.СпособПолученияМатериала			= Перечисления.СпособыПолученияМатериаловВСпецификации.Обеспечивать;
			КонецЕсли;
			НовСтрока.ИсточникПолученияПолуфабриката	= Справочники.РесурсныеСпецификации.ПустаяСсылка();
		КонецЕсли;
		
		//+ПараметризацияРецептур
		Если НЕ ТаблицаСвойствПустая Тогда
			Если НЕ ЭтоНоваяСтрока Тогда
				// Удалить строки отбора свойств, которые были в специцикации для данной строки.
				СтрокиСвойствСпец = Спецификация.ОтборПоСвойствам.НайтиСтроки(Новый Структура("КлючСвязи", Выборка.КлючСвязи));
				Для каждого ТекСтрокаСвойствСпец Из СтрокиСвойствСпец Цикл
					Спецификация.ОтборПоСвойствам.Удалить(ТекСтрокаСвойствСпец);
				КонецЦикла;
			КонецЕсли;
			// Заполнить строки отбора свойств в спецификации из рецептуры.
			СтрокиСвойств = ТаблицаСвойств.НайтиСтроки(Новый Структура("КлючСвязи", Выборка.КлючСвязи));
			Для каждого ТекСтрокаСвойств Из СтрокиСвойств Цикл
				НовСтрокаСвойствСпец = Спецификация.ОтборПоСвойствам.Добавить();
				ЗаполнитьЗначенияСвойств(НовСтрокаСвойствСпец, ТекСтрокаСвойств);
			КонецЦикла;
		КонецЕсли;
		//-ПараметризацияРецептур
		
		//+АвтовыборНоменклатуры
		Если НЕ ТаблицаСвойствАвтовыборПустая Тогда
			Если НЕ ЭтоНоваяСтрока Тогда
				// Удалить строки отбора свойств, которые были в специцикации для данной строки.
				СтрокиСвойствСпец = Спецификация.СоответствиеСвойств.НайтиСтроки(Новый Структура("КлючСвязи", Выборка.КлючСвязи));
				Для каждого ТекСтрокаСвойствСпец Из СтрокиСвойствСпец Цикл
					Спецификация.СоответствиеСвойств.Удалить(ТекСтрокаСвойствСпец);
				КонецЦикла;
			КонецЕсли;
			// Заполнить строки отбора свойств в спецификации из рецептуры.
			СтрокиСвойств = ТаблицаСвойствАвтовыбор.НайтиСтроки(Новый Структура("КлючСвязи", Выборка.КлючСвязи));
			Для каждого ТекСтрокаСвойств Из СтрокиСвойств Цикл
				НовСтрокаСвойствСпец = Спецификация.СоответствиеСвойств.Добавить();
				ЗаполнитьЗначенияСвойств(НовСтрокаСвойствСпец, ТекСтрокаСвойств);
			КонецЦикла;
		КонецЕсли;
		//-АвтовыборНоменклатуры
		
		Если ЗначениеЗаполнено(Выборка.Рецептура) Тогда
			
			// Получение спецификации производимого в процессе изделия.
			СпецификацияАвтопередел = Неопределено;
			ПараметрыПолучения = Новый Структура("УпорядочитьПоДатеИНомеру, ФильтрПоТипу", Ложь, "Справочник.РесурсныеСпецификации");
			НайтиТиповойДокументДляДокументапит(Выборка.Рецептура, СпецификацияАвтопередел, , ПараметрыПолучения);
			
			Если НЕ СпецификацияАвтопередел = Неопределено Тогда
				НовСтрока.ПроизводитсяВПроцессе		= Истина;
				Если ОбщегоНазначения.ЕстьРеквизитОбъекта("СпособПолученияМатериала", мМетаданныеТЧМатериалыИУслуги) Тогда
					НовСтрока.СпособПолученияМатериала	= Перечисления.СпособыПолученияМатериаловВСпецификации.ПроизвестиПоСпецификации; // по умолчанию
				КонецЕсли;
				НовСтрока.СтатьяКалькуляции			= Справочники.СтатьиКалькуляции.ПолуфабрикатыПроизводимыеВПроцессе;
				НовСтрока.ИсточникПолученияПолуфабриката = СпецификацияАвтопередел;
			КонецЕсли;
			
		КонецЕсли;
		
		ПерезаполненныеСтроки.Добавить(НовСтрока);
		
	КонецЦикла;
	// Удаление строк, которые не перезаполнялись(они не актуальны).
	СтрокиУдалить = Новый Массив;
	Для каждого ТекСтрокаТЧ Из Спецификация.МатериалыИУслуги Цикл
		Если ПерезаполненныеСтроки.Найти(ТекСтрокаТЧ) = Неопределено Тогда
			СтрокиУдалить.Добавить(ТекСтрокаТЧ);
		КонецЕсли;
	КонецЦикла;
	Для каждого ТекСтрокаУдалить Из СтрокиУдалить Цикл
		Спецификация.МатериалыИУслуги.Удалить(ТекСтрокаУдалить);
	КонецЦикла;
	
	Если ДокРецептура.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.РецептураПриготовление Тогда
		// В ТЧ "Выходные измелия" будет 1 строка с номенклатурой из шапки рецептуры.
		НовСтрока = Спецификация.ВыходныеИзделия.Добавить();
		НовСтрока.Номенклатура			= ДокРецептура.Номенклатура;
		НовСтрока.Характеристика		= ДокРецептура.Характеристика;
		НовСтрока.Упаковка				= ДокРецептура.Упаковка;
		НовСтрока.КоличествоУпаковок	= ДокРецептура.КоличествоУпаковок;
		//+25
		//НовСтрока.Количество			= ДокРецептура.Количество;
		Если НовСтрока.КлючСвязи = ПустойУИД Тогда
			НовСтрока.КлючСвязи				= Новый УникальныйИдентификатор;
		КонецЕсли;
		НовСтрока.СпособАвтовыбораНоменклатуры		= Перечисления.СпособыАвтовыбораНоменклатуры.УказываетсяВНСИ;
		НовСтрока.СпособАвтовыбораХарактеристики	= Перечисления.СпособыАвтовыбораХарактеристики.УказываетсяВНСИ;
		НовСтрока.ВидНоменклатуры					= Спецификация.ОсновноеИзделиеВидНоменклатуры;
		//-25
		НовСтрока.ДоляСтоимости			= 1; // В ТЧ "Выходные изделия всегда 1 строка"
	КонецЕсли;
	
	// ТРУДОЗАТРАТЫ
	ПерезаполненныеСтроки = Новый Массив;
	ЭтоНоваяСтрока = Истина;
	Если НЕ РезультатПакет[1].Пустой() Тогда
		ВыборкаТрудозатрат = РезультатПакет[1].Выбрать();
		Пока ВыборкаТрудозатрат.Следующий() Цикл
			
			///////////////////////////////////////////////
			// +Поиск строки в ТЧ.
			ЭтоНоваяСтрока = Истина;
			Если НЕ ЭтоНоваяСпецификация Тогда
				// Поиск в существующей спецификации строки, соответствующей текущей строке рецептуры.
				СП = Новый Структура("ВидРабот,СтатьяКалькуляции");
				ЗаполнитьЗначенияСвойств(СП, ВыборкаТрудозатрат);
				НайденныеСтроки = Спецификация.Трудозатраты.НайтиСтроки(СП);
				НайденныеСтрокиВрем = Новый Массив;
				Для Инд = 0 По НайденныеСтроки.Количество()-1 Цикл
					Если ПерезаполненныеСтроки.Найти(НайденныеСтроки[Инд]) = Неопределено Тогда
						НайденныеСтрокиВрем.Добавить(НайденныеСтроки[Инд]);
					КонецЕсли;
				КонецЦикла;
				НайденныеСтроки = НайденныеСтрокиВрем;
				
				КоличествоНайденных = НайденныеСтроки.Количество();
				Если КоличествоНайденных = 1 Тогда
					// Найдена одна строка, ее и перезаполняем.
					НовТрудозатрата = НайденныеСтроки[0];
					ЭтоНоваяСтрока = Ложь;
				ИначеЕсли КоличествоНайденных > 1 Тогда
					// Найдено несколько строк
					НовТрудозатрата = НайтиСтрокуСМинимальнымЭтапом(НайденныеСтроки);
					ЭтоНоваяСтрока = Ложь;
				Иначе
					// Ничего не найдено, добавить новую строку
					НовТрудозатрата = Спецификация.Трудозатраты.Добавить();
				КонецЕсли;
			Иначе
				// Ничего не найдено, добавить новую строку
				НовТрудозатрата = Спецификация.Трудозатраты.Добавить();
			КонецЕсли;
			// -Поиск строки в ТЧ.
			//////////////////////////////////////////////////////////////
			
			НовТрудозатрата.ВидРабот = ВыборкаТрудозатрат.ВидРабот;
			НовТрудозатрата.Количество = ВыборкаТрудозатрат.Количество;
			НовТрудозатрата.НазначениеРабот = ВыборкаТрудозатрат.НазначениеРабот;
			НовТрудозатрата.СтатьяКалькуляции = ВыборкаТрудозатрат.СтатьяКалькуляции;
			//+25
			Если НовТрудозатрата.КлючСвязи = ПустойУИД Тогда
				НовТрудозатрата.КлючСвязи = Новый УникальныйИдентификатор;
			КонецЕсли;
			//-25
			
			// Если этап не указан, то это означает, что используется для первого по порядку этапа.
			//НовТрудозатрата.Этап = ПроизводственныйПроцессОбъект;
			
			ПерезаполненныеСтроки.Добавить(НовТрудозатрата);
			
		КонецЦикла;
	КонецЕсли;
	// Удаление строк, которые не перезаполнялись(они не актуальны).
	СтрокиУдалить = Новый Массив;
	Для каждого ТекСтрокаТЧ Из Спецификация.Трудозатраты Цикл
		Если ПерезаполненныеСтроки.Найти(ТекСтрокаТЧ) = Неопределено Тогда
			СтрокиУдалить.Добавить(ТекСтрокаТЧ);
		КонецЕсли;
	КонецЦикла;
	Для каждого ТекСтрокаУдалить Из СтрокиУдалить Цикл
		Спецификация.Трудозатраты.Удалить(ТекСтрокаУдалить);
	КонецЦикла;
	
	// Побочные выпуски
	ПерезаполненныеСтроки = Новый Массив;
	ЭтоНоваяСтрока = Истина;
	Если НЕ РезультатПакет[2].Пустой() Тогда
		ВыборкаПобочные = РезультатПакет[2].Выбрать();
		Пока ВыборкаПобочные.Следующий() Цикл
			
			///////////////////////////////////////////////
			// +Поиск строки в ТЧ.
			ЭтоНоваяСтрока = Истина;
			Если НЕ ЭтоНоваяСпецификация Тогда
				// Поиск в существующей спецификации строки, соответствующей текущей строке рецептуры.
				СП = Новый Структура("Номенклатура,Характеристика,Упаковка");
				ЗаполнитьЗначенияСвойств(СП, ВыборкаПобочные);
				НайденныеСтроки = Спецификация.ВозвратныеОтходы.НайтиСтроки(СП);
				НайденныеСтрокиВрем = Новый Массив;
				Для Инд = 0 По НайденныеСтроки.Количество()-1 Цикл
					Если ПерезаполненныеСтроки.Найти(НайденныеСтроки[Инд]) = Неопределено Тогда
						НайденныеСтрокиВрем.Добавить(НайденныеСтроки[Инд]);
					КонецЕсли;
				КонецЦикла;
				НайденныеСтроки = НайденныеСтрокиВрем;
				
				КоличествоНайденных = НайденныеСтроки.Количество();
				Если КоличествоНайденных = 1 Тогда
					// Найдена одна строка, ее и перезаполняем.
					НовПобочное = НайденныеСтроки[0];
					ЭтоНоваяСтрока = Ложь;
				ИначеЕсли КоличествоНайденных > 1 Тогда
					// Найдено несколько строк
					НовПобочное = НайтиСтрокуСМинимальнымЭтапом(НайденныеСтроки, 999);
					ЭтоНоваяСтрока = Ложь;
				Иначе
					// Ничего не найдено, добавить новую строку
					НовПобочное = Спецификация.ВозвратныеОтходы.Добавить();
				КонецЕсли;
			Иначе
				// Ничего не найдено, добавить новую строку
				НовПобочное = Спецификация.ВозвратныеОтходы.Добавить();
			КонецЕсли;
			// -Поиск строки в ТЧ.
			//////////////////////////////////////////////////////////////
			
			НовПобочное.Номенклатура		= ВыборкаПобочные.Номенклатура;
			НовПобочное.Характеристика		= ВыборкаПобочные.Характеристика;
			НовПобочное.Упаковка			= ВыборкаПобочные.Упаковка;
			НовПобочное.КоличествоУпаковок	= ВыборкаПобочные.КоличествоУпаковок;
			НовПобочное.СтатьяКалькуляции	= ВыборкаПобочные.СтатьяКалькуляции;
			НовПобочное.СпособАвтовыбораНоменклатуры		= Перечисления.СпособыАвтовыбораНоменклатуры.УказываетсяВНСИ;
			НовПобочное.СпособАвтовыбораХарактеристики	= Перечисления.СпособыАвтовыбораХарактеристики.УказываетсяВНСИ;
			
			// Если этап не указан, то это означает, что используется для последнего по порядку этапа.
			НовПобочное.Этап = Неопределено;
			
			ПерезаполненныеСтроки.Добавить(НовПобочное);
			
		КонецЦикла;
	КонецЕсли;
	// Удаление строк, которые не перезаполнялись(они не актуальны).
	СтрокиУдалить = Новый Массив;
	Для каждого ТекСтрокаТЧ Из Спецификация.ВозвратныеОтходы Цикл
		Если ПерезаполненныеСтроки.Найти(ТекСтрокаТЧ) = Неопределено Тогда
			СтрокиУдалить.Добавить(ТекСтрокаТЧ);
		КонецЕсли;
	КонецЦикла;
	Для каждого ТекСтрокаУдалить Из СтрокиУдалить Цикл
		Спецификация.ВозвратныеОтходы.Удалить(ТекСтрокаУдалить);
	КонецЦикла;
	
	//////////////////////////////////
	// ЗАПИСЬ ЭТАПА ПРОИЗВОДСТВА
	
	Если НЕ Спецификация.МногоэтапныйПроизводственныйПроцесс Тогда
		
		//////////////////////////////////
		// Данные по производству
		
		ПроизводственныйПроцессОбъект = ПолучитьОбъектЭтапПроизводства(Спецификация.Ссылка, ЭтоНоваяСпецификация);
		
		ПроизводственныйПроцессОбъект.Владелец =		Спецификация.Ссылка;
		ПроизводственныйПроцессОбъект.Подразделение =	ДокРецептура.Подразделение;
		
		Если НЕ ЗначениеЗаполнено(ПроизводственныйПроцессОбъект.ЕдиницаИзмеренияДлительностиЭтапа) Тогда
			ПроизводственныйПроцессОбъект.ЕдиницаИзмеренияДлительностиЭтапа = Перечисления.ЕдиницыИзмеренияВремени.День;
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(ПроизводственныйПроцессОбъект.ЕдиницаИзмеренияПредварительногоБуфера) Тогда
			ПроизводственныйПроцессОбъект.ЕдиницаИзмеренияПредварительногоБуфера = Перечисления.ЕдиницыИзмеренияВремени.День;
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(ПроизводственныйПроцессОбъект.ЕдиницаИзмеренияЗавершающегоБуфера) Тогда
			ПроизводственныйПроцессОбъект.ЕдиницаИзмеренияЗавершающегоБуфера = Перечисления.ЕдиницыИзмеренияВремени.День;
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(ПроизводственныйПроцессОбъект.ЗанимаемаяМощность) Тогда
			ПроизводственныйПроцессОбъект.ЗанимаемаяМощность = 100;
		КонецЕсли;
		
		Если ЭтоНоваяСпецификация Тогда
			СсылкаНового = Справочники.РесурсныеСпецификации.ПолучитьСсылку();
			ПроизводственныйПроцессОбъект.Владелец = СсылкаНового;
			ПроизводственныйПроцессОбъект.ОбменДанными.Загрузка = Истина;
			Спецификация.УстановитьСсылкуНового(СсылкаНового);
		КонецЕсли;
		
		ПроизводственныйПроцессОбъект.ДополнительныеСвойства.Вставить("РазрешитьЗапись");
		ПроизводственныйПроцессОбъект.НомерЭтапа            = 1;
		ПроизводственныйПроцессОбъект.НомерСледующегоЭтапа  = 0;
		
		Если ПустаяСтрока(ПроизводственныйПроцессОбъект.Наименование) Тогда
			ИмяЭтапа = ?(ДокРецептура.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.РецептураРазделка, 
				"Производство", "Разборка");
			ПроизводственныйПроцессОбъект.Наименование = НСтр(СтрШаблон("ru = '%1'", ИмяЭтапа));
		КонецЕсли;
		
		Попытка
			ПроизводственныйПроцессОбъект.Записать();
		Исключение
			ТекстОшибки = ТекстОшибки + "
			|Ошибка записи справочника """ + Спецификация.Метаданные().Представление() + """
			| по документу Общепит """+ДокРецептура+"""
			|по причине: <"+ОписаниеОшибки()+">";
			Возврат Ложь;
		КонецПопытки;
		
	КонецЕсли;
	
	//////////////////////////////////
	// ЗАПИСЬ СПЕЦИФИКАЦИИ
	
	Попытка
		Спецификация.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
		Спецификация.Записать();
	Исключение
		ТекстОшибки = ТекстОшибки + "
		|Ошибка записи справочника """ + Спецификация.Метаданные().Представление() + """
		| по документу Общепит """+ДокРецептура+"""
		|по причине: <"+ОписаниеОшибки()+">";
		Возврат Ложь;
	КонецПопытки;
	
	// Добавление записи в результирующую таблицу в случае успешной записи документов.
	ДобавитьНовуюЗапись(ДокРецептура, Спецификация, тблСозданныеДокументы);
	
	Возврат ВсеОк;
	
КонецФункции

Функция НайтиСтрокуСМинимальнымЭтапом(НайденныеСтроки, ТекПорядокПустогоЭтапа = 0)
	
	// Массив этапов производства, по которым будем получать порядок.
	МассивСсылокЭтапов = Новый Массив;
	
	// Поиск строки с минимальным этапом.
	Для каждого ТекНайденнаяСтрока Из НайденныеСтроки Цикл
		Если ЗначениеЗаполнено(ТекНайденнаяСтрока.Этап) Тогда
			МассивСсылокЭтапов.Добавить(ТекНайденнаяСтрока.Этап);
		КонецЕсли;
	КонецЦикла;
	СоответствиеЭтапПорядок = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(МассивСсылокЭтапов, "НомерЭтапа");
	МинЭтап = Справочники.ЭтапыПроизводства.ПустаяСсылка();
	МинПорядокЭтап = 0;
	СчетчикСтрок = 0;
	СтрокаМинЭтап = Неопределено;
	Для каждого ТекНайденнаяСтрока Из НайденныеСтроки Цикл
		Если СчетчикСтрок = 0 Тогда
			МинЭтап = ТекНайденнаяСтрока.Этап;
			МинПорядокЭтап = СоответствиеЭтапПорядок.Получить(МинЭтап);
			Если МинПорядокЭтап = Неопределено Тогда
				МинПорядокЭтап = ТекПорядокПустогоЭтапа;
			КонецЕсли;
			СтрокаМинЭтап = ТекНайденнаяСтрока;
		Иначе
			ТекЭтап = ТекНайденнаяСтрока.Этап;
			ТекПорядокЭтап = СоответствиеЭтапПорядок.Получить(ТекЭтап);
			Если ТекПорядокЭтап = Неопределено Тогда
				ТекПорядокЭтап = ТекПорядокПустогоЭтапа;
			КонецЕсли;
			МинПорядокЭтап = Мин(МинПорядокЭтап, ТекПорядокЭтап);
			Если МинПорядокЭтап = ТекПорядокЭтап Тогда
				МинЭтап = ТекЭтап;
				СтрокаМинЭтап = ТекНайденнаяСтрока;
			КонецЕсли;
		КонецЕсли;
		СчетчикСтрок = СчетчикСтрок + 1;
	КонецЦикла;
	Возврат СтрокаМинЭтап;
	
КонецФункции


// Процедура по переданной ссылке на рецептуру ищет типовые элементы справочника "Ресурсные спецификации".
//  Если не находит, то создает для них пустой объект.
//
// Параметры:
//  ДокументРецептура			 - ДокументСсылка	 - Ссылка на документ, для которого ищем "Ресурсные спецификации".
//  выхСпецификация				 - СправочникОбъект	 - Справочник "Ресурсные спецификации".
//
Процедура ПолучитьСпецификациюПоРецептуре(ДокументРецептура, выхСпецификация = Неопределено)
	
	Запрос = Новый Запрос;
	
	// Поиск связанных с рецептурой спецификаций изделия.
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питТиповыеДокументы.ТиповойДокумент
	|ПОМЕСТИТЬ втДокументыВыпускПродукции
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|	И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Справочник.РесурсныеСпецификации
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втДокументыВыпускПродукции.ТиповойДокумент КАК Спецификация
	|ИЗ
	|	втДокументыВыпускПродукции КАК втДокументыВыпускПродукции
	|";
	
	Запрос.УстановитьПараметр("Документпит", ДокументРецептура);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	// Если документы найдены, то инициализируем соответствующие переменные.
	Пока Выборка.Следующий() Цикл
		выхСпецификация = Выборка.Спецификация.ПолучитьОбъект();
	КонецЦикла;
	
	// Если переменные не инициализированны, значит документы не были найдены
	// и необходимо создать пустые документы-объекты, которые далее будут заполняться.
	Если (выхСпецификация = Неопределено) Тогда
		выхСпецификация = Справочники.РесурсныеСпецификации.СоздатьЭлемент();
	КонецЕсли;
	
КонецПроцедуры

// Процедура по переданной ссылке на спецификацию изделия ищет типовой элементы справочника "ЭтапыПроизводства",
//  владельцем которого является переданная спецификация.
//  Если не находит, то создает для пустой объект.
//
// Параметры:
//  Спецификация			 - СправочникСсылка	 - Ссылка на документ, для которого ищем "Ресурсные спецификации".
//
Функция ПолучитьОбъектЭтапПроизводства(Спецификация, ЭтоНоваяСпецификация = Ложь)
	
	Если ЭтоНоваяСпецификация Тогда
		ОбъектЭтапПроизводства = Справочники.ЭтапыПроизводства.СоздатьЭлемент();
		ОбъектЭтапПроизводства.Владелец = Спецификация;
		Возврат ОбъектЭтапПроизводства;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	|	Этапы.Ссылка
	|ИЗ
	|	Справочник.ЭтапыПроизводства КАК Этапы
	|ГДЕ
	|	НЕ Этапы.ПометкаУдаления
	|	И Этапы.Владелец = &Спецификация
	|
	|УПОРЯДОЧИТЬ ПО
	|	Этапы.Ссылка";
	
	Запрос.УстановитьПараметр("Спецификация", Спецификация);
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		ОбъектЭтапПроизводства = Справочники.ЭтапыПроизводства.СоздатьЭлемент();
		ОбъектЭтапПроизводства.Владелец = Спецификация;
		Возврат ОбъектЭтапПроизводства;
	КонецЕсли;
	
	Выборка = Результат.Выбрать();
	
	Выборка.Следующий();
	
	ОбъектЭтапПроизводства = Выборка.Ссылка.ПолучитьОбъект();
	ОбъектЭтапПроизводства.Владелец = Спецификация;
	
	Возврат ОбъектЭтапПроизводства;
	
КонецФункции

#КонецОбласти

#Область ФормированиеТиповыхДокументовПоРегистрацииЗамен

// Процедура формирования типовых документов по переданному выпуску блюд.
//
// Параметры:
//  ДокументВыпускБлюд		 - ДокументСсылка	 - Ссылка на документ "Выпуск блюд", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьТиповыеДокументыПоРегистрацииЗамен(ДокРегистрацияЗамен, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки = "")
	
	ВсеОк = Истина;
	
	ЭтоЕРП = питПроизводствоПовтИсп.ПолучитьИмяОсновнойКонфигурации() = "УправлениеПредприятием" 
		ИЛИ питПроизводствоПовтИсп.ПолучитьИмяОсновнойКонфигурации() = "ERPWE"
		ИЛИ питПроизводствоПовтИсп.ПолучитьИмяОсновнойКонфигурации() = "УправлениеПредприятиемДляБеларуси";
	ЭтоКА = питПроизводствоПовтИсп.ПолучитьИмяОсновнойКонфигурации() = "КомплекснаяАвтоматизация";
	
	Если ЭтоЕРП Тогда
		
		///////////////////////////////////////////////////
		// Разрешения на замену материалов
		ВсеОк = СформироватьРазрешенияНаЗаменуПоРегистрацииЗамен(ДокРегистрацияЗамен, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
		
	КонецЕсли;
	
	///////////////////////////////////////////////////
	// Разрешения на замену материалов
	
	ВсеОк = ОбновитьКоэффициентДокументаИсточникаПоРегистрацииЗамен(ДокРегистрацияЗамен, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
	Если НЕ ВсеОк Тогда 
		Возврат ВсеОк;
	КонецЕсли;
	
	ВсеОк = СформироватьРегистрацииЗаменПоРегистрацииЗамен(ДокРегистрацияЗамен, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
	Если НЕ ВсеОк Тогда 
		Возврат ВсеОк;
	КонецЕсли;
	
	Возврат ВсеОк;
	
КонецФункции

// Функция формирует документы "Разрешения на замену".
//
// Параметры:
//  ДокРегистрацияЗамен		 - ДокументСсылка	 - Ссылка на документ "Регистрация замен", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция ОбновитьКоэффициентДокументаИсточникаПоРегистрацииЗамен(ДокРегистрацияЗамен, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки)
	
	Перем ДатаФормированияПотребности, мМетаданныеТиповогоОбъекта, мМетаданныеТЧ, НовСтр, ПараметрыЗаписи, Стр, ТекРежимЗаписи;
	
	ВсеОк = Истина;
	
	Если НЕ Константы.питОбновлятьКоэффициентДокументаИсточникаПоРегистрацииЗамен.Получить() Тогда
		Возврат ВсеОк;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	питРегистрацияЗаменЗаменители.Коэффициент КАК Коэффициент,
	|	питРегистрацияЗаменЗаменители.Ссылка.Номенклатура КАК Заменяемое,
	|	питРегистрацияЗаменЗаменители.Ссылка.Характеристика КАК ЗаменяемоеХарактеристика,
	|	питРегистрацияЗаменЗаменители.ИсточникОбратимости КАК ИсточникОбратимости
	|ПОМЕСТИТЬ втПодкладнойДок
	|ИЗ
	|	Документ.питРегистрацияЗамен.Заменители КАК питРегистрацияЗаменЗаменители
	|ГДЕ
	|	питРегистрацияЗаменЗаменители.Ссылка = &Ссылка
	|	И питРегистрацияЗаменЗаменители.Обратимость
	|	И НЕ питРегистрацияЗаменЗаменители.ИсточникОбратимости = ЗНАЧЕНИЕ(Документ.питРегистрацияЗамен.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втПодкладнойДок.Заменяемое КАК Заменяемое,
	|	втПодкладнойДок.ЗаменяемоеХарактеристика КАК ЗаменяемоеХарактеристика,
	|	втПодкладнойДок.Коэффициент КАК Коэффициент,
	|	питРегистрацияЗаменЗаменители.Коэффициент КАК КоэффициентИсходногоДока,
	|	втПодкладнойДок.ИсточникОбратимости КАК ИсходныйДок
	|ИЗ
	|	втПодкладнойДок КАК втПодкладнойДок
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.питРегистрацияЗамен.Заменители КАК питРегистрацияЗаменЗаменители
	|		ПО втПодкладнойДок.ИсточникОбратимости = питРегистрацияЗаменЗаменители.Ссылка
	|			И втПодкладнойДок.Заменяемое = питРегистрацияЗаменЗаменители.Номенклатура
	|			И втПодкладнойДок.ЗаменяемоеХарактеристика = питРегистрацияЗаменЗаменители.Характеристика";
	Запрос.УстановитьПараметр("Ссылка", ДокРегистрацияЗамен);
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	Если Выборка.Следующий() Тогда
		НовыйКэф = 1/Выборка.Коэффициент;
		Если НовыйКэф <> Выборка.КоэффициентИсходногоДока Тогда
			ТекДокументОбъект = Выборка.ИсходныйДок.ПолучитьОбъект();
			СтрокиИсходногоДока = ТекДокументОбъект.Заменители.НайтиСтроки(Новый Структура("Номенклатура,Характеристика",Выборка.Заменяемое,Выборка.ЗаменяемоеХарактеристика));
			Если СтрокиИсходногоДока.Количество() Тогда
				СтрокиИсходногоДока[0].Коэффициент = НовыйКэф;
			КонецЕсли;
			Попытка
				ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
				ТекДокументОбъект.ДополнительныеСвойства.Вставить("питБезОбновленияПодкладныхДокументов",Истина);
				ТекДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
			Исключение
				ТекстОшибки = ТекстОшибки + "
				|Ошибка обновления документа """ + ТекДокументОбъект.Метаданные().Представление() + """
				|по причине: <"+ОписаниеОшибки()+">";
				Возврат Ложь;
			КонецПопытки;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

// Функция формирует документы "Разрешения на замену".
//
// Параметры:
//  ДокРегистрацияЗамен		 - ДокументСсылка	 - Ссылка на документ "Регистрация замен", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьРазрешенияНаЗаменуПоРегистрацииЗамен(ДокРегистрацияЗамен, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки)
	
	Перем ДатаФормированияПотребности, мМетаданныеТиповогоОбъекта, мМетаданныеТЧ, НовСтр, ПараметрыЗаписи, Стр, ТекРежимЗаписи;
	
	ДокРазрешениеНаЗамену = Неопределено;
	ВсеОк = Истина;
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	|	питТиповыеДокументы.ТиповойДокумент КАК ТиповойДокумент,
	|	питТиповыеДокументы.ТиповойДокумент.Проведен КАК Проведен,
	|	питТиповыеДокументы.ТиповойДокумент.ПометкаУдаления КАК ПометкаУдаления
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Ссылка
	|	И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.РазрешениеНаЗаменуМатериалов";
	Запрос.УстановитьПараметр("Ссылка", ДокРегистрацияЗамен);
	
	ВыборкаСуществующиеТиповыеДокументы		= Запрос.Выполнить().Выбрать();	// Существующие типовые доки.
	
	Пока ВыборкаСуществующиеТиповыеДокументы.Следующий() Цикл
		Если ВыборкаСуществующиеТиповыеДокументы.Проведен Тогда
			ТекДокументОбъект = ВыборкаСуществующиеТиповыеДокументы.ТиповойДокумент.ПолучитьОбъект();
			Попытка
				ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
				ТекДокументОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
			Исключение
				ТекстОшибки = ТекстОшибки + "
				|Ошибка отмены проведения документа """ + ТекДокументОбъект.Метаданные().Представление() + """
				|по причине: <"+ОписаниеОшибки()+">";
				Возврат Ложь;
			КонецПопытки;
		КонецЕсли;
	КонецЦикла;
	ВыборкаСуществующиеТиповыеДокументы.Сбросить();
	
	Если Константы.питФормироватьРазрешенияНаЗаменуПоРегистрациямЗамен.Получить() Тогда
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	питРегистрацияЗамен.Дата КАК Дата,
		|	питРегистрацияЗамен.Проведен КАК Проведен,
		|	питРегистрацияЗамен.Номенклатура КАК Заменяемое,
		|	питРегистрацияЗамен.Характеристика КАК ЗаменяемоеХарактеристика,
		|	питРегистрацияЗамен.Ответственный КАК Ответственный,
		|	питРегистрацияЗамен.ДатаНачалаДействия КАК ДатаНачалаДействия,
		|	питРегистрацияЗамен.ДатаОкончанияДействия КАК ДатаОкончанияДействия,
		|	питРегистрацияЗамен.Комментарий КАК Комментарий,
		|	питРегистрацияЗамен.ПометкаУдаления КАК ПометкаУдаления,
		|	питРегистрацияЗамен.Представление КАК Представление,
		|	СпрНоменклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения
		|ИЗ
		|	Документ.питРегистрацияЗамен КАК питРегистрацияЗамен
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНоменклатура
		|		ПО питРегистрацияЗамен.Номенклатура = СпрНоменклатура.Ссылка
		|ГДЕ
		|	питРегистрацияЗамен.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	питРегистрацияЗаменЗаменители.Номенклатура КАК Заменитель,
		|	питРегистрацияЗаменЗаменители.Характеристика КАК ЗаменительХарактеристика,
		|	питРегистрацияЗаменЗаменители.Коэффициент КАК Коэффициент,
		|	питРегистрацияЗаменЗаменители.Приоритет КАК Приоритет,
		|	питРегистрацияЗаменЗаменители.Обратимость КАК Обратимость,
		|	СпрНоменклатураЗаменители.ЕдиницаИзмерения КАК ЕдиницаИзмерения
		|ИЗ
		|	Документ.питРегистрацияЗамен.Заменители КАК питРегистрацияЗаменЗаменители
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНоменклатураЗаменители
		|		ПО питРегистрацияЗаменЗаменители.Номенклатура = СпрНоменклатураЗаменители.Ссылка
		|ГДЕ
		|	питРегистрацияЗаменЗаменители.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	питРегистрацияЗаменПодразделения.Подразделение КАК Подразделение,
		|	питРегистрацияЗаменПодразделения.ВключаяПодчиненные КАК ВключаяПодчиненные
		|ИЗ
		|	Документ.питРегистрацияЗамен.Подразделения КАК питРегистрацияЗаменПодразделения
		|ГДЕ
		|	питРегистрацияЗаменПодразделения.Ссылка = &Ссылка
		|";
		РезультатЗапроса = Запрос.ВыполнитьПакет();
		
		ВыборкаШапка							= РезультатЗапроса[0].Выбрать();	// Шапка
		ВыборкаШапка.Следующий();
		ВыборкаЗаменители						= РезультатЗапроса[1].Выбрать();	// Заменители
		ТаблицаПодразделения					= РезультатЗапроса[2].Выгрузить();	// Подразделения
		
		// Структура текущего типового дока.
		ТекТиповойДокумент = Новый Структура("ТиповойДокумент,ПометкаУдаления,Проведен");
		
		// Получение всех подразделений, включая подчиненные.
		ВсеПодразделения = питПроизводство.НайтиПодразделенияПоРазрешенным(ТаблицаПодразделения);
		Для каждого ТекПодразделение Из ВсеПодразделения Цикл
			
			ТекДокументОбъект = Неопределено;
			
			// Выборка по типовым.
			// Если документ существует, тогда заполняем его данными структуру,
			// иначе - заполняем значениями по умолчанию.
			Если ВыборкаСуществующиеТиповыеДокументы.Следующий() Тогда
				ЗаполнитьЗначенияСвойств(ТекТиповойДокумент,ВыборкаСуществующиеТиповыеДокументы);
			Иначе
				ТекТиповойДокумент.ТиповойДокумент = Документы.РазрешениеНаЗаменуМатериалов.ПустаяСсылка();
				ТекТиповойДокумент.ПометкаУдаления = Ложь;
				ТекТиповойДокумент.Проведен = Ложь;
			КонецЕсли;
			
			////////////////////////////
			// Определение режима записи
			ПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(ВыборкаШапка.Проведен,ВыборкаШапка.ПометкаУдаления
			,ТекТиповойДокумент.Проведен,ТекТиповойДокумент.ПометкаУдаления,СтруктураПараметров);
			ТекРежимЗаписи = ПараметрыЗаписи.РежимЗаписи;
			////////////////////////////
			
			// Если тек списание затрат не было найдено, то создаем новый объект.
			Если ТекТиповойДокумент.ТиповойДокумент = Документы.РазрешениеНаЗаменуМатериалов.ПустаяСсылка() Тогда
				ТекДокументОбъект = Документы.РазрешениеНаЗаменуМатериалов.СоздатьДокумент();
			Иначе
				ТекДокументОбъект = ТекТиповойДокумент.ТиповойДокумент.ПолучитьОбъект();
				
				// Если нужно установить пометку удаления, то перед синхронизацией сделаем это.
				Если ПараметрыЗаписи.НужнаУстановкаПометкиУдаления Тогда
					
					// Помечаем на удаление / снимаем пометку в док. "Списание затрат...".
					Попытка
						ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
						ТекДокументОбъект.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
					Исключение
						ТекстОшибки = ТекстОшибки + "
						|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
						| по документу Общепит """+ВыборкаШапка.Представление+"""
						|по причине: <"+ОписаниеОшибки()+">";
						Возврат Ложь;
					КонецПопытки;
					
				КонецЕсли;
				
				// Очистка табличных частей для избежания дублирования информации.
				ТекДокументОбъект.Материалы.Очистить();
				ТекДокументОбъект.Аналоги.Очистить();
				ТекДокументОбъект.ДополнительныеРеквизиты.Очистить();
				
			КонецЕсли;
			
			// Заполнение шапки.
			ТекДокументОбъект.Дата					= ВыборкаШапка.Дата + ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0);
			ТекДокументОбъект.Подразделение			= ТекПодразделение;
			ТекДокументОбъект.Ответственный			= ВыборкаШапка.Ответственный;
			ТекДокументОбъект.УказаниеПоПрименению	= "Введен автоматически по документу ""Общепит"" <"+ВыборкаШапка.Представление+">";
			ТекДокументОбъект.ЗаказНаПроизводство	= Неопределено;
			ТекДокументОбъект.Спецификация			= Неопределено;
			ТекДокументОбъект.Изделие				= Неопределено;
			ТекДокументОбъект.ХарактеристикаИзделия	= Неопределено;
			ТекДокументОбъект.ЗаказКлиента			= Неопределено;
			ТекДокументОбъект.ДатаНачалаДействия	= ВыборкаШапка.ДатаНачалаДействия;
			ТекДокументОбъект.ДатаОкончанияДействия	= ВыборкаШапка.ДатаОкончанияДействия;
			ТекДокументОбъект.Статус				= Перечисления.СтатусыРазрешенийНаЗаменуМатериалов.Утверждено;
			ТекДокументОбъект.Комментарий			= ВыборкаШапка.Комментарий;
			
			Пока ВыборкаЗаменители.Следующий() Цикл
				НовСтрокаАналоги = ТекДокументОбъект.Аналоги.Добавить();
				НовСтрокаАналоги.Номенклатура			= ВыборкаЗаменители.Заменитель;
				НовСтрокаАналоги.Характеристика			= ВыборкаЗаменители.ЗаменительХарактеристика;
				//+25
				//НовСтрокаАналоги.Количество				= ВыборкаЗаменители.Коэффициент;
				//-25
				НовСтрокаАналоги.КоличествоУпаковок		= ВыборкаЗаменители.Коэффициент;
				НовСтрокаАналоги.Упаковка				= ВыборкаЗаменители.ЕдиницаИзмерения;
			КонецЦикла;
			ВыборкаЗаменители.Сбросить();
			
			НовСтрокаАналоги = ТекДокументОбъект.Материалы.Добавить();
			НовСтрокаАналоги.Номенклатура				= ВыборкаШапка.Заменяемое;
			НовСтрокаАналоги.Характеристика				= ВыборкаШапка.ЗаменяемоеХарактеристика;
			//+25
			//НовСтрокаАналоги.Количество					= 1;
			//-25
			НовСтрокаАналоги.КоличествоУпаковок			= 1;
			НовСтрокаАналоги.Упаковка					= ВыборкаШапка.ЕдиницаИзмерения;
			
			// Запись заполненного документа.
			Если НЕ ТекДокументОбъект = Неопределено Тогда
				
				Попытка
					Если НЕ ТекРежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда // Отмена проведения произошла ранее
						ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
						ТекДокументОбъект.Записать(ТекРежимЗаписи);
					КонецЕсли;
				Исключение
					ТекстОшибки = ТекстОшибки + "
					|Ошибка записи документа """ + ТекДокументОбъект.Метаданные().Представление() + """
					| по документу Общепит """+ВыборкаШапка.Представление+"""
					|по причине: <"+ОписаниеОшибки()+">";
					Возврат Ложь;
				КонецПопытки;
				
				// Добавление записи в результирующую таблицу в случае успешной записи документов.
				ДобавитьНовуюЗапись(ДокРегистрацияЗамен, ТекДокументОбъект, тблСозданныеДокументы);
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	// "Обнуление" переменной текущего объекта.
	ТекДокументОбъект = Неопределено;
	
	// Если остались лишние типовые документы, то нужно пометить их на удаление.
	Пока ВыборкаСуществующиеТиповыеДокументы.Следующий() Цикл
		
		ТекДокументОбъект = ВыборкаСуществующиеТиповыеДокументы.ТиповойДокумент.ПолучитьОбъект();
		
		// Помечаем на удаление "Производство без заказа", если он еще не помечен.
		Если НЕ ВыборкаСуществующиеТиповыеДокументы.ПометкаУдаления Тогда
			Попытка
				ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
				ТекДокументОбъект.УстановитьПометкуУдаления(Истина);
			Исключение
				ТекстОшибки = ТекстОшибки + "
				|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
				| по документу Общепит """+ВыборкаШапка.Представление+"""
				|по причине: <"+ОписаниеОшибки()+">";
				Возврат Ложь;
			КонецПопытки;
		КонецЕсли;
		
		// Добавление записи в результирующую таблицу.
		ДобавитьНовуюЗапись(ДокРегистрацияЗамен, ТекДокументОбъект, тблСозданныеДокументы);
		
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

// Функция формирует документы "Разрешения на замену".
//
// Параметры:
//  ДокРегистрацияЗамен		 - ДокументСсылка	 - Ссылка на документ "Регистрация замен", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьРегистрацииЗаменПоРегистрацииЗамен(ДокРегистрацияЗамен, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки)
	
	Перем ДатаФормированияПотребности, мМетаданныеТиповогоОбъекта, мМетаданныеТЧ, НовСтр, ПараметрыЗаписи, Стр, ТекРежимЗаписи;
	
	ВсеОк = Истина;
	
	// 1. Выбираются существующие связанные документы
	// 2. Выбираются данные шапки из связанных документов
	// 3. Делается матрица Данные шапки + Данные ТЧ "Заменители" в найденных документах.
	// 4. Выбирается шапка исходного документа
	// 5. Выбирается ТЧ "Заменители" исходного документа + ТЧ "Заменители" найденных документов. Итоги по Заменителям из исходного дока.
	// 6. Выбираются подразделения исходногодокумента
	// 7. Выбираются найденные документы.
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ВЫРАЗИТЬ(питТиповыеДокументы.ТиповойДокумент КАК Документ.питРегистрацияЗамен) КАК ТиповойДокумент
	|ПОМЕСТИТЬ втТиповые
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Ссылка
	|	И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.питРегистрацияЗамен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втТиповые.ТиповойДокумент КАК ТиповойДокумент,
	|	втТиповые.ТиповойДокумент.Проведен КАК Проведен,
	|	втТиповые.ТиповойДокумент.ПометкаУдаления КАК ПометкаУдаления,
	|	втТиповые.ТиповойДокумент.Номенклатура КАК Заменяемое,
	|	втТиповые.ТиповойДокумент.Характеристика КАК ЗаменяемоеХарактеристика,
	|	втТиповые.ТиповойДокумент.ДокументИсточник КАК ДокументИсточник
	|ПОМЕСТИТЬ втДанныеТиповые
	|ИЗ
	|	втТиповые КАК втТиповые
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втТиповые.ТиповойДокумент КАК ТиповойДокумент,
	|	втТиповые.ТиповойДокумент.ПометкаУдаления КАК ПометкаУдаления,
	|	втТиповые.ТиповойДокумент.Проведен КАК Проведен,
	|	втТиповые.ТиповойДокумент.Номенклатура КАК Заменяемое,
	|	втТиповые.ТиповойДокумент.Характеристика КАК ЗаменяемоеХарактеристика,
	|	питРегистрацияЗаменЗаменители.Номенклатура КАК Заменитель,
	|	питРегистрацияЗаменЗаменители.Характеристика КАК ЗаменительХарактеристика,
	|	питРегистрацияЗаменЗаменители.Коэффициент КАК Коэффициент,
	|	питРегистрацияЗаменЗаменители.Приоритет КАК Приоритет,
	|	питРегистрацияЗаменЗаменители.Обратимость КАК Обратимость,
	|	питРегистрацияЗаменЗаменители.ИсточникОбратимости КАК ИсточникОбратимости
	|ПОМЕСТИТЬ втСущЗамены
	|ИЗ
	|	втТиповые КАК втТиповые
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.питРегистрацияЗамен.Заменители КАК питРегистрацияЗаменЗаменители
	|		ПО втТиповые.ТиповойДокумент = питРегистрацияЗаменЗаменители.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	питРегистрацияЗамен.Дата КАК Дата,
	|	питРегистрацияЗамен.Проведен КАК Проведен,
	|	питРегистрацияЗамен.Номенклатура КАК Заменяемое,
	|	питРегистрацияЗамен.Характеристика КАК ЗаменяемоеХарактеристика,
	|	питРегистрацияЗамен.Ответственный КАК Ответственный,
	|	питРегистрацияЗамен.ДатаНачалаДействия КАК ДатаНачалаДействия,
	|	питРегистрацияЗамен.ДатаОкончанияДействия КАК ДатаОкончанияДействия,
	|	питРегистрацияЗамен.Комментарий КАК Комментарий,
	|	питРегистрацияЗамен.ПометкаУдаления КАК ПометкаУдаления,
	|	питРегистрацияЗамен.Представление КАК Представление
	|ИЗ
	|	Документ.питРегистрацияЗамен КАК питРегистрацияЗамен
	|ГДЕ
	|	питРегистрацияЗамен.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	питРегистрацияЗаменЗаменители.Номенклатура КАК Заменитель,
	|	питРегистрацияЗаменЗаменители.Характеристика КАК ЗаменительХарактеристика,
	|	питРегистрацияЗаменЗаменители.Коэффициент КАК Коэффициент,
	|	питРегистрацияЗаменЗаменители.Приоритет КАК Приоритет,
	|	питРегистрацияЗаменЗаменители.Обратимость КАК Обратимость,
	|	питРегистрацияЗаменЗаменители.Ссылка КАК Ссылка,
	|	ЕСТЬNULL(втТЧ.Заменитель, ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)) КАК ТиповойЗаменитель,
	|	ЕСТЬNULL(втТЧ.ЗаменительХарактеристика, ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)) КАК ТиповойЗаменительХарактеристика,
	|	ЕСТЬNULL(втТЧ.Коэффициент, 1) КАК ТиповойКоэффициент,
	|	ЕСТЬNULL(втТЧ.Приоритет, 1) КАК ТиповойПриоритет,
	|	ЕСТЬNULL(втТЧ.Обратимость, ЛОЖЬ) КАК ТиповойОбратимость,
	|	ЕСТЬNULL(втТЧ.ИсточникОбратимости, ЗНАЧЕНИЕ(Документ.питРегистрацияЗамен.ПустаяСсылка)) КАК ТиповойИсточникОбратимости
	|ИЗ
	|	Документ.питРегистрацияЗамен.Заменители КАК питРегистрацияЗаменЗаменители
	|		ЛЕВОЕ СОЕДИНЕНИЕ втСущЗамены КАК втТЧ
	|		ПО питРегистрацияЗаменЗаменители.Номенклатура = втТЧ.Заменяемое
	|			И питРегистрацияЗаменЗаменители.Характеристика = втТЧ.ЗаменяемоеХарактеристика
	|ГДЕ
	|	питРегистрацияЗаменЗаменители.Ссылка = &Ссылка
	|	И питРегистрацияЗаменЗаменители.Обратимость
	|	И питРегистрацияЗаменЗаменители.ИсточникОбратимости = ЗНАЧЕНИЕ(Документ.питРегистрацияЗамен.ПустаяСсылка)
	|ИТОГИ
	|	МАКСИМУМ(Коэффициент),
	|	МАКСИМУМ(Приоритет)
	|ПО
	|	Номенклатура,
	|	Характеристика
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	питРегистрацияЗаменПодразделения.Подразделение КАК Подразделение,
	|	питРегистрацияЗаменПодразделения.ВключаяПодчиненные КАК ВключаяПодчиненные
	|ИЗ
	|	Документ.питРегистрацияЗамен.Подразделения КАК питРегистрацияЗаменПодразделения
	|ГДЕ
	|	питРегистрацияЗаменПодразделения.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	втСущЗамены.ТиповойДокумент КАК ТиповойДокумент,
	|	втСущЗамены.ПометкаУдаления КАК ПометкаУдаления,
	|	втСущЗамены.Проведен КАК Проведен
	|ИЗ
	|	втСущЗамены КАК втСущЗамены";
	Запрос.УстановитьПараметр("Ссылка", ДокРегистрацияЗамен);
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ВыборкаШапка							= РезультатЗапроса[3].Выбрать();	// Шапка
	ВыборкаШапка.Следующий();
	ВыборкаЗаменителиНоменклатура			= РезультатЗапроса[4].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);	// Заменители
	ВыборкаПодразделения					= РезультатЗапроса[5].Выбрать();	// Подразделения
	ВыборкаСуществующиеТиповыеДокументы		= РезультатЗапроса[6].Выбрать();
	
	// Отмена проведения существующих доков.
	Пока ВыборкаСуществующиеТиповыеДокументы.Следующий() Цикл
		Если ВыборкаСуществующиеТиповыеДокументы.Проведен Тогда
			ТекДокументОбъект = ВыборкаСуществующиеТиповыеДокументы.ТиповойДокумент.ПолучитьОбъект();
			Попытка
				ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
				ТекДокументОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
			Исключение
				ТекстОшибки = ТекстОшибки + "
				|Ошибка отмены проведения документа """ + ТекДокументОбъект.Метаданные().Представление() + """
				|по причине: <"+ОписаниеОшибки()+">";
				Возврат Ложь;
			КонецПопытки;
		КонецЕсли;
	КонецЦикла;
	ВыборкаСуществующиеТиповыеДокументы.Сбросить();
	
	// Структура текущего типового дока.
	ТекТиповойДокумент = Новый Структура("ТиповойДокумент,ПометкаУдаления,Проведен");
	
	// Обход Заменителей(По группировкам).
	// Для каждой группировки Заменитель,ХарактеристикаЗаменителя из исходного документа(для которых стоит флаг ""Обратимость"")
	//  создается подкладной документ "Регистрация замен" или используется существующий из списка существующих.
	Пока ВыборкаЗаменителиНоменклатура.Следующий() Цикл // Ном-ра
		ВыборкаЗаменителиХарактеристика = ВыборкаЗаменителиНоменклатура.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаЗаменителиХарактеристика.Следующий() Цикл
			
			ТекДокументОбъект = Неопределено;
			
			// Выборка по типовым.
			// Если документ существует, тогда заполняем его данными структуру,
			// иначе - заполняем значениями по умолчанию.
			Если ВыборкаСуществующиеТиповыеДокументы.Следующий() Тогда
				ЗаполнитьЗначенияСвойств(ТекТиповойДокумент,ВыборкаСуществующиеТиповыеДокументы);
			Иначе
				ТекТиповойДокумент.ТиповойДокумент = Документы.питРегистрацияЗамен.ПустаяСсылка();
				ТекТиповойДокумент.ПометкаУдаления = Ложь;
				ТекТиповойДокумент.Проведен = Ложь;
			КонецЕсли;
			
			////////////////////////////
			// Определение режима записи
			ПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(ВыборкаШапка.Проведен,ВыборкаШапка.ПометкаУдаления
			,ТекТиповойДокумент.Проведен,ТекТиповойДокумент.ПометкаУдаления,СтруктураПараметров);
			ТекРежимЗаписи = ПараметрыЗаписи.РежимЗаписи;
			////////////////////////////
			
			// Если тек документ не был найден, то создаем новый объект.
			Если ТекТиповойДокумент.ТиповойДокумент = Документы.питРегистрацияЗамен.ПустаяСсылка() Тогда
				ТекДокументОбъект = Документы.питРегистрацияЗамен.СоздатьДокумент();
			Иначе
				ТекДокументОбъект = ТекТиповойДокумент.ТиповойДокумент.ПолучитьОбъект();
				
				// Если нужно установить пометку удаления, то перед синхронизацией сделаем это.
				Если ПараметрыЗаписи.НужнаУстановкаПометкиУдаления Тогда
					
					// Помечаем на удаление / снимаем пометку в док. "Списание затрат...".
					Попытка
						ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
						ТекДокументОбъект.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
					Исключение
						ТекстОшибки = ТекстОшибки + "
						|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
						| по документу Общепит """+ВыборкаШапка.Представление+"""
						|по причине: <"+ОписаниеОшибки()+">";
						Возврат Ложь;
					КонецПопытки;
					
				КонецЕсли;
				
				// Очистка табличных частей для избежания дублирования информации.
				ТекДокументОбъект.Заменители.Очистить();
				ТекДокументОбъект.Подразделения.Очистить();
				
			КонецЕсли;
			
			// Заполнение шапки.
			// У подкладного документа в качестве заменяемого выступает заменитель из ТЧ "Заменители" с флагом "Обратимость".
			ТекДокументОбъект.Дата						= ВыборкаШапка.Дата + ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0);
			ТекДокументОбъект.Номенклатура				= ВыборкаЗаменителиХарактеристика.Заменитель;
			ТекДокументОбъект.Характеристика			= ВыборкаЗаменителиХарактеристика.ЗаменительХарактеристика;
			ТекДокументОбъект.Ответственный				= ВыборкаШапка.Ответственный;
			ТекДокументОбъект.ДатаНачалаДействия		= ВыборкаШапка.ДатаНачалаДействия;
			ТекДокументОбъект.ДатаОкончанияДействия		= ВыборкаШапка.ДатаОкончанияДействия;
			ТекДокументОбъект.Комментарий				= ВыборкаШапка.Комментарий;
			ТекДокументОбъект.ДокументИсточник			= ДокРегистрацияЗамен;
			
			ВыборкаЗаменители = ВыборкаЗаменителиХарактеристика.Выбрать();
			ОбратимостьВключенаВДок = Ложь;
			Пока ВыборкаЗаменители.Следующий() Цикл
				
				// Детальные записи, обход заменителей в подкладном документе.
				// Для строки заменителя, которая соответствует заменяемому в основном документе обновляем все данные
				// Для остальных строк переносим 1к1
				// Если нет связанных данных, то добавляется 1 строка - данные из шапки исходного документа.
				НовСтрокаЗаменители							= ТекДокументОбъект.Заменители.Добавить();
				Если (ВыборкаШапка.Заменяемое = ВыборкаЗаменители.ТиповойЗаменитель 
					И ВыборкаШапка.ЗаменяемоеХарактеристика = ВыборкаЗаменители.ТиповойЗаменительХарактеристика)
					ИЛИ НЕ ЗначениеЗаполнено(ВыборкаЗаменители.ТиповойЗаменитель) Тогда
					ОбратимостьВключенаВДок = Истина;
					НовСтрокаЗаменители.Номенклатура			= ВыборкаШапка.Заменяемое;
					НовСтрокаЗаменители.Характеристика			= ВыборкаШапка.ЗаменяемоеХарактеристика;
					НовСтрокаЗаменители.Коэффициент				= 1/ВыборкаЗаменители.Коэффициент;
					НовСтрокаЗаменители.Приоритет				= ?(ВыборкаЗаменители.ТиповойПриоритет>1,ВыборкаЗаменители.ТиповойПриоритет,ВыборкаЗаменители.Приоритет);
					НовСтрокаЗаменители.Обратимость				= Истина;
					НовСтрокаЗаменители.ИсточникОбратимости		= ДокРегистрацияЗамен;
				Иначе
					НовСтрокаЗаменители.Номенклатура			= ВыборкаЗаменители.ТиповойЗаменитель;
					НовСтрокаЗаменители.Характеристика			= ВыборкаЗаменители.ТиповойЗаменительХарактеристика;
					НовСтрокаЗаменители.Коэффициент				= ВыборкаЗаменители.ТиповойКоэффициент;
					НовСтрокаЗаменители.Приоритет				= ВыборкаЗаменители.ТиповойПриоритет;
					НовСтрокаЗаменители.Обратимость				= ВыборкаЗаменители.ТиповойОбратимость;
					НовСтрокаЗаменители.ИсточникОбратимости		= ВыборкаЗаменители.ТиповойИсточникОбратимости;
				КонецЕсли;
			КонецЦикла;
			Если НЕ ОбратимостьВключенаВДок Тогда
				НовСтрокаЗаменители							= ТекДокументОбъект.Заменители.Добавить();
				НовСтрокаЗаменители.Номенклатура			= ВыборкаШапка.Заменяемое;
				НовСтрокаЗаменители.Характеристика			= ВыборкаШапка.ЗаменяемоеХарактеристика;
				НовСтрокаЗаменители.Коэффициент				= 1/ВыборкаЗаменителиХарактеристика.Коэффициент;
				НовСтрокаЗаменители.Приоритет				= 1;
				НовСтрокаЗаменители.Обратимость				= Истина;
				НовСтрокаЗаменители.ИсточникОбратимости		= ДокРегистрацияЗамен;
			КонецЕсли;
			
			// Заполнение ТЧ "Подразделения"
			Пока ВыборкаПодразделения.Следующий() Цикл
				НовСтрокаПодразделения = ТекДокументОбъект.Подразделения.Добавить();
				НовСтрокаПодразделения.Подразделение		= ВыборкаПодразделения.Подразделение;
				НовСтрокаПодразделения.ВключаяПодчиненные	= ВыборкаПодразделения.ВключаяПодчиненные;
			КонецЦикла;
			ВыборкаПодразделения.Сбросить();
			
			// Запись заполненного документа.
			Если НЕ ТекДокументОбъект = Неопределено Тогда
				
				Попытка
					Если НЕ ТекРежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда // Отмена проведения произошла ранее
						ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
						ТекДокументОбъект.Записать(ТекРежимЗаписи);
					КонецЕсли;
				Исключение
					ТекстОшибки = ТекстОшибки + "
					|Ошибка записи документа """ + ТекДокументОбъект.Метаданные().Представление() + """
					| по документу Общепит """+ВыборкаШапка.Представление+"""
					|по причине: <"+ОписаниеОшибки()+">";
					Возврат Ложь;
				КонецПопытки;
				
				// Добавление записи в результирующую таблицу в случае успешной записи документов.
				ДобавитьНовуюЗапись(ДокРегистрацияЗамен, ТекДокументОбъект, тблСозданныеДокументы);
				
			КонецЕсли;
			
		КонецЦикла;
	КонецЦикла;
	
	// "Обнуление" переменной текущего объекта.
	ТекДокументОбъект = Неопределено;
	
	// Если остались лишние типовые документы.
	СПЗаменители = Новый Структура("Номенклатура, Характеристика");
	Пока ВыборкаСуществующиеТиповыеДокументы.Следующий() Цикл
		
		ТекДокументОбъект = ВыборкаСуществующиеТиповыеДокументы.ТиповойДокумент.ПолучитьОбъект();
		
		// Если в заменителях незаиспользованного документа больше 1 строки, то удалим строку, которая соответствует исходному доку и отвяжем такой док
		// от исходного.
		Если ТекДокументОбъект.Заменители.Количество() > 1 Тогда
			
			// У оставшегося неиспользованным документа удалим строки из заменителей, которая соответствует заменяемому из шапки основного документа.
			СПЗаменители.Номенклатура				= ВыборкаШапка.Заменяемое;
			СПЗаменители.Характеристика				= ВыборкаШапка.ЗаменяемоеХарактеристика;
			НайденныеЗаменители = ТекДокументОбъект.Заменители.НайтиСтроки(СПЗаменители);
			Если НайденныеЗаменители.Количество() Тогда
				ТекДокументОбъект.Заменители.Удалить(НайденныеЗаменители[0]);
			КонецЕсли;
			
			ТекДокументОбъект.ДокументИсточник = Неопределено;
			
			Если ВыборкаСуществующиеТиповыеДокументы.Проведен Тогда
				РежимОтвязываемогоДокумента = РежимЗаписиДокумента.Проведение;
			Иначе
				РежимОтвязываемогоДокумента = РежимЗаписиДокумента.Запись;
			КонецЕсли;
			
			Попытка
				ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
				ТекДокументОбъект.Записать(РежимОтвязываемогоДокумента);
			Исключение
				ТекстОшибки = ТекстОшибки + "
				|Ошибка записи документа """ + ТекДокументОбъект.Метаданные().Представление() + """
				| по документу Общепит """+ВыборкаШапка.Представление+"""
				|по причине: <"+ОписаниеОшибки()+">";
				Возврат Ложь;
			КонецПопытки;
			
			// Отвязываем док.
			ВсеОк = УдалитьСвязьТиповогоДокументаСДокументомПит(ТекДокументОбъект.Ссылка,ДокРегистрацияЗамен,ТекстОшибки);
			Если НЕ ВсеОк Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
				Возврат ВсеОк;
			КонецЕсли;
			
		Иначе
			
			// Иначе помечаем док на удаление.
			
			
			Если НЕ ВыборкаСуществующиеТиповыеДокументы.ПометкаУдаления Тогда
				Попытка
					ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
					ТекДокументОбъект.УстановитьПометкуУдаления(Истина);
				Исключение
					ТекстОшибки = ТекстОшибки + "
					|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
					| по документу Общепит """+ВыборкаШапка.Представление+"""
					|по причине: <"+ОписаниеОшибки()+">";
					Возврат Ложь;
				КонецПопытки;
			КонецЕсли;
			
			// Добавление записи в результирующую таблицу.
			ДобавитьНовуюЗапись(ДокРегистрацияЗамен, ТекДокументОбъект, тблСозданныеДокументы);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

#КонецОбласти

#Область ФормированиеТиповыхДокументовПоИнвентаризацииТоваровОбщепита

// Процедура формирования типовых документов по переданному документу инвентаризации.
//
// Параметры:
//  ДокИнвентаризация		 - ДокументСсылка	 - Ссылка на документ "питИнвентаризацияТоваров", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьТиповыеДокументыПоИнвентаризацииТоваровОбщепит(ДокИнвентаризация, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки = "")
	
	ВсеОк = Истина;
	
	ВсеОк = СформироватьПересчетТоваровПоИнвентаризацииОбщепит(ДокИнвентаризация, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
	Если НЕ ВсеОк Тогда 
		Возврат ВсеОк;
	КонецЕсли;
	
	Если Константы.питФормироватьСкладскиеАктыПоИнвентаризацииТоваров.Получить() Тогда
		
		ВсеОк = СформироватьОприходованиеИзлишковПоИнвентаризацииОбщепит(ДокИнвентаризация, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
		
		ВсеОк = СформироватьСписаниеНедостачПоИнвентаризацииОбщепит(ДокИнвентаризация, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
		
	Иначе
		
		Если НЕ ОтменитьПроведениеТиповогоДокументаПоДокументупит(ДокИнвентаризация, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки, "СписаниеНедостачТоваров") Тогда
			Возврат Ложь;
		КонецЕсли;
		
		Если НЕ ОтменитьПроведениеТиповогоДокументаПоДокументупит(ДокИнвентаризация, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки, "ОприходованиеИзлишковТоваров") Тогда
			Возврат Ложь;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ВсеОк;
	
КонецФункции

// Функция формирует документ "ПересчетТоваров" для инвентаризации.
//
// Параметры:
//  ДокументВыпускБлюд		 - ДокументСсылка	 - Ссылка на документ "Выпуск блюд", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьПересчетТоваровПоИнвентаризацииОбщепит(ДокументОбщепит, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки)
	
	//<< Портал-Юг, Свинцов И.И., 2019.03.26 [5.3.6 Чтение и изменение данных инвентаризации товаров]
	Если ТипЗнч(ДокументОбщепит) = Тип("ДокументСсылка.питИнвентаризацияТоваров") Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;	
	//>> Портал-Юг, Свинцов И.И., 2019.03.26	
	
	Запрос = Новый Запрос;
	
	// Поиск существующего документа "Списание недостач товаров",
	// связанного с текущим "Выпуском блюд".
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питТиповыеДокументы.ТиповойДокумент
	|ПОМЕСТИТЬ втДокументыВыпускПродукции
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|	И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.ПересчетТоваров
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втДокументыВыпускПродукции.ТиповойДокумент
	|ИЗ
	|	втДокументыВыпускПродукции КАК втДокументыВыпускПродукции";
	Запрос.УстановитьПараметр("Документпит",				ДокументОбщепит);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	// Если документ найден, то получаем объект иначе создаем новый.
	Если Выборка.Следующий() Тогда
		ТекДокументОбъект = Выборка.ТиповойДокумент.ПолучитьОбъект();
		ЭтоНовый = Ложь;
	Иначе
		ЭтоНовый = Истина;
		ТекДокументОбъект = Документы.ПересчетТоваров.СоздатьДокумент();
	КонецЕсли;
	
	// Определение параметров записи.
	ПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокументОбщепит.Проведен,ДокументОбщепит.ПометкаУдаления,
		ТекДокументОбъект.Проведен,ТекДокументОбъект.ПометкаУдаления,СтруктураПараметров);
	
	// Определение режима записи
	ТекРежимЗаписи = ПараметрыЗаписи.РежимЗаписи;
	
	// Для нового дока отменять проведения не требуется.
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения
		И ЭтоНовый Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ПараметрыЗаписи.НужнаУстановкаПометкиУдаления Тогда
		
		Попытка
			ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
			ТекДокументОбъект.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
		Исключение
			ТекстОшибки = ТекстОшибки + "
			|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
			| по документу Общепит """+ДокументОбщепит+"""
			|по причине: <"+ОписаниеОшибки()+">";
			Возврат Ложь;
		КонецПопытки;
		
	КонецЕсли;
	
	/////////////////////////////////
	// ЗАПОЛНЕНИЕ ШАПКИ.
	ТекДокументОбъект.Дата								= ДокументОбщепит.Дата + ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0);
	ТекДокументОбъект.Исполнитель						= Справочники.Пользователи.ПустаяСсылка();
	ТекДокументОбъект.Комментарий						= ДокументОбщепит.Комментарий;
	// << MRS #ERP-5670 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 11.02.26, (Проблема с документом "Инвентаризация товаров")
	//ТекДокументОбъект.ОтборПересчета					= ДокументОбщепит.ОтборПересчета;
	СтруктураХранимыхДанных = ДокументОбщепит.ОтборПересчета.Получить();
	Если ТипЗнч(СтруктураХранимыхДанных) = Тип("Структура") Тогда		
		ОтборПересчета = СтруктураХранимыхДанных.ОтборПересчета;		
	Иначе	
		ОтборПересчета = СтруктураХранимыхДанных;
	КонецЕсли;	
	ТекДокументОбъект.ОтборПересчета					= ОтборПересчета;
	// >> MRS #ERP-5670 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 11.02.26, (Проблема с документом "Инвентаризация товаров")
	ТекДокументОбъект.Ответственный						= ДокументОбщепит.Ответственный;
	ТекДокументОбъект.Помещение							= Справочники.СкладскиеПомещения.ПустаяСсылка();
	ТекДокументОбъект.Склад								= ДокументОбщепит.Склад;
	ТекДокументОбъект.ПечататьКоличествоПоУчету			= Ложь;
	ТекДокументОбъект.УчетныеДанныеЗаполнены			= Истина;
	
	// Очистка табличных частей, т.к. будет их перезаполнение.
	ТекДокументОбъект.Товары.Очистить();
	
	// Получение данных по табличной части "Товары" отраслевого документа "Выпуск блюд".
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	питИнвентаризацияТоваров.Номенклатура КАК Номенклатура,
	|	питИнвентаризацияТоваров.Характеристика КАК Характеристика,
	|	питИнвентаризацияТоваров.Серия КАК Серия,
	|	питИнвентаризацияТоваров.СтатусУказанияСерий КАК СтатусУказанияСерий,
	|	питИнвентаризацияТоваров.Назначение КАК Назначение,   
	|	Значение(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка) КАК Упаковка,
	|	питИнвентаризацияТоваров.Количество КАК КоличествоУпаковок,
	|	питИнвентаризацияТоваров.Количество КАК Количество,
	|	питИнвентаризацияТоваров.КоличествоФакт КАК КоличествоУпаковокФакт,
	|	питИнвентаризацияТоваров.КоличествоФакт КАК КоличествоФакт
	|ИЗ
	|	Документ.питИнвентаризацияТоваров.Товары КАК питИнвентаризацияТоваров
	|ГДЕ
	|	питИнвентаризацияТоваров.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", ДокументОбщепит.Ссылка);
	
	// Обход таб. части и заполнение таб. частей "Товары" документа "Передача материалов в производство". 
	// << MRS #VINE-94 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 12.05.25, (Единица измерения в документы)
	ТекКэшированныеЗначения = ОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
	// >> MRS #VINE-94 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 12.05.25, (Единица измерения в документы)
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		НовСтрока							= ТекДокументОбъект.Товары.Добавить();
		НовСтрока.Номенклатура				= Выборка.Номенклатура;
		НовСтрока.Характеристика			= Выборка.Характеристика;
		НовСтрока.Серия						= Выборка.Серия;
		//НовСтрока.СтатусУказанияСерий		= Выборка.СтатусУказанияСерий;
		НовСтрока.Назначение				= Выборка.Назначение;
		НовСтрока.Упаковка					= Выборка.Упаковка;
		НовСтрока.КоличествоУпаковок		= Выборка.КоличествоУпаковок;
		НовСтрока.Количество				= Выборка.Количество;
		НовСтрока.КоличествоУпаковокФакт	= Выборка.КоличествоУпаковокФакт;
		НовСтрока.КоличествоФакт			= Выборка.КоличествоФакт;   
		
		// << MRS #VINE-94 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 13.05.25, (Единица измерения потребительской упаковки)
		СтруктураДействий = Новый Структура;     
		СтруктураДействий.Вставить("ПересчитатьКоличествоУпаковокСуффикс", "Факт");
		СтруктураДействий.Вставить("ПересчитатьКоличествоУпаковок");
		ОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(НовСтрока, СтруктураДействий, ТекКэшированныеЗначения);
		// >> MRS #VINE-94 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 13.05.25, (Единица измерения потребительской упаковки)
	КонецЦикла;
	
	/////////////////////////////////////////////////////////
	// ЗАПИСЬ ДОКУМЕНТА
	
	Попытка
		
		//+Серии
		Если ТекРежимЗаписи <> РежимЗаписиДокумента.ОтменаПроведения Тогда
			ЗаполнитьСерииТиповогоДокумента(ТекДокументОбъект, ДокументОбщепит);
		КонецЕсли;
		//-Серии
		
		ТекДокументОбъект.Статус							= Перечисления.СтатусыПересчетовТоваров.ВРаботе;
		ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
		ТекДокументОбъект.Записать(ТекРежимЗаписи);
		
		ТекДокументОбъект.Статус							= Перечисления.СтатусыПересчетовТоваров.Выполнено;
		ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
		ТекДокументОбъект.Записать(ТекРежимЗаписи);
		
		СтруктураПараметров.Вставить("питДокументПересчетТоваров", ТекДокументОбъект.Ссылка);
		
	Исключение
		ТекстОшибки = ТекстОшибки + "
		|Ошибка записи документа """ + ТекДокументОбъект.Метаданные().Представление() + """
		| по документу Общепит """+ДокументОбщепит+"""
		|по причине: <"+ОписаниеОшибки()+">";
		Возврат Ложь;
	КонецПопытки;
	
	// Добавление записи в результирующую таблицу в случае успешной записи документов.
	ДобавитьНовуюЗапись(ДокументОбщепит, ТекДокументОбъект, тблСозданныеДокументы);
	
	Возврат Истина;
	
КонецФункции

// Функция формирует документ "ОприходованиеИзлишковТоваров" для инвентаризации.
//
// Параметры:
//  ДокументВыпускБлюд		 - ДокументСсылка	 - Ссылка на документ "Выпуск блюд", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьОприходованиеИзлишковПоИнвентаризацииОбщепит(ДокументОбщепит, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки)
	
	Запрос = Новый Запрос;
	
	// Поиск существующего документа "Списание недостач товаров",
	// связанного с текущим "Выпуском блюд".
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питТиповыеДокументы.ТиповойДокумент
	|ПОМЕСТИТЬ втДокументыВыпускПродукции
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|	И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.ОприходованиеИзлишковТоваров
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втДокументыВыпускПродукции.ТиповойДокумент
	|ИЗ
	|	втДокументыВыпускПродукции КАК втДокументыВыпускПродукции";
	Запрос.УстановитьПараметр("Документпит",				ДокументОбщепит);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	// Если документ найден, то получаем объект иначе создаем новый.
	Если Выборка.Следующий() Тогда
		ТекДокументОбъект = Выборка.ТиповойДокумент.ПолучитьОбъект();
		ЭтоНовый = Ложь;
	ИначеЕсли НЕ ДокументОбщепит.Проведен Тогда
		Возврат Истина; // Для непроведенного выпуска, если раньше не было оприходования, то не создаем.
	Иначе
		ЭтоНовый = Истина;
		ТекДокументОбъект = Документы.ОприходованиеИзлишковТоваров.СоздатьДокумент();
	КонецЕсли;
	
	// Определение параметров записи.
	ПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокументОбщепит.Проведен,ДокументОбщепит.ПометкаУдаления,
	ТекДокументОбъект.Проведен,ТекДокументОбъект.ПометкаУдаления,СтруктураПараметров);
	
	// Определение режима записи
	ТекРежимЗаписи = ПараметрыЗаписи.РежимЗаписи;
	
	// Для нового дока отменять проведения не требуется.
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения
		И ЭтоНовый Тогда
		Возврат Истина;
	КонецЕсли;
	
	// Получение данных по табличной части "Товары" отраслевого документа "питИнвентаризацияТоваров".
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	питИнвентаризацияТоваров.Номенклатура КАК Номенклатура,
	|	питИнвентаризацияТоваров.Характеристика КАК Характеристика,
	|	питИнвентаризацияТоваров.Серия КАК Серия,
	|	питИнвентаризацияТоваров.СтатусУказанияСерий КАК СтатусУказанияСерий,
	|	питИнвентаризацияТоваров.Назначение КАК Назначение,
	|	питИнвентаризацияТоваров.Упаковка КАК Упаковка,
	|	питИнвентаризацияТоваров.КоличествоФакт - питИнвентаризацияТоваров.Количество КАК Количество
	|ИЗ
	|	Документ.питИнвентаризацияТоваров.Товары КАК питИнвентаризацияТоваров
	|ГДЕ
	|	питИнвентаризацияТоваров.Ссылка = &Ссылка
	|	И питИнвентаризацияТоваров.КоличествоФакт > питИнвентаризацияТоваров.Количество";
	Запрос.УстановитьПараметр("Ссылка", ДокументОбщепит.Ссылка);
	
	РезультатЗапросаТовары = Запрос.Выполнить();
	ПодкладнойДокументПустой = Ложь;
	Если РезультатЗапросаТовары.Пустой() Тогда
		ПодкладнойДокументПустой = Истина;
		НоваяПометкаУдаления = ?(НЕ ЭтоНовый, Истина, Неопределено);
	ИначеЕсли ПараметрыЗаписи.НужнаУстановкаПометкиУдаления Тогда
		НоваяПометкаУдаления = ПараметрыЗаписи.ПометкаУдаления;
	Иначе
		НоваяПометкаУдаления = Неопределено;
	КонецЕсли;
	
	Если НЕ НоваяПометкаУдаления = Неопределено Тогда
		Попытка
			ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
			ТекДокументОбъект.УстановитьПометкуУдаления(НоваяПометкаУдаления);
		Исключение
			ТекстОшибки = ТекстОшибки + "
			|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
			| по документу Общепит """+ДокументОбщепит+"""
			|по причине: <"+ОписаниеОшибки()+">";
			Возврат Ложь;
		КонецПопытки;
	КонецЕсли;
	
	Если ПодкладнойДокументПустой Тогда
		Если НЕ ЭтоНовый Тогда
			ДобавитьНовуюЗапись(ДокументОбщепит, ТекДокументОбъект, тблСозданныеДокументы);
		КонецЕсли;
		Возврат Истина;
	КонецЕсли;
	
	/////////////////////////////////
	// ЗАПОЛНЕНИЕ ШАПКИ.
	ТекДокументОбъект.Дата						= ДокументОбщепит.Дата + ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0);
	ТекДокументОбъект.Комментарий				= ДокументОбщепит.Комментарий;
	ТекДокументОбъект.Ответственный				= ДокументОбщепит.Ответственный;
	ТекДокументОбъект.Подразделение				= ДокументОбщепит.Подразделение;
	ТекДокументОбъект.Склад						= ДокументОбщепит.Склад;
	ТекДокументОбъект.СтатьяДоходов				= ДокументОбщепит.СтатьяДоходов;
	ТекДокументОбъект.АналитикаДоходов			= ДокументОбщепит.АналитикаДоходов;
	ТекДокументОбъект.ВидЦены					= питОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументОбщепит.Склад,"УчетныйВидЦены");
	ТекДокументОбъект.ПересчетТоваров			= ?(СтруктураПараметров.Свойство("питДокументПересчетТоваров"),СтруктураПараметров.питДокументПересчетТоваров,Неопределено);
	ТекДокументОбъект.Организация				= ДокументОбщепит.ОрганизацияСкладскихАктов;
	ТекДокументОбъект.Валюта					= Константы.ВалютаУправленческогоУчета.Получить();
	
	// Очистка табличных частей, т.к. будет их перезаполнение.
	ТекДокументОбъект.Товары.Очистить();
	
	Выборка = РезультатЗапросаТовары.Выбрать();
	Пока Выборка.Следующий() Цикл
		НовСтрока						= ТекДокументОбъект.Товары.Добавить();
		НовСтрока.Номенклатура			= Выборка.Номенклатура;
		НовСтрока.Характеристика		= Выборка.Характеристика;
		НовСтрока.Количество			= Выборка.Количество;
	КонецЦикла;
	
	// Заполнение ЦЕН
	Если ЗначениеЗаполнено(ТекДокументОбъект.ВидЦены) Тогда
		СтруктураДействий = Новый Структура;
		СтруктураДействий.Вставить("ПересчитатьСумму", "Количество");
		КолонкиПоЗначению = Новый Структура("Упаковка", Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка());
		ПараметрыЗаполнения = Новый Структура;
		ПараметрыЗаполнения.Вставить("Дата", ТекДокументОбъект.Дата);
		ПараметрыЗаполнения.Вставить("Валюта", Константы.ВалютаУправленческогоУчета.Получить());
		ПараметрыЗаполнения.Вставить("ВидЦены", ТекДокументОбъект.ВидЦены);
		ПараметрыЗаполнения.Вставить("КолонкиПоЗначению", КолонкиПоЗначению);
		ЦеныПредприятияЗаполнениеСервер.ЗаполнитьЦены(
		ТекДокументОбъект.Товары, // Табличная часть
		, // Выделенные строки (заполнять во всех строках)
		ПараметрыЗаполнения,
		СтруктураДействий);
	КонецЕсли;
	
	// Проверка на заполненность цен, отсутствие цен критично и это ошибка!
	ТоварыСНезаполненнымиЦенами = Новый Массив;
	Для каждого ТекСтрокаТовары Из ТекДокументОбъект.Товары Цикл
		Если ТекСтрокаТовары.Цена = 0 ИЛИ ТекСтрокаТовары.Сумма = 0 Тогда
			ТоварыСНезаполненнымиЦенами.Добавить(ТекСтрокаТовары.Номенклатура);
		КонецЕсли;
	КонецЦикла;
	Если ТоварыСНезаполненнымиЦенами.Количество() Тогда
		
		ТекстОшибки = ТекстОшибки + "
		|Ошибка заполнения документа """ + ТекДокументОбъект.Метаданные().Представление() + """
		| по документу Общепит """+ДокументОбщепит+"""
		|по причине: Не заполнены цены по виду цен <"+ТекДокументОбъект.ВидЦены+"> для следующих номенклатурных позиций:
		|";
		Для Сч = 0 По ТоварыСНезаполненнымиЦенами.Количество()-1 Цикл
			ТекстОшибки = ТекстОшибки + ?(Сч=0,"",",")+"<"+ТоварыСНезаполненнымиЦенами[Сч]+">";
		КонецЦикла;
		
		Возврат Ложь;
		
	КонецЕсли;
	
	/////////////////////////////////////////////////////////
	// ЗАПИСЬ ДОКУМЕНТА
	
	Попытка
		ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
		ТекДокументОбъект.Записать(ТекРежимЗаписи);
	Исключение
		ТекстОшибки = ТекстОшибки + "
		|Ошибка записи документа """ + ТекДокументОбъект.Метаданные().Представление() + """
		| по документу Общепит """+ДокументОбщепит+"""
		|по причине: <"+ОписаниеОшибки()+">";
		Возврат Ложь;
	КонецПопытки;
	
	// Добавление записи в результирующую таблицу в случае успешной записи документов.
	ДобавитьНовуюЗапись(ДокументОбщепит, ТекДокументОбъект, тблСозданныеДокументы);
	
	Возврат Истина;
	
КонецФункции

// Функция формирует документ "СписаниеНедостачТоваров" для инвентаризации.
//
// Параметры:
//  ДокументВыпускБлюд		 - ДокументСсылка	 - Ссылка на документ "Выпуск блюд", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьСписаниеНедостачПоИнвентаризацииОбщепит(ДокументОбщепит, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки)
	
	Запрос = Новый Запрос;
	
	// Поиск существующего документа "Списание недостач товаров",
	// связанного с текущим "Выпуском блюд".
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питТиповыеДокументы.ТиповойДокумент
	|ПОМЕСТИТЬ втДокументыВыпускПродукции
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|	И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.СписаниеНедостачТоваров
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втДокументыВыпускПродукции.ТиповойДокумент
	|ИЗ
	|	втДокументыВыпускПродукции КАК втДокументыВыпускПродукции";
	Запрос.УстановитьПараметр("Документпит",				ДокументОбщепит);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	// Если документ найден, то получаем объект иначе создаем новый.
	Если Выборка.Следующий() Тогда
		ТекДокументОбъект = Выборка.ТиповойДокумент.ПолучитьОбъект();
		ЭтоНовый = Ложь;
	ИначеЕсли НЕ ДокументОбщепит.Проведен Тогда
		Возврат Истина; // Для непроведенного выпуска, если раньше не было оприходования, то не создаем.
	Иначе
		ЭтоНовый = Истина;
		ТекДокументОбъект = Документы.СписаниеНедостачТоваров.СоздатьДокумент();
	КонецЕсли;
	
	// Определение параметров записи.
	ПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокументОбщепит.Проведен,ДокументОбщепит.ПометкаУдаления,
	ТекДокументОбъект.Проведен,ТекДокументОбъект.ПометкаУдаления,СтруктураПараметров);
	
	// Определение режима записи
	ТекРежимЗаписи = ПараметрыЗаписи.РежимЗаписи;
	
	// Для нового дока отменять проведения не требуется.
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения
		И ЭтоНовый Тогда
		Возврат Истина;
	КонецЕсли;
	
	// Получение данных по табличной части "Товары" отраслевого документа "питИнвентаризацияТоваров".
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	питИнвентаризацияТоваров.Номенклатура КАК Номенклатура,
	|	питИнвентаризацияТоваров.Характеристика КАК Характеристика,
	|	питИнвентаризацияТоваров.Серия КАК Серия,
	|	питИнвентаризацияТоваров.СтатусУказанияСерий КАК СтатусУказанияСерий,
	|	питИнвентаризацияТоваров.Назначение КАК Назначение,
	|	питИнвентаризацияТоваров.Упаковка КАК Упаковка,
	|	питИнвентаризацияТоваров.Количество - питИнвентаризацияТоваров.КоличествоФакт КАК Количество
	|ИЗ
	|	Документ.питИнвентаризацияТоваров.Товары КАК питИнвентаризацияТоваров
	|ГДЕ
	|	питИнвентаризацияТоваров.Ссылка = &Ссылка
	|	И питИнвентаризацияТоваров.Количество > питИнвентаризацияТоваров.КоличествоФакт";
	Запрос.УстановитьПараметр("Ссылка", ДокументОбщепит.Ссылка);
	
	РезультатЗапросаТовары = Запрос.Выполнить();
	ПодкладнойДокументПустой = Ложь;
	Если РезультатЗапросаТовары.Пустой() Тогда
		ПодкладнойДокументПустой = Истина;
		НоваяПометкаУдаления = ?(НЕ ЭтоНовый, Истина, Неопределено);
	ИначеЕсли ПараметрыЗаписи.НужнаУстановкаПометкиУдаления Тогда
		НоваяПометкаУдаления = ПараметрыЗаписи.ПометкаУдаления;
	Иначе
		НоваяПометкаУдаления = Неопределено;
	КонецЕсли;
	
	Если НЕ НоваяПометкаУдаления = Неопределено Тогда
		Попытка
			ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
			ТекДокументОбъект.УстановитьПометкуУдаления(НоваяПометкаУдаления);
		Исключение
			ТекстОшибки = ТекстОшибки + "
			|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
			| по документу Общепит """+ДокументОбщепит+"""
			|по причине: <"+ОписаниеОшибки()+">";
			Возврат Ложь;
		КонецПопытки;
	КонецЕсли;
	
	Если ПодкладнойДокументПустой Тогда
		Если НЕ ЭтоНовый Тогда
			ДобавитьНовуюЗапись(ДокументОбщепит, ТекДокументОбъект, тблСозданныеДокументы);
		КонецЕсли;
		Возврат Истина;
	КонецЕсли;
	
	/////////////////////////////////
	// ЗАПОЛНЕНИЕ ШАПКИ.
	ТекДокументОбъект.Дата						= ДокументОбщепит.Дата + ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0);
	ТекДокументОбъект.АналитикаРасходов			= ДокументОбщепит.АналитикаРасходов;
	ТекДокументОбъект.Комментарий				= ДокументОбщепит.Комментарий;
	ТекДокументОбъект.Организация				= ДокументОбщепит.ОрганизацияСкладскихАктов;
	ТекДокументОбъект.Ответственный				= ДокументОбщепит.Ответственный;
	ТекДокументОбъект.Подразделение				= ДокументОбщепит.Подразделение;
	ТекДокументОбъект.Склад						= ДокументОбщепит.Склад;
	ТекДокументОбъект.СтатьяРасходов			= ДокументОбщепит.СтатьяРасходов;
	ТекДокументОбъект.ВидЦены					= питОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументОбщепит.Склад,"УчетныйВидЦены");
	ТекДокументОбъект.ПересчетТоваров			= ?(СтруктураПараметров.Свойство("питДокументПересчетТоваров"),СтруктураПараметров.питДокументПересчетТоваров,Неопределено);
	ТекДокументОбъект.ИсточникИнформацииОЦенахДляПечати = Перечисления.ИсточникиИнформацииОЦенахДляПечати.ПоВидуЦен;
	
	// Очистка табличных частей, т.к. будет их перезаполнение.
	ТекДокументОбъект.Товары.Очистить();
	ТекДокументОбъект.ВидыЗапасов.Очистить();
	ТекДокументОбъект.ДополнительныеРеквизиты.Очистить();
	
	Выборка = РезультатЗапросаТовары.Выбрать();
	Пока Выборка.Следующий() Цикл
		НовСтрока						= ТекДокументОбъект.Товары.Добавить();
		НовСтрока.Номенклатура			= Выборка.Номенклатура;
		НовСтрока.Характеристика		= Выборка.Характеристика;
		НовСтрока.Количество			= Выборка.Количество;
		НовСтрока.Назначение			= Выборка.Назначение;
	КонецЦикла;
	
	/////////////////////////////////////////////////////////
	// ЗАПИСЬ ДОКУМЕНТА
	
	Попытка
		ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
		ТекДокументОбъект.Записать(ТекРежимЗаписи);
	Исключение
		ТекстОшибки = ТекстОшибки + "
		|Ошибка записи документа """ + ТекДокументОбъект.Метаданные().Представление() + """
		| по документу Общепит """+ДокументОбщепит+"""
		|по причине: <"+ОписаниеОшибки()+">";
		Возврат Ложь;
	КонецПопытки;
	
	// Добавление записи в результирующую таблицу в случае успешной записи документов.
	ДобавитьНовуюЗапись(ДокументОбщепит, ТекДокументОбъект, тблСозданныеДокументы);
	
	Возврат Истина;
	
КонецФункции

#КонецОбласти

#Область ФормированиеТиповыхДокументовПоПеремещениюНоменклатурыСкладаПроизводства

// Процедура формирования типовых документов по переданному документу питПеремещениеНоменклатурыСкладаПроизводства.
//
// Параметры:
//  ДокПеремещение			 - ДокументСсылка.питПеремещениеНоменклатурыСкладаПроизводства	 - Ссылка на документ "питПеремещениеНоменклатурыСкладаПроизводства", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьТиповыеДокументыПоПеремещениюНоменклатурыСкладаПроизводства(ДокПеремещение, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки = "")
	
	ВсеОк = Истина;
	
	ВсеОк = СформироватьПроизводствоБезЗаказовПоПеремещениюНоменклатурыСкладаПроизводства(ДокПеремещение, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
	Если НЕ ВсеОк Тогда 
		Возврат ВсеОк;
	КонецЕсли;
	
	СтруктураСкладовКладовая = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокПеремещение, "СкладОтправитель, СкладОтправитель.ЦеховаяКладовая, СкладПолучатель, СкладПолучатель.ЦеховаяКладовая");
	
	Если СтруктураСкладовКладовая.СкладОтправитель = СтруктураСкладовКладовая.СкладПолучатель Тогда
		
		Если НЕ ОтменитьПроведениеТиповогоДокументаПоДокументупит(ДокПеремещение, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки, "ПеремещениеТоваров",,Истина) Тогда
			Возврат Ложь;
		КонецЕсли;
		
		Если НЕ ОтменитьПроведениеТиповогоДокументаПоДокументупит(ДокПеремещение, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки, "ДвижениеПродукцииИМатериалов",,Истина) Тогда
			Возврат Ложь;
		КонецЕсли;
		
	ИначеЕсли СтруктураСкладовКладовая.СкладОтправительЦеховаяКладовая
		ИЛИ СтруктураСкладовКладовая.СкладПолучательЦеховаяКладовая Тогда
		
		Если НЕ ОтменитьПроведениеТиповогоДокументаПоДокументупит(ДокПеремещение, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки, "ПеремещениеТоваров",,Истина) Тогда
			Возврат Ложь;
		КонецЕсли;
		
		ВсеОк = СформироватьДвижениеПродукцииИМатериаловПоПеремещениюНоменклатурыСкладаПроизводства(ДокПеремещение, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
		
	Иначе
		
		Если НЕ ОтменитьПроведениеТиповогоДокументаПоДокументупит(ДокПеремещение, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки, "ДвижениеПродукцииИМатериалов",,Истина) Тогда
			Возврат Ложь;
		КонецЕсли;
		
		ВсеОк = СформироватьПеремещениеТоваровПеремещениюНоменклатурыСкладаПроизводства(ДокПеремещение, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки);
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ВсеОк;
	
КонецФункции

// Функция формирует документ "ПроизводствоБезЗаказа".
//
// Параметры:
//  ДокументВыпускБлюд		 - ДокументСсылка	 - Ссылка на документ "Выпуск блюд", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьПроизводствоБезЗаказовПоПеремещениюНоменклатурыСкладаПроизводства(ДокументОбщепит, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки)
	
	Запрос = Новый Запрос;
	
	// Поиск существующего документа "Производство без заказа",
	// связанного с текущим "Выпуском блюд".
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питТиповыеДокументы.ТиповойДокумент
	|ПОМЕСТИТЬ втДокументыВыпускПродукции
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|	И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.ПроизводствоБезЗаказа
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втДокументыВыпускПродукции.ТиповойДокумент
	|ИЗ
	|	втДокументыВыпускПродукции КАК втДокументыВыпускПродукции";
	Запрос.УстановитьПараметр("Документпит",				ДокументОбщепит);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	// Если документ найден, то получаем объект иначе создаем новый.
	Если Выборка.Следующий() Тогда
		ТекДокументОбъект = Выборка.ТиповойДокумент.ПолучитьОбъект();
		ЭтоНовый = Ложь;
	ИначеЕсли НЕ ДокументОбщепит.Проведен Тогда
		Возврат Истина; // Для непроведенного выпуска, если раньше не было оприходования, то не создаем.
	Иначе
		ЭтоНовый = Истина;
		ТекДокументОбъект = Документы.ПроизводствоБезЗаказа.СоздатьДокумент();
	КонецЕсли;
	
	// Определение параметров записи.
	ПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокументОбщепит.Проведен,ДокументОбщепит.ПометкаУдаления,
		ТекДокументОбъект.Проведен,ТекДокументОбъект.ПометкаУдаления,СтруктураПараметров);
	
	// Определение режима записи
	ТекРежимЗаписи = ПараметрыЗаписи.РежимЗаписи;
	
	Если ПараметрыЗаписи.НужнаУстановкаПометкиУдаления Тогда
		
		Попытка
			ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
			Если ЗначениеЗаполнено(ДокументОбщепит.ДокументИсточник) Тогда
				ТекДокументОбъект.ДополнительныеСвойства.Вставить("питДокументОбщепитРаспределениеЗапасов", ДокументОбщепит);
			КонецЕсли;
			ТекДокументОбъект.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
		Исключение
			ТекстОшибки = ТекстОшибки + "
			|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
			| по документу Общепит """+ДокументОбщепит+"""
			|по причине: <"+ОписаниеОшибки()+">";
			Возврат Ложь;
		КонецПопытки;
		
	КонецЕсли;
	
	// Получение данных отраслевого документа "питПеремещениеНоменклатурыСкладаПроизводства".
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	питПеремещениеНоменклатурыСкладаПроизводства.Номер КАК Номер,
	|	питПеремещениеНоменклатурыСкладаПроизводства.Дата КАК Дата,
	|	питПеремещениеНоменклатурыСкладаПроизводства.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
	|	питПеремещениеНоменклатурыСкладаПроизводства.Организация КАК Организация,
	|	питПеремещениеНоменклатурыСкладаПроизводства.Подразделение КАК Подразделение,
	|	питПеремещениеНоменклатурыСкладаПроизводства.СкладОтправитель КАК СкладОтправитель,
	|	питПеремещениеНоменклатурыСкладаПроизводства.СкладПолучатель КАК СкладПолучатель,
	|	питПеремещениеНоменклатурыСкладаПроизводства.Ответственный КАК Ответственный,
	|	питПеремещениеНоменклатурыСкладаПроизводства.Комментарий КАК Комментарий,
	|	питПеремещениеНоменклатурыСкладаПроизводства.Валюта КАК Валюта,
	|	питПеремещениеНоменклатурыСкладаПроизводства.СтатьяКалькуляции КАК СтатьяКалькуляции
	|ИЗ
	|	Документ.питПеремещениеНоменклатурыСкладаПроизводства КАК питПеремещениеНоменклатурыСкладаПроизводства
	|ГДЕ
	|	питПеремещениеНоменклатурыСкладаПроизводства.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаТоваров.Номенклатура КАК Номенклатура,
	|	ТаблицаТоваров.Характеристика КАК Характеристика,
	|	ТаблицаТоваров.Назначение КАК Назначение,
	|	ТаблицаТоваров.Серия КАК Серия,
	|	ТаблицаТоваров.СтатусУказанияСерий КАК СтатусУказанияСерий,
	|	ТаблицаТоваров.Упаковка КАК Упаковка,
	|	ТаблицаТоваров.НоменклатураОприходование КАК НоменклатураОприходование,
	|	ТаблицаТоваров.ХарактеристикаОприходование КАК ХарактеристикаОприходование,
	|	ТаблицаТоваров.НазначениеОприходование КАК НазначениеОприходование,
	|	ТаблицаТоваров.СерияОприходование КАК СерияОприходование,
	|	ТаблицаТоваров.СтатусУказанияСерийОприходование КАК СтатусУказанияСерийОприходование,
	|	ТаблицаТоваров.УпаковкаОприходование КАК УпаковкаОприходование,
	|	ТаблицаТоваров.Количество КАК Количество,
	|	ТаблицаТоваров.КоличествоОприходование КАК КоличествоОприходование,
	|	ТаблицаТоваров.КоэффициентПроизводства КАК КоэффициентПроизводства,
	|	ТаблицаТоваров.КоличествоУпаковок КАК КоличествоУпаковок,
	|	ТаблицаТоваров.КоличествоУпаковокОприходование КАК КоличествоУпаковокОприходование
	|ИЗ
	|	Документ.питПеремещениеНоменклатурыСкладаПроизводства.Товары КАК ТаблицаТоваров
	|ГДЕ
	|	ТаблицаТоваров.Ссылка = &Ссылка
	|	И НЕ(ТаблицаТоваров.Номенклатура = ТаблицаТоваров.НоменклатураОприходование
	|				И ТаблицаТоваров.Характеристика = ТаблицаТоваров.ХарактеристикаОприходование
	|				И ТаблицаТоваров.Серия = ТаблицаТоваров.СерияОприходование)";
	Запрос.УстановитьПараметр("Ссылка", ДокументОбщепит.Ссылка);
	РезультатЗапросаПакет = Запрос.ВыполнитьПакет();
	
	ШапкаДокументаОбщепит = РезультатЗапросаПакет[0].Выбрать();
	ШапкаДокументаОбщепит.Следующий();
	
	// Заполнение шапки.
	ТекДокументОбъект.Дата					= ШапкаДокументаОбщепит.Дата 
		+ ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0);
	ТекДокументОбъект.Организация			= ШапкаДокументаОбщепит.Организация;
	ТекДокументОбъект.Подразделение			= ШапкаДокументаОбщепит.Подразделение;
	ТекДокументОбъект.ГруппировкаЗатрат		= Перечисления.ГруппировкиЗатратВПроизводствеБезЗаказа.ПоПродукции;
	ТекДокументОбъект.Ответственный			= ШапкаДокументаОбщепит.Ответственный;
	ТекДокументОбъект.Комментарий			= ШапкаДокументаОбщепит.Комментарий;
	ТекДокументОбъект.Валюта				= ШапкаДокументаОбщепит.Валюта;
	
	// Автоопределение значения налогообложения НДС.
	ТекДокументОбъект.ВыпускПодДеятельность = Неопределено;
	ПараметрыЗаполнения = Документы.ПроизводствоБезЗаказа.ПараметрыЗаполненияВидаДеятельностиНДС(ТекДокументОбъект);
	УчетНДСУП.ЗаполнитьВидДеятельностиНДС(ТекДокументОбъект.ВыпускПодДеятельность, ПараметрыЗаполнения);
	
	// Очистка табличных частей, т.к. будет их перезаполнение.
	ТекДокументОбъект.ВыходныеИзделия.Очистить();
	ТекДокументОбъект.ВыходныеИзделияСерии.Очистить();
	ТекДокументОбъект.ПобочныеИзделия.Очистить();
	ТекДокументОбъект.ПобочныеИзделияСерии.Очистить();
	ТекДокументОбъект.МатериалыИРаботы.Очистить();
	ТекДокументОбъект.ДополнительныеРеквизиты.Очистить();
	ТекДокументОбъект.ВидыЗапасовМатериалыИРаботы.Очистить();
	ТекДокументОбъект.ВидыЗапасовВыходныеИзделия.Очистить();
	ТекДокументОбъект.ВидыЗапасовПобочныеИзделия.Очистить();
	ТекДокументОбъект.Трудозатраты.Очистить();
	
	ВыборкаБлюда = РезультатЗапросаПакет[1].Выбрать();
	ТекНомерГруппыЗатрат = 1;
	Пока ВыборкаБлюда.Следующий() Цикл
		Если ВыборкаБлюда.Количество > 0 Тогда
			
			НовСтрокаТЧ						= ТекДокументОбъект.ВыходныеИзделия.Добавить();
			НовСтрокаТЧ.НаправлениеВыпуска	= Перечисления.ХозяйственныеОперации.ВыпускПродукцииНаСклад;
			НовСтрокаТЧ.Получатель			= ШапкаДокументаОбщепит.СкладПолучатель;
			НовСтрокаТЧ.Номенклатура		= ВыборкаБлюда.НоменклатураОприходование;
			НовСтрокаТЧ.Характеристика		= ВыборкаБлюда.ХарактеристикаОприходование;
			НовСтрокаТЧ.Серия				= ВыборкаБлюда.СерияОприходование;
			НовСтрокаТЧ.Назначение			= ВыборкаБлюда.НазначениеОприходование;
			НовСтрокаТЧ.КоличествоУпаковок	= ВыборкаБлюда.КоличествоУпаковокОприходование;
			НовСтрокаТЧ.Количество			= ВыборкаБлюда.КоличествоОприходование;
			НовСтрокаТЧ.Упаковка			= ВыборкаБлюда.УпаковкаОприходование;
			НовСтрокаТЧ.ИдентификаторСтроки	= Новый УникальныйИдентификатор;
			НовСтрокаТЧ.НомерГруппыЗатрат	= ТекНомерГруппыЗатрат;
			НовСтрокаТЧ.Подразделение		= ШапкаДокументаОбщепит.Подразделение;
			
			НовСтрокаТЧ						= ТекДокументОбъект.МатериалыИРаботы.Добавить();
			НовСтрокаТЧ.Склад				= ШапкаДокументаОбщепит.СкладОтправитель;
			НовСтрокаТЧ.Подразделение		= ШапкаДокументаОбщепит.Подразделение;
			НовСтрокаТЧ.Номенклатура		= ВыборкаБлюда.Номенклатура;
			НовСтрокаТЧ.Характеристика		= ВыборкаБлюда.Характеристика;
			НовСтрокаТЧ.Серия				= ВыборкаБлюда.Серия;
			НовСтрокаТЧ.КоличествоУпаковок	= ВыборкаБлюда.КоличествоУпаковок;
			НовСтрокаТЧ.Количество			= ВыборкаБлюда.Количество;
			НовСтрокаТЧ.Упаковка			= ВыборкаБлюда.Упаковка;
			//+25
			НовСтрокаТЧ.ИдентификаторСтроки	= Новый УникальныйИдентификатор;
			//-25
			Если ЗначениеЗаполнено(ШапкаДокументаОбщепит.СтатьяКалькуляции) Тогда
				НовСтрокаТЧ.СтатьяКалькуляции	= ШапкаДокументаОбщепит.СтатьяКалькуляции;
			Иначе
				НовСтрокаТЧ.СтатьяКалькуляции	= питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("СтатьяКалькуляцииПоУмолчанию");
			КонецЕсли;
			НовСтрокаТЧ.НомерГруппыЗатрат	= ТекНомерГруппыЗатрат;
			
			ТекНомерГруппыЗатрат = ТекНомерГруппыЗатрат + 1;
		КонецЕсли;
	КонецЦикла;
	
	/////////////////////////////////////////////////////////
	// ЗАПИСЬ ДОКУМЕНТА
	
	//+Серии
	Если ТекРежимЗаписи <> РежимЗаписиДокумента.ОтменаПроведения И НЕ СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
		ЗаполнитьСерииТиповогоДокумента(ТекДокументОбъект, ДокументОбщепит);
	КонецЕсли;
	//-Серии
	
	ОтменитьЗапись = ТекДокументОбъект.ЭтоНовый() И НЕ ТекДокументОбъект.ВыходныеИзделия.Количество();
	Если НЕ ОтменитьЗапись Тогда
		
		// Если табличная часть пустая, то либо отмена проведения либо запись.
		Если НЕ ТекДокументОбъект.ВыходныеИзделия.Количество() Тогда
			Если ТекДокументОбъект.Проведен Тогда
				ТекРежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения;
			Иначе
				ТекРежимЗаписи = РежимЗаписиДокумента.Запись;
			КонецЕсли;
		КонецЕсли;
		
		Попытка
			ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
			Если ЗначениеЗаполнено(ДокументОбщепит.ДокументИсточник) Тогда
				ТекДокументОбъект.ДополнительныеСвойства.Вставить("питДокументОбщепитРаспределениеЗапасов", ДокументОбщепит);
			КонецЕсли;
			ТекДокументОбъект.Записать(ТекРежимЗаписи);
		Исключение
			ТекстОшибки = ТекстОшибки + "
			|Ошибка записи документа """ + ТекДокументОбъект.Метаданные().Представление() + """
			| по документу Общепит """+ДокументОбщепит+"""
			|по причине: <"+ОписаниеОшибки()+">";
			Возврат Ложь;
		КонецПопытки;
		
	КонецЕсли;
	
	// Добавление записи в результирующую таблицу в случае успешной записи документов.
	ДобавитьНовуюЗапись(ДокументОбщепит, ТекДокументОбъект, тблСозданныеДокументы);
	
	Возврат Истина;
	
КонецФункции

// Функция формирует документ "ДвижениеПродукцииИМатериалов".
//
// Параметры:
//  ДокументВыпускБлюд		 - ДокументСсылка	 - Ссылка на документ "Выпуск блюд", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьДвижениеПродукцииИМатериаловПоПеремещениюНоменклатурыСкладаПроизводства(ДокументОбщепит, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки)
	
	Запрос = Новый Запрос;
	
	// Поиск существующего документа "Производство без заказа",
	// связанного с текущим "Выпуском блюд".
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питТиповыеДокументы.ТиповойДокумент
	|ПОМЕСТИТЬ втДокументыВыпускПродукции
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|	И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.ДвижениеПродукцииИМатериалов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втДокументыВыпускПродукции.ТиповойДокумент
	|ИЗ
	|	втДокументыВыпускПродукции КАК втДокументыВыпускПродукции";
	Запрос.УстановитьПараметр("Документпит",				ДокументОбщепит);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	// Если документ найден, то получаем объект иначе создаем новый.
	Если Выборка.Следующий() Тогда
		ТекДокументОбъект = Выборка.ТиповойДокумент.ПолучитьОбъект();
		ЭтоНовый = Ложь;
	ИначеЕсли НЕ ДокументОбщепит.Проведен Тогда
		Возврат Истина; // Для непроведенного выпуска, если раньше не было оприходования, то не создаем.
	Иначе
		ЭтоНовый = Истина;
		ТекДокументОбъект = Документы.ДвижениеПродукцииИМатериалов.СоздатьДокумент();
	КонецЕсли;
	
	// Определение параметров записи.
	ПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокументОбщепит.Проведен,ДокументОбщепит.ПометкаУдаления,
		ТекДокументОбъект.Проведен,ТекДокументОбъект.ПометкаУдаления,СтруктураПараметров);
	
	// Определение режима записи
	ТекРежимЗаписи = ПараметрыЗаписи.РежимЗаписи;
	
	Если ПараметрыЗаписи.НужнаУстановкаПометкиУдаления Тогда
		
		Попытка
			ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
			Если ЗначениеЗаполнено(ДокументОбщепит.ДокументИсточник) Тогда
				ТекДокументОбъект.ДополнительныеСвойства.Вставить("питДокументОбщепитРаспределениеЗапасов", ДокументОбщепит);
			КонецЕсли;
			ТекДокументОбъект.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
		Исключение
			ТекстОшибки = ТекстОшибки + "
			|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
			| по документу Общепит """+ДокументОбщепит+"""
			|по причине: <"+ОписаниеОшибки()+">";
			Возврат Ложь;
		КонецПопытки;
		
	КонецЕсли;
	
	// Получение данных отраслевого документа "питПеремещениеНоменклатурыСкладаПроизводства".
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	питПеремещениеНоменклатурыСкладаПроизводства.Дата КАК Дата,
	|	питПеремещениеНоменклатурыСкладаПроизводства.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
	|	питПеремещениеНоменклатурыСкладаПроизводства.Организация КАК Организация,
	|	питПеремещениеНоменклатурыСкладаПроизводства.Подразделение КАК Подразделение,
	|	питПеремещениеНоменклатурыСкладаПроизводства.СкладОтправитель КАК СкладОтправитель,
	|	питПеремещениеНоменклатурыСкладаПроизводства.СкладПолучатель КАК СкладПолучатель,
	|	питПеремещениеНоменклатурыСкладаПроизводства.Ответственный КАК Ответственный,
	|	питПеремещениеНоменклатурыСкладаПроизводства.Комментарий КАК Комментарий,
	|	ЕСТЬNULL(СпрСкладОтправитель.ЦеховаяКладовая, ИСТИНА) КАК СкладОтправительЦеховаяКладовая,
	|	ЕСТЬNULL(СпрСкладПолучатель.ЦеховаяКладовая, ИСТИНА) КАК СкладПолучательЦеховаяКладовая,
	|	питПеремещениеНоменклатурыСкладаПроизводства.Валюта КАК Валюта
	|ИЗ
	|	Документ.питПеремещениеНоменклатурыСкладаПроизводства КАК питПеремещениеНоменклатурыСкладаПроизводства
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Склады КАК СпрСкладОтправитель
	|		ПО питПеремещениеНоменклатурыСкладаПроизводства.СкладОтправитель = СпрСкладОтправитель.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Склады КАК СпрСкладПолучатель
	|		ПО питПеремещениеНоменклатурыСкладаПроизводства.СкладПолучатель = СпрСкладПолучатель.Ссылка
	|ГДЕ
	|	питПеремещениеНоменклатурыСкладаПроизводства.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаТоваров.Номенклатура КАК Номенклатура,
	|	ТаблицаТоваров.Характеристика КАК Характеристика,
	|	ТаблицаТоваров.Назначение КАК Назначение,
	|	ТаблицаТоваров.Серия КАК Серия,
	|	ТаблицаТоваров.СтатусУказанияСерий КАК СтатусУказанияСерий,
	|	ТаблицаТоваров.Упаковка КАК Упаковка,
	|	ТаблицаТоваров.Количество КАК Количество,
	|	ТаблицаТоваров.КоличествоУпаковок КАК КоличествоУпаковок
	|ИЗ
	|	Документ.питПеремещениеНоменклатурыСкладаПроизводства.Товары КАК ТаблицаТоваров
	|ГДЕ
	|	ТаблицаТоваров.Ссылка = &Ссылка
	|	И ТаблицаТоваров.Номенклатура = ТаблицаТоваров.НоменклатураОприходование
	|	И ТаблицаТоваров.Характеристика = ТаблицаТоваров.ХарактеристикаОприходование
	|	И ТаблицаТоваров.Серия = ТаблицаТоваров.СерияОприходование";
	Запрос.УстановитьПараметр("Ссылка", ДокументОбщепит.Ссылка);
	РезультатЗапросаПакет = Запрос.ВыполнитьПакет();
	
	ШапкаДокументаОбщепит = РезультатЗапросаПакет[0].Выбрать();
	ШапкаДокументаОбщепит.Следующий();
	
	// Заполнение шапки.
	ТекДокументОбъект.Дата							= ШапкаДокументаОбщепит.Дата 
		+ ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0);
	ТекДокументОбъект.Организация					= ШапкаДокументаОбщепит.Организация;
	ТекДокументОбъект.Отправитель					= ШапкаДокументаОбщепит.СкладОтправитель;
	ТекДокументОбъект.Получатель					= ШапкаДокументаОбщепит.СкладПолучатель;
	ТекДокументОбъект.Ответственный					= ШапкаДокументаОбщепит.Ответственный;
	ТекДокументОбъект.Комментарий					= ШапкаДокументаОбщепит.Комментарий;
	ТекДокументОбъект.Статус						= Перечисления.СтатусыДвиженияПродукцииИМатериалов.Принято;
	//+25
	ТекДокументОбъект.Валюта						= ?(ЗначениеЗаполнено(ШапкаДокументаОбщепит.Валюта), ШапкаДокументаОбщепит.Валюта, Константы.ВалютаРегламентированногоУчета.Получить());
	ТекДокументОбъект.ВариантПриемкиТоваров			= Перечисления.ВариантыПриемкиТоваров.РазделенаТолькоПоНакладным;
	//-25
	
	// Матрица хоз операций движения продукции и материалов выглядит так:
	//							|| Перемещение в номенклатуру производства	|| Перемещение в номенклатуру склада
	//--------------------------------------------------------------------------------------------------------
	//Из кладовой на склад		|| Возврат материалов из кладовой			|| Возврат материалов из кладовой
	//Со склада в кладовую		|| Передача материалов в кладовую			|| Передача материалов в кладовую
	//Из кладовой в кладовую	|| Передача материалов в кладовую			|| Возврат материалов из кладовой
	Если ШапкаДокументаОбщепит.СкладОтправительЦеховаяКладовая И НЕ ШапкаДокументаОбщепит.СкладПолучательЦеховаяКладовая Тогда
		ТекДокументОбъект.ХозяйственнаяОперация			= Перечисления.ХозяйственныеОперации.ВозвратМатериаловИзКладовой;
	ИначеЕсли НЕ ШапкаДокументаОбщепит.СкладОтправительЦеховаяКладовая И ШапкаДокументаОбщепит.СкладПолучательЦеховаяКладовая Тогда
		ТекДокументОбъект.ХозяйственнаяОперация			= Перечисления.ХозяйственныеОперации.ПередачаМатериаловВКладовую;
	ИначеЕсли ШапкаДокументаОбщепит.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.ПеремещениеСкладскойНоменклатурыВПроизводство Тогда
		ТекДокументОбъект.ХозяйственнаяОперация			= Перечисления.ХозяйственныеОперации.ПередачаМатериаловВКладовую;
	Иначе
		ТекДокументОбъект.ХозяйственнаяОперация			= Перечисления.ХозяйственныеОперации.ВозвратМатериаловИзКладовой;
	КонецЕсли;
	
	// Автоопределение значения налогообложения НДС.
	ТекДокументОбъект.НалогообложениеНДС = Неопределено;
	ПараметрыЗаполнения = Документы.ДвижениеПродукцииИМатериалов.ПараметрыЗаполненияВидаДеятельностиНДС(ТекДокументОбъект);
	УчетНДСУП.ЗаполнитьВидДеятельностиНДС(ТекДокументОбъект.НалогообложениеНДС, ПараметрыЗаполнения);
	
	// Очистка табличных частей для избежания дублирования информации.
	ТекДокументОбъект.Товары.Очистить();
	ТекДокументОбъект.Серии.Очистить();
	ТекДокументОбъект.ВидыЗапасов.Очистить();
	ТекДокументОбъект.ДополнительныеРеквизиты.Очистить();
	
	Выборка = РезультатЗапросаПакет[1].Выбрать();
	ТекНомерГруппыЗатрат = 1;
	Пока Выборка.Следующий() Цикл
		Если Выборка.Количество > 0 Тогда
			
			НовСтрока						= ТекДокументОбъект.Товары.Добавить();
			НовСтрока.Номенклатура			= Выборка.Номенклатура;
			НовСтрока.Характеристика		= Выборка.Характеристика;
			НовСтрока.Серия					= Выборка.Серия;
			НовСтрока.Назначение			= Выборка.Назначение;
			НовСтрока.НазначениеОтправителя	= Выборка.Назначение;
			НовСтрока.Упаковка				= Выборка.Упаковка;
			НовСтрока.КоличествоУпаковок	= Выборка.КоличествоУпаковок;
			НовСтрока.Количество			= Выборка.Количество;    
			НовСтрока.ИдентификаторСтроки	= Новый УникальныйИдентификатор;
			
		КонецЕсли;
	КонецЦикла;
	
	/////////////////////////////////////////////////////////
	// ЗАПИСЬ ДОКУМЕНТА
	
	//+Серии
	Если ТекРежимЗаписи <> РежимЗаписиДокумента.ОтменаПроведения И НЕ СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
		ЗаполнитьСерииТиповогоДокумента(ТекДокументОбъект, ДокументОбщепит);
	КонецЕсли;
	//-Серии
	
	ОтменитьЗапись = ТекДокументОбъект.ЭтоНовый() И НЕ ТекДокументОбъект.Товары.Количество();
	Если НЕ ОтменитьЗапись Тогда
		
		// Если табличная часть пустая, то либо отмена проведения либо запись.
		Если НЕ ТекДокументОбъект.Товары.Количество() Тогда
			Если ТекДокументОбъект.Проведен Тогда
				ТекРежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения;
			Иначе
				ТекРежимЗаписи = РежимЗаписиДокумента.Запись;
			КонецЕсли;
		КонецЕсли;
		
		Попытка
			ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
			Если ЗначениеЗаполнено(ДокументОбщепит.ДокументИсточник) Тогда
				ТекДокументОбъект.ДополнительныеСвойства.Вставить("питДокументОбщепитРаспределениеЗапасов", ДокументОбщепит);
			КонецЕсли;
			ТекДокументОбъект.Записать(ТекРежимЗаписи);
		Исключение
			ТекстОшибки = ТекстОшибки + "
			|Ошибка записи документа """ + ТекДокументОбъект.Метаданные().Представление() + """
			| по документу Общепит """+ДокументОбщепит+"""
			|по причине: <"+ОписаниеОшибки()+">";
			Возврат Ложь;
		КонецПопытки;
		
	КонецЕсли;
	
	// Добавление записи в результирующую таблицу в случае успешной записи документов.
	ДобавитьНовуюЗапись(ДокументОбщепит, ТекДокументОбъект, тблСозданныеДокументы);
	
	Возврат Истина;
	
КонецФункции

// Функция формирует документ "ПеремещениеТоваров".
//
// Параметры:
//  ДокументВыпускБлюд		 - ДокументСсылка	 - Ссылка на документ "Выпуск блюд", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьПеремещениеТоваровПеремещениюНоменклатурыСкладаПроизводства(ДокументОбщепит, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки)
	
	Запрос = Новый Запрос;
	
	// Поиск существующего документа "Производство без заказа",
	// связанного с текущим "Выпуском блюд".
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питТиповыеДокументы.ТиповойДокумент
	|ПОМЕСТИТЬ втДокументыВыпускПродукции
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|	И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.ПеремещениеТоваров
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втДокументыВыпускПродукции.ТиповойДокумент
	|ИЗ
	|	втДокументыВыпускПродукции КАК втДокументыВыпускПродукции";
	Запрос.УстановитьПараметр("Документпит",				ДокументОбщепит);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	// Если документ найден, то получаем объект иначе создаем новый.
	Если Выборка.Следующий() Тогда
		ТекДокументОбъект = Выборка.ТиповойДокумент.ПолучитьОбъект();
		ЭтоНовый = Ложь;
	ИначеЕсли НЕ ДокументОбщепит.Проведен Тогда
		Возврат Истина; // Для непроведенного выпуска, если раньше не было оприходования, то не создаем.
	Иначе
		ЭтоНовый = Истина;
		ТекДокументОбъект = Документы.ПеремещениеТоваров.СоздатьДокумент();
	КонецЕсли;
	
	// Определение параметров записи.
	ПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокументОбщепит.Проведен,ДокументОбщепит.ПометкаУдаления,
		ТекДокументОбъект.Проведен,ТекДокументОбъект.ПометкаУдаления,СтруктураПараметров);
	
	// Определение режима записи
	ТекРежимЗаписи = ПараметрыЗаписи.РежимЗаписи;
	
	Если ПараметрыЗаписи.НужнаУстановкаПометкиУдаления Тогда
		
		Попытка
			ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
			Если ЗначениеЗаполнено(ДокументОбщепит.ДокументИсточник) Тогда
				ТекДокументОбъект.ДополнительныеСвойства.Вставить("питДокументОбщепитРаспределениеЗапасов", ДокументОбщепит);
			КонецЕсли;
			ТекДокументОбъект.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
		Исключение
			ТекстОшибки = ТекстОшибки + "
			|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
			| по документу Общепит """+ДокументОбщепит+"""
			|по причине: <"+ОписаниеОшибки()+">";
			Возврат Ложь;
		КонецПопытки;
		
	КонецЕсли;
	
	// Получение данных отраслевого документа "питПеремещениеНоменклатурыСкладаПроизводства".
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	питПеремещениеНоменклатурыСкладаПроизводства.Дата КАК Дата,
	|	питПеремещениеНоменклатурыСкладаПроизводства.Организация КАК Организация,
	|	питПеремещениеНоменклатурыСкладаПроизводства.Подразделение КАК Подразделение,
	|	питПеремещениеНоменклатурыСкладаПроизводства.СкладОтправитель КАК СкладОтправитель,
	|	питПеремещениеНоменклатурыСкладаПроизводства.СкладПолучатель КАК СкладПолучатель,
	|	питПеремещениеНоменклатурыСкладаПроизводства.Ответственный КАК Ответственный,
	|	питПеремещениеНоменклатурыСкладаПроизводства.Комментарий КАК Комментарий
	|ИЗ
	|	Документ.питПеремещениеНоменклатурыСкладаПроизводства КАК питПеремещениеНоменклатурыСкладаПроизводства
	|ГДЕ
	|	питПеремещениеНоменклатурыСкладаПроизводства.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаТоваров.Номенклатура КАК Номенклатура,
	|	ТаблицаТоваров.Характеристика КАК Характеристика,
	|	ТаблицаТоваров.Назначение КАК Назначение,
	|	ТаблицаТоваров.Серия КАК Серия,
	|	ТаблицаТоваров.СтатусУказанияСерий КАК СтатусУказанияСерий,
	|	ТаблицаТоваров.Упаковка КАК Упаковка,
	|	ТаблицаТоваров.Количество КАК Количество,
	|	ТаблицаТоваров.КоличествоУпаковок КАК КоличествоУпаковок
	|ИЗ
	|	Документ.питПеремещениеНоменклатурыСкладаПроизводства.Товары КАК ТаблицаТоваров
	|ГДЕ
	|	ТаблицаТоваров.Ссылка = &Ссылка
	|	И ТаблицаТоваров.Номенклатура = ТаблицаТоваров.НоменклатураОприходование
	|	И ТаблицаТоваров.Характеристика = ТаблицаТоваров.ХарактеристикаОприходование
	|	И ТаблицаТоваров.Серия = ТаблицаТоваров.СерияОприходование";
	Запрос.УстановитьПараметр("Ссылка", ДокументОбщепит.Ссылка);
	РезультатЗапросаПакет = Запрос.ВыполнитьПакет();
	
	ШапкаДокументаОбщепит = РезультатЗапросаПакет[0].Выбрать();
	ШапкаДокументаОбщепит.Следующий();
	
	/////////////////////////////////
	// ЗАПОЛНЕНИЕ ШАПКИ.
	//+25
	//ТекДокументОбъект.ДатаРаспоряжения				= КонецДня(ШапкаДокументаОбщепит.Дата);
	//-25
	// << MRS #ERP-5021 ДенисламовАД <Adel.Denislamov@mriyaresort.com> 14.04.25, ()
	//ТекДокументОбъект.ВидЦены						= питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("НормативныйТипЦенОбщепит");	// исходная строка
	Стр = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ШапкаДокументаОбщепит.СкладПолучатель, "РозничныйВидЦены, РозничныйВидЦены.ЦенаВключаетНДС");
	Если ЗначениеЗаполнено(Стр.РозничныйВидЦены) Тогда
		ТекДокументОбъект.ВидЦены = Стр.РозничныйВидЦены;
	Иначе
		ТекДокументОбъект.ВидЦены = Константы.питНормативнаяЦена.Получить();
	КонецЕсли;
	// >> MRS #ERP-5021 ДенисламовАД <Adel.Denislamov@mriyaresort.com> 14.04.25, ()
	ТекДокументОбъект.Дата							= ШапкаДокументаОбщепит.Дата 
		+ ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0);
	ТекДокументОбъект.Организация					= ШапкаДокументаОбщепит.Организация;
	//ТекДокументОбъект.ОрганизацияПолучатель			= ШапкаДокументаОбщепит.Организация;
	ТекДокументОбъект.Ответственный					= ШапкаДокументаОбщепит.Ответственный;
	ТекДокументОбъект.Подразделение					= ШапкаДокументаОбщепит.Подразделение;
	ТекДокументОбъект.СкладОтправитель				= ШапкаДокументаОбщепит.СкладОтправитель;
	ТекДокументОбъект.СкладПолучатель				= ШапкаДокументаОбщепит.СкладПолучатель;
	ТекДокументОбъект.Статус						= Перечисления.СтатусыПеремещенийТоваров.Принято;
	ТекДокументОбъект.ХозяйственнаяОперация			= Перечисления.ХозяйственныеОперации.ПеремещениеТоваров;
	ТекДокументОбъект.Комментарий					= ШапкаДокументаОбщепит.Комментарий;
	ТекДокументОбъект.СпособДоставки				= Перечисления.СпособыДоставки.Самовывоз;

	// Очистка табличных частей, т.к. будет их перезаполнение.
	ТекДокументОбъект.Товары.Очистить();
	ТекДокументОбъект.ВидыЗапасов.Очистить();
	ТекДокументОбъект.Серии.Очистить();
	ТекДокументОбъект.ДополнительныеРеквизиты.Очистить();
	
	Выборка = РезультатЗапросаПакет[1].Выбрать();
	ТекНомерГруппыЗатрат = 1;
	Пока Выборка.Следующий() Цикл
		Если Выборка.Количество > 0 Тогда
			
			НовСтрока						= ТекДокументОбъект.Товары.Добавить();
			НовСтрока.Номенклатура			= Выборка.Номенклатура;
			НовСтрока.Характеристика		= Выборка.Характеристика;
			НовСтрока.Серия					= Выборка.Серия;
			НовСтрока.Назначение			= Выборка.Назначение;
			НовСтрока.НазначениеОтправителя	= Выборка.Назначение;
			НовСтрока.Упаковка				= Выборка.Упаковка;
			НовСтрока.КоличествоУпаковок	= Выборка.КоличествоУпаковок;
			НовСтрока.Количество			= Выборка.Количество;
			
		КонецЕсли;
	КонецЦикла;
	
	/////////////////////////////////////////////////////////
	// ЗАПИСЬ ДОКУМЕНТА
	
	//+Серии
	Если ТекРежимЗаписи <> РежимЗаписиДокумента.ОтменаПроведения И НЕ СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
		ЗаполнитьСерииТиповогоДокумента(ТекДокументОбъект, ДокументОбщепит);
	КонецЕсли;
	//-Серии
	
	ОтменитьЗапись = ТекДокументОбъект.ЭтоНовый() И НЕ ТекДокументОбъект.Товары.Количество();
	Если НЕ ОтменитьЗапись Тогда
		
		// Если табличная часть пустая, то либо отмена проведения либо запись.
		Если НЕ ТекДокументОбъект.Товары.Количество() Тогда
			Если ТекДокументОбъект.Проведен Тогда
				ТекРежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения;
			Иначе
				ТекРежимЗаписи = РежимЗаписиДокумента.Запись;
			КонецЕсли;
		КонецЕсли;
		
		Попытка
			ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
			Если ЗначениеЗаполнено(ДокументОбщепит.ДокументИсточник) Тогда
				ТекДокументОбъект.ДополнительныеСвойства.Вставить("питДокументОбщепитРаспределениеЗапасов", ДокументОбщепит);
			КонецЕсли;
			ТекДокументОбъект.Записать(ТекРежимЗаписи);
		Исключение
			ТекстОшибки = ТекстОшибки + "
			|Ошибка записи документа """ + ТекДокументОбъект.Метаданные().Представление() + """
			| по документу Общепит """+ДокументОбщепит+"""
			|по причине: <"+ОписаниеОшибки()+">";
			Возврат Ложь;
		КонецПопытки;
		
	КонецЕсли;
	
	// Добавление записи в результирующую таблицу в случае успешной записи документов.
	ДобавитьНовуюЗапись(ДокументОбщепит, ТекДокументОбъект, тблСозданныеДокументы);
	
	Возврат Истина;
	
КонецФункции

#КонецОбласти

#Область УниверсальноеЗаполнениеДокументов

Процедура ЗаполнитьШапкуПеремещенияТоваровПоВыпускуБлюд(ДокументПеремещения, ДокументВыпускБлюд, СтруктураПараметров, БазовоеСмещение = 0, Организация = Неопределено)
	
	/////////////////////////////////
	// ЗАПОЛНЕНИЕ ШАПКИ.
	//+25
	//ДокументПеремещения.ДатаРаспоряжения				= КонецДня(ДокументВыпускБлюд.Дата);
	//-25
	ДокументПеремещения.ВидЦены						= ДокументВыпускБлюд.ТипЦен;
	ДокументПеремещения.Дата							= ДокументВыпускБлюд.Дата 
	+ ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0)
	- БазовоеСмещение;
	ДокументПеремещения.Организация					= ?(Организация = Неопределено, ДокументВыпускБлюд.Организация, Организация);
	//ТекДокументОбъект.ОрганизацияПолучатель			= ДокументВыпускБлюд.Организация;
	ДокументПеремещения.Ответственный					= ДокументВыпускБлюд.Ответственный;
	ДокументПеремещения.Подразделение					= ДокументВыпускБлюд.Подразделение;
	ДокументПеремещения.СкладОтправитель				= ДокументВыпускБлюд.Склад;
	ДокументПеремещения.СкладПолучатель				= ДокументВыпускБлюд.СкладПолучатель;
	ДокументПеремещения.Статус						= Перечисления.СтатусыПеремещенийТоваров.Принято;
	ДокументПеремещения.ХозяйственнаяОперация			= Перечисления.ХозяйственныеОперации.ПеремещениеТоваров;
	ДокументПеремещения.Комментарий					= ДокументВыпускБлюд.Комментарий;
	ДокументПеремещения.СпособДоставки				= Перечисления.СпособыДоставки.Самовывоз;
	ДокументПеремещения.НаправлениеДеятельности		= ДокументВыпускБлюд.НаправлениеДеятельности;
	
	ДокументПеремещения.ВариантПриемкиТоваров = Перечисления.ВариантыПриемкиТоваров.РазделенаТолькоПоНакладным;
	
КонецПроцедуры

Процедура ЗаполнитьШапкуДвиженияПродукцииИМатериаловПоВыпускуБлюд(ТекДокументОбъект, ДокументВыпускБлюд, СтруктураПараметров, БазовоеСмещение, Организация = Неопределено, ХозяйственнаяОперация = Неопределено)
	
	// Заполнение шапки.
	ТекДокументОбъект.Дата					= ДокументВыпускБлюд.Дата 
		+ ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0)
		- БазовоеСмещение;
	ТекДокументОбъект.Организация			= ?(Организация = Неопределено, ДокументВыпускБлюд.Организация, Организация);
	ТекДокументОбъект.Отправитель			= ДокументВыпускБлюд.Склад;
	ТекДокументОбъект.Получатель			= ДокументВыпускБлюд.СкладПолучатель;
	ТекДокументОбъект.Ответственный			= ДокументВыпускБлюд.Ответственный;
	ТекДокументОбъект.Комментарий			= ДокументВыпускБлюд.Комментарий;
	ТекДокументОбъект.ХозяйственнаяОперация	= ?(ХозяйственнаяОперация = Неопределено, Перечисления.ХозяйственныеОперации.ПередачаПродукцииИзКладовой, ХозяйственнаяОперация);
	ТекДокументОбъект.Статус				= Перечисления.СтатусыДвиженияПродукцииИМатериалов.Принято;
	ТекДокументОбъект.НаправлениеДеятельности	= ДокументВыпускБлюд.НаправлениеДеятельности;
	ТекДокументОбъект.Валюта				= ?(ЗначениеЗаполнено(ДокументВыпускБлюд.Валюта), ДокументВыпускБлюд.Валюта, Константы.ВалютаРегламентированногоУчета.Получить());
	ТекДокументОбъект.ВариантПриемкиТоваров	= Перечисления.ВариантыПриемкиТоваров.РазделенаТолькоПоНакладным;
	// Автоопределение значения налогообложения НДС.
	ТекДокументОбъект.НалогообложениеНДС = ?(СтруктураПараметров.Свойство("НалогообложениеНДС"), СтруктураПараметров.НалогообложениеНДС, Неопределено);
	
КонецПроцедуры

Процедура ОчиститьТабличныеЧастиДвиженияПродукцииИМатериалов(ТекДокументДвижениеПродукции)
	
	// Очистка табличных частей для избежания дублирования информации.
	ТекДокументДвижениеПродукции.Товары.Очистить();
	ТекДокументДвижениеПродукции.Серии.Очистить();
	ТекДокументДвижениеПродукции.ВидыЗапасов.Очистить();
	ТекДокументДвижениеПродукции.ДополнительныеРеквизиты.Очистить();
	
КонецПроцедуры

Процедура ОчиститьТабличныеЧастиПеремещенияТоваров(ТекДокументОбъект)
	
	// Очистка табличных частей, т.к. будет их перезаполнение.
	ТекДокументОбъект.Товары.Очистить();
	ТекДокументОбъект.ВидыЗапасов.Очистить();
	ТекДокументОбъект.Серии.Очистить();
	ТекДокументОбъект.ДополнительныеРеквизиты.Очистить();

