// Функция получаает режим записи документа общепита по действию отложенного проведения.
//
// Параметры:
//  ПеречислениеСсылка.питДействияОтложенногоПроведения - Действие отложенного проведения.
// 
// Возвращаемое значение:
// РежимЗаписиДокумента - Режим записи документа.
//
Функция ПолучитьРежимЗаписиДокументаОбщепитПоТекущемуДействию(ТекущееДействие)
	
	ТекРежимЗаписиДокумента = Неопределено;
	Если ТекущееДействие = Перечисления.питДействияОтложенногоПроведения.ЗаписатьДокументОбщепит Тогда
		ТекРежимЗаписиДокумента = РежимЗаписиДокумента.Запись;
	ИначеЕсли ТекущееДействие = Перечисления.питДействияОтложенногоПроведения.ПровестиДокументОбщепит Тогда
		ТекРежимЗаписиДокумента = РежимЗаписиДокумента.Проведение;
	ИначеЕсли ТекущееДействие = Перечисления.питДействияОтложенногоПроведения.ОтменитьПроведениеДокументаОбщепит Тогда
		ТекРежимЗаписиДокумента = РежимЗаписиДокумента.ОтменаПроведения;
	КонецЕсли;
	
	Возврат ТекРежимЗаписиДокумента;
	
КонецФункции

// Процедура-обработчик регламентного задания по обработке очереди отложенного проведения.
//
Процедура питОбработкаОчередиОтложенногоПроведения(ПараметрыЗадания = Неопределено) Экспорт
	
	// Обработка очереди происходит в привелегированном режиме.
	УстановитьПривилегированныйРежим(Истина);
	
	// Получение списка организаций из параметров регламентного задания.
	Организации = Неопределено;
	Если НЕ ПараметрыЗадания = Неопределено 
		И ПараметрыЗадания.Свойство("питОрганизации") 
		И ТипЗнч(ПараметрыЗадания.питОрганизации) = Тип("ТаблицаЗначений") Тогда
		Организации = ПараметрыЗадания.питОрганизации.ВыгрузитьКолонку("Организация");
		Если НЕ Организации.Количество() Тогда
			Организации = Неопределено;
		КонецЕсли;
	КонецЕсли;
	
	// Останавливать обработку очереди при возникновении ошибок.
	ОстанавливатьОбработкуОчередиПриВозникновенииОшибок = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питОстанавливатьОбработкуОчередиПриВозникновенииОшибок");
	
	// Текст ошибки.
	ТекстОшибки = "";
	
	// Получение текущего обрабатываемого документа из регистра обработки очереди.
	ТекСтруктураТекущийОбрабатываемыйДокумент = ПолучитьТекущийОбрабатываемыйДокумент(Неопределено, Организации);
	ТекДокумент			= ТекСтруктураТекущийОбрабатываемыйДокумент.ДокументОбщепит;
	ТекМоментВремени	= ТекСтруктураТекущийОбрабатываемыйДокумент.МоментВремени;
	Если ТекДокумент = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	//+питОценкаПроизводительности
	//ДатаНачалаЗамера = ОценкаПроизводительностиКлиентСервер.НачатьЗамерВремени();
	//-питОценкаПроизводительности
	
	// Получение текущих обрабатываемых действий по документу общепита.
	ТекДействия = ПолучитьТекущиеОбрабатываемыеДействия(ТекДокумент, Организации);
	Пока ТекДокумент <> Неопределено Цикл
		Если ТекДействия = Неопределено Тогда
			
			//+питОценкаПроизводительности
			//ОценкаПроизводительностиКлиентСервер.ЗакончитьЗамерВремени("питОтложенноеПроведениеВыпускаБлюд", ДатаНачалаЗамера, "Общепит отложенное проведение выпуска блюд");
			//-питОценкаПроизводительност
			
			// Если обрабатываемые действия закончились, то переходим к следующему документу общепита и получаем его действия.
			ТекСтруктураТекущийОбрабатываемыйДокумент = ПолучитьТекущийОбрабатываемыйДокумент(ТекМоментВремени, Организации);
			ТекДокумент			= ТекСтруктураТекущийОбрабатываемыйДокумент.ДокументОбщепит;
			ТекМоментВремени	= ТекСтруктураТекущийОбрабатываемыйДокумент.МоментВремени;
			Если НЕ ТекДокумент = Неопределено Тогда
				ТекДействия = ПолучитьТекущиеОбрабатываемыеДействия(ТекДокумент, Организации);
				
				//+питОценкаПроизводительности
				//ДатаНачалаЗамера = ОценкаПроизводительностиКлиентСервер.НачатьЗамерВремени();
				//-питОценкаПроизводительности
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если НЕ ТекДействия = Неопределено Тогда
			// Обработка выбранных действий отложенного проведения.
			ВсеОк = ОбработатьДействияОтложенногоПроведения(ТекДействия, ТекстОшибки);
			Если НЕ ВсеОк Тогда
				
				// Ошибка, запишем это в журнал регистрации.
				ИмяСобытияЖурнала = НСтр("ru = 'Обработка очереди отложенного проведения документов общепита'", ОбщегоНазначенияКлиентСервер.КодОсновногоЯзыка());
				ЗаписьЖурналаРегистрации(ИмяСобытияЖурнала, УровеньЖурналаРегистрации.Ошибка,,, ТекстОшибки);
				Если ОстанавливатьОбработкуОчередиПриВозникновенииОшибок Тогда
					ВызватьИсключение ТекстОшибки;
				Иначе
					// Завершаем обработку действий по текущему документу и переходим к следующему.
					ТекДействия = Неопределено;
					ТекстОшибки = "";
					Продолжить;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		Если НЕ ТекДокумент = Неопределено Тогда
			// Получение следующей "порции" обрабатываемых действий по текущему документу.
			ТекДействия = ПолучитьТекущиеОбрабатываемыеДействия(ТекДокумент, Организации);
		КонецЕсли;
	КонецЦикла;
	
	// Снятие привелегированного режима.
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

// Функция получает текущие обрабатываемые действия по документу общепита.
//
// Параметры:
//  ДокументОбщепит	 - ДокументСсылка.питВыпускБлюд - Документ общепита.
// 
// Возвращаемое значение:
//  ТаблицаЗначений - Таблица обрабатываемых действий из регистра.
//
Функция ПолучитьТекущиеОбрабатываемыеДействия(ДокументОбщепит, Организации = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питОчередьОтложенногоПроведения.ДокументОбщепит КАК ДокументОбщепит,
	|	питОчередьОтложенногоПроведения.Действие КАК Действие,
	|	питОчередьОтложенногоПроведения.ТиповойДокумент КАК ТиповойДокумент,
	|	питОчередьОтложенногоПроведения.Приоритет КАК Приоритет
	|ПОМЕСТИТЬ втДействия
	|ИЗ
	|	РегистрСведений.питОчередьОтложенногоПроведения КАК питОчередьОтложенногоПроведения
	|ГДЕ
	|	питОчередьОтложенногоПроведения.ДокументОбщепит = &ДокументОбщепит
	|%ОтборОрганизации%
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	питТиповыеДокументы.ДокументОбщепит КАК ДокументОбщепит,
	|	питТиповыеДокументы.ТиповойДокумент КАК ТиповойДокумент,
	|	питТиповыеДокументы.ПричинаТиповогоДокумента КАК ПричинаТиповогоДокумента
	|ПОМЕСТИТЬ втТиповыеДокументы
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	(питТиповыеДокументы.ДокументОбщепит, питТиповыеДокументы.ТиповойДокумент) В
	|			(ВЫБРАТЬ
	|				втДействия.ДокументОбщепит,
	|				втДействия.ТиповойДокумент
	|			ИЗ
	|				втДействия КАК втДействия)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втДействия.ДокументОбщепит КАК ДокументОбщепит,
	|	втДействия.Действие КАК Действие,
	|	втДействия.ТиповойДокумент КАК ТиповойДокумент,
	|	втДействия.Приоритет КАК Приоритет,
	|	втТиповыеДокументы.ПричинаТиповогоДокумента КАК ПричинаТиповогоДокумента,
	|	втДействия.ДокументОбщепит.Представление КАК ДокументОбщепитПредставление,
	|	втДействия.ТиповойДокумент.Представление КАК ТиповойДокументПредставление
	|ИЗ
	|	втДействия КАК втДействия
	|		ЛЕВОЕ СОЕДИНЕНИЕ втТиповыеДокументы КАК втТиповыеДокументы
	|		ПО втДействия.ДокументОбщепит = втТиповыеДокументы.ДокументОбщепит
	|			И втДействия.ТиповойДокумент = втТиповыеДокументы.ТиповойДокумент
	|
	|УПОРЯДОЧИТЬ ПО
	|	Приоритет";
	
	ОтборОрганизации = "";
	Если НЕ Организации = Неопределено Тогда
		ОтборОрганизации = " И питОчередьОтложенногоПроведения.ДокументОбщепит.Организация В (&Организации) ";
		Запрос.УстановитьПараметр("Организации", Организации);
	КонецЕсли;
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ОтборОрганизации%", ОтборОрганизации);
	
	Запрос.УстановитьПараметр("ДокументОбщепит", ДокументОбщепит);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Неопределено;
	Иначе
		Возврат РезультатЗапроса.Выгрузить();
	КонецЕсли;
	
КонецФункции

// Функция получает текущий обрабатываемый документ общепита.
// 
// Возвращаемое значение:
//  ДокументСсылка.питВыпускБлюд - Документ общепита.
//
Функция ПолучитьТекущийОбрабатываемыйДокумент(ТекМоментВремени, Организации = Неопределено)
	
	Результат = Новый Структура("ДокументОбщепит,МоментВремени", Неопределено, Неопределено);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	питОчередьОтложенногоПроведения.ДокументОбщепит КАК ДокументОбщепит,
	|	питОчередьОтложенногоПроведения.ДокументОбщепит.МоментВремени КАК МоментВремени
	|ИЗ
	|	РегистрСведений.питОчередьОтложенногоПроведения КАК питОчередьОтложенногоПроведения
	|%ОтборМоментВремениОрганизация%
	|
	|УПОРЯДОЧИТЬ ПО
	|	питОчередьОтложенногоПроведения.ДокументОбщепит.МоментВремени";
	
	ТекстОтбор = "";
	Если НЕ ТекМоментВремени = Неопределено Тогда
		ТекстОтбор = ТекстОтбор + ?(ПустаяСтрока(ТекстОтбор), " ГДЕ ", " И ") + " питОчередьОтложенногоПроведения.ДокументОбщепит.МоментВремени > &МоментВремени ";
	КонецЕсли;
	Если НЕ Организации = Неопределено Тогда
		ТекстОтбор = ТекстОтбор + ?(ПустаяСтрока(ТекстОтбор), " ГДЕ ", " И ") + " питОчередьОтложенногоПроведения.ДокументОбщепит.Организация В (&Организации) ";
		Запрос.УстановитьПараметр("Организации", Организации);
	КонецЕсли;
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ОтборМоментВремениОрганизация%", ТекстОтбор);
	
	Запрос.УстановитьПараметр("МоментВремени", ТекМоментВремени);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Результат;
	КонецЕсли;
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	ВыборкаДетальныеЗаписи.Следующий();
	ЗаполнитьЗначенияСвойств(Результат, ВыборкаДетальныеЗаписи);
	Возврат Результат;
	
КонецФункции

// Функция обрабатывает переданные действия отложенного проведения.
//
// Параметры:
//  ОбрабатываемыеДействия	 - ТаблицаЗначений - Таблица дейтсвий, которые необходимо обработать.
//  ТекстОшибки				 - Строка - Текст ошибки, в случае если она произойдет.
// 
// Возвращаемое значение:
//  Булево - Результат выполнения функции.
//
Функция ОбработатьДействияОтложенногоПроведения(ОбрабатываемыеДействия, ТекстОшибки = "")
	
	Для каждого ТекДействие Из ОбрабатываемыеДействия Цикл
		
		// Запись журнала регистрации о начале обработки дейтвия.
		ИмяСобытияЖурнала = НСтр("ru = 'Обработка очереди отложенного проведения документов общепита'", ОбщегоНазначенияКлиентСервер.КодОсновногоЯзыка());
		ТекстСообщения = "Документ <" + ТекДействие.ДокументОбщепитПредставление +">, обработка действия <"+ТекДействие.Действие+?(ЗначениеЗаполнено(ТекДействие.ТиповойДокументПредставление), ">, типовой документ <"+ТекДействие.ТиповойДокументПредставление+">", "");
		ЗаписьЖурналаРегистрации(ИмяСобытияЖурнала, УровеньЖурналаРегистрации.Информация,,, ТекстСообщения);
		
		// Каждое действие обрабатывается в отдельной транзакции.
		НачатьТранзакцию();
		
		// Блокировка записи регистра, которая соответствует обрабатываемому действию.
		Блокировка = Новый БлокировкаДанных;
		ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.питОчередьОтложенногоПроведения");
		ЭлементБлокировки.УстановитьЗначение("ДокументОбщепит"	, ТекДействие.ДокументОбщепит);
		ЭлементБлокировки.УстановитьЗначение("Действие"			, ТекДействие.Действие);
		ЭлементБлокировки.УстановитьЗначение("ТиповойДокумент"	, ТекДействие.ТиповойДокумент);
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
		Попытка
			Блокировка.Заблокировать();
		Исключение
			ТекстОшибки = ТекстОшибки + "
			|Ошибка блокировки записи регистра действий отложенного проведения
			| по документу Общепит """+ТекДействие.ДокументОбщепитПредставление+"""
			|по причине: <"+ОписаниеОшибки()+">";
			ОтменитьТранзакцию();
			Возврат Ложь;
		КонецПопытки;
		
		// Запись, проведение, отмена проведения.
		ЭтоДействиеЗаписиТиповогоДокумента	= ЭтоДействиеЗаписиТиповогоДокумента(ТекДействие.Действие);
		ЭтоДействиеЗаписиДокументаОбщепит	= ЭтоДействиеЗаписиДокументаОбщепит(ТекДействие.Действие);
		
		// Для каждого дейстивия выполняется свой алгоритм.
		Если ЭтоДействиеЗаписиДокументаОбщепит 
			ИЛИ ТекДействие.Действие = Перечисления.питДействияОтложенногоПроведения.ПометитьНаУдалениеДокументОбщепит 
			ИЛИ ТекДействие.Действие = Перечисления.питДействияОтложенногоПроведения.СнятьПометкуУдаленияДокументОбщепит Тогда
			
			// Запись документа общепита(производственные таблицы будут заполнены для режима "по норме").
			
			Попытка
				
				ТекДокументОбъект = ТекДействие.ДокументОбщепит.ПолучитьОбъект();
				
				Если НЕ ЭтоДействиеЗаписиДокументаОбщепит Тогда
					ТекРежимЗаписи = РежимЗаписиДокумента.Запись;
				Иначе
					ТекРежимЗаписи = ПолучитьРежимЗаписиДокументаОбщепитПоТекущемуДействию(ТекДействие.Действие);
				КонецЕсли;
				
				ТекДокументОбъект.ДополнительныеСвойства.Вставить("питВыполнениеДействияОтложенногоПроведения",Истина);
				ТекДокументОбъект.Записать(ТекРежимЗаписи);
			Исключение
				ТекстОшибки = ТекстОшибки + "
				|Ошибка записи документа общепит """ +ТекДействие.ДокументОбщепитПредставление+"""
				|по причине: <"+ОписаниеОшибки()+">";
				ОтменитьТранзакцию();
				Возврат Ложь;
			КонецПопытки;
			
		ИначеЕсли ТекДействие.Действие = Перечисления.питДействияОтложенногоПроведения.СформироватьТиповыеДокументы Тогда
			
			// Формирование типовых документов.
			ТекстОшибки = "";
			СтруктураПараметров = Новый Структура;
			// Проверка режима производства.
			ФормироватьДокументыПроизводства22 = Константы.питФормироватьДокументыПроизводства22.Получить();
			РежимПроизводстваРазрешен = питОбщегоНазначения.ПроверитьРежимПроизводстваERP(ФормироватьДокументыПроизводства22, ТекстОшибки);
			Если НЕ РежимПроизводстваРазрешен Тогда
				ОтменитьТранзакцию();
				Возврат Ложь;
			КонецЕсли;
			// Структура параметров.
			СтруктураПараметров.Вставить("ДатаСмещение", 0);
			СтруктураПараметров.Вставить("РежимПроизводстваРазрешен", РежимПроизводстваРазрешен);
			СтруктураПараметров.Вставить("ФормироватьДокументыПроизводства22", ФормироватьДокументыПроизводства22);
			
			ДокументОбщепитПроведен = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекДействие.ДокументОбщепит, "Проведен");
			Если НЕ ДокументОбщепитПроведен Тогда
				// Получение типовых документов с фильтром по типу.
				ЕстьПроведенныеТиповыеДокументы = Ложь;
				ТекТиповыеДокументы = Неопределено;
				ПараметрыПолучения = Новый Структура("УпорядочитьПоДатеИНомеру, УпорядочитьПоМоментуВремени, ФильтрПоТипу", Ложь, Ложь, "Документ.ПроизводствоБезЗаказа");
				НайтиТиповойДокументДляДокументапит(ТекДействие.ДокументОбщепит, ТекТиповыеДокументы, ТекстСообщения, ПараметрыПолучения);
				Если НЕ ТекТиповыеДокументы = Неопределено Тогда
					Если НЕ ТипЗнч(ТекТиповыеДокументы) = Тип("Массив") Тогда
						МассивТиповых = Новый Массив(1);
						МассивТиповых[0] = ТекТиповыеДокументы;
					Иначе
						МассивТиповых = ТекТиповыеДокументы;
					КонецЕсли;
					СоответствиеТиповых = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(МассивТиповых, "Проведен");
					Для каждого ТекСоответствиеТипового Из СоответствиеТиповых Цикл
						Если ТекСоответствиеТипового.Значение Тогда
							ЕстьПроведенныеТиповыеДокументы = Истина;
							Прервать;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
				ТекРежимЗаписи = ?(ЕстьПроведенныеТиповыеДокументы, РежимЗаписиДокумента.ОтменаПроведения, РежимЗаписиДокумента.Запись);
			Иначе
				ТекРежимЗаписи = РежимЗаписиДокумента.Проведение;
			КонецЕсли;
			СтруктураПараметров.Вставить("РежимЗаписи", ТекРежимЗаписи);
			
			// Синхронизация рецептуры и спецификации.
			Отказ = НЕ питТиповыеДокументы.СформироватьТиповыеДокументы(ТекДействие.ДокументОбщепит,СтруктураПараметров,,ТекстОшибки);
			Если Отказ Тогда
				ОтменитьТранзакцию();
				Возврат Ложь;
			КонецЕсли;
			
		ИначеЕсли ЭтоДействиеЗаписиТиповогоДокумента Тогда
			
			// Запись типовых документов.
			
			Попытка
				
				ТекДокументОбъект = ТекДействие.ТиповойДокумент.ПолучитьОбъект();
				
				ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
				ТекДокументОбъект.УстановитьПометкуУдаления(Ложь);
				
				//+Серии
				Если НЕ ТекДействие = Перечисления.питДействияОтложенногоПроведения.ОтменитьПроведениеТиповогоДокумента Тогда
					ЗаполнитьСерииТиповогоДокумента(ТекДокументОбъект, ТекДействие.ДокументОбщепит, ТекДействие.ПричинаТиповогоДокумента);
				КонецЕсли;
				//-Серии
				
				ТекРежимЗаписи = ПолучитьРежимЗаписиТиповогоДокументаПоТекущемуДействию(ТекДействие.Действие);
				
				ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
				ТекДокументОбъект.Записать(ТекРежимЗаписи);
			Исключение
				ОтменитьТранзакцию();
				ТекстОшибки = ТекстОшибки + "
				|Ошибка записи документа """ + ТекДействие.ТиповойДокументПредставление + """
				| по документу Общепит """+ТекДействие.ДокументОбщепитПредставление+"""
				|по причине: <"+ОписаниеОшибки()+">";
				Возврат Ложь;
			КонецПопытки;
			
			ВсеОк = УстановитьСинхронизациюТиповыхДокументов(ТекДействие.ДокументОбщепит, ТекДействие.ТиповойДокумент, Истина, ТекстОшибки);
			Если НЕ ВсеОк Тогда
				ОтменитьТранзакцию();
				Возврат ВсеОк;
			КонецЕсли;
			
		ИначеЕсли ТекДействие.Действие = Перечисления.питДействияОтложенногоПроведения.ПометитьНаУдалениеТиповойДокумент 
			ИЛИ ТекДействие.Действие = Перечисления.питДействияОтложенногоПроведения.СнятьПометкуУдаленияТиповойДокумент Тогда
			
			// Пометка удаления типовых документов.
			ТекПометкаУдаления = ТекДействие.Действие = Перечисления.питДействияОтложенногоПроведения.ПометитьНаУдалениеТиповойДокумент;
			
			ТекДокументОбъект = ТекДействие.ТиповойДокумент.ПолучитьОбъект();
			
			Попытка
				ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
				ТекДокументОбъект.УстановитьПометкуУдаления(ТекПометкаУдаления);
			Исключение
				ТекстОшибки = ТекстОшибки + "
				|Ошибка при установке пометки удаления типового документа""" + ТекДокументОбъект.Метаданные().Представление() + """
				| по документу Общепит """+ТекДействие.ДокументОбщепитПредставление+"""
				|по причине: <"+ОписаниеОшибки()+">";
				ОтменитьТранзакцию();
				Возврат Ложь;
			КонецПопытки;
			
			ВсеОк = УстановитьСинхронизациюТиповыхДокументов(ТекДействие.ДокументОбщепит, ТекДействие.ТиповойДокумент, Истина, ТекстОшибки);
			Если НЕ ВсеОк Тогда
				ОтменитьТранзакцию();
				Возврат ВсеОк;
			КонецЕсли;
			
		ИначеЕсли ТекДействие.Действие = Перечисления.питДействияОтложенногоПроведения.ОтвязатьТиповойДокумент Тогда
			
			// Удаление связи типовых документов.
			
			ВсеОк = УдалитьСвязьТиповогоДокументаСДокументомПит(ТекДействие.ТиповойДокумент, ТекДействие.ДокументОбщепит, ТекстОшибки);
			Если НЕ ВсеОк Тогда
				ОтменитьТранзакцию();
				Возврат ВсеОк;
			КонецЕсли;
			
		ИначеЕсли ТекДействие.Действие = Перечисления.питДействияОтложенногоПроведения.УстановитьСинхронизациюТиповогоДокумента Тогда
			
			// Установка синхронизации типовых документов.
			
			ВсеОк = УстановитьСинхронизациюТиповыхДокументов(ТекДействие.ДокументОбщепит, ТекДействие.ТиповойДокумент, Истина, ТекстОшибки);
			Если НЕ ВсеОк Тогда
				ОтменитьТранзакцию();
				Возврат ВсеОк;
			КонецЕсли;
			
		КонецЕсли;
		
		// Дейтвие выполнено, происходит его удаление из регистра.
		ВсеОк = УдалитьДействиеОтложенногоПроведения(ТекДействие.ДокументОбщепит, ТекДействие.Действие, ТекДействие.ТиповойДокумент, ТекстОшибки);
		Если НЕ ВсеОк Тогда
			ОтменитьТранзакцию();
			Возврат ВсеОк;
		КонецЕсли;
		
		// Фиксация транзакции.
		ЗафиксироватьТранзакцию();
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

// Функция определяет дейтсвие записи, проведения или отмены проведения.
