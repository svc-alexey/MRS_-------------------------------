// Функция ищет все связанные и проведенные с док. "Выпуск блюд" документы "Списание затрат на выпуск"
//  и перезаписывает их с отменой проведения.
//
// Параметры:
//  Документпит		 - ДокументСсылка	 - Ссылка на документ пита, по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция ОтменитьПроведениеТиповогоДокументаПоДокументупит(Документпит, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки = "", ИмяОтменяемогоДокумента = "", Причина = Неопределено, Синхронизировать = Ложь)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	питТиповыеДокументы.ТиповойДокумент
	|ПОМЕСТИТЬ втСписанияЗатрат
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|	%ТипДокумента%
	|	%Причина%
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втСписанияЗатрат.ТиповойДокумент
	|ИЗ
	|	втСписанияЗатрат КАК втСписанияЗатрат
	|ГДЕ
	|	втСписанияЗатрат.ТиповойДокумент.Проведен
	|УПОРЯДОЧИТЬ ПО
	|	втСписанияЗатрат.ТиповойДокумент УБЫВ";
	Запрос.УстановитьПараметр("Документпит",Документпит);
	
	Если НЕ Причина = Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"%Причина%", "И питТиповыеДокументы.ПричинаТиповогоДокумента = &Причина");
		Запрос.УстановитьПараметр("Причина", Причина);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"%Причина%", "");
	КонецЕсли;
	
	Если НЕ ПустаяСтрока(ИмяОтменяемогоДокумента) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ТипДокумента%", "И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ."+ИмяОтменяемогоДокумента+"");
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ТипДокумента%", "");
	КонецЕсли; 
	
	//<< Портал-Юг, Баринов, 2019.03.26 [5.3.6 Чтение и изменение данных инвентаризации товаров]
	// На чтение и изменение типовых документов прав может не быть
	УстановитьПривилегированныйРежим(Истина);
	//>> Портал-Юг, Баринов, 2019.03.26
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		ТекДокОбъект = Выборка.ТиповойДокумент.ПолучитьОбъект();
		Попытка
			УстановитьПривилегированныйРежим(Истина);
			ТекДокОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
			ТекДокОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
			УстановитьПривилегированныйРежим(Ложь);
		Исключение
			ТекстОшибки = ТекстОшибки + "
			|Ошибка отмены проведения документа """ + ТекДокОбъект.Метаданные().Представление() + """
			| по документу Общепит """+Документпит+"""
			|по причине: <"+ОписаниеОшибки()+">";
			Возврат Ложь;
		КонецПопытки;
		
		Если Синхронизировать Тогда
			// При отмене проведения сразу добавляем док в результирующую таблицу, что он синхронизирован.
			ДобавитьНовуюЗапись(Документпит, ТекДокОбъект, тблСозданныеДокументы, Причина, Истина);
		КонецЕсли;
		
	КонецЦикла;
	
	//<< Портал-Юг, Баринов, 2019.03.26 [5.3.6 Чтение и изменение данных инвентаризации товаров]
	УстановитьПривилегированныйРежим(Ложь);
	//>> Портал-Юг, Баринов, 2019.03.26
	
	Возврат Истина;
	
КонецФункции

// Функция ищет все связанные и проведенные с док. "Выпуск блюд" и отменяет их проведение в обратном порядке 
//  отосительно того, как документы были созданы.
//
// Параметры:
//  Документпит		 - ДокументСсылка	 - Ссылка на документ пита, по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция ОтменитьПроведениеТиповыхДокументовПоВыпускуБлюд(Документпит, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки = "")
	
	//<<===Портал-Юг Крым === Плотникова Н.Ю. 03.02.2021 [SD31412]   
	пл_БылиПривилегии = ПривилегированныйРежим();
	Если пл_БылиПривилегии = Ложь Тогда
	    УстановитьПривилегированныйРежим(Истина);
	КонецЕсли; 
	//>>===Портал-Юг Крым === Плотникова Н.Ю. 03.02.2021	
	
	//+ОтложенноеПроведение
	Если НЕ СтруктураПараметров.Свойство("питИспользоватьОтложенноеПроведениеВыпускаБлюд") Тогда
		СтруктураПараметров.Вставить("питИспользоватьОтложенноеПроведениеВыпускаБлюд", питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питИспользоватьОтложенноеПроведениеВыпускаБлюд"));
	КонецЕсли;
	Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд
		И НЕ СтруктураПараметров.Свойство("питТекущийПриоритетДействияОтложенногоПроведения") Тогда
		СтруктураПараметров.Вставить("питТекущийПриоритетДействияОтложенногоПроведения", ПолучитьТекущийПриоритетДействияОтложенногоПроведения(Документпит));
	КонецЕсли;
	//-ОтложенноеПроведение
	
	Если НЕ СтруктураПараметров.Свойство("ТаблицаПорядокПроведенияТиповыхДокументовВыпускаБлюд") Тогда
		СтруктураПараметров.Вставить("ТаблицаПорядокПроведенияТиповыхДокументовВыпускаБлюд", ПолучитьТаблицуПорядокПроведенияТиповыхДокументовВыпускаБлюд(СтруктураПараметров));
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	питТиповыеДокументы.ТиповойДокумент,
	|	питТиповыеДокументы.ПричинаТиповогоДокумента
	|ПОМЕСТИТЬ втВсеТиповые
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|;";
	
	Сч = 0;
	Для каждого ТекСтрокаТаблица Из СтруктураПараметров.ТаблицаПорядокПроведенияТиповыхДокументовВыпускаБлюд Цикл
		
		Запрос.Текст = Запрос.Текст + "
		|%ОбъединитьВсе%
		|
		|ВЫБРАТЬ
		|	ВЫРАЗИТЬ(питТиповыеДокументы.ТиповойДокумент КАК Документ.%ИмяТиповогоДокумента%) КАК ТиповойДокумент,
		|	питТиповыеДокументы.ПричинаТиповогоДокумента КАК ПричинаТиповогоДокумента,
		|	%Порядок% КАК Порядок,
		|	%ИмяТиповогоДокументаСтрока% КАК ИмяТиповогоДокумента
		|%ПОМЕСТИТЬ% 
		|ИЗ
		|	втВсеТиповые КАК питТиповыеДокументы
		|ГДЕ
		|	питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.%ИмяТиповогоДокумента%
		|	%ПричинаТиповогоДокумента%
		|";
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"%ОбъединитьВсе%", ?(Сч = 0, "", " ОБЪЕДИНИТЬ ВСЕ "));
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"%ПОМЕСТИТЬ%", ?(Сч = 0, " ПОМЕСТИТЬ втТиповыеДокументы ", ""));
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ИмяТиповогоДокумента%", ТекСтрокаТаблица.ИмяТиповогоДокумента);
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"%ПричинаТиповогоДокумента%", "И питТиповыеДокументы.ПричинаТиповогоДокумента = &Причина"+ТекСтрокаТаблица.Порядок);
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "%Порядок%", "&Порядок"+ТекСтрокаТаблица.Порядок);
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ИмяТиповогоДокументаСтрока%", "&ИмяТиповогоДокумента"+ТекСтрокаТаблица.Порядок);
		
		Запрос.УстановитьПараметр("Причина"+ТекСтрокаТаблица.Порядок, ТекСтрокаТаблица.ПричинаТиповогоДокумента);
		Запрос.УстановитьПараметр("Порядок"+ТекСтрокаТаблица.Порядок, ТекСтрокаТаблица.Порядок);
		Запрос.УстановитьПараметр("ИмяТиповогоДокумента"+ТекСтрокаТаблица.Порядок, ТекСтрокаТаблица.ИмяТиповогоДокумента);
		
		Сч = Сч + 1;
	КонецЦикла;
	
	Запрос.Текст = Запрос.Текст + "
	|;
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втТиповыеДокументы.ТиповойДокумент,
	|	втТиповыеДокументы.ПричинаТиповогоДокумента,
	|	втТиповыеДокументы.Порядок,
	|	втТиповыеДокументы.ИмяТиповогоДокумента
	|ИЗ
	|	втТиповыеДокументы КАК втТиповыеДокументы
	|ГДЕ
	|	втТиповыеДокументы.ТиповойДокумент.Проведен
	|УПОРЯДОЧИТЬ ПО
	|	втТиповыеДокументы.Порядок УБЫВ,
	|	втТиповыеДокументы.ТиповойДокумент УБЫВ
	|ИТОГИ
	|	КОЛИЧЕСТВО(ТиповойДокумент),
	|	МАКСИМУМ(ИмяТиповогоДокумента)
	|ПО
	|	Порядок";
	
	Запрос.УстановитьПараметр("Документпит",Документпит);
	
	СтароеЗначениеПараметраСеанса = ПараметрыСеанса.ПроводитьБезКонтроляОстатковТоваровОрганизаций;
	ПорядокПроизводствБезЗаказа = -1;
	
	ВыборкаВерхняя = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаВерхняя.Следующий() Цикл
		
		Если (ВыборкаВерхняя.ИмяТиповогоДокумента = "ДвижениеПродукцииИМатериалов"
			И ВыборкаВерхняя.ПричинаТиповогоДокумента = 0)
			ИЛИ ВыборкаВерхняя.ИмяТиповогоДокумента = "ПроизводствоБезЗаказа" Тогда
			ПараметрыСеанса.ПроводитьБезКонтроляОстатковТоваровОрганизаций = Истина;
		КонецЕсли;
		
		КоличествоДокументов = ВыборкаВерхняя.ТиповойДокумент;
		ТекКоличествоДокументов = 0;
		
		ВыборкаДетальная = ВыборкаВерхняя.Выбрать();
		Пока ВыборкаДетальная.Следующий() Цикл
			ТекКоличествоДокументов = ТекКоличествоДокументов + 1;
			
			Если КоличествоДокументов = ТекКоличествоДокументов Тогда
				ПараметрыСеанса.ПроводитьБезКонтроляОстатковТоваровОрганизаций = СтароеЗначениеПараметраСеанса;
			КонецЕсли;
			
			ТекДокОбъект = ВыборкаДетальная.ТиповойДокумент.ПолучитьОбъект();
			
			//+ОтложенноеПроведение
			Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
