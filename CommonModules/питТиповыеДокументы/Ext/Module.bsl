						НайденныйДокумент.Дата					= ДокументВыпускБлюд.Дата + ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0) - БазовоеСмещение;
						НайденныйДокумент.Организация			= ДокументВыпускБлюд.Организация;
						НайденныйДокумент.Отправитель			= ВыборкаДетальныеЗаписи.Склад; // Склад, на котором есть остаток
						НайденныйДокумент.Получатель			= ДокументВыпускБлюд.Склад;
						НайденныйДокумент.Ответственный			= ДокументВыпускБлюд.Ответственный;
						НайденныйДокумент.Комментарий			= ДокументВыпускБлюд.Комментарий;
						НайденныйДокумент.ХозяйственнаяОперация	= Перечисления.ХозяйственныеОперации.ПередачаПродукцииИзКладовой;
						НайденныйДокумент.Статус				= Перечисления.СтатусыДвиженияПродукцииИМатериалов.Принято;
						НайденныйДокумент.НаправлениеДеятельности = ДокументВыпускБлюд.НаправлениеДеятельности;
						// Автоопределение значения налогообложения НДС.
						НайденныйДокумент.НалогообложениеНДС	= ?(СтруктураПараметров.Свойство("НалогообложениеНДС"), СтруктураПараметров.НалогообложениеНДС, Неопределено);
						
						//+25
						НайденныйДокумент.Валюта				= ?(ЗначениеЗаполнено(ДокументВыпускБлюд.Валюта), ДокументВыпускБлюд.Валюта, Константы.ВалютаРегламентированногоУчета.Получить());
						НайденныйДокумент.ВариантПриемкиТоваров	= Перечисления.ВариантыПриемкиТоваров.РазделенаТолькоПоНакладным;
						//-25
						
						// Очистка табличных частей для избежания дублирования информации.
						НайденныйДокумент.Товары.Очистить();
						НайденныйДокумент.Серии.Очистить();
						НайденныйДокумент.ВидыЗапасов.Очистить();
						НайденныйДокумент.ДополнительныеРеквизиты.Очистить();
						
						НовСтрокаТаблицыДокументов = ТаблицаДокументов.Добавить();
						НовСтрокаТаблицыДокументов.Документ			= НайденныйДокумент;
						НовСтрокаТаблицыДокументов.СкладОтправитель	= ВыборкаДетальныеЗаписи.Склад;
						
					КонецЕсли;
					
					НовСтрокаДвижениеПродукцииИМатериалов = НайденныйДокумент.Товары.Добавить();
					НовСтрокаДвижениеПродукцииИМатериалов.Номенклатура				= ВыборкаДетальныеЗаписи.Номенклатура;
					НовСтрокаДвижениеПродукцииИМатериалов.Характеристика			= ВыборкаДетальныеЗаписи.Характеристика;
					НовСтрокаДвижениеПродукцииИМатериалов.Серия						= Справочники.СерииНоменклатуры.ПустаяСсылка(); // Серии заполнятся по FEFO позже
					НовСтрокаДвижениеПродукцииИМатериалов.Назначение				= ВыборкаДетальныеЗаписи.Назначение;
					НовСтрокаДвижениеПродукцииИМатериалов.НазначениеОтправителя		= ВыборкаДетальныеЗаписи.Назначение;
					НовСтрокаДвижениеПродукцииИМатериалов.КоличествоУпаковок		= КПеремещению;
					НовСтрокаДвижениеПродукцииИМатериалов.Количество				= КПеремещению;
					НовСтрокаДвижениеПродукцииИМатериалов.Упаковка					= Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка();
					НовСтрокаДвижениеПродукцииИМатериалов.ИдентификаторСтроки		= Новый УникальныйИдентификатор;
					НовСтрокаДвижениеПродукцииИМатериалов.ГруппаПродукции			= ВыборкаДетальныеЗаписи.ГруппаАналитическогоУчета;
					
					ОсталосьПереместить = ОсталосьПереместить - КПеремещению;
					
				КонецЦикла;
				
			КонецЦикла;
			
		КонецЕсли;
		
		/////////////////////////////////////////////////////////
		// ЗАПИСЬ ТИПОВОГО ДОКУМЕНТА 
		
		ТекДок = Неопределено;
		Для Инд = 0 По ТекущийИндексТиповогоДокумента-1 Цикл
			ТекДок = ТекДокументыОбъекты.Получить(Инд);
			
			// Определение параметров записи.
			ТекДокПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокументВыпускБлюд.Проведен,ДокументВыпускБлюд.ПометкаУдаления,
			ТекДок.Проведен,ТекДок.ПометкаУдаления,СтруктураПараметров);
			
			// Определение режима записи
			ТекДокТекРежимЗаписи = ТекДокПараметрыЗаписи.РежимЗаписи;
			Если НЕ ТекДок.Проведен И ТекДокТекРежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
				ТекДокТекРежимЗаписи = РежимЗаписиДокумента.Запись;
			КонецЕсли;
			
			//+Серии
			Если ТекДокТекРежимЗаписи <> РежимЗаписиДокумента.ОтменаПроведения И НЕ СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
				ЗаполнитьСерииТиповогоДокумента(ТекДок, ДокументВыпускБлюд, 2);
			КонецЕсли;
			//-Серии
			
			//+ОтложенноеПроведение
			Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
				ИсходныйДокТекРежимЗаписи	= ТекДокТекРежимЗаписи;
				ТекДокТекРежимЗаписи		= РежимЗаписиДокумента.Запись;
			КонецЕсли;
			//-ОтложенноеПроведение
			
			Попытка
				ТекДок.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
				ТекДок.Записать(ТекДокТекРежимЗаписи);
			Исключение
				ТекстОшибки = ТекстОшибки + "
				|Ошибка записи документа """ + ТекДок.Метаданные().Представление() + """
				| по документу Общепит """+ДокументВыпускБлюд+"""
				|по причине: <"+ОписаниеОшибки()+">";
				Возврат Ложь;
			КонецПопытки;
			
			//+ОтложенноеПроведение
			Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
				ТекДействие = ПолучитьТекущееДействиеПоРежимузаписиТиповогоДокумента(ИсходныйДокТекРежимЗаписи);
				ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ТекДействие, ТекДок.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
				СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
				Если НЕ ВсеОк Тогда 
					Возврат ВсеОк;
				КонецЕсли;
				ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.УстановитьСинхронизациюТиповогоДокумента, ТекДок.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
				СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
				Если НЕ ВсеОк Тогда 
					Возврат ВсеОк;
				КонецЕсли;
			КонецЕсли;
			//-ОтложенноеПроведение
			
			//+ОтложенноеПроведение
			ТекСинхронизирован = ?(СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд, Ложь, Истина);
			//-ОтложенноеПроведение
			
			// Добавление записи в результирующую таблицу в случае успешной записи документов.
			ДобавитьНовуюЗапись(ДокументВыпускБлюд, ТекДок, тблСозданныеДокументы, 2, ТекСинхронизирован);
			
		КонецЦикла;
		
	КонецЕсли; // Найдены НЕ разрешенные к производству позиции
	
	Если ТекДокументыОбъекты.Количество() > ТекущийИндексТиповогоДокумента Тогда
		
		Для Инд = ТекущийИндексТиповогоДокумента По ТекДокументыОбъекты.Количество()-1 Цикл
			
			ТекДок = ТекДокументыОбъекты.Получить(Инд);
			
			Если НЕ ПустаяСтрока(ТекДок.ВерсияДанных) Тогда
				
				//+ОтложенноеПроведение
				Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
					ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ПолучитьТекущееДействиеПоПометкеУдаленияТиповогоДокумента(Истина), ТекДок.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
					СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
					Если НЕ ВсеОк Тогда 
						Возврат ВсеОк;
					КонецЕсли;
					ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.УстановитьСинхронизациюТиповогоДокумента, ТекДок.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
					СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
					Если НЕ ВсеОк Тогда 
						Возврат ВсеОк;
					КонецЕсли;
				Иначе
				//-ОтложенноеПроведение
					
					Попытка
						ТекДок.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
						ТекДок.УстановитьПометкуУдаления(Истина);
					Исключение
						ТекстОшибки = ТекстОшибки + "
						|Ошибка при установке пометки удаления """ + ТекДок.Метаданные().Представление() + """
						| по документу Общепит """+ДокументВыпускБлюд+"""
						|по причине: <"+ОписаниеОшибки()+">";
						Возврат Ложь;
					КонецПопытки;
					
				КонецЕсли;
				
				//+ОтложенноеПроведение
				ТекСинхронизирован = ?(СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд, Ложь, Истина);
				//-ОтложенноеПроведение
				
				// Добавление записи в результирующую таблицу в случае успешной записи документов.
				ДобавитьНовуюЗапись(ДокументВыпускБлюд, ТекДок, тблСозданныеДокументы, 2, ТекСинхронизирован);
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

#Область ДокументыПоКомплекснымВыпускамБлюд

// Функция формирует документ "Отчет о розничных продажах" для выпуска с розничной реализацией.
//
// Параметры:
//  ДокументВыпускБлюд		 - ДокументСсылка	 - Ссылка на документ "Выпуск блюд", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьОтчетОРозничныхПродажахПоВыпускуБлюд(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки)
	
	Если СтруктураПараметров.Свойство("ФормироватьДокументыПроизводства22") Тогда
		ФормироватьДокументыПроизводства22 = СтруктураПараметров.ФормироватьДокументыПроизводства22;
	Иначе
		ФормироватьДокументыПроизводства22 = Константы.питФормироватьДокументыПроизводства22.Получить();
	КонецЕсли;
	
	Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументВыпускБлюд, "Склад.ЦеховаяКладовая") Тогда
		ИмяДокументаПеремещения = "ДвижениеПродукцииИМатериалов";
	Иначе
		ИмяДокументаПеремещения = "ПеремещениеТоваров";
	КонецЕсли;
	
	//+БазовоеСмещение
	Если НЕ СтруктураПараметров.Свойство("питСмещатьДатыТиповыхДокументов") Тогда
		СтруктураПараметров.Вставить("питСмещатьДатыТиповыхДокументов", питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питСмещатьДатыТиповыхДокументов"));
	КонецЕсли;
	// +++ Адель 31.07.2024 для сдига даты только Отчета о розничных продажах на 1 сек
	//БазовоеСмещениеОтчетаОРозничныхПродажах = 0;
	БазовоеСмещениеОтчетаОРозничныхПродажах = -1;
	// --- Адель 31.07.2024 для сдига даты только Отчета о розничных продажах на 1 сек
	БазовоеСмещениеДокументаПеремещения = 0;
	Если СтруктураПараметров.питСмещатьДатыТиповыхДокументов Тогда
		СтрокиСмещение = СтруктураПараметров.ТаблицаПорядокПроведенияТиповыхДокументовВыпускаБлюд.НайтиСтроки(
		Новый Структура("ИмяТиповогоДокумента,ПричинаТиповогоДокумента", "ОтчетОРозничныхПродажах", 0));
		Если СтрокиСмещение.Количество() Тогда
			БазовоеСмещениеОтчетаОРозничныхПродажах = СтрокиСмещение[0].БазовоеСмещение;
		КонецЕсли;
		СтрокиСмещение = СтруктураПараметров.ТаблицаПорядокПроведенияТиповыхДокументовВыпускаБлюд.НайтиСтроки(
		Новый Структура("ИмяТиповогоДокумента,ПричинаТиповогоДокумента", ИмяДокументаПеремещения, 1));
		Если СтрокиСмещение.Количество() Тогда
			БазовоеСмещениеДокументаПеремещения = СтрокиСмещение[0].БазовоеСмещение;
		КонецЕсли;
	КонецЕсли;
	//-БазовоеСмещение
	
	ОрганизацияКассыККМ = питОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументВыпускБлюд.КассаККМ, "Владелец");
	
	Запрос = Новый Запрос;
	
	// Поиск существующего документа "Отчет о розничных продажах",
	// связанного с текущим "Выпуском блюд".
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питТиповыеДокументы.ТиповойДокумент,
	|	питТиповыеДокументы.ДокументОбщепит,
	|	питТиповыеДокументы.ПричинаТиповогоДокумента
	|ПОМЕСТИТЬ втТиповыеДокументы
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	питТиповыеДокументы.ТиповойДокумент
	|ИЗ
	|	втТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.ОтчетОРозничныхПродажах
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫРАЗИТЬ(втТиповыеДокументы.ТиповойДокумент КАК Документ.%ИмяДокументаПеремещения%) КАК ТиповойДокумент,
	|	ВЫРАЗИТЬ(втТиповыеДокументы.ДокументОбщепит КАК Документ.питВыпускБлюд) КАК ДокументОбщепит
	|ПОМЕСТИТЬ втДвжиенияПродукцииИМатериалов
	|ИЗ
	|	втТиповыеДокументы КАК втТиповыеДокументы
	|ГДЕ
	|	втТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.%ИмяДокументаПеремещения%
	|	И втТиповыеДокументы.ПричинаТиповогоДокумента = 1
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втДвжиенияПродукцииИМатериалов.ТиповойДокумент
	|ИЗ
	|	втДвжиенияПродукцииИМатериалов КАК втДвжиенияПродукцииИМатериалов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.питВыпускБлюд КАК питВыпускБлюд
	|		ПО втДвжиенияПродукцииИМатериалов.ДокументОбщепит = питВыпускБлюд.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.%ИмяДокументаПеремещения% КАК %ИмяДокументаПеремещения%
	|		ПО втДвжиенияПродукцииИМатериалов.ТиповойДокумент = %ИмяДокументаПеремещения%.Ссылка
	|ГДЕ
	|	%ИмяДокументаПеремещения%.%ИмяПоляПолучатель% <> питВыпускБлюд.Склад
	//>>Швецов.11.02.2025. Розничные продажи алкоголя. 
	//По заборному листу разбиваем серийный алкоголь и все остальное на ОРП и ВН "списание на расходы"
	|;
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	питТиповыеДокументы.ТиповойДокумент
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|	И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.ВнутреннееПотребление
	|";
	//>>Швецов.11.02.2025. Розничные продажи алкоголя. 
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ИмяДокументаПеремещения%", ИмяДокументаПеремещения);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ИмяПоляПолучатель%", ?(ИмяДокументаПеремещения = "ДвижениеПродукцииИМатериалов", "Получатель", "СкладПолучатель"));
	
	Запрос.УстановитьПараметр("Документпит",				ДокументВыпускБлюд);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Выборка = РезультатЗапроса[1].Выбрать();
	
	// Если документ найден, то получаем объект иначе создаем новый.
	Если Выборка.Следующий() Тогда
		ТекДокументОбъект = Выборка.ТиповойДокумент.ПолучитьОбъект();
	Иначе
		ТекДокументОбъект = Документы.ОтчетОРозничныхПродажах.СоздатьДокумент();
	КонецЕсли;
	
	// Определение параметров записи.
	ПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокументВыпускБлюд.Проведен,ДокументВыпускБлюд.ПометкаУдаления,
		ТекДокументОбъект.Проведен,ТекДокументОбъект.ПометкаУдаления,СтруктураПараметров);
	
