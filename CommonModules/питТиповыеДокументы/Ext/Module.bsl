		Запрос.УстановитьПараметр("ДокументОбщепит", ДокументВыпускБлюд.Ссылка);
		Запрос.УстановитьПараметр("НаДату", КонецМесяца(ДокументВыпускБлюд.Дата));
		Запрос.УстановитьПараметр("НаДатуДата", КонецМесяца(ДокументВыпускБлюд.Дата));
