	// подмена основной выборки на выборку с ингредиентами и договорами
	//Выборка = РезультатЗапроса[0].Выбрать();
	Выборка = ПЛ_ВтЗапроса[3].Выбрать();
	
	// ПЛ_ТЗДляПроверкиКоличестваИнгредиентов - таблица, по которой будут рассчитываться отклонения после округления
	ПЛ_ТЗДляПроверкиКоличестваИнгредиентов = ПЛ_ВтЗапроса[0].Выгрузить();
	
	// ПЛ_ТЗДляОпределенияДоговора - таблица, из которой будет получен договор при переносе ошибок округления
	ПЛ_ТЗДляОпределенияДоговора = ПЛ_ВтЗапроса[1].Выгрузить();
	
