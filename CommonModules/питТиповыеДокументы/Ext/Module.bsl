				СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
				Если НЕ ВсеОк Тогда 
					//<<===Портал-Юг Крым === Плотникова Н.Ю. 03.02.2021 [SD31412]   
					Если пл_БылиПривилегии = Ложь Тогда
					    УстановитьПривилегированныйРежим(Ложь);
					КонецЕсли; 
					//>>===Портал-Юг Крым === Плотникова Н.Ю. 03.02.2021
					Возврат ВсеОк;
				КонецЕсли;
			Иначе
			//-ОтложенноеПроведение
				
				Попытка
					ТекДокОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
					ТекДокОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
					Если СтруктураПараметров.Свойство("ПометкаУдаленияНовая")
						И СтруктураПараметров.ПометкаУдаленияНовая <> ТекДокОбъект.ПометкаУдаления Тогда
						ТекДокОбъект.УстановитьПометкуУдаления(СтруктураПараметров.ПометкаУдаленияНовая);
					КонецЕсли;
				Исключение
					ТекстОшибки = ТекстОшибки + "
					|Ошибка отмены проведения документа """ + ТекДокОбъект.Метаданные().Представление() + """
					| по документу Общепит """+Документпит+"""
					|по причине: <"+ОписаниеОшибки()+">";
					//<<===Портал-Юг Крым === Плотникова Н.Ю. 03.02.2021 [SD31412]   
					Если пл_БылиПривилегии = Ложь Тогда
					    УстановитьПривилегированныйРежим(Ложь);
					КонецЕсли; 
					//>>===Портал-Юг Крым === Плотникова Н.Ю. 03.02.2021					
					Возврат Ложь;
				КонецПопытки;
				
			КонецЕсли;
			
			Если СтруктураПараметров.РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
				
				//+ОтложенноеПроведение
				Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
					ВсеОк = ДобавитьДействиеОтложенногоПроведения(Документпит, Перечисления.питДействияОтложенногоПроведения.УстановитьСинхронизациюТиповогоДокумента	, ВыборкаДетальная.ТиповойДокумент, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
					СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
					Если НЕ ВсеОк Тогда 
						//<<===Портал-Юг Крым === Плотникова Н.Ю. 03.02.2021 [SD31412]   
						Если пл_БылиПривилегии = Ложь Тогда
						    УстановитьПривилегированныйРежим(Ложь);
						КонецЕсли; 
						//>>===Портал-Юг Крым === Плотникова Н.Ю. 03.02.2021
						Возврат ВсеОк;
					КонецЕсли;
				КонецЕсли;
				//-ОтложенноеПроведение
				
				//+ОтложенноеПроведение
				ТекСинхронизирован = ?(СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд, Ложь, Истина);
				//-ОтложенноеПроведение
				
				// При отмене проведения сразу добавляем док в результирующую таблицу, что он синхронизирован.
				ДобавитьНовуюЗапись(Документпит, ТекДокОбъект, тблСозданныеДокументы, ВыборкаДетальная.ПричинаТиповогоДокумента, ТекСинхронизирован);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	ПараметрыСеанса.ПроводитьБезКонтроляОстатковТоваровОрганизаций = СтароеЗначениеПараметраСеанса;
	
	//<<===Портал-Юг Крым === Плотникова Н.Ю. 03.02.2021 [SD31412]   
	Если пл_БылиПривилегии = Ложь Тогда
	    УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли; 
	//>>===Портал-Юг Крым === Плотникова Н.Ю. 03.02.2021
	Возврат Истина;
	
КонецФункции

// Функция получает таблицу порядка проведения типовых документов выпуска блюд.
//
// Параметры:
//  СтруктураПараметров	 - Структура - Структура параметров.
// 
// Возвращаемое значение:
//  ТаблицаЗначений - таблица порядка проведения типовых документов выпуска блюд.
//
Функция ПолучитьТаблицуПорядокПроведенияТиповыхДокументовВыпускаБлюд(СтруктураПараметров, ОпорнаяДата = Неопределено)
	
	ИмяДокументаВнутреннееПотребление = питОбратнаяСовместимостьПовтИсп.ИмяДокументаВнутреннееПотребление();
	
	Если СтруктураПараметров.Свойство("ФормироватьДокументыПроизводства22") Тогда
		ФормироватьДокументыПроизводства22 = СтруктураПараметров.ФормироватьДокументыПроизводства22;
	Иначе
		ФормироватьДокументыПроизводства22 = Константы.питФормироватьДокументыПроизводства22.Получить();
	КонецЕсли;
	
	// Задача заполнить базовое смещение по дате для каждого подкладного документа, причем сделать это так, чтобы не
	//  выйти за пределы дня опорной даты(даты выпуска блюд).
	Если НЕ ОпорнаяДата = Неопределено Тогда
		СекундСНачалаДня = ОпорнаяДата - НачалоДня(ОпорнаяДата);
	Иначе
		СекундСНачалаДня = 60*60*24; // Значение по умолчанию.
	КонецЕсли;
	МаксимальноеБазовоеСмещение = ?(ФормироватьДокументыПроизводства22, 4, 5);
	Дельта = МаксимальноеБазовоеСмещение - СекундСНачалаДня;
	СдвигБазового = ?(Дельта > 0, Дельта, 0);
	
	КвалификаторыЧисла	= Новый КвалификаторыЧисла(3, 0, ДопустимыйЗнак.Любой);
	ОписаниеЧисла30		= Новый ОписаниеТипов("Число", КвалификаторыЧисла);
	ПорядокПроведенияТиповыхДокументов = Новый ТаблицаЗначений;
	ПорядокПроведенияТиповыхДокументов.Колонки.Добавить("ИмяТиповогоДокумента"		, Новый ОписаниеТипов("Строка"));
	ПорядокПроведенияТиповыхДокументов.Колонки.Добавить("ПричинаТиповогоДокумента"	, ОписаниеЧисла30);
	ПорядокПроведенияТиповыхДокументов.Колонки.Добавить("Порядок"					, ОписаниеЧисла30);
	ПорядокПроведенияТиповыхДокументов.Колонки.Добавить("БазовоеСмещение"			, ОписаниеЧисла30);
	Если ФормироватьДокументыПроизводства22 Тогда
		НовСтрокаПорядок = ПорядокПроведенияТиповыхДокументов.Добавить();
		НовСтрокаПорядок.ИмяТиповогоДокумента		= "ДвижениеПродукцииИМатериалов";
		НовСтрокаПорядок.ПричинаТиповогоДокумента	= 2;
		НовСтрокаПорядок.Порядок					= 0;
		НовСтрокаПорядок.БазовоеСмещение			= 4 - СдвигБазового;
		НовСтрокаПорядок = ПорядокПроведенияТиповыхДокументов.Добавить();
		НовСтрокаПорядок.ИмяТиповогоДокумента		= "ОприходованиеИзлишковТоваров";
		НовСтрокаПорядок.ПричинаТиповогоДокумента	= 0;
		НовСтрокаПорядок.Порядок					= 1;
		НовСтрокаПорядок.БазовоеСмещение			= 3 - СдвигБазового;
		НовСтрокаПорядок = ПорядокПроведенияТиповыхДокументов.Добавить();
		НовСтрокаПорядок.ИмяТиповогоДокумента		= "ПроизводствоБезЗаказа";
		НовСтрокаПорядок.ПричинаТиповогоДокумента	= 0;
		НовСтрокаПорядок.Порядок					= 2;
		НовСтрокаПорядок.БазовоеСмещение			= 2 - СдвигБазового;
		НовСтрокаПорядок = ПорядокПроведенияТиповыхДокументов.Добавить();
		НовСтрокаПорядок.ИмяТиповогоДокумента		= "ДвижениеПродукцииИМатериалов";
		НовСтрокаПорядок.ПричинаТиповогоДокумента	= 0;
		НовСтрокаПорядок.Порядок					= 3;
		НовСтрокаПорядок.БазовоеСмещение			= 2 - СдвигБазового;
	Иначе
		НовСтрокаПорядок = ПорядокПроведенияТиповыхДокументов.Добавить();
		НовСтрокаПорядок.ИмяТиповогоДокумента		= "ОприходованиеИзлишковТоваров";
		НовСтрокаПорядок.ПричинаТиповогоДокумента	= 0;
		НовСтрокаПорядок.Порядок					= 0;
		НовСтрокаПорядок.БазовоеСмещение			= 5 - СдвигБазового;
		НовСтрокаПорядок = ПорядокПроведенияТиповыхДокументов.Добавить();
		НовСтрокаПорядок.ИмяТиповогоДокумента		= "ПередачаМатериаловВПроизводство";
		НовСтрокаПорядок.ПричинаТиповогоДокумента	= 0;
		НовСтрокаПорядок.Порядок					= 1;
		НовСтрокаПорядок.БазовоеСмещение			= 4 - СдвигБазового;
		НовСтрокаПорядок = ПорядокПроведенияТиповыхДокументов.Добавить();
		НовСтрокаПорядок.ИмяТиповогоДокумента		= "ВыпускПродукции";
		НовСтрокаПорядок.ПричинаТиповогоДокумента	= 0;
		НовСтрокаПорядок.Порядок					= 2;
		НовСтрокаПорядок.БазовоеСмещение			= 3 - СдвигБазового;
		НовСтрокаПорядок = ПорядокПроведенияТиповыхДокументов.Добавить();
		НовСтрокаПорядок.ИмяТиповогоДокумента		= "СписаниеЗатратНаВыпуск";
		НовСтрокаПорядок.ПричинаТиповогоДокумента	= 0;
		НовСтрокаПорядок.Порядок					= 3;
		НовСтрокаПорядок.БазовоеСмещение			= 2 - СдвигБазового;
	КонецЕсли;
	НовСтрокаПорядок = ПорядокПроведенияТиповыхДокументов.Добавить();
	НовСтрокаПорядок.ИмяТиповогоДокумента		= "ДвижениеПродукцииИМатериалов";
	НовСтрокаПорядок.ПричинаТиповогоДокумента	= 1;
	НовСтрокаПорядок.Порядок					= 4;
	НовСтрокаПорядок.БазовоеСмещение			= 1 - СдвигБазового;
	НовСтрокаПорядок = ПорядокПроведенияТиповыхДокументов.Добавить();
	НовСтрокаПорядок.ИмяТиповогоДокумента		= "ПеремещениеТоваров";
	НовСтрокаПорядок.ПричинаТиповогоДокумента	= 1;
	НовСтрокаПорядок.Порядок					= 5;
	НовСтрокаПорядок.БазовоеСмещение			= 1 - СдвигБазового;
	НовСтрокаПорядок = ПорядокПроведенияТиповыхДокументов.Добавить();
	НовСтрокаПорядок.ИмяТиповогоДокумента		= "ОтчетОРозничныхПродажах";
	НовСтрокаПорядок.ПричинаТиповогоДокумента	= 0;
	НовСтрокаПорядок.Порядок					= 6;
	НовСтрокаПорядок.БазовоеСмещение			= 0 - СдвигБазового;
	НовСтрокаПорядок = ПорядокПроведенияТиповыхДокументов.Добавить();
	НовСтрокаПорядок.ИмяТиповогоДокумента		= "РеализацияТоваровУслуг";
	НовСтрокаПорядок.ПричинаТиповогоДокумента	= 0;
	НовСтрокаПорядок.Порядок					= 7;
	НовСтрокаПорядок.БазовоеСмещение			= 0 - СдвигБазового;
	НовСтрокаПорядок = ПорядокПроведенияТиповыхДокументов.Добавить();
	НовСтрокаПорядок.ИмяТиповогоДокумента		= "ДвижениеПродукцииИМатериалов";
	НовСтрокаПорядок.ПричинаТиповогоДокумента	= 3;
	НовСтрокаПорядок.Порядок					= 8;
	НовСтрокаПорядок.БазовоеСмещение			= 0 - СдвигБазового;
	НовСтрокаПорядок = ПорядокПроведенияТиповыхДокументов.Добавить();
	НовСтрокаПорядок.ИмяТиповогоДокумента		= "ПеремещениеТоваров";
	НовСтрокаПорядок.ПричинаТиповогоДокумента	= 0;
	НовСтрокаПорядок.Порядок					= 9;
	НовСтрокаПорядок.БазовоеСмещение			= 0 - СдвигБазового;
	НовСтрокаПорядок = ПорядокПроведенияТиповыхДокументов.Добавить();
	НовСтрокаПорядок.ИмяТиповогоДокумента		= ИмяДокументаВнутреннееПотребление;
	НовСтрокаПорядок.ПричинаТиповогоДокумента	= 0;
	НовСтрокаПорядок.Порядок					= 10;
	НовСтрокаПорядок.БазовоеСмещение			= 0 - СдвигБазового;
	НовСтрокаПорядок = ПорядокПроведенияТиповыхДокументов.Добавить();
	НовСтрокаПорядок.ИмяТиповогоДокумента		= "питКорректировкаОстатковИС";
	НовСтрокаПорядок.ПричинаТиповогоДокумента	= 0;
	НовСтрокаПорядок.Порядок					= 11;
	НовСтрокаПорядок.БазовоеСмещение			= 0 - СдвигБазового;
	//>>Швецов. 17.03.2025. Отмена проведения акта списания по выпуску блюд
	НовСтрокаПорядок = ПорядокПроведенияТиповыхДокументов.Добавить();
	НовСтрокаПорядок.ИмяТиповогоДокумента		= "АктСписанияЕГАИС";
	НовСтрокаПорядок.ПричинаТиповогоДокумента	= 0;
	НовСтрокаПорядок.Порядок					= 12;
	НовСтрокаПорядок.БазовоеСмещение			= 0 - СдвигБазового;
	//<<
	
