КонецФункции

// Функция обновляет регистр сведений "Типовые документы" по переданной таблице значений.
//
// Параметры:
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно
//  Ложь         - при выполнении функции возникли ошибки
//
Функция ОбновитьРегистрТиповыеДокументы(тблСозданныеДокументы, ТекстОшибки = "")
	
	// Регистраторы регистра потребностей
	
	// Запись движений
	Для Каждого ТекСтрока Из тблСозданныеДокументы Цикл
		Если ЗначениеЗаполнено(ТекСтрока.ТиповойДокумент) И ЗначениеЗаполнено(ТекСтрока.ДокументОбщепит) Тогда
			
			мМенеджерЗаписи = РегистрыСведений.питТиповыеДокументы.СоздатьМенеджерЗаписи();
			мМенеджерЗаписи.ТиповойДокумент				= ТекСтрока.ТиповойДокумент;
			мМенеджерЗаписи.ДокументОбщепит				= ТекСтрока.ДокументОбщепит;
			мМенеджерЗаписи.ПричинаТиповогоДокумента	= ТекСтрока.ПричинаТиповогоДокумента;
			мМенеджерЗаписи.Синхронизирован				= ТекСтрока.Синхронизирован;
			
			Попытка
				мМенеджерЗаписи.Записать();
			Исключение
				ТекстОшибки = ТекстОшибки + "
				|Ошибка обновления регистра сведений ""Типовые документы"":
				|" + ОписаниеОшибки();
				Возврат Ложь;
			КонецПопытки;
			
		КонецЕсли;
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

// (не используется) Процедура заполнения общих реквизитов типового документа по документу Общепит
//
// Параметры:
//  мДокументпит - ДокументСсылка - Ссылка на отраслевой документ.
//  мТиповойДокумент - ДокументОбъект - Документ-объект, который заполняем.
//
Процедура ЗаполнитьОбщиеРеквизиты(мДокументпит, мТиповойДокумент)
	
	мМетаданныеТиповогоДокумента	= мТиповойДокумент.Метаданные();
	мМетаданныеДокументапит		= мДокументпит.Метаданные();
	
	мТиповойДокумент.Дата = мДокументпит.Дата;
		
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Организация", мМетаданныеТиповогоДокумента) 
		И ОбщегоНазначения.ЕстьРеквизитОбъекта("Организация", мМетаданныеДокументапит) Тогда
		мТиповойДокумент.Организация		= мДокументпит.Организация;
	КонецЕсли;
	
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Подразделение", мМетаданныеТиповогоДокумента) Тогда
		Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Подразделение", мМетаданныеДокументапит) Тогда
			мТиповойДокумент.Подразделение 		= мДокументпит.Подразделение;
		ИначеЕсли ОбщегоНазначения.ЕстьРеквизитОбъекта("ПодразделениеОрганизации", мМетаданныеДокументапит) Тогда
			мТиповойДокумент.Подразделение 		= мДокументпит.ПодразделениеОрганизации;
		КонецЕсли;
	КонецЕсли;	
	
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("ПодразделениеОрганизации", мМетаданныеТиповогоДокумента) 
		И ОбщегоНазначения.ЕстьРеквизитОбъекта("ПодразделениеОрганизации", мМетаданныеДокументапит) Тогда
		мТиповойДокумент.ПодразделениеОрганизации 	= мДокументпит.ПодразделениеОрганизации;
	КонецЕсли;	
	
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("СуммаВключаетНДС", мМетаданныеТиповогоДокумента) 
		И ОбщегоНазначения.ЕстьРеквизитОбъекта("СуммаВключаетНДС", мМетаданныеДокументапит) Тогда
		мТиповойДокумент.СуммаВключаетНДС 	= мДокументпит.СуммаВключаетНДС;
	КонецЕсли;
	
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("ЦенаВключаетНДС", мМетаданныеТиповогоДокумента) 
		И ОбщегоНазначения.ЕстьРеквизитОбъекта("СуммаВключаетНДС", мМетаданныеДокументапит) Тогда
		мТиповойДокумент.ЦенаВключаетНДС 	= мДокументпит.СуммаВключаетНДС;
	КонецЕсли;
	
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Контрагент", мМетаданныеТиповогоДокумента)
		И ОбщегоНазначения.ЕстьРеквизитОбъекта("Контрагент", мМетаданныеДокументапит) Тогда
		мТиповойДокумент.Контрагент = мДокументпит.Контрагент;
	КонецЕсли;
	
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Договор", мМетаданныеТиповогоДокумента) Тогда
		Если ОбщегоНазначения.ЕстьРеквизитОбъекта("ДоговорКонтрагента", мМетаданныеДокументапит) Тогда
			мТиповойДокумент.Договор = мДокументпит.ДоговорКонтрагента;
		ИначеЕсли ОбщегоНазначения.ЕстьРеквизитОбъекта("Договор", мМетаданныеДокументапит) Тогда
			мТиповойДокумент.Договор = мДокументпит.Договор;
		КонецЕсли;
	КонецЕсли;
	
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Валюта", мМетаданныеТиповогоДокумента) 
		И ОбщегоНазначения.ЕстьРеквизитОбъекта("ВалютаДокумента", мМетаданныеДокументапит) Тогда
		
		мТиповойДокумент.Валюта = мДокументпит.ВалютаДокумента;
	КонецЕсли;
	
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Валюта", мМетаданныеТиповогоДокумента) 
		И ОбщегоНазначения.ЕстьРеквизитОбъекта("Валюта", мМетаданныеДокументапит) Тогда
		
		мТиповойДокумент.Валюта = мДокументпит.Валюта;
	КонецЕсли;
	
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("НалогообложениеНДС", мМетаданныеТиповогоДокумента)
		И ОбщегоНазначения.ЕстьРеквизитОбъекта("УчитыватьНДС", мМетаданныеДокументапит) Тогда
		
		Если мДокументпит.УчитыватьНДС Тогда
			мТиповойДокумент.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС;
		Иначе
			мТиповойДокумент.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаНеОблагаетсяНДС;
		КонецЕсли;
	КонецЕсли;
	
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("ЗакупкаПодДеятельность", мМетаданныеТиповогоДокумента)
		И ОбщегоНазначения.ЕстьРеквизитОбъекта("УчитыватьНДС", мМетаданныеДокументапит) Тогда
		
		Если мДокументпит.УчитыватьНДС Тогда
			мТиповойДокумент.ЗакупкаПодДеятельность = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС;
		Иначе
			мТиповойДокумент.ЗакупкаПодДеятельность = Перечисления.ТипыНалогообложенияНДС.ПродажаНеОблагаетсяНДС;
		КонецЕсли;
	КонецЕсли;
	
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Склад", мМетаданныеТиповогоДокумента) 
		И ОбщегоНазначения.ЕстьРеквизитОбъекта("Склад", мМетаданныеДокументапит) Тогда
		мТиповойДокумент.Склад 				= мДокументпит.Склад;
	КонецЕсли;
	
	//в некоторых документах УПП вместо реквизита "Склад" - реквизит "СкладОрдер" составного типа
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("СкладОрдер", мМетаданныеТиповогоДокумента)
		И ОбщегоНазначения.ЕстьРеквизитОбъекта("Склад", мМетаданныеДокументапит) Тогда
		мТиповойДокумент.ВидПоступления				= Перечисления.ВидыПоступленияТоваров.НаСклад;
		мТиповойДокумент.СкладОрдер 				= мДокументпит.Склад;
	КонецЕсли;
	
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Комментарий", мМетаданныеТиповогоДокумента) 
		И ОбщегоНазначения.ЕстьРеквизитОбъекта("Комментарий", мМетаданныеДокументапит) Тогда
		мТиповойДокумент.Комментарий = мДокументпит.Комментарий;
	КонецЕсли;
	
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Ответственный", мМетаданныеТиповогоДокумента) 
		И ОбщегоНазначения.ЕстьРеквизитОбъекта("Ответственный", мМетаданныеДокументапит) Тогда
		мТиповойДокумент.Ответственный = мДокументпит.Ответственный;
	КонецЕсли;
	
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("НомерВходящегоДокумента", мМетаданныеТиповогоДокумента) 
		И ОбщегоНазначения.ЕстьРеквизитОбъекта("НомерВходящегоДокумента", мМетаданныеДокументапит) Тогда
		мТиповойДокумент.НомерВходящегоДокумента = мДокументпит.НомерВходящегоДокумента;
	КонецЕсли;
	
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("ДатаВходящегоДокумента", мМетаданныеТиповогоДокумента) 
		И ОбщегоНазначения.ЕстьРеквизитОбъекта("ДатаВходящегоДокумента", мМетаданныеДокументапит) Тогда
		мТиповойДокумент.ДатаВходящегоДокумента = мДокументпит.ДатаВходящегоДокумента;
	КонецЕсли;
	
КонецПроцедуры

// Добавляет новую запись в таблицу со значениями измерений мТиповойДокумент и мДокументпит
//
// Параметры:
//  мДокументпит				 - ДокументСсылка	 - Ссылка на документ "пит".
//  мТиповойДокумент			 - ДокументОбъект	 - Ссылка на типовой документ.
//  тблСозданныеДокументы		 - ТаблицаЗначений	 - Таблица созданных документов.
//  ПричинаТиповогоДокумента	 - Число			 - Индекс, указывающий на назначение типового документа.
//   По умолчанию равен 0. Используется для:
//   - документа "ДвижениеПродукцииИМатериалов":
//    0 - При приготовлении полуфабрикатов на разных подразделениях(константа "питПодразделениеПроизводстваПолуфабрикатов");
//    1 - В выпуске с розничной реализацией для перемещения на склад реализации, если кладовая и склад реализации отличаются;
//    2 - При перемещений из кладовых производства;
//    3 - В выпуске с перемещением для перемещения на финальный склад в случае, если исходный является цеховой кладовой;
//
Процедура ДобавитьНовуюЗапись(мДокументпит, мТиповойДокумент, тблСозданныеДокументы, ПричинаТиповогоДокумента = 0, Синхронизирован = Истина)
	
	НоваяСтрока = тблСозданныеДокументы.Добавить();
	НоваяСтрока.ДокументОбщепит		= мДокументпит;
	НоваяСтрока.ТиповойДокумент		= мТиповойДокумент.Ссылка;
	НоваяСтрока.ПричинаТиповогоДокумента	= ПричинаТиповогоДокумента;
	НоваяСтрока.Синхронизирован				= Синхронизирован;
	
КонецПроцедуры

// Функция определяет параметры записи типового документа, такие как режим записи, пометка удаления.
//
// Параметры:
//  ДокпитПроведен	 - Булево	 - Признак проведения документа "пит".
//  ДокпитПомечен	 - Булево	 - Признак пометки на удаление документа "пит".
//  ТДПроведен			 - Булево	 - Признак проведения типового документа.
//  ТДПомечен			 - Булево	 - Признак пометки удаления типового документа.
//  ДопПараметры		 - Структура - Структура доп. параметров, которые используются при формировани типовых документов.
// 
// Возвращаемое значение:
//  Структура - Параметры записи типового документа.
//
Функция ОпределитьПараметрыЗаписиТиповогоДокумента(ДокпитПроведен, ДокпитПомечен, ТДПроведен = Неопределено, ТДПомечен, ДопПараметры)
	
	ПараметрыЗаписи = Новый Структура;
	ПараметрыЗаписи.Вставить("НужнаУстановкаПометкиУдаления"	,Ложь);
	ПараметрыЗаписи.Вставить("ПометкаУдаления"					,Ложь);
	ПараметрыЗаписи.Вставить("РежимЗаписи"						,Неопределено);
	
	// Нужно ли помечать на удаление типовой документ?
	Если ДопПараметры.Свойство("НужнаУстановкаПометкиУдаления") И НЕ ДопПараметры.НужнаУстановкаПометкиУдаления = Неопределено 
		И ДопПараметры.Свойство("ПометкаУдаления") И НЕ ДопПараметры.ПометкаУдаления = Неопределено Тогда
		
		ПараметрыЗаписи.НужнаУстановкаПометкиУдаления			= ДопПараметры.НужнаУстановкаПометкиУдаления;
		ПараметрыЗаписи.ПометкаУдаления							= ДопПараметры.ПометкаУдаления;
	ИначеЕсли ДокпитПомечен И НЕ ТДПомечен Тогда
		ПараметрыЗаписи.НужнаУстановкаПометкиУдаления			= Истина;
		ПараметрыЗаписи.ПометкаУдаления							= Истина;
	ИначеЕсли НЕ ДокпитПомечен И ТДПомечен Тогда
		ПараметрыЗаписи.НужнаУстановкаПометкиУдаления			= Истина;
		ПараметрыЗаписи.ПометкаУдаления							= Ложь;
	Иначе // пометка удаления не отличается.
		ПараметрыЗаписи.НужнаУстановкаПометкиУдаления			= Ложь;
	КонецЕсли;
	
	////////////////////////////
	// Определение режима записи
	
	ОпределятьРежимЗаписи = Истина;
	Если ДопПараметры.Свойство("ОпределятьРежимЗаписи") Тогда
		ОпределятьРежимЗаписи = ДопПараметры.ОпределятьРежимЗаписи;
	КонецЕсли;
	
	Если ОпределятьРежимЗаписи Тогда
		
		Если ДопПараметры.Свойство("РежимЗаписи") И НЕ ДопПараметры.РежимЗаписи = Неопределено Тогда
			ТекРежимЗаписи = ДопПараметры.РежимЗаписи;
		ИначеЕсли ДокпитПроведен Тогда
			ТекРежимЗаписи = РежимЗаписиДокумента.Проведение;
		ИначеЕсли НЕ ДокпитПроведен И ТДПроведен Тогда
			ТекРежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения;
		ИначеЕсли НЕ ДокпитПроведен И НЕ ТДПроведен Тогда
			ТекРежимЗаписи = РежимЗаписиДокумента.Запись;
		КонецЕсли;
		ПараметрыЗаписи.РежимЗаписи = ТекРежимЗаписи;
		
	КонецЕсли;
	
	////////////////////////////
	
	Возврат ПараметрыЗаписи;
	
КонецФункции

// Функция удаляет связь между типовым документом и документом общепита по регистру "питТиповыеДокументы"
//
// Параметры:
//  ТиповойДокумент	 - ДокументСсылка - Ссылка на типовой документ.
//  ДокументПит		 - ДокументСсылка - Ссылка на документ общепит.
//  ТекстОшибки		 - Строка - ТекстОшибки
// 
// Возвращаемое значение:
//  Булево - Результат выполнения функции
//
Функция УдалитьСвязьТиповогоДокументаСДокументомПит(ТиповойДокумент, ДокументПит, ТекстОшибки = "")
	
	МенеджерЗаписи = РегистрыСведений.питТиповыеДокументы.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.ДокументОбщепит = ДокументПит;
	МенеджерЗаписи.ТиповойДокумент = ТиповойДокумент;
	
	Попытка
		МенеджерЗаписи.Удалить();
	Исключение
		ТекстОшибки = "Ошибка удаления связи типового документа с документом общепит по причине: 
		|< "+ ОписаниеОшибки() + " >";
		Возврат Ложь;
	КонецПопытки;
	
	Возврат Истина;
	
КонецФункции

// Функция помечает на удаление и удаляет связь переданного массива типовых типовых документов
//  с переданным документом пит. Пметка на удаление происходит в том порядке, в котором документы пришли в массиве.
//
// Параметры:
//  ДокументПит			 - ДокументСсылка	 - Ссылка на документ Общепита
//  ТиповыеДокументы	 - Массив			 - Массив ссылок на типовые документы.
//  СтруктураПараметров	 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  ТекстОшибки			 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция ПометитьНаУдалениеИОтвязатьТиповыеДокументы(ДокументПит, ТиповыеДокументы, СтруктураПараметров, ТекстОшибки)
	
	Для каждого ТиповойДокумент Из ТиповыеДокументы Цикл
		
		Попытка
			ДокОбъект = ТиповойДокумент.ПолучитьОбъект();
			ДокОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
			ДокОбъект.УстановитьПометкуУдаления(Истина);
		Исключение
			ТекстОшибки = ТекстОшибки + "
			|Ошибка при установке пометки удаления """ + ДокОбъект.Метаданные().Представление() + """
			| по документу Общепит """+ДокументПит+"""
			|по причине: <"+ОписаниеОшибки()+">";
			Возврат Ложь;
		КонецПопытки;
		
		ВсеОк = УдалитьСвязьТиповогоДокументаСДокументомПит(ТиповойДокумент, ДокументПит, ТекстОшибки);
		Если НЕ ВсеОк Тогда
			Возврат Ложь;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

//+Серии
// Процедура заполняет серии типового документа перед его записью/проведением.
//
// Параметры:
//  ТекДокументОбъект		 - ДокументОбъект - Обьъект документа, в котором происходит заполнение серий.
//  ПричинаТиповогоДокумента - Число - Причина типового документа
//   По умолчанию равен 0. Используется для:
//   - документа "ДвижениеПродукцииИМатериалов":
//    0 - При приготовлении полуфабрикатов на разных подразделениях(константа "питПодразделениеПроизводстваПолуфабрикатов");
//    1 - В выпуске с розничной реализацией для перемещения на склад реализации, если кладовая и склад реализации отличаются;
//    2 - При перемещений из кладовых производства;
//    3 - В выпуске с перемещением для перемещения на финальный склад в случае, если исходный является цеховой кладовой;
//
Процедура ЗаполнитьСерииТиповогоДокумента(ТекДокументОбъект, ТекДокументОбщепит, ПричинаТиповогоДокумента = 0, тблСозданныеДокументы = Неопределено)
	
	ИмяДокументаВнутреннееПотребление = питОбратнаяСовместимостьПовтИсп.ИмяДокументаВнутреннееПотребление();
	
	Если ТипЗнч(ТекДокументОбщепит) = Тип("ДокументОбъект.питВыпускБлюд")
		ИЛИ ТипЗнч(ТекДокументОбщепит) = Тип("ДокументСсылка.питВыпускБлюд") Тогда
		
		// В зависимости от типа документа и причины типового документа заполнение серий происходит по разному.
		Если ТипЗнч(ТекДокументОбъект) = Тип("ДокументОбъект.ПроизводствоБезЗаказа") Тогда
			
			ПараметрыУказанияСерий = Новый ФиксированнаяСтруктура(НоменклатураСервер.ПараметрыУказанияСерий(ТекДокументОбъект, Документы.ПроизводствоБезЗаказа));
			
			НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(ТекДокументОбъект, ПараметрыУказанияСерий["ВыходныеИзделия"]);
			НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(ТекДокументОбъект, ПараметрыУказанияСерий["МатериалыИРаботы"]);
			НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(ТекДокументОбъект, ПараметрыУказанияСерий["ПобочныеИзделия"]);
			
			питПроизводство.ЗаполнитьСерииПоFEFO(ТекДокументОбъект,ПараметрыУказанияСерий["МатериалыИРаботы"], , тблСозданныеДокументы);
			
			питПроизводство.ЗаполнитьСерииВТЧСерииПоТЧТовары(ТекДокументОбъект, ПараметрыУказанияСерий["ВыходныеИзделия"]);
			питПроизводство.ЗаполнитьСерииВТЧСерииПоТЧТовары(ТекДокументОбъект, ПараметрыУказанияСерий["ПобочныеИзделия"]);
			
			питПроизводство.ЗаполнитьСерииВТЧТоварыПоТЧСерииПоСебестоимости(ТекДокументОбъект, ПараметрыУказанияСерий["ВыходныеИзделия"]);
			питПроизводство.ЗаполнитьСерииВТЧТоварыПоТЧСерииПоСебестоимости(ТекДокументОбъект, ПараметрыУказанияСерий["ПобочныеИзделия"]);
			
		ИначеЕсли ТипЗнч(ТекДокументОбъект) = Тип("ДокументОбъект.ДвижениеПродукцииИМатериалов") Тогда
			
			Если ПричинаТиповогоДокумента = 0 Тогда
				
				// Движение продукции из подразделений производства полуфабрикатов.
				ПараметрыУказанияСерий = Новый ФиксированнаяСтруктура(НоменклатураСервер.ПараметрыУказанияСерий(ТекДокументОбъект, Документы.ДвижениеПродукцииИМатериалов));
				НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(ТекДокументОбъект, ПараметрыУказанияСерий);
				//Здесь не может быть случая, когда необходимо заполнять по FEFO, т.к. перемещаются только что приготовленные ПФ по служебной серии.
				ТекДокументОбъект.Серии.Очистить();
				питПроизводство.ЗаполнитьСерииВТЧСерииПоТЧТовары(ТекДокументОбъект, ПараметрыУказанияСерий);
				
			ИначеЕсли ПричинаТиповогоДокумента = 1 Тогда
				
				// Движение продукции на склад реализации.
				ПараметрыУказанияСерий = Новый ФиксированнаяСтруктура(НоменклатураСервер.ПараметрыУказанияСерий(ТекДокументОбъект, Документы.ДвижениеПродукцииИМатериалов));
				НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(ТекДокументОбъект, ПараметрыУказанияСерий);
				питПроизводство.ЗаполнитьСерииПоFEFO(ТекДокументОбъект,ПараметрыУказанияСерий); 
				питПроизводство.ЗаполнитьСерииВТЧСерииПоТЧТовары(ТекДокументОбъект, ПараметрыУказанияСерий);
				питПроизводство.ЗаполнитьСерииВТЧТоварыПоТЧСерииПоСебестоимости(ТекДокументОбъект, ПараметрыУказанияСерий);
				
			ИначеЕсли ПричинаТиповогоДокумента = 2 Тогда
				
				// Движение продукции из разрешенных кладовых.
				ПараметрыУказанияСерий = Новый ФиксированнаяСтруктура(НоменклатураСервер.ПараметрыУказанияСерий(ТекДокументОбъект, Документы.ДвижениеПродукцииИМатериалов));
				НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(ТекДокументОбъект, ПараметрыУказанияСерий);
				питПроизводство.ЗаполнитьСерииПоFEFO(ТекДокументОбъект,ПараметрыУказанияСерий); 
				питПроизводство.ЗаполнитьСерииВТЧСерииПоТЧТовары(ТекДокументОбъект, ПараметрыУказанияСерий);
				питПроизводство.ЗаполнитьСерииВТЧТоварыПоТЧСерииПоСебестоимости(ТекДокументОбъект, ПараметрыУказанияСерий);
				
			ИначеЕсли ПричинаТиповогоДокумента = 3 Тогда
				
				// Перемещение из кладовой на склад получатель.
				ПараметрыУказанияСерий = Новый ФиксированнаяСтруктура(НоменклатураСервер.ПараметрыУказанияСерий(ТекДокументОбъект, Документы.ДвижениеПродукцииИМатериалов));
				НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(ТекДокументОбъект, ПараметрыУказанияСерий);
				питПроизводство.ЗаполнитьСерииПоFEFO(ТекДокументОбъект,ПараметрыУказанияСерий);
				питПроизводство.ЗаполнитьСерииВТЧСерииПоТЧТовары(ТекДокументОбъект, ПараметрыУказанияСерий);
				питПроизводство.ЗаполнитьСерииВТЧТоварыПоТЧСерииПоСебестоимости(ТекДокументОбъект, ПараметрыУказанияСерий);
				
			КонецЕсли;
			
		ИначеЕсли ТипЗнч(ТекДокументОбъект) = Тип("ДокументОбъект.ОтчетОРозничныхПродажах") Тогда
			
			ПараметрыУказанияСерий = Новый ФиксированнаяСтруктура(НоменклатураСервер.ПараметрыУказанияСерий(ТекДокументОбъект, Документы.ОтчетОРозничныхПродажах));
			НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(ТекДокументОбъект, ПараметрыУказанияСерий);
			питПроизводство.ЗаполнитьСерииПоFEFO(ТекДокументОбъект,ПараметрыУказанияСерий); 
			питПроизводство.ЗаполнитьСерииВТЧСерииПоТЧТовары(ТекДокументОбъект, ПараметрыУказанияСерий);
			питПроизводство.ЗаполнитьСерииВТЧТоварыПоТЧСерииПоСебестоимости(ТекДокументОбъект, ПараметрыУказанияСерий, Ложь);
			
		ИначеЕсли ТипЗнч(ТекДокументОбъект) = Тип("ДокументОбъект.РеализацияТоваровУслуг") Тогда
			
			ПараметрыУказанияСерий = Новый ФиксированнаяСтруктура(НоменклатураСервер.ПараметрыУказанияСерий(ТекДокументОбъект, Документы.РеализацияТоваровУслуг));
			НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(ТекДокументОбъект, ПараметрыУказанияСерий);
			питПроизводство.ЗаполнитьСерииПоFEFO(ТекДокументОбъект,ПараметрыУказанияСерий); 
			питПроизводство.ЗаполнитьСерииВТЧСерииПоТЧТовары(ТекДокументОбъект, ПараметрыУказанияСерий);
			питПроизводство.ЗаполнитьСерииВТЧТоварыПоТЧСерииПоСебестоимости(ТекДокументОбъект, ПараметрыУказанияСерий, Ложь);
			
		ИначеЕсли ТипЗнч(ТекДокументОбъект) = Тип("ДокументОбъект.ПеремещениеТоваров") Тогда
			
			// ПричинаТиповогоДокумента = 0 - комплексный документ Перемещение товаров
			// ПричинаТиповогоДокумента = 1 - перемещение продукции на склад реализации.
			ПараметрыУказанияСерий = Новый ФиксированнаяСтруктура(НоменклатураСервер.ПараметрыУказанияСерий(ТекДокументОбъект, Документы.ПеремещениеТоваров));
			НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(ТекДокументОбъект, ПараметрыУказанияСерий);
			питПроизводство.ЗаполнитьСерииПоFEFO(ТекДокументОбъект,ПараметрыУказанияСерий); 
			питПроизводство.ЗаполнитьСерииВТЧСерииПоТЧТовары(ТекДокументОбъект, ПараметрыУказанияСерий);
			питПроизводство.ЗаполнитьСерииВТЧТоварыПоТЧСерииПоСебестоимости(ТекДокументОбъект, ПараметрыУказанияСерий);
			
		ИначеЕсли ТипЗнч(ТекДокументОбъект) = Тип(СтрШаблон("ДокументОбъект.%1", ИмяДокументаВнутреннееПотребление)) Тогда
			
			ПараметрыУказанияСерий = Новый ФиксированнаяСтруктура(НоменклатураСервер.ПараметрыУказанияСерий(ТекДокументОбъект, Документы[ИмяДокументаВнутреннееПотребление]));
			НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(ТекДокументОбъект, ПараметрыУказанияСерий);
			питПроизводство.ЗаполнитьСерииВТЧСерииПоТЧТовары(ТекДокументОбъект, ПараметрыУказанияСерий);
			питПроизводство.ЗаполнитьСерииВТЧТоварыПоТЧСерииПоСебестоимости(ТекДокументОбъект, ПараметрыУказанияСерий);
			
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(ТекДокументОбщепит) = Тип("ДокументОбъект.питИнвентаризацияТоваров")
		ИЛИ ТипЗнч(ТекДокументОбщепит) = Тип("ДокументСсылка.питИнвентаризацияТоваров") Тогда
		
		Если ТипЗнч(ТекДокументОбъект) = Тип("ДокументОбъект.ПересчетТоваров") Тогда
			
			ПараметрыУказанияСерий = Новый ФиксированнаяСтруктура(НоменклатураСервер.ПараметрыУказанияСерий(ТекДокументОбъект, Документы.ПересчетТоваров));
			НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(ТекДокументОбъект, ПараметрыУказанияСерий);
			
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(ТекДокументОбщепит) = Тип("ДокументОбъект.питПеремещениеНоменклатурыСкладаПроизводства")
		ИЛИ ТипЗнч(ТекДокументОбщепит) = Тип("ДокументСсылка.питПеремещениеНоменклатурыСкладаПроизводства") Тогда
		
		// В зависимости от типа документа и причины типового документа заполнение серий происходит по разному.
		Если ТипЗнч(ТекДокументОбъект) = Тип("ДокументОбъект.ПроизводствоБезЗаказа") Тогда
			
			ПараметрыУказанияСерий = Новый ФиксированнаяСтруктура(НоменклатураСервер.ПараметрыУказанияСерий(ТекДокументОбъект, Документы.ПроизводствоБезЗаказа));
			
			НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(ТекДокументОбъект, ПараметрыУказанияСерий["ВыходныеИзделия"]);
			НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(ТекДокументОбъект, ПараметрыУказанияСерий["МатериалыИРаботы"]);
			НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(ТекДокументОбъект, ПараметрыУказанияСерий["ПобочныеИзделия"]);
			
			питПроизводство.ЗаполнитьСерииВТЧСерииПоТЧТовары(ТекДокументОбъект, ПараметрыУказанияСерий["ВыходныеИзделия"]);
			питПроизводство.ЗаполнитьСерииВТЧСерииПоТЧТовары(ТекДокументОбъект, ПараметрыУказанияСерий["ПобочныеИзделия"]);
			
			питПроизводство.ЗаполнитьСерииВТЧТоварыПоТЧСерииПоСебестоимости(ТекДокументОбъект, ПараметрыУказанияСерий["ВыходныеИзделия"]);
			питПроизводство.ЗаполнитьСерииВТЧТоварыПоТЧСерииПоСебестоимости(ТекДокументОбъект, ПараметрыУказанияСерий["ПобочныеИзделия"]);
			
		ИначеЕсли ТипЗнч(ТекДокументОбъект) = Тип("ДокументОбъект.ДвижениеПродукцииИМатериалов") Тогда
			
			ПараметрыУказанияСерий = Новый ФиксированнаяСтруктура(НоменклатураСервер.ПараметрыУказанияСерий(ТекДокументОбъект, Документы.ДвижениеПродукцииИМатериалов));
			НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(ТекДокументОбъект, ПараметрыУказанияСерий);
			питПроизводство.ЗаполнитьСерииВТЧСерииПоТЧТовары(ТекДокументОбъект, ПараметрыУказанияСерий);
			питПроизводство.ЗаполнитьСерииВТЧТоварыПоТЧСерииПоСебестоимости(ТекДокументОбъект, ПараметрыУказанияСерий);
			
		ИначеЕсли ТипЗнч(ТекДокументОбъект) = Тип("ДокументОбъект.ПеремещениеТоваров") Тогда
			
			ПараметрыУказанияСерий = Новый ФиксированнаяСтруктура(НоменклатураСервер.ПараметрыУказанияСерий(ТекДокументОбъект, Документы.ПеремещениеТоваров));
			НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(ТекДокументОбъект, ПараметрыУказанияСерий);
			питПроизводство.ЗаполнитьСерииВТЧСерииПоТЧТовары(ТекДокументОбъект, ПараметрыУказанияСерий);
			питПроизводство.ЗаполнитьСерииВТЧТоварыПоТЧСерииПоСебестоимости(ТекДокументОбъект, ПараметрыУказанияСерий);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры
