		ТекРежимЗаписи		= РежимЗаписиДокумента.Запись;
	КонецЕсли;
	//-ОтложенноеПроведение
	
	Попытка
		ДокВыпускПродукцииНаСклад.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
		ДокВыпускПродукцииНаСклад.Записать(ТекРежимЗаписи);
	Исключение
		ТекстОшибки = ТекстОшибки + "
		|Ошибка записи документа """ + ДокВыпускПродукцииНаСклад.Метаданные().Представление() + """(на склад)
		| по документу Общепит """+ДокументВыпускБлюд+"""
		|по причине: <"+ОписаниеОшибки()+">";
		Возврат Ложь;
	КонецПопытки;
	
	//+ОтложенноеПроведение
	Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
		ТекДействие = ПолучитьТекущееДействиеПоРежимузаписиТиповогоДокумента(ИсходныйРежимЗаписи);
		ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ТекДействие, ДокВыпускПродукцииНаСклад.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
		СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
		ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.УстановитьСинхронизациюТиповогоДокумента, ДокВыпускПродукцииНаСклад.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
		СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
		Если НЕ ВсеОк Тогда 
			Возврат ВсеОк;
		КонецЕсли;
	КонецЕсли;
	//-ОтложенноеПроведение
	
	//+ОтложенноеПроведение
	ТекСинхронизирован = ?(СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд, Ложь, Истина);
	//-ОтложенноеПроведение
	
	// Добавление записи в результирующую таблицу в случае успешной записи документов.
	ДобавитьНовуюЗапись(ДокументВыпускБлюд, ДокВыпускПродукцииНаСклад, тблСозданныеДокументы,,ТекСинхронизирован);
	ДобавитьНовуюЗапись(ДокументВыпускБлюд, ДокВыпускПродукцииВПодр, тблСозданныеДокументы,,ТекСинхронизирован);
	
	// Массив обновленных выпусков продукции, на которых будут ссылаться
	// документы "Списание затрат на выпуск".
	ДокументыВыпускаПродукции = Новый Массив;
	ДокументыВыпускаПродукции.Добавить(ДокВыпускПродукцииВПодр.Ссылка);
	ДокументыВыпускаПродукции.Добавить(ДокВыпускПродукцииНаСклад.Ссылка);
	СтруктураПараметров.Вставить("ДокументыВыпускаПродукции",ДокументыВыпускаПродукции);
	
	Возврат Истина;
	
КонецФункции

// Процедура по переданной ссылке на выпуск блюд ищет типовые документы "Выпуск продукции" с хоз. операцией
//  "В подразделение" или "На склад" возвращая ДокОбъект. Если не находит, то создает для них пустой объект.
//
// Параметры:
//  ДокументВыпускБлюд			 - ДокументСсылка	 - Ссылка на документ, для которого ищем "Выпуски продукции".
//  выхДокВыпускПродукцииНаСклад - ДокументОбъект	 - Документ "Выпуск продукции"(на склад).
//  выхДокВыпускПродукцииВПодр	 - ДокументОбъект	 - Документ "Выпуск продукции"(в подразделение).
//
Процедура ПолучитьВыпускиПродукцииДляВыпускаБлюд(ДокументВыпускБлюд, выхДокВыпускПродукцииНаСклад = Неопределено, выхДокВыпускПродукцииВПодр = Неопределено)
	
	Запрос = Новый Запрос;
	
	// Поиск всех выпусков продукции "В подразделение" или "На склад", 
	// связанных с текущим выпуском блюд.
	Запрос.Текст = 
	"ВЫБРАТЬ 
	|	питТиповыеДокументы.ТиповойДокумент
	|ПОМЕСТИТЬ втДокументыВыпускПродукции
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|	И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.ВыпускПродукции
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ 
	|	ВыпускПродукции.НаправлениеВыпуска,
	|	втДокументыВыпускПродукции.ТиповойДокумент КАК ВыпускПродукции
	|ИЗ
	|	втДокументыВыпускПродукции КАК втДокументыВыпускПродукции
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВыпускПродукции КАК ВыпускПродукции
	|		ПО (втДокументыВыпускПродукции.ТиповойДокумент = ВыпускПродукции.Ссылка)
	|ГДЕ
	|	ВыпускПродукции.НаправлениеВыпуска В(&НеобходимыеНаправленияВыпуска)";
	
	// Список хоз. операций, поиск будет производиться только для них.
	НаправленияВыпуска = Новый СписокЗначений;
	НаправленияВыпуска.Добавить(Перечисления.ХозяйственныеОперации.ВыпускПродукцииВПодразделение);
	НаправленияВыпуска.Добавить(Перечисления.ХозяйственныеОперации.ВыпускПродукцииНаСклад);
	
	Запрос.УстановитьПараметр("Документпит",				ДокументВыпускБлюд);
	Запрос.УстановитьПараметр("НеобходимыеНаправленияВыпуска",	НаправленияВыпуска);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	// Если документы найдены, то инициализируем соответствующие переменные.
	Пока Выборка.Следующий() Цикл
		Если Выборка.НаправлениеВыпуска = Перечисления.ХозяйственныеОперации.ВыпускПродукцииВПодразделение Тогда
			Если выхДокВыпускПродукцииВПодр = Неопределено Тогда
				выхДокВыпускПродукцииВПодр = Выборка.ВыпускПродукции.ПолучитьОбъект();
			Иначе
				// Случай, когда С "Выпуском блюд" связано более 1го "Выпуск продукции"(В подразделение).
			КонецЕсли;
		ИначеЕсли Выборка.НаправлениеВыпуска = Перечисления.ХозяйственныеОперации.ВыпускПродукцииНаСклад Тогда
			Если выхДокВыпускПродукцииНаСклад = Неопределено Тогда
				выхДокВыпускПродукцииНаСклад = Выборка.ВыпускПродукции.ПолучитьОбъект();
			Иначе
				// Случай, когда С "Выпуском блюд" связано более 1го "Выпуск продукции"(На склад).
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	// Если переменные не инициализированны, значит документы не были найдены
	// и необходимо создать пустые документы-объекты, которые далее будут заполняться.
	Если выхДокВыпускПродукцииВПодр = Неопределено Тогда
		выхДокВыпускПродукцииВПодр = Документы["ВыпускПродукции"].СоздатьДокумент();
	КонецЕсли;
	Если выхДокВыпускПродукцииНаСклад = Неопределено Тогда
		выхДокВыпускПродукцииНаСклад = Документы["ВыпускПродукции"].СоздатьДокумент();
	КонецЕсли;
	
КонецПроцедуры

// Функция формирует документы "Списание затрат на выпуск" для каждой номенклатурной позиции
//  в ТЧ "Блюда" + ТЧ "Ингредиенты" переданного документа "Выпуск блюд" или обновляет существующие.
//
// Параметры:
//  ДокументВыпускБлюд		 - ДокументСсылка	 - Ссылка на документ "Выпуск блюд", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьСписанияЗатратПоВыпускуБлюд(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки = "")
	
	// Запрос:
	// 1. Получение ВТ с реквизитами шапки документа "Выпуск блюд".
	// 2. Выбор в ВТ всех "Списаний затрат на выпуск", связанных с переданным выпуском блюд.
	// 3. Выбор в ВТ необходимых реквизитов ТЧ Производство док. "Выпуск блюд" + реквизитов шапки из (1).
	// 4. Выбор номенклатуры и флагов проведения из документов "Списание затрат...", связанных с "Выпуск блюд"(2).
	// 5. Выбор данных из вт(3) с итогом по номенклатуре.
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питВыпускБлюд.Ссылка,
	|	питВыпускБлюд.ПометкаУдаления,
	|	питВыпускБлюд.Проведен,
	|	питВыпускБлюд.Организация,
	|	питВыпускБлюд.Ответственный,
	|	питВыпускБлюд.Комментарий,
	|	питВыпускБлюд.Подразделение,
	|	питВыпускБлюд.Дата,
	|	питВыпускБлюд.СтатьяКалькуляции
	|ПОМЕСТИТЬ втШапкаВыпускаБлюд
	|ИЗ
	|	Документ.питВыпускБлюд КАК питВыпускБлюд
	|ГДЕ
	|	питВыпускБлюд.Ссылка = &Документпит
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	питТиповыеДокументы.ТиповойДокумент
	|ПОМЕСТИТЬ втДокументыСписаниеЗатрат
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|	И питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.СписаниеЗатратНаВыпуск
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВыпускПродукции.Ссылка,
	|	ВЫБОР
	|		КОГДА ВыпускПродукции.НаправлениеВыпуска = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВыпускПродукцииВПодразделение)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Автопередел
	|ПОМЕСТИТЬ втВыпускиПродукцииАвтопередел
	|ИЗ
	|	Документ.ВыпускПродукции КАК ВыпускПродукции
	|ГДЕ
	|	ВыпускПродукции.Ссылка В(&ДокументыВыпускаПродукции)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВыпускПродукцииТовары.Ссылка КАК Распоряжение,
	|	ВыпускПродукцииТовары.Номенклатура,
	|	ВыпускПродукцииТовары.КодСтроки,
	|	втВыпускиПродукцииАвтопередел.Автопередел
	|ПОМЕСТИТЬ втРаспоряжения
	|ИЗ
	|	Документ.ВыпускПродукции.Товары КАК ВыпускПродукцииТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ втВыпускиПродукцииАвтопередел КАК втВыпускиПродукцииАвтопередел
	|		ПО ВыпускПродукцииТовары.Ссылка = втВыпускиПродукцииАвтопередел.Ссылка
	|ГДЕ
	|	ВыпускПродукцииТовары.Ссылка В(&ДокументыВыпускаПродукции)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	питВыпускБлюдБлюда.Ссылка,
	|	питВыпускБлюдБлюда.Номенклатура,
	|	питВыпускБлюдБлюда.Автопередел,
	|	питВыпускБлюдБлюда.КоличествоУпаковокНоменклатуры,
	|	питВыпускБлюдБлюда.УпаковкаНоменклатуры,
	|	питВыпускБлюдБлюда.КоличествоНоменклатуры,
	|	питВыпускБлюдИнгредиенты.УпаковкаИнгредиента,
	|	питВыпускБлюдИнгредиенты.КоличествоУпаковокИнгредиентаФакт,
	|	питВыпускБлюдИнгредиенты.КоличествоИнгредиентаФакт,
	|	питВыпускБлюдИнгредиенты.Ингредиент
	|ПОМЕСТИТЬ втПроизводство
	|ИЗ
	|	Документ.питВыпускБлюд.Блюда КАК питВыпускБлюдБлюда
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.питВыпускБлюд.Ингредиенты КАК питВыпускБлюдИнгредиенты
	|		ПО питВыпускБлюдБлюда.ИдентификаторСтроки = питВыпускБлюдИнгредиенты.ИдентификаторБлюда
	|ГДЕ
	|	питВыпускБлюдБлюда.Ссылка = &Документпит
	|	И питВыпускБлюдИнгредиенты.Ссылка = &Документпит
	|	И НЕ питВыпускБлюдИнгредиенты.КоличествоИнгредиентаФакт = 0
	|	И НЕ питВыпускБлюдИнгредиенты.Ингредиент.питВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.питВидыНоменклатуры.ТехнологическийИнгредиент)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	питВыпускБлюдБлюда.Ссылка,
	|	питВыпускБлюдБлюда.Номенклатура,
	|	питВыпускБлюдБлюда.Автопередел,
	|	питВыпускБлюдБлюда.КоличествоУпаковокНоменклатуры,
	|	питВыпускБлюдБлюда.УпаковкаНоменклатуры,
	|	питВыпускБлюдБлюда.КоличествоНоменклатуры,
	|	питВыпускБлюдЗамены.УпаковкаИнгредиентаЗамена,
	|	питВыпускБлюдЗамены.КоличествоУпаковокИнгредиентаЗамена,
	|	питВыпускБлюдЗамены.КоличествоИнгредиентаЗамена,
	|	питВыпускБлюдЗамены.ИнгредиентЗамена
	|ИЗ
	|	Документ.питВыпускБлюд.Блюда КАК питВыпускБлюдБлюда
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.питВыпускБлюд.Замены КАК питВыпускБлюдЗамены
	|		ПО питВыпускБлюдБлюда.Номенклатура = питВыпускБлюдЗамены.Блюдо
	|			И питВыпускБлюдБлюда.Рецептура = питВыпускБлюдЗамены.Рецептура
	|			И питВыпускБлюдБлюда.Автопередел = питВыпускБлюдЗамены.Автопередел
	|ГДЕ
	|	питВыпускБлюдБлюда.Ссылка = &Документпит
	|	И питВыпускБлюдЗамены.Ссылка = &Документпит
	|	И НЕ питВыпускБлюдЗамены.ИнгредиентЗамена.питВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.питВидыНоменклатуры.ТехнологическийИнгредиент)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втПроизводство.Ссылка,
	|	втПроизводство.Номенклатура,
	|	втПроизводство.Автопередел,
	|	втПроизводство.КоличествоУпаковокНоменклатуры,
	|	втПроизводство.УпаковкаНоменклатуры,
	|	втПроизводство.КоличествоНоменклатуры,
	|	втПроизводство.Ингредиент,
	|	втПроизводство.УпаковкаИнгредиента,
	|	СУММА(втПроизводство.КоличествоУпаковокИнгредиентаФакт) КАК КоличествоУпаковокИнгредиентаФакт,
	|	СУММА(втПроизводство.КоличествоИнгредиентаФакт) КАК КоличествоИнгредиентаФакт
	|ПОМЕСТИТЬ втПроизводствоВсе
	|ИЗ
	|	втПроизводство КАК втПроизводство
	|ГДЕ
	|	втПроизводство.Ссылка = &Документпит
	|
	|СГРУППИРОВАТЬ ПО
	|	втПроизводство.КоличествоНоменклатуры,
	|	втПроизводство.КоличествоУпаковокНоменклатуры,
	|	втПроизводство.Ссылка,
	|	втПроизводство.Номенклатура,
	|	втПроизводство.Автопередел,
	|	втПроизводство.УпаковкаНоменклатуры,
	|	втПроизводство.Ингредиент,
	|	втПроизводство.УпаковкаИнгредиента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втПроизводствоВсе.Номенклатура,
