// Функция получает текущий максимальный приоритет действия отложенного проведения +1 для переданного документа Общепита.
//
// Параметры:
//  ДокументОбщепит	 - ДокументСсылка.питВыпускБлюд - Документ общепита.
// 
// Возвращаемое значение:
//  Число - Приоритет.
//
Функция ПолучитьТекущийПриоритетДействияОтложенногоПроведения(ДокументОбщепит) Экспорт
	
	Результат = 0;
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	питОчередьОтложенногоПроведения.Приоритет + 1 КАК ТекущийПриоритет
		|ИЗ
		|	РегистрСведений.питОчередьОтложенногоПроведения КАК питОчередьОтложенногоПроведения
		|ГДЕ
		|	питОчередьОтложенногоПроведения.ДокументОбщепит = &ДокументОбщепит
		|
		|УПОРЯДОЧИТЬ ПО
		|	ТекущийПриоритет УБЫВ";
	
	Запрос.УстановитьПараметр("ДокументОбщепит", ДокументОбщепит);
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		ВыборкаДетальныеЗаписи.Следующий();
		Результат = ВыборкаДетальныеЗаписи.ТекущийПриоритет;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Функция добавляет действие отложенного проведения в регистр.
//
// Параметры:
//  ДокументОбщепит	 - ДокументСсылка.питВыпускБлюд - Документ общепита.
//  Действие		 - ПеречислениеСсылка.питДействияОтложенногоПроведения - Действие отложенного проведения.
//  ТиповойДокумент	 - ДокументСсылка - Типовой документ.
//  Приоритет		 - Число - Приоритет действия.
//  ТекстОшибки		 - Строка - Строка, в которую будет записан текст ошибки в случае ее возникновения.
// 
// Возвращаемое значение:
//  Булево - Результат выполнения функции.
//
Функция ДобавитьДействиеОтложенногоПроведения(ДокументОбщепит, Действие, ТиповойДокумент, Приоритет, ТекстОшибки = "") Экспорт
	
	МенеджерЗаписи = РегистрыСведений.питОчередьОтложенногоПроведения.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.ДокументОбщепит			= ДокументОбщепит;
	МенеджерЗаписи.Действие					= Действие;
	МенеджерЗаписи.ТиповойДокумент			= ТиповойДокумент;
	МенеджерЗаписи.Приоритет				= Приоритет;
	Попытка
		МенеджерЗаписи.Записать();
	Исключение
		ТекстОшибки = "Ошибка добавления действия отложенного проведения по причине: 
		|< "+ ОписаниеОшибки() + " >";
		Возврат Ложь;
	КонецПопытки;
	
	Возврат Истина;
	
КонецФункции

// Функция удаляет действия отложенного проведения по документу общепит.
//
// Параметры:
//  ДокументОбщепит	 - ДокументСсылка.питВыпускБлюд - Документ общепита.
//  Действие		 - ПеречислениеСсылка.питДействияОтложенногоПроведения - Действие отложенного проведения.
