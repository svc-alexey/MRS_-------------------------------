	|	Номенклатура,
	|	Автопередел";
	
	// Если документы "Выпуск продукции" не заданы, то инициализируем их как пустой массив.
	Если СтруктураПараметров.Свойство("ДокументыВыпускаПродукции") И НЕ СтруктураПараметров.ДокументыВыпускаПродукции = Неопределено Тогда
		ДокументыВыпускаПродукции = СтруктураПараметров.ДокументыВыпускаПродукции;
	Иначе
		ДокументыВыпускаПродукции = Новый Массив;
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Документпит",			ДокументВыпускБлюд);
	Запрос.УстановитьПараметр("ДокументыВыпускаПродукции",	ДокументыВыпускаПродукции);
	
	// Выполнение запроса и получение 2х выборок:
	// - Основная выборка с данными по номенклатуре и ее ингридиентам
	// - Доп. выборка существующих документов "Списание затрат" по текущему документу "пит".
	РезультатПакет = Запрос.ВыполнитьПакет();
	Выборка								= РезультатПакет[8].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаСуществующиеСписания			= РезультатПакет[7].Выбрать();
	
	// Структура текущего "Списания затрат".
	ТекСписаниеЗатрат = Новый Структура("СписаниеЗатрат,ПометкаУдаления,Проведен");
	
	// Обход основной выборки
	Пока Выборка.Следующий() Цикл
		
		ВыборкаАвтопередел = Выборка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаАвтопередел.Следующий() Цикл
			
			ВыборкаДетальная = ВыборкаАвтопередел.Выбрать();
			
			// Выборка по списаниям затрат.
			// Если документ существует, тогда заполняем его данными структуру тек. списания,
			// иначе - заполняем значениями по умолчанию.
			Если ВыборкаСуществующиеСписания.Следующий() Тогда
				ЗаполнитьЗначенияСвойств(ТекСписаниеЗатрат,ВыборкаСуществующиеСписания);
			Иначе
				ТекСписаниеЗатрат.СписаниеЗатрат = Документы["СписаниеЗатратНаВыпуск"].ПустаяСсылка();
				ТекСписаниеЗатрат.ПометкаУдаления = Ложь;
				ТекСписаниеЗатрат.Проведен = Ложь;
			КонецЕсли;
			
			// "Обнуление" переменной текущего объекта
			ТекДокументОбъект = Неопределено;
			
			ПерваяДетальнаяСтрока = Истина; // В момент обхода первой строки детальной выборки заполняем шапку.
			
			// Детальный обход основной выборки
			Пока ВыборкаДетальная.Следующий() Цикл
				
				Если ПерваяДетальнаяСтрока Тогда
					
					////////////////////////////
					// Определение режима записи
					ПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(ВыборкаДетальная.Проведен,ВыборкаДетальная.ПометкаУдаления
					,ТекСписаниеЗатрат.Проведен,ТекСписаниеЗатрат.ПометкаУдаления,СтруктураПараметров);
					ТекРежимЗаписи = ПараметрыЗаписи.РежимЗаписи;
					////////////////////////////
					
					// Если тек списание затрат не было найдено, то создаем новый объект.
					Если ТекСписаниеЗатрат.СписаниеЗатрат = Документы["СписаниеЗатратНаВыпуск"].ПустаяСсылка() Тогда
						ТекДокументОбъект = Документы["СписаниеЗатратНаВыпуск"].СоздатьДокумент();
					Иначе
						ТекДокументОбъект = ТекСписаниеЗатрат.СписаниеЗатрат.ПолучитьОбъект();
						
						// Если нужно установить пометку удаления, то перед синхронизацией сделаем это.
						Если ПараметрыЗаписи.НужнаУстановкаПометкиУдаления Тогда
							
							//+ОтложенноеПроведение
							Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
								ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ПолучитьТекущееДействиеПоПометкеУдаленияТиповогоДокумента(ПараметрыЗаписи.ПометкаУдаления), ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
								СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
								Если НЕ ВсеОк Тогда 
									Возврат ВсеОк;
								КонецЕсли;
							Иначе
							//-ОтложенноеПроведение
								
								// Помечаем на удаление / снимаем пометку в док. "Списание затрат...".
								Попытка
									ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
									ТекДокументОбъект.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
								Исключение
									ТекстОшибки = ТекстОшибки + "
									|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
									| по документу Общепит """+ДокументВыпускБлюд+"""
									|по причине: <"+ОписаниеОшибки()+">";
									Возврат Ложь;
								КонецПопытки;
								
							КонецЕсли;
							
						КонецЕсли;
						
						// Очистка табличных частей для избежания дублирования информации.
						ТекДокументОбъект.ВыходныеИзделия.Очистить();
						ТекДокументОбъект.МатериалыИУслуги.Очистить();
						ТекДокументОбъект.ВозвратныеОтходы.Очистить();
						ТекДокументОбъект.Трудозатраты.Очистить();
						ТекДокументОбъект.Серии.Очистить();
						
					КонецЕсли;
					
					// Заполнение шапки.
					ТекДокументОбъект.Дата			= ВыборкаДетальная.Дата + ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0);
					ТекДокументОбъект.Организация	= ВыборкаДетальная.Организация;
					ТекДокументОбъект.Номенклатура	= ВыборкаДетальная.Номенклатура;
					ТекДокументОбъект.Ответственный	= ВыборкаДетальная.Ответственный;
					ТекДокументОбъект.Комментарий	= ВыборкаДетальная.Комментарий;
					ТекДокументОбъект.Количество	= ВыборкаДетальная.КоличествоНоменклатуры;
					ТекДокументОбъект.Подразделение	= ВыборкаДетальная.Подразделение;
					
					// Заполнение табличной части "Выходные изделия".
					НовСтрокаТЧ						= ТекДокументОбъект.ВыходныеИзделия.Добавить();
					НовСтрокаТЧ.Номенклатура		= ВыборкаДетальная.Номенклатура;
					НовСтрокаТЧ.КоличествоУпаковок	= ВыборкаДетальная.КоличествоУпаковокНоменклатуры;
					НовСтрокаТЧ.Количество			= ВыборкаДетальная.КоличествоНоменклатуры;
					НовСтрокаТЧ.Упаковка			= ВыборкаДетальная.УпаковкаНоменклатуры;
					НовСтрокаТЧ.Подразделение		= ВыборкаДетальная.Подразделение;
					НовСтрокаТЧ.Распоряжение		= ВыборкаДетальная.Распоряжение;
					НовСтрокаТЧ.КодСтроки			= ВыборкаДетальная.КодСтроки;
					
					ПерваяДетальнаяСтрока = Ложь;
				КонецЕсли;
				
				// Заполнение табличной части "Материалы и услуги".
				НовСтрокаТЧ							= ТекДокументОбъект.МатериалыИУслуги.Добавить();
				НовСтрокаТЧ.Номенклатура			= ВыборкаДетальная.Ингредиент;
				НовСтрокаТЧ.СтатьяКалькуляции		= ВыборкаДетальная.СтатьяКалькуляции;
				НовСтрокаТЧ.Количество				= ВыборкаДетальная.КоличествоИнгредиентаФакт;
				НовСтрокаТЧ.Упаковка				= ВыборкаДетальная.УпаковкаИнгредиента;
				НовСтрокаТЧ.КоличествоУпаковок		= ВыборкаДетальная.КоличествоУпаковокИнгредиентаФакт;
				НовСтрокаТЧ.Подразделение			= ВыборкаДетальная.Подразделение;
				
			КонецЦикла;
			
			Если НЕ ТекДокументОбъект = Неопределено Тогда
				
				//+ОтложенноеПроведение
				Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
					ИсходныйРежимЗаписи	= ТекРежимЗаписи;
					ТекРежимЗаписи		= РежимЗаписиДокумента.Запись;
				КонецЕсли;
				//-ОтложенноеПроведение
				
				// Запись заполненного документа "Списание затрат".
				Попытка
					ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
					ТекДокументОбъект.Записать(ТекРежимЗаписи);
				Исключение
					ТекстОшибки = ТекстОшибки + "
					|Ошибка записи документа """ + ТекДокументОбъект.Метаданные().Представление() + """
					| по документу Общепит """+ДокументВыпускБлюд+"""
					|по причине: <"+ОписаниеОшибки()+">";
					Возврат Ложь;
				КонецПопытки;
				
				//+ОтложенноеПроведение
				Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
					ТекДействие = ПолучитьТекущееДействиеПоРежимузаписиТиповогоДокумента(ИсходныйРежимЗаписи);
					ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ТекДействие, ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
					СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
					Если НЕ ВсеОк Тогда 
						Возврат ВсеОк;
					КонецЕсли;
					ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.УстановитьСинхронизациюТиповогоДокумента, ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
					СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
					Если НЕ ВсеОк Тогда 
						Возврат ВсеОк;
					КонецЕсли;
				КонецЕсли;
				//-ОтложенноеПроведение
				
			КонецЕсли;
			
			//+ОтложенноеПроведение
			ТекСинхронизирован = ?(СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд, Ложь, Истина);
			//-ОтложенноеПроведение
			
			// Добавление записи в результирующую таблицу в случае успешной записи документов.
			ДобавитьНовуюЗапись(ДокументВыпускБлюд, ТекДокументОбъект, тблСозданныеДокументы,,ТекСинхронизирован);
			
		КонецЦикла;
		
	КонецЦикла;
	
	// "Обнуление" переменной текущего объекта.
	ТекДокументОбъект = Неопределено;
	
	// Если остались лишние документы "Списания затрат", то нужно пометить их на удаление.
	Пока ВыборкаСуществующиеСписания.Следующий() Цикл
		
		ТекДокументОбъект = ВыборкаСуществующиеСписания.СписаниеЗатрат.ПолучитьОбъект();
		
		//+ОтложенноеПроведение
		Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
			ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ПолучитьТекущееДействиеПоПометкеУдаленияТиповогоДокумента(Истина), ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
			СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
			Если НЕ ВсеОк Тогда 
				Возврат ВсеОк;
			КонецЕсли;
			ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.УстановитьСинхронизациюТиповогоДокумента, ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
			СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
			Если НЕ ВсеОк Тогда 
				Возврат ВсеОк;
			КонецЕсли;
		Иначе
		//-ОтложенноеПроведение
			
			// Помечаем на удаление "Списание затрат...", если он еще не помечен.
			Если НЕ ВыборкаСуществующиеСписания.ПометкаУдаления Тогда
				Попытка
					ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
					ТекДокументОбъект.УстановитьПометкуУдаления(Истина);
				Исключение
					ТекстОшибки = ТекстОшибки + "
					|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
					| по документу Общепит """+ДокументВыпускБлюд+"""
					|по причине: <"+ОписаниеОшибки()+">";
					Возврат Ложь;
				КонецПопытки;
			КонецЕсли;
			
		КонецЕсли;
		
		//+ОтложенноеПроведение
		ТекСинхронизирован = ?(СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд, Ложь, Истина);
		//-ОтложенноеПроведение
		
		// Добавление записи в результирующую таблицу.
		ДобавитьНовуюЗапись(ДокументВыпускБлюд, ТекДокументОбъект, тблСозданныеДокументы,,ТекСинхронизирован);
		
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

// Функция формирует документы "Производство без заказа" для каждой номенклатурной позиции
//  в ТЧ "Блюда" + ТЧ "Ингредиенты" переданного документа "Выпуск блюд" или обновляет существующие.
//
// Параметры:
//  ДокументВыпускБлюд		 - ДокументСсылка	 - Ссылка на документ "Выпуск блюд", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьПроизводствоБезЗаказа22ПоВыпускуБлюд(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки = "")
	
	//+БазовоеСмещение
	Если НЕ СтруктураПараметров.Свойство("питСмещатьДатыТиповыхДокументов") Тогда
		СтруктураПараметров.Вставить("питСмещатьДатыТиповыхДокументов", питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питСмещатьДатыТиповыхДокументов"));
	КонецЕсли;
	БазовоеСмещениеПроизводстваБезЗаказов = 0;
	БазовоеСмещениеДвиженияПродукцииИМатериалов = 0;
	Если СтруктураПараметров.питСмещатьДатыТиповыхДокументов Тогда
		СтрокиСмещение = СтруктураПараметров.ТаблицаПорядокПроведенияТиповыхДокументовВыпускаБлюд.НайтиСтроки(
		Новый Структура("ИмяТиповогоДокумента,ПричинаТиповогоДокумента", "ПроизводствоБезЗаказа", 0));
		Если СтрокиСмещение.Количество() Тогда
			БазовоеСмещениеПроизводстваБезЗаказов = СтрокиСмещение[0].БазовоеСмещение;
		КонецЕсли;
		СтрокиСмещение = СтруктураПараметров.ТаблицаПорядокПроведенияТиповыхДокументовВыпускаБлюд.НайтиСтроки(
		Новый Структура("ИмяТиповогоДокумента,ПричинаТиповогоДокумента", "ДвижениеПродукцииИМатериалов", 0));
		Если СтрокиСмещение.Количество() Тогда
			БазовоеСмещениеДвиженияПродукцииИМатериалов = СтрокиСмещение[0].БазовоеСмещение;
		КонецЕсли;
	КонецЕсли;
	//-БазовоеСмещение
	
	// Где производим полуфабрикаты
	ПодразделениеПроизводстваПолуфабрикатов = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питПодразделениеПроизводстваПолуфабрикатов");
	
	// Запрос:
	// 1. Формирование таблицы производства с данными по Блюдам и Ингредиентам/Заменам
	//  с упорядочиванием по полю "Порядок" и итогами по "Порядок" и "Номенклатура" 
	//  для разделения таблицы на несколько типовых документов.
	// 2. Выборка всех существующих "Производств без заказов" и данных по ним.
	// 3. Выборка данных шапки текущего выпуска блюд.
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питВыпускБлюдБлюда.Ссылка КАК Ссылка,
	|	питВыпускБлюдБлюда.Номенклатура КАК Номенклатура,
	|	питВыпускБлюдБлюда.Характеристика КАК Характеристика,
	|	питВыпускБлюдБлюда.Серия КАК Серия,
	|	питВыпускБлюдБлюда.Назначение КАК Назначение,
	|	питВыпускБлюдБлюда.Автопередел КАК Автопередел,
	|	питВыпускБлюдБлюда.КоличествоУпаковокНоменклатуры КАК КоличествоУпаковокНоменклатуры,
	|	питВыпускБлюдБлюда.УпаковкаНоменклатуры КАК УпаковкаНоменклатуры,
	|	питВыпускБлюдБлюда.КоличествоНоменклатуры КАК КоличествоНоменклатуры,
	|	питВыпускБлюдБлюда.Рецептура КАК РецептураБлюда,
	|	ЕСТЬNULL(питВыпускБлюдИнгредиенты.УпаковкаИнгредиента, ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)) КАК УпаковкаИнгредиента,
	|	ЕСТЬNULL(питВыпускБлюдИнгредиенты.КоличествоУпаковокИнгредиентаФакт, 0) КАК КоличествоУпаковокИнгредиентаФакт,
	|	ЕСТЬNULL(питВыпускБлюдИнгредиенты.КоличествоИнгредиентаФакт, 0) КАК КоличествоИнгредиентаФакт,
	|	ЕСТЬNULL(питВыпускБлюдИнгредиенты.Ингредиент, ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)) КАК Ингредиент,
	|	ЕСТЬNULL(питВыпускБлюдИнгредиенты.Характеристика, ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)) КАК ХарактеристикаИнгредиента,
	|	ЕСТЬNULL(питВыпускБлюдИнгредиенты.Назначение, ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)) КАК НазначениеИнгредиента,
	|	ЕСТЬNULL(питВыпускБлюдИнгредиенты.Серия,ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)) КАК СерияИнгредиента,
	|	ЕСТЬNULL(питВыпускБлюдИнгредиенты.СтатьяКалькуляции, ЗНАЧЕНИЕ(Справочник.СтатьиКалькуляции.ПустаяСсылка)) КАК СтатьяКалькуляции,
	|	питВыпускБлюдБлюда.Порядок КАК Порядок,
	|	питВыпускБлюдБлюда.ИдентификаторСтроки КАК ИдентификаторСтроки,
	|	ВЫБОР
	|		КОГДА &ПодразделениеПроизводстваПолуфабрикатов = ЗНАЧЕНИЕ(Перечисление.питПодразделенияПроизводстваПолуфабрикатов.ПодразделениеРецептуры)
	|				И питВыпускБлюдБлюда.Автопередел = ИСТИНА
	|			ТОГДА питРецептура.Подразделение
	|		ИНАЧЕ питВыпускБлюд.Подразделение
	|	КОНЕЦ КАК ПодразделениеПроизводства,
	|	ВЫБОР
	|		КОГДА &ПодразделениеПроизводстваПолуфабрикатов = ЗНАЧЕНИЕ(Перечисление.питПодразделенияПроизводстваПолуфабрикатов.ПодразделениеРецептуры)
	|				И питВыпускБлюдБлюда.Автопередел = ИСТИНА
	|			ТОГДА питРецептура.ЦеховаяКладовая
	|		ИНАЧЕ питВыпускБлюд.Склад
	|	КОНЕЦ КАК ЦеховаяКладовая
	|ПОМЕСТИТЬ втПроизводствоПред
	|ИЗ
	|	Документ.питВыпускБлюд.Блюда КАК питВыпускБлюдБлюда
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.питВыпускБлюд.Ингредиенты КАК питВыпускБлюдИнгредиенты
	|		ПО питВыпускБлюдБлюда.ИдентификаторСтроки = питВыпускБлюдИнгредиенты.ИдентификаторБлюда
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.питВыпускБлюд КАК питВыпускБлюд
	|		ПО питВыпускБлюдБлюда.Ссылка = питВыпускБлюд.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.питРецептура КАК питРецептура
	|		ПО питВыпускБлюдБлюда.Рецептура = питРецептура.Ссылка
	|ГДЕ
	|	питВыпускБлюдБлюда.Ссылка = &Документпит
	|	И питВыпускБлюдИнгредиенты.Ссылка = &Документпит
	//|	И НЕ питВыпускБлюдИнгредиенты.КоличествоИнгредиентаФакт = 0
	//|	И НЕ питВыпускБлюдИнгредиенты.Ингредиент.питВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.питВидыНоменклатуры.ТехнологическийИнгредиент)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	питВыпускБлюдБлюда.Ссылка,
	|	питВыпускБлюдБлюда.Номенклатура,
	|	питВыпускБлюдБлюда.Характеристика,
	|	питВыпускБлюдБлюда.Серия,
	|	питВыпускБлюдБлюда.Назначение,
	|	питВыпускБлюдБлюда.Автопередел,
	|	питВыпускБлюдБлюда.КоличествоУпаковокНоменклатуры,
	|	питВыпускБлюдБлюда.УпаковкаНоменклатуры,
	|	питВыпускБлюдБлюда.КоличествоНоменклатуры,
	|	питВыпускБлюдБлюда.Рецептура,
	|	ЕСТЬNULL(питВыпускБлюдЗамены.УпаковкаИнгредиентаЗамена, ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)),
	|	ЕСТЬNULL(питВыпускБлюдЗамены.КоличествоУпаковокИнгредиентаЗамена, 0),
	|	ЕСТЬNULL(питВыпускБлюдЗамены.КоличествоИнгредиентаЗамена, 0),
	|	ЕСТЬNULL(питВыпускБлюдЗамены.ИнгредиентЗамена, ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)),
	|	ЕСТЬNULL(питВыпускБлюдЗамены.ХарактеристикаИнгредиентаЗамена, ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)),
	|	ЕСТЬNULL(питВыпускБлюдЗамены.НазначениеИнгредиентаЗамена, ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)),
	|	ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка),
	|	ЕСТЬNULL(питВыпускБлюдЗамены.СтатьяКалькуляции, ЗНАЧЕНИЕ(Справочник.СтатьиКалькуляции.ПустаяСсылка)),
	|	питВыпускБлюдБлюда.Порядок,
	|	питВыпускБлюдБлюда.ИдентификаторСтроки,
	|	ВЫБОР
	|		КОГДА &ПодразделениеПроизводстваПолуфабрикатов = ЗНАЧЕНИЕ(Перечисление.питПодразделенияПроизводстваПолуфабрикатов.ПодразделениеРецептуры)
	|				И питВыпускБлюдБлюда.Автопередел = ИСТИНА
	|			ТОГДА питРецептура.Подразделение
	|		ИНАЧЕ питВыпускБлюд.Подразделение
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА &ПодразделениеПроизводстваПолуфабрикатов = ЗНАЧЕНИЕ(Перечисление.питПодразделенияПроизводстваПолуфабрикатов.ПодразделениеРецептуры)
	|				И питВыпускБлюдБлюда.Автопередел = ИСТИНА
	|			ТОГДА питРецептура.ЦеховаяКладовая
	|		ИНАЧЕ питВыпускБлюд.Склад
	|	КОНЕЦ
	|ИЗ
	|	Документ.питВыпускБлюд.Блюда КАК питВыпускБлюдБлюда
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.питВыпускБлюд.Замены КАК питВыпускБлюдЗамены
	|		ПО питВыпускБлюдБлюда.Номенклатура = питВыпускБлюдЗамены.Блюдо
	|			И питВыпускБлюдБлюда.Характеристика = питВыпускБлюдЗамены.ХарактеристикаБлюда
	|			И питВыпускБлюдБлюда.Рецептура = питВыпускБлюдЗамены.Рецептура
	|			И питВыпускБлюдБлюда.Автопередел = питВыпускБлюдЗамены.Автопередел
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.питРецептура КАК питРецептура
	|		ПО питВыпускБлюдБлюда.Рецептура = питРецептура.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.питВыпускБлюд КАК питВыпускБлюд
	|		ПО питВыпускБлюдБлюда.Ссылка = питВыпускБлюд.Ссылка
	|ГДЕ
	|	питВыпускБлюдБлюда.Ссылка = &Документпит
	|	И питВыпускБлюдЗамены.Ссылка = &Документпит
	//|	И НЕ питВыпускБлюдЗамены.ИнгредиентЗамена.питВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.питВидыНоменклатуры.ТехнологическийИнгредиент)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МИНИМУМ(Склады.Ссылка) КАК Ссылка,
	|	Склады.Подразделение КАК Подразделение
	|ПОМЕСТИТЬ втЦеховыеКладовые
	|ИЗ
	|	Справочник.Склады КАК Склады
	|ГДЕ
	|	Склады.ЦеховаяКладовая = ИСТИНА
	|	И Склады.Подразделение В
	|			(ВЫБРАТЬ
	|				вт.ПодразделениеПроизводства
	|			ИЗ
	|				втПроизводствоПред КАК вт)
	|
	|СГРУППИРОВАТЬ ПО
	|	Склады.Подразделение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втПроизводствоПред.Ссылка,
	|	втПроизводствоПред.Номенклатура,
	|	втПроизводствоПред.Характеристика,
	|	втПроизводствоПред.Серия,
	|	втПроизводствоПред.Назначение,
	|	втПроизводствоПред.Автопередел,
	|	втПроизводствоПред.КоличествоУпаковокНоменклатуры,
	|	втПроизводствоПред.УпаковкаНоменклатуры,
	|	втПроизводствоПред.КоличествоНоменклатуры,
	//<< Портал-Юг, Гребенюк, 29.05.2023, [Обновление 2.5, некорректно присваивается псевдоним в схеме запроса]
	//|	втПроизводствоПред.УпаковкаИнгредиента,
	|	втПроизводствоПред.УпаковкаИнгредиента КАК УпаковкаИнгредиента,
	//>> Портал-Юг, Гребенюк, 29.05.2023	
	|	втПроизводствоПред.КоличествоУпаковокИнгредиентаФакт,
	|	втПроизводствоПред.КоличествоИнгредиентаФакт,
	|	втПроизводствоПред.Ингредиент,
	|	втПроизводствоПред.ХарактеристикаИнгредиента,
	|	втПроизводствоПред.НазначениеИнгредиента,
	|	втПроизводствоПред.СерияИнгредиента,
	|	втПроизводствоПред.СтатьяКалькуляции,
	|	втПроизводствоПред.Порядок,
	|	втПроизводствоПред.ИдентификаторСтроки,
	|	втПроизводствоПред.ПодразделениеПроизводства,
	|	втПроизводствоПред.РецептураБлюда,
	|	ВЫБОР
	|		КОГДА втПроизводствоПред.ЦеховаяКладовая = ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
	|			ТОГДА втЦеховыеКладовые.Ссылка
	|		ИНАЧЕ втПроизводствоПред.ЦеховаяКладовая
	|	КОНЕЦ КАК ЦеховаяКладовая
	|ПОМЕСТИТЬ втПроизводство
