		//<<Швецов.11.02.2025. Розничные продажи алкоголя
		
		НовСтрока						= ТекДокументОбъект.Товары.Добавить();
		НовСтрока.Номенклатура			= Выборка.Номенклатура;
		НовСтрока.Характеристика		= Выборка.Характеристика;
		НовСтрока.Серия					= Справочники.СерииНоменклатуры.ПустаяСсылка(); // Заполним по FEFO непосредсвенно перед записью
		// Назначения в отчете о РП нет.
		//НовСтрока.Назначение			= Выборка.Назначение; 
		НовСтрока.Упаковка				= Выборка.Упаковка;
		НовСтрока.КоличествоУпаковок	= Выборка.КоличествоУпаковок;
		НовСтрока.Количество			= Выборка.Количество;
		НовСтрока.Цена					= Выборка.Цена;
		НовСтрока.Сумма					= Выборка.Сумма;
		НовСтрока.СтавкаНДС				= Выборка.СтавкаНДС;
		НовСтрока.СуммаНДС				= Выборка.СуммаНДС;
		НовСтрока.ПроцентРучнойСкидки	= Выборка.ПроцентРучнойСкидки;
		НовСтрока.СуммаРучнойСкидки		= Выборка.СуммаРучнойСкидки;
		НовСтрока.Партнер				= Справочники.Партнеры.РозничныйПокупатель;
		
		//<< Портал-Юг, Баринов, 2019.10.04 [9.09 Обособление продаж по открытой цене]
		НовСтрока.НоменклатураНабора    = Выборка.НоменклатураНабора;
		НовСтрока.ХарактеристикаНабора  = Выборка.ХарактеристикаНабора;
		//>> Портал-Юг, Баринов, 2019.10.04
		//<< Портал-Юг, Баринов, 2019.11.28 [9.14. Обособление шведской линии и банкетов по номенклатурным группам в БП]
		НовСтрока.ПЛ_Номенклатура = ПЛ_Номенклатура;
		//>> Портал-Юг, Баринов, 2019.11.28
		//<<Портал-Юг, Давиденко 2019.03.20 [4.2.8 Заполнение отчёта о розничных продажах из выпуска блюд для особых продаж]
		НовСтрока.ПЛ_Договор = Выборка.ПЛ_Договор;
		// признаком "ПЛ_ЭтоБлюдо" отделены строки из запроса, которые получены из ТЧ "Товары", по ним нет необходимости производить контроль количества
				
		Если Не Выборка.ПЛ_ЭтоБлюдо Тогда
			ПЛ_НоваяСтрокаТЗ = ПЛ_ТЗДляПроверкиКоличестваИнгредиентов.Добавить();
			ЗаполнитьЗначенияСвойств(ПЛ_НоваяСтрокаТЗ, Выборка);
			ПЛ_НоваяСтрокаТЗ.Ингредиент = Выборка.Номенклатура;
			ПЛ_НоваяСтрокаТЗ.Номенклатура = Выборка.ПЛ_Блюдо;
			ПЛ_НоваяСтрокаТЗ.Рецептура = Выборка.ПЛ_Рецептура;
			ПЛ_НоваяСтрокаТЗ.ХарактеристикаНоменклатуры = Выборка.ПЛ_ХарактеристикаНоменклатуры;
			ПЛ_НоваяСтрокаТЗ.СерияНоменклатуры = Выборка.ПЛ_СерияНоменклатуры;
			// таблица содержит все строки с отрицательным количеством, добавим строки с положительным, чтобы отследить разницу
			ПЛ_НоваяСтрокаТЗ.КоличествоИнгредиентаКонтроль = Выборка.ПЛ_Количество;
			ПЛ_НоваяСтрокаТЗ.КоличествоУпаковокИнгредиентаКонтроль = Выборка.ПЛ_КоличествоУпаковок;
		КонецЕсли;
		//>>Портал-Юг, Давиденко 2019.03.20
		
		//+ДВИЖЕНИЕ ПРОДУКЦИИ И МАТЕРИАЛОВ 22
		Если НЕ ТекДокументПеремещения = Неопределено Тогда
			
			//<<Портал-Юг, Финик 02.06.2021 Исправление после обновления. В выборке этого нет
			//Если СкладскиеТипыНоменклатуры.Найти(Выборка.ТипНоменклатуры) = Неопределено Тогда
			//	Продолжить;
			//КонецЕсли;
			//>>Портал-Юг, Финик 02.06.2021
			
			//<<Портал-Юг, Давиденко 2019.03.21 [4.2.8 Заполнение отчёта о розничных продажах из выпуска блюд для особых продаж]
			// заполнение только товаров с закладки "товары"
			Если Не Выборка.ПЛ_ЭтоБлюдо 
				Или Не Выборка.ПЛ_ЭтоТовар Тогда 
				Продолжить;
			КонецЕсли;
			//>>Портал-Юг, Давиденко 2019.03.21			
			
			НовСтрокаДокПеремещения = ТекДокументПеремещения.Товары.Добавить();
			НовСтрокаДокПеремещения.Номенклатура				= Выборка.Номенклатура;
			НовСтрокаДокПеремещения.Характеристика				= Выборка.Характеристика;	
			НовСтрокаДокПеремещения.Серия						= Справочники.СерииНоменклатуры.ПустаяСсылка(); // Заполним по FEFO непосредсвенно перед записью
			НовСтрокаДокПеремещения.Назначение					= Выборка.Назначение;
			НовСтрокаДокПеремещения.НазначениеОтправителя		= Выборка.Назначение;
			НовСтрокаДокПеремещения.КоличествоУпаковок			= Выборка.КоличествоУпаковок;
			НовСтрокаДокПеремещения.Количество					= Выборка.Количество;
			НовСтрокаДокПеремещения.Упаковка					= Выборка.Упаковка;
			
			Если ИмяДокументаПеремещения = "ДвижениеПродукцииИМатериалов" Тогда
				НовСтрокаДокПеремещения.ИдентификаторСтроки		= Новый УникальныйИдентификатор;
				НовСтрокаДокПеремещения.ГруппаПродукции			= Выборка.ГруппаАналитическогоУчета;
			КонецЕсли;
			
		КонецЕсли;
		//-ДВИЖЕНИЕ ПРОДУКЦИИ И МАТЕРИАЛОВ 22
				
	КонецЦикла;
	
	//>>Швецов. 10.12.2024 Розничные продажи алкоголя. Заполним серии из выпуска
	Если НЕ MRS_ЗаборныйЛист Тогда
						
		Пока MRS_ТЧСерииАлкоголь.Следующий() Цикл
			
			НоваяСтрокаСерия = ТекДокументОбъект.Серии.Добавить();
			НоваяСтрокаСерия.Номенклатура = MRS_ТЧСерииАлкоголь.Номенклатура;
			НоваяСтрокаСерия.Количество = MRS_ТЧСерииАлкоголь.Количество;
			НоваяСтрокаСерия.Серия = MRS_ТЧСерииАлкоголь.Серия;
			//НоваяСтрокаСерия.СтатусУказанияСерий = 4;
			
		КонецЦикла;
		
		MRS_ТЧСерииАлкоголь.Сбросить();
		
	КонецЕсли;	
	//<<Швецов. 10.12.2024 Розничные продажи алкоголя. Заполним серии из выпуска

	
	//<<Портал-Юг, Давиденко 2019.03.20 [4.2.8 Заполнение отчёта о розничных продажах из выпуска блюд для особых продаж]
	
	//>>Швецов.11.02.2025. Розничные продажи алкоголя. 
	//По заборному листу разбиваем серийный алкоголь и все остальное на ОРП и ВН "списание на расходы"
	Если НЕ ТекДокументСписания = Неопределено И MRS_ЗаборныйЛист И MRS_ТЧАлкоголь.Количество() <> 0 Тогда
		
		//+БазовоеСмещение
		Если НЕ СтруктураПараметров.Свойство("питСмещатьДатыТиповыхДокументов") Тогда
			СтруктураПараметров.Вставить("питСмещатьДатыТиповыхДокументов", питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питСмещатьДатыТиповыхДокументов"));
		КонецЕсли;
		БазовоеСмещение = 0;
		Если СтруктураПараметров.питСмещатьДатыТиповыхДокументов Тогда
			СтрокиСмещение = СтруктураПараметров.ТаблицаПорядокПроведенияТиповыхДокументовВыпускаБлюд.НайтиСтроки(
			Новый Структура("ИмяТиповогоДокумента,ПричинаТиповогоДокумента", ИмяДокументаВнутреннееПотребление, 0));
			Если СтрокиСмещение.Количество() Тогда
				БазовоеСмещение = СтрокиСмещение[0].БазовоеСмещение;
			КонецЕсли;
		КонецЕсли;
		//-БазовоеСмещение
		
		/////////////////////////////////
		// ЗАПОЛНЕНИЕ ШАПКИ.
		ТекДокументСписания.Дата								= ДокументВыпускБлюд.Дата 
		+ ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0)
		- БазовоеСмещение;
		ТекДокументСписания.Организация						= ДокументВыпускБлюд.Организация;     
		
		// << MRS #VINE-142 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 15.07.25, (Заполнение алкогольной лицензии по умолчанию)
		Если ТекДокументСписания.Метаданные().Реквизиты.Найти("алкЛицензияОрганизации") <> Неопределено  Тогда
			ЗапросАлкЛицензия = Новый Запрос;
			ЗапросАлкЛицензия.Текст = 
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	алкЛицензии.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.алкЛицензии КАК алкЛицензии
			|ГДЕ
			|	&ДатаДокумента МЕЖДУ алкЛицензии.ДатаНачалаСрокаДействия И алкЛицензии.ДатаОкончанияСрокаДействия
			|	И алкЛицензии.Владелец = &Владелец";
			
			ЗапросАлкЛицензия.УстановитьПараметр("Владелец", ТекДокументСписания.Организация);
			ЗапросАлкЛицензия.УстановитьПараметр("ДатаДокумента", ТекДокументСписания.Дата);
			
			РезультатЗапросаалкЛицензияОрганизации = ЗапросАлкЛицензия.Выполнить();
			
			ВыборкаДетальныеЗаписиалкЛицензияОрганизации = РезультатЗапросаалкЛицензияОрганизации.Выбрать();
			
			Если ВыборкаДетальныеЗаписиалкЛицензияОрганизации.Следующий() Тогда
				ТекДокументСписания.алкЛицензияОрганизации = ВыборкаДетальныеЗаписиалкЛицензияОрганизации.Ссылка;
			КонецЕсли; 
			
		КонецЕсли;
		// >> MRS #VINE-142 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 15.07.25, (Заполнение алкогольной лицензии по умолчанию)   
		
		ТекДокументСписания.Склад								= ДокументВыпускБлюд.СкладПолучатель;
		ТекДокументСписания.Подразделение						= ДокументВыпускБлюд.Подразделение;
		ТекДокументСписания.Ответственный						= ДокументВыпускБлюд.Ответственный;
		ТекДокументСписания.Комментарий						= ДокументВыпускБлюд.Комментарий;
		//+25
		//ТекДокументОбъект.ДатаРаспоряжения					= КонецДня(ДокументВыпускБлюд.Дата);
		//-25
		ТекДокументСписания.ВидЦены							= ДокументВыпускБлюд.ТипЦен;
		ТекДокументСписания.ХозяйственнаяОперация				= Перечисления.ХозяйственныеОперации.СписаниеТоваровПоТребованию;
		ТекДокументСписания.НаправлениеДеятельности			= ДокументВыпускБлюд.НаправлениеДеятельности;
		
		// Очистка табличных частей, т.к. будет их перезаполнение.
		ТекДокументСписания.Товары.Очистить();
		ТекДокументСписания.Серии.Очистить();
		ТекДокументСписания.ВидыЗапасов.Очистить();
		ТекДокументСписания.ДополнительныеРеквизиты.Очистить();
		
		// << MRS #ERP-5519 ДенисламовАД <Adel.Denislamov@mriyaresort.com> 20.11.25, ()
		ПричинаСписания = Справочники.MRS_ПричиныСписания.ПустаяСсылка();
		ПричинаСписания = MRS_СлужебныеПараметрыПовтИсп.ПолучитьЗначение("ПричинаСписанияДляСозданияВП_из_ЗаборногоЛиста","Значение");
		// >> MRS #ERP-5519 ДенисламовАД <Adel.Denislamov@mriyaresort.com> 20.11.25, ()
		
		Пока MRS_ТЧАлкоголь.Следующий() Цикл
			НовСтрокаДокСписания = ТекДокументСписания.Товары.Добавить();
			НовСтрокаДокСписания.Номенклатура				= MRS_ТЧАлкоголь.Номенклатура;
			НовСтрокаДокСписания.СтатьяРасходов				= ДокументВыпускБлюд.СтатьяРасходов;
			НовСтрокаДокСписания.Характеристика				= MRS_ТЧАлкоголь.Характеристика;	
			НовСтрокаДокСписания.Серия						= Справочники.СерииНоменклатуры.ПустаяСсылка(); // Заполним по FEFO непосредсвенно перед записью
			НовСтрокаДокСписания.Назначение					= MRS_ТЧАлкоголь.Назначение;   
			// << MRS #VINE-128 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 11.06.25, ()
			//НовСтрокаДокСписания.КоличествоУпаковок			= MRS_ТЧАлкоголь.Количество;
			НовСтрокаДокСписания.КоличествоУпаковок			= MRS_ТЧАлкоголь.КоличествоУпаковок;
			// >> MRS #VINE-128 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 11.06.25, ()
			НовСтрокаДокСписания.Количество					= MRS_ТЧАлкоголь.Количество;
			НовСтрокаДокСписания.Упаковка					= MRS_ТЧАлкоголь.Упаковка;
            НовСтрокаДокСписания.СтатусУказанияСерий		= 4;
			НовСтрокаДокСписания.СтатусУказанияСерийОтправитель		= 4;
			// << MRS #ERP-5519 ДенисламовАД <Adel.Denislamov@mriyaresort.com> 20.11.25, ()
			НовСтрокаДокСписания.MRS_ПричиныСписания = ПричинаСписания;
			// >> MRS #ERP-5519 ДенисламовАД <Adel.Denislamov@mriyaresort.com> 20.11.25, ()
		КонецЦикла;
		
		Пока MRS_ТЧСерииАлкоголь.Следующий() Цикл
			НоваяСтрокаСерияСписания = ТекДокументСписания.Серии.Добавить();
			НоваяСтрокаСерияСписания.Номенклатура = MRS_ТЧСерииАлкоголь.Номенклатура;
			НоваяСтрокаСерияСписания.Количество = MRS_ТЧСерииАлкоголь.Количество;;
			НоваяСтрокаСерияСписания.Серия = MRS_ТЧСерииАлкоголь.Серия;
		КонецЦикла;
	
	КонецЕсли;
	//<<Швецов.11.02.2025. Розничные продажи алкоголя.

	// необходимо дополнить состав товаров документа ТекДокументПеремещения
	Если НЕ ТекДокументПеремещения = Неопределено Тогда
		Для Каждого ПЛ_СтрокаТаблицыИнгридиентов Из ПЛ_ТЗДляДвиженияПродукции Цикл
			Если ПЛ_СтрокаТаблицыИнгридиентов.ЭтоТовар Тогда
				НовСтрокаДвижениеПродукцииИМатериалов = ТекДокументПеремещения.Товары.Добавить();
				НовСтрокаДвижениеПродукцииИМатериалов.Номенклатура				= ПЛ_СтрокаТаблицыИнгридиентов.Ингредиент;
				НовСтрокаДвижениеПродукцииИМатериалов.Характеристика			= ПЛ_СтрокаТаблицыИнгридиентов.Характеристика;
				НовСтрокаДвижениеПродукцииИМатериалов.Серия						= Справочники.СерииНоменклатуры.ПустаяСсылка(); // Заполним по FEFO непосредсвенно перед записью
				//НовСтрокаДвижениеПродукцииИМатериалов.Назначение???
				НовСтрокаДвижениеПродукцииИМатериалов.КоличествоУпаковок		= ПЛ_СтрокаТаблицыИнгридиентов.КоличествоУпаковокИнгредиентаФакт;
				НовСтрокаДвижениеПродукцииИМатериалов.Количество				= ПЛ_СтрокаТаблицыИнгридиентов.КоличествоИнгредиентаФакт;
				НовСтрокаДвижениеПродукцииИМатериалов.Упаковка					= ПЛ_СтрокаТаблицыИнгридиентов.Упаковка;
				НовСтрокаДвижениеПродукцииИМатериалов.ИдентификаторСтроки		= Новый УникальныйИдентификатор;
				НовСтрокаДвижениеПродукцииИМатериалов.ГруппаПродукции			= ПЛ_СтрокаТаблицыИнгридиентов.ГруппаАналитическогоУчета;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	// Сворачиваем получившуюся таблицу по ключевым полям и удаляем строки с нулевым количеством
	ПЛ_ТЗДляПроверкиКоличестваИнгредиентов.Свернуть("Номенклатура, Ингредиент, Характеристика, Серия, ХарактеристикаНоменклатуры, СерияНоменклатуры, Рецептура, Назначение", "КоличествоИнгредиентаКонтроль, КоличествоУпаковокИнгредиентаКонтроль"); 
	
	// обход таблицы с выявленными различиями после округления
	ПЛ_СтруктураПоиска = Новый Структура;
	Для Каждого ПЛ_СтрокаСРазницейПослеОкругления Из ПЛ_ТЗДляПроверкиКоличестваИнгредиентов Цикл
		Если ПЛ_СтрокаСРазницейПослеОкругления.КоличествоУпаковокИнгредиентаКонтроль = 0
			И ПЛ_СтрокаСРазницейПослеОкругления.КоличествоИнгредиентаКонтроль = 0
			Тогда Продолжить;
		КонецЕсли;

		ПЛ_СтруктураПоиска.Вставить("Ингредиент", ПЛ_СтрокаСРазницейПослеОкругления.Ингредиент);
		ПЛ_СтруктураПоиска.Вставить("Номенклатура", ПЛ_СтрокаСРазницейПослеОкругления.Номенклатура);
		ПЛ_СтруктураПоиска.Вставить("Характеристика", ПЛ_СтрокаСРазницейПослеОкругления.Характеристика);
		ПЛ_СтруктураПоиска.Вставить("Серия", ПЛ_СтрокаСРазницейПослеОкругления.Серия);

		ПЛ_СтруктураПоиска.Вставить("ХарактеристикаНоменклатуры", ПЛ_СтрокаСРазницейПослеОкругления.ХарактеристикаНоменклатуры);
		ПЛ_СтруктураПоиска.Вставить("СерияНоменклатуры", ПЛ_СтрокаСРазницейПослеОкругления.СерияНоменклатуры);
		ПЛ_СтруктураПоиска.Вставить("Рецептура", ПЛ_СтрокаСРазницейПослеОкругления.Рецептура);
		ПЛ_СтруктураПоиска.Вставить("Назначение", ПЛ_СтрокаСРазницейПослеОкругления.Назначение);
		
		// договор получаем из другой таблицы по связке ключевых полей
		ПЛ_СтрокаСДоговором = ПЛ_ТЗДляОпределенияДоговора.НайтиСтроки(ПЛ_СтруктураПоиска);
		Если ПЛ_СтрокаСДоговором.Количество() > 0 Тогда
			ПЛ_СтруктураПоиска.Вставить("ПЛ_Договор", ПЛ_СтрокаСДоговором[0].ПЛ_Договор);
		КонецЕсли;
		
		ПЛ_СтруктураПоиска.Номенклатура = ПЛ_СтруктураПоиска.Ингредиент;
		ПЛ_СтруктураПоиска.Удалить("Ингредиент");
		ПЛ_СтруктураПоиска.Удалить("ХарактеристикаНоменклатуры");
		ПЛ_СтруктураПоиска.Удалить("СерияНоменклатуры");
		ПЛ_СтруктураПоиска.Удалить("Рецептура");
		ПЛ_СтруктураПоиска.Удалить("Назначение");
		
		// поиск нужной строки в документе
		ПЛ_СтрокаТЧТовары = ТекДокументОбъект.Товары.НайтиСтроки(ПЛ_СтруктураПоиска);
		
		// в случае, если строка документа найдена, изменяем количество в ней 
		Если ПЛ_СтрокаТЧТовары.Количество() > 0 Тогда
			ПЛ_СтрокаТЧТовары[0].Количество = ПЛ_СтрокаТЧТовары[0].Количество - ПЛ_СтрокаСРазницейПослеОкругления.КоличествоИнгредиентаКонтроль;
			ПЛ_СтрокаТЧТовары[0].КоличествоУпаковок = ПЛ_СтрокаТЧТовары[0].КоличествоУпаковок - ПЛ_СтрокаСРазницейПослеОкругления.КоличествоУпаковокИнгредиентаКонтроль;
		КонецЕсли;
		ПЛ_СтруктураПоиска.Очистить();
	КонецЦикла;
	//>>Портал-Юг, Давиденко 2019.03.20
	
	// Обход таб. части и заполнение таб. частей "Оплаты".
	Выборка = РезультатЗапроса[1].Выбрать();
	Пока Выборка.Следующий() Цикл
		
		НовСтрока						= ТекДокументОбъект.ОплатаПлатежнымиКартами.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтрока, Выборка);
		//>>Швецов. 22.05.2025. ERP-5059. Способы оплат в ОРП
		НовСтрока.ВидОплаты				= Перечисления.ТипыПлатежнойСистемыККТ.ПлатежнаяКарта; 
		//<<
	КонецЦикла;
	
	// Обход таб. части и заполнение таб. частей "Подарочные сертификаты".
	Выборка = РезультатЗапроса[2].Выбрать();
	Пока Выборка.Следующий() Цикл
		
		НовСтрока						= ТекДокументОбъект.ПодарочныеСертификаты.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтрока, Выборка);
		
	КонецЦикла;
	
	// Обход таб. части и заполнение таб. частей "НачислениеБонусныхБаллов".
	Выборка = РезультатЗапроса[3].Выбрать();
	Пока Выборка.Следующий() Цикл
		
		НовСтрока						= ТекДокументОбъект.НачислениеБонусныхБаллов.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтрока, Выборка);
		
	КонецЦикла;
	
	// Обход таб. части и заполнение таб. частей "НачислениеБонусныхБаллов".
	Выборка = РезультатЗапроса[4].Выбрать();
	Пока Выборка.Следующий() Цикл
		
		НовСтрока						= ТекДокументОбъект.ОплатаБонуснымиБаллами.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтрока, Выборка);
		
	КонецЦикла;
	
	//>>Швецов.11.02.2025. Розничные продажи алкоголя. 
	//По заборному листу разбиваем серийный алкоголь и все остальное на ОРП и ВН "списание на расходы"
	Если НЕ ТекДокументСписания = Неопределено И НЕ(ТекДокументСписания = РежимЗаписиДокумента.ОтменаПроведения И ПустаяСтрока(ТекДокументСписания.ВерсияДанных)) И 
			ТекДокументСписания.Товары.Количество() <> 0 Тогда
			
		//+ОтложенноеПроведение
		Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
			ИсходныйРежимЗаписиДокСписания	= ТекДокументСписания;
			ТекРежимЗаписиДокСписания			= РежимЗаписиДокумента.Запись;
		КонецЕсли;
		//-ОтложенноеПроведение
		
		Попытка
			
			//+Серии
			Если ТекРежимЗаписи <> РежимЗаписиДокумента.ОтменаПроведения И НЕ СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
				ЗаполнитьСерииТиповогоДокумента(ТекДокументОбъект, ДокументВыпускБлюд);
			КонецЕсли;
			//-Серии

			ТекДокументСписания.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
			Если ЗначениеЗаполнено(ДокументВыпускБлюд.ДокументОснование) И ТипЗнч(ДокументВыпускБлюд.ДокументОснование) = Тип("ДокументСсылка.питПланМеню") Тогда
				ТекДокументСписания.ДополнительныеСвойства.Вставить("питДокументОбщепитРаспределениеЗапасов", ДокументВыпускБлюд);
			КонецЕсли;                        
			
			// << MRS #ERP-5640 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 13.02.26, (Формирование акта на основании Заборного листа/Внутреннего потребления)
			Если Не ТекДокументСписания.ДополнительныеСвойства.Свойство("питДокументОбщепитРаспределениеЗапасов") И ТипЗнч(ДокументВыпускБлюд) = Тип("ДокументСсылка.питВыпускБлюд") Тогда
				ТекДокументСписания.ДополнительныеСвойства.Вставить("питДокументОбщепитРаспределениеЗапасов", ДокументВыпускБлюд);
			КонецЕсли;                                                                   
			// >> MRS #ERP-5640 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 13.02.26, (Формирование акта на основании Заборного листа/Внутреннего потребления) 
			
			ТекДокументСписания.Записать(ТекРежимЗаписиДокСписания);
		Исключение
			ТекстОшибки = ТекстОшибки + "
			|Ошибка записи документа """ + ТекДокументСписания.Метаданные().Представление() + """
			| по документу Общепит """+ДокументВыпускБлюд+"""
			|по причине: <"+ОписаниеОшибки()+">";
			Возврат Ложь;
		КонецПопытки;
		
		//+ОтложенноеПроведение
		Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
			ТекДействие = ПолучитьТекущееДействиеПоРежимузаписиТиповогоДокумента(ИсходныйРежимЗаписиДокСписания);
			ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ТекДействие, ТекДокументСписания.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
			СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
			Если НЕ ВсеОк Тогда 
				Возврат ВсеОк;
			КонецЕсли;
			ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.УстановитьСинхронизациюТиповогоДокумента, ТекДокументСписания.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
			СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
			Если НЕ ВсеОк Тогда 
				Возврат ВсеОк;
			КонецЕсли;
		КонецЕсли;
		//-ОтложенноеПроведение
		
		//+ОтложенноеПроведение
		ТекСинхронизирован = ?(СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд, Ложь, Истина);
		//-ОтложенноеПроведение
		
		// Добавление записи в результирующую таблицу в случае успешной записи документов.
		ДобавитьНовуюЗапись(ДокументВыпускБлюд, ТекДокументСписания, тблСозданныеДокументы, 0, ТекСинхронизирован);
		
	КонецЕсли;
	
	//<<Швецов.11.02.2025. Розничные продажи алкоголя. ОРП может быть пустой
	Если НЕ ТекДокументПеремещения = Неопределено И НЕ(ТекРежимЗаписиДокПеремещения = РежимЗаписиДокумента.ОтменаПроведения И ПустаяСтрока(ТекДокументПеремещения.ВерсияДанных)) Тогда 
		Если MRS_ЗаборныйЛист И ТекДокументПеремещения.Товары.Количество() <> 0 Тогда
	//+ДВИЖЕНИЕ ПРОДУКЦИИ И МАТЕРИАЛОВ 22
			//+Серии
			Если ТекРежимЗаписиДокПеремещения <> РежимЗаписиДокумента.ОтменаПроведения И НЕ СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
				ЗаполнитьСерииТиповогоДокумента(ТекДокументПеремещения, ДокументВыпускБлюд, 1);
			КонецЕсли;
			//-Серии
			
			//+ОтложенноеПроведение
			Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
				ИсходныйРежимЗаписиДокПеремещения	= ТекРежимЗаписиДокПеремещения;
				ТекРежимЗаписиДокПеремещения			= РежимЗаписиДокумента.Запись;
			КонецЕсли;
			//-ОтложенноеПроведение
			
			Попытка
				ТекДокументПеремещения.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
				Если ЗначениеЗаполнено(ДокументВыпускБлюд.ДокументОснование) И ТипЗнч(ДокументВыпускБлюд.ДокументОснование) = Тип("ДокументСсылка.питПланМеню") Тогда
					ТекДокументПеремещения.ДополнительныеСвойства.Вставить("питДокументОбщепитРаспределениеЗапасов", ДокументВыпускБлюд);
				КонецЕсли;
				ТекДокументПеремещения.Записать(ТекРежимЗаписиДокПеремещения);
			Исключение
				ТекстОшибки = ТекстОшибки + "
				|Ошибка записи документа """ + ТекДокументПеремещения.Метаданные().Представление() + """
				| по документу Общепит """+ДокументВыпускБлюд+"""
				|по причине: <"+ОписаниеОшибки()+">";
				Возврат Ложь;
			КонецПопытки;
			
			//+ОтложенноеПроведение
			Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
				ТекДействие = ПолучитьТекущееДействиеПоРежимузаписиТиповогоДокумента(ИсходныйРежимЗаписиДокПеремещения);
				ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ТекДействие, ТекДокументПеремещения.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
				СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
				Если НЕ ВсеОк Тогда 
					Возврат ВсеОк;
				КонецЕсли;
				ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.УстановитьСинхронизациюТиповогоДокумента, ТекДокументПеремещения.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
				СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
				Если НЕ ВсеОк Тогда 
					Возврат ВсеОк;
				КонецЕсли;
			КонецЕсли;
			//-ОтложенноеПроведение
			
			//+ОтложенноеПроведение
			ТекСинхронизирован = ?(СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд, Ложь, Истина);
			//-ОтложенноеПроведение
			
			// Добавление записи в результирующую таблицу в случае успешной записи документов.
			ДобавитьНовуюЗапись(ДокументВыпускБлюд, ТекДокументПеремещения, тблСозданныеДокументы, 1, ТекСинхронизирован);
			
		КонецЕсли;
	КонецЕсли;
	//<<Швецов.11.02.2025. Розничные продажи алкоголя.
	
	// Если документ найден, то получаем объект иначе создаем новый.
	ТекДокументПеремещения = Неопределено;
	Если НЕ ВыборкаДокПеремещения = Неопределено И ВыборкаДокПеремещения.Следующий() Тогда
		ТекДокументПеремещения = ВыборкаДокПеремещения.ТиповойДокумент.ПолучитьОбъект();
		
		
		// Определение параметров записи.
		ПараметрыЗаписиДокПеремещения = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокументВыпускБлюд.Проведен,ДокументВыпускБлюд.ПометкаУдаления,
		ТекДокументПеремещения.Проведен,ТекДокументПеремещения.ПометкаУдаления, Новый Структура);
		
		// Определение режима записи
		ТекРежимЗаписиДокПеремещения = ПараметрыЗаписиДокПеремещения.РежимЗаписи;
		
		Если ПараметрыЗаписиДокПеремещения.НужнаУстановкаПометкиУдаления Тогда
			
			//+ОтложенноеПроведение
			Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
				ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ПолучитьТекущееДействиеПоПометкеУдаленияТиповогоДокумента(ПараметрыЗаписи.ПометкаУдаления), ТекДокументПеремещения.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
				СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
				Если НЕ ВсеОк Тогда 
					Возврат ВсеОк;
				КонецЕсли;
				ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.УстановитьСинхронизациюТиповогоДокумента, ТекДокументПеремещения.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
				СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
				Если НЕ ВсеОк Тогда 
					Возврат ВсеОк;
				КонецЕсли;
			Иначе
			//-ОтложенноеПроведение
				
				Попытка
					ТекДокументПеремещения.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
					Если ЗначениеЗаполнено(ДокументВыпускБлюд.ДокументОснование) И ТипЗнч(ДокументВыпускБлюд.ДокументОснование) = Тип("ДокументСсылка.питПланМеню") Тогда
						ТекДокументПеремещения.ДополнительныеСвойства.Вставить("питДокументОбщепитРаспределениеЗапасов", ДокументВыпускБлюд);
					КонецЕсли;
					ТекДокументПеремещения.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
				Исключение
					ТекстОшибки = ТекстОшибки + "
					|Ошибка при установке пометки удаления """ + ТекДокументПеремещения.Метаданные().Представление() + """
					| по документу Общепит """+ДокументВыпускБлюд+"""
					|по причине: <"+ОписаниеОшибки()+">";
					Возврат Ложь;
				КонецПопытки;
				
			КонецЕсли;
			
		КонецЕсли;
		
		//+ОтложенноеПроведение
		ТекСинхронизирован = ?(СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд, Ложь, Истина);
		//-ОтложенноеПроведение
		
		// Добавление записи в результирующую таблицу в случае успешной записи документов.
		ДобавитьНовуюЗапись(ДокументВыпускБлюд, ТекДокументПеремещения, тблСозданныеДокументы, 1,ТекСинхронизирован);
		
	КонецЕсли;
	//-ДВИЖЕНИЕ ПРОДУКЦИИ И МАТЕРИАЛОВ 22
	
	/////////////////////////////////////////////////////////
	// ЗАПИСЬ ДОКУМЕНТА
	//<<Швецов.11.02.2025. Розничные продажи алкоголя. ОРП может быть пустой
	Если ТекДокументОбъект.Товары.Количество() <> 0 Тогда
		Если НЕ(ТекРежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения И ПустаяСтрока(ТекДокументОбъект.ВерсияДанных)) Тогда
			
			//+Серии
			Если ТекРежимЗаписи <> РежимЗаписиДокумента.ОтменаПроведения И НЕ СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
				ПараметрыУказанияСерий = Новый ФиксированнаяСтруктура(НоменклатураСервер.ПараметрыУказанияСерий(ТекДокументОбъект, Документы.ОтчетОРозничныхПродажах));
				ЗаполнитьСерииТиповогоДокумента(ТекДокументОбъект, ДокументВыпускБлюд);
			КонецЕсли;
			//-Серии
			
			//+ОтложенноеПроведение
			Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
				ИсходныйРежимЗаписи	= ТекРежимЗаписи;
				ТекРежимЗаписи		= РежимЗаписиДокумента.Запись;
			КонецЕсли;
			//-ОтложенноеПроведение
			
			Попытка
				ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
				ТекДокументОбъект.Записать(ТекРежимЗаписи);
			Исключение
				ТекстОшибки = ТекстОшибки + "
				|Ошибка записи документа """ + ТекДокументОбъект.Метаданные().Представление() + """
				| по документу Общепит """+ДокументВыпускБлюд+"""
				|по причине: <"+ОписаниеОшибки()+">";
				Возврат Ложь;
			КонецПопытки;
			
			//+ОтложенноеПроведение
			Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
				ТекДействие = ПолучитьТекущееДействиеПоРежимузаписиТиповогоДокумента(ИсходныйРежимЗаписи);
				ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ТекДействие, ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
				СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
				Если НЕ ВсеОк Тогда 
					Возврат ВсеОк;
				КонецЕсли;
				ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, Перечисления.питДействияОтложенногоПроведения.УстановитьСинхронизациюТиповогоДокумента, ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
				СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
				Если НЕ ВсеОк Тогда 
					Возврат ВсеОк;
				КонецЕсли;
			КонецЕсли;
			//-ОтложенноеПроведение
			
			//+ОтложенноеПроведение
			ТекСинхронизирован = ?(СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд, Ложь, Истина);
			//-ОтложенноеПроведение
			
			// Добавление записи в результирующую таблицу в случае успешной записи документов.
			ДобавитьНовуюЗапись(ДокументВыпускБлюд, ТекДокументОбъект, тблСозданныеДокументы,,ТекСинхронизирован);
			
		КонецЕсли;
	КонецЕсли;
	Возврат Истина;
	
КонецФункции

// Функция формирует документ "Отчет о розничных продажах" для выпуска с розничной реализацией.
//
// Параметры:
//  ДокументВыпускБлюд		 - ДокументСсылка	 - Ссылка на документ "Выпуск блюд", по которому формируются
//  	типовые документы.
//  СтруктураПараметров		 - Структура		 - Структура, содержащая некоторые дополнительные параметры формирования.
//  тблСозданныеДокументы	 - ТаблицаЗначений	 - Результирующая таблица созданных документов.
//  ТекстОшибки				 - Строка			 - В случае ошибочного выполнения в эту переменную будет
//  			дописан текст ошибки.
// 
// Возвращаемое значение:
//  Истина - Выполнение функции завершено успешно.
//  Ложь - При выполнении функции возникли ошибки.
//
Функция СформироватьРеализациюТоваровУслугПоВыпускуБлюд(ДокументВыпускБлюд, СтруктураПараметров, тблСозданныеДокументы, ТекстОшибки)
	
	Если СтруктураПараметров.Свойство("ФормироватьДокументыПроизводства22") Тогда
		ФормироватьДокументыПроизводства22 = СтруктураПараметров.ФормироватьДокументыПроизводства22;
	Иначе
		ФормироватьДокументыПроизводства22 = Константы.питФормироватьДокументыПроизводства22.Получить();
	КонецЕсли;
	
	Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументВыпускБлюд, "Склад.ЦеховаяКладовая") Тогда
		ИмяДокументаПеремещения = "ДвижениеПродукцииИМатериалов";
	Иначе
		ИмяДокументаПеремещения = "ПеремещениеТоваров";
	КонецЕсли;
	
	//+БазовоеСмещение
	Если НЕ СтруктураПараметров.Свойство("питСмещатьДатыТиповыхДокументов") Тогда
		СтруктураПараметров.Вставить("питСмещатьДатыТиповыхДокументов", питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питСмещатьДатыТиповыхДокументов"));
	КонецЕсли;
	БазовоеСмещениеРеализацияТоваровУслуг = 0;
	БазовоеСмещениеДокументаПеремещения = 0;
	Если СтруктураПараметров.питСмещатьДатыТиповыхДокументов Тогда
		СтрокиСмещение = СтруктураПараметров.ТаблицаПорядокПроведенияТиповыхДокументовВыпускаБлюд.НайтиСтроки(
		Новый Структура("ИмяТиповогоДокумента,ПричинаТиповогоДокумента", "ОтчетОРозничныхПродажах", 0));
		Если СтрокиСмещение.Количество() Тогда
			БазовоеСмещениеРеализацияТоваровУслуг = СтрокиСмещение[0].БазовоеСмещение;
		КонецЕсли;
		СтрокиСмещение = СтруктураПараметров.ТаблицаПорядокПроведенияТиповыхДокументовВыпускаБлюд.НайтиСтроки(
		Новый Структура("ИмяТиповогоДокумента,ПричинаТиповогоДокумента", ИмяДокументаПеремещения, 1));
		Если СтрокиСмещение.Количество() Тогда
			БазовоеСмещениеДокументаПеремещения = СтрокиСмещение[0].БазовоеСмещение;
		КонецЕсли;
	КонецЕсли;
	//-БазовоеСмещение
	
	ОрганизацияКассыККМ = питОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументВыпускБлюд.КассаККМ, "Владелец");
	
	Запрос = Новый Запрос;
	
	// Поиск существующего документа "Отчет о розничных продажах",
	// связанного с текущим "Выпуском блюд".
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питТиповыеДокументы.ТиповойДокумент,
	|	питТиповыеДокументы.ДокументОбщепит,
	|	питТиповыеДокументы.ПричинаТиповогоДокумента
	|ПОМЕСТИТЬ втТиповыеДокументы
	|ИЗ
	|	РегистрСведений.питТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ДокументОбщепит = &Документпит
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	питТиповыеДокументы.ТиповойДокумент
	|ИЗ
	|	втТиповыеДокументы КАК питТиповыеДокументы
	|ГДЕ
	|	питТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.РеализацияТоваровУслуг
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫРАЗИТЬ(втТиповыеДокументы.ТиповойДокумент КАК Документ.%ИмяДокументаПеремещения%) КАК ТиповойДокумент,
	|	ВЫРАЗИТЬ(втТиповыеДокументы.ДокументОбщепит КАК Документ.питВыпускБлюд) КАК ДокументОбщепит
	|ПОМЕСТИТЬ втДвжиенияПродукцииИМатериалов
	|ИЗ
	|	втТиповыеДокументы КАК втТиповыеДокументы
	|ГДЕ
	|	втТиповыеДокументы.ТиповойДокумент ССЫЛКА Документ.%ИмяДокументаПеремещения%
	|	И втТиповыеДокументы.ПричинаТиповогоДокумента = 1
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втДвжиенияПродукцииИМатериалов.ТиповойДокумент
	|ИЗ
	|	втДвжиенияПродукцииИМатериалов КАК втДвжиенияПродукцииИМатериалов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.питВыпускБлюд КАК питВыпускБлюд
	|		ПО втДвжиенияПродукцииИМатериалов.ДокументОбщепит = питВыпускБлюд.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.%ИмяДокументаПеремещения% КАК %ИмяДокументаПеремещения%
	|		ПО втДвжиенияПродукцииИМатериалов.ТиповойДокумент = %ИмяДокументаПеремещения%.Ссылка
	|ГДЕ
	|	%ИмяДокументаПеремещения%.%ИмяПоляПолучатель% <> питВыпускБлюд.Склад";
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ИмяДокументаПеремещения%", ИмяДокументаПеремещения);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ИмяПоляПолучатель%", ?(ИмяДокументаПеремещения = "ДвижениеПродукцииИМатериалов", "Получатель", "СкладПолучатель"));
	
	Запрос.УстановитьПараметр("Документпит",				ДокументВыпускБлюд);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Выборка = РезультатЗапроса[1].Выбрать();
	
	// Если документ найден, то получаем объект иначе создаем новый.
	Если Выборка.Следующий() Тогда
		ТекДокументОбъект = Выборка.ТиповойДокумент.ПолучитьОбъект();
	Иначе
		ТекДокументОбъект = Документы.РеализацияТоваровУслуг.СоздатьДокумент();
	КонецЕсли;
	
	// Определение параметров записи.
	ПараметрыЗаписи = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокументВыпускБлюд.Проведен,ДокументВыпускБлюд.ПометкаУдаления,
		ТекДокументОбъект.Проведен,ТекДокументОбъект.ПометкаУдаления,СтруктураПараметров);
	
	// Определение режима записи
	ТекРежимЗаписи = ПараметрыЗаписи.РежимЗаписи;
	
	Если ПараметрыЗаписи.НужнаУстановкаПометкиУдаления Тогда
		
		//+ОтложенноеПроведение
		Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
			ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ПолучитьТекущееДействиеПоПометкеУдаленияТиповогоДокумента(ПараметрыЗаписи.ПометкаУдаления), ТекДокументОбъект.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
			СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
			Если НЕ ВсеОк Тогда 
				Возврат ВсеОк;
			КонецЕсли;
		Иначе
		//-ОтложенноеПроведение
			
			Попытка
				ТекДокументОбъект.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
				ТекДокументОбъект.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
			Исключение
				ТекстОшибки = ТекстОшибки + "
				|Ошибка при установке пометки удаления """ + ТекДокументОбъект.Метаданные().Представление() + """
				| по документу Общепит """+ДокументВыпускБлюд+"""
				|по причине: <"+ОписаниеОшибки()+">";
				Возврат Ложь;
			КонецПопытки;
			
		КонецЕсли;
		
	КонецЕсли;
	
	//+ДВИЖЕНИЕ ПРОДУКЦИИ И МАТЕРИАЛОВ 22
	ТекДокументПеремещения = Неопределено;
	ВыборкаДокПеремещения = РезультатЗапроса[3].Выбрать();
	Если ФормироватьДокументыПроизводства22 
		И ДокументВыпускБлюд.СкладПолучатель <> ДокументВыпускБлюд.Склад Тогда
		
		// Если документ найден, то получаем объект иначе создаем новый.
		Если ВыборкаДокПеремещения.Следующий() Тогда
			ТекДокументПеремещения = ВыборкаДокПеремещения.ТиповойДокумент.ПолучитьОбъект();
		Иначе
			ТекДокументПеремещения = Документы[ИмяДокументаПеремещения].СоздатьДокумент();
		КонецЕсли;
		
		// Определение параметров записи.
		ПараметрыЗаписиДокПеремещения = ОпределитьПараметрыЗаписиТиповогоДокумента(ДокументВыпускБлюд.Проведен,ДокументВыпускБлюд.ПометкаУдаления,
		ТекДокументПеремещения.Проведен,ТекДокументПеремещения.ПометкаУдаления, Новый Структура);
		
		// Определение режима записи
		ТекРежимЗаписиДвижениеПродукции = ПараметрыЗаписиДокПеремещения.РежимЗаписи;
		
		Если ПараметрыЗаписиДокПеремещения.НужнаУстановкаПометкиУдаления Тогда
			
			//+ОтложенноеПроведение
			Если СтруктураПараметров.питИспользоватьОтложенноеПроведениеВыпускаБлюд Тогда
				ВсеОк = ДобавитьДействиеОтложенногоПроведения(ДокументВыпускБлюд, ПолучитьТекущееДействиеПоПометкеУдаленияТиповогоДокумента(ПараметрыЗаписи.ПометкаУдаления), ТекДокументПеремещения.Ссылка, СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения,ТекстОшибки);
				СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения = СтруктураПараметров.питТекущийПриоритетДействияОтложенногоПроведения + 1;
				Если НЕ ВсеОк Тогда 
					Возврат ВсеОк;
				КонецЕсли;
			Иначе
			//-ОтложенноеПроведение
				
				Попытка
					ТекДокументПеремещения.ДополнительныеСвойства.Вставить("питРазрешитьЗаписьТиповогоДокумента",Истина);
					Если ЗначениеЗаполнено(ДокументВыпускБлюд.ДокументОснование) И ТипЗнч(ДокументВыпускБлюд.ДокументОснование) = Тип("ДокументСсылка.питПланМеню") Тогда
						ТекДокументПеремещения.ДополнительныеСвойства.Вставить("питДокументОбщепитРаспределениеЗапасов", ДокументВыпускБлюд);
					КонецЕсли;
					ТекДокументПеремещения.УстановитьПометкуУдаления(ПараметрыЗаписи.ПометкаУдаления);
				Исключение
					ТекстОшибки = ТекстОшибки + "
					|Ошибка при установке пометки удаления """ + ТекДокументПеремещения.Метаданные().Представление() + """
					| по документу Общепит """+ДокументВыпускБлюд+"""
					|по причине: <"+ОписаниеОшибки()+">";
					Возврат Ложь;
				КонецПопытки;
				
			КонецЕсли;
			
		КонецЕсли;
		
		
	КонецЕсли;
	//-ДВИЖЕНИЕ ПРОДУКЦИИ И МАТЕРИАЛОВ 22
	
	/////////////////////////////////
	// ЗАПОЛНЕНИЕ ШАПКИ.
	мМетаданныеДокументапит =		ДокументВыпускБлюд.Метаданные();
	мМетаданныеТиповогоДокумента =	ТекДокументОбъект.Метаданные();
	
	ТекДокументОбъект.Дата								= ДокументВыпускБлюд.Дата 
	+ ?(СтруктураПараметров.Свойство("ДатаСмещение"),СтруктураПараметров.ДатаСмещение, 0)
