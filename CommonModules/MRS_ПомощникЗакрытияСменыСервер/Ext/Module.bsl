#Область ПрограммныйИнтерфейс

// Сопоставляет объект фронт-системы (кассу или номенклатуру) с объектом 1С.
// Создаёт запись в регистре ПЛ_СоответствиеСФронтСистемами, если её ещё нет.
//
// Параметры:
//  ТипОбъекта     - ПланВидовХарактеристикСсылка.ПЛ_ТипыОбъектовФронтСистем - тип сопоставляемого объекта
//  ФронтСистема   - ПеречислениеСсылка.ПЛ_ТипыФронтСистем - фронт-система
//  Код            - Строка - код объекта во фронт-системе
//  Объект         - Произвольный - сопоставленный объект 1С
//                   (СправочникСсылка.КассыККМ или СправочникСсылка.Номенклатура)
//
// Возвращаемое значение:
//  Булево - Истина, если запись успешно создана или обновлена
//
Функция СопоставитьОбъектФронта(ТипОбъекта, ФронтСистема, Код, Объект) Экспорт

	НаборЗаписей = РегистрыСведений.ПЛ_СоответствиеСФронтСистемами.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ТипОбъекта.Установить(ТипОбъекта);
	НаборЗаписей.Отбор.ФронтСистема.Установить(ФронтСистема);
	НаборЗаписей.Отбор.Код.Установить(Код);
	НаборЗаписей.Прочитать();

	Если НаборЗаписей.Количество() = 0 Тогда
		НоваяЗапись = НаборЗаписей.Добавить();
		НоваяЗапись.ТипОбъекта = ТипОбъекта;
		НоваяЗапись.ФронтСистема = ФронтСистема;
		НоваяЗапись.Код = Код;
	Иначе
		НоваяЗапись = НаборЗаписей[0];
	КонецЕсли;

	НоваяЗапись.Объект = Объект;
	НаборЗаписей.Записать();

	Возврат Истина;

КонецФункции

// Вычисляет статус шага «Сопоставление объектов фронта» для выбранного дня и складов.
// Возвращает структуру с полным состоянием шага для отображения в форме.
//
// Параметры:
//  День           - Дата - выбранный день
//  МассивСкладов  - Массив из СправочникСсылка.Склады - выбранные склады
//
// Возвращаемое значение:
//  Структура:
//   - Статус       - Строка - «Пройден» / «НеПройден»
//   - Строки       - ТаблицаЗначений - строки несопоставленных объектов
//       колонки: ТипОбъекта, ФронтСистема, Код, НаименованиеНаФронте
//
Функция СтатусШагаСопоставление(День, МассивСкладов) Экспорт

	Результат = Новый Структура;
	Результат.Вставить("Статус", "Пройден");
	Результат.Вставить("Строки", Новый ТаблицаЗначений);
   
	ТаблицаНесопоставленных = Результат.Строки;
	ТаблицаНесопоставленных.Колонки.Добавить("ТипОбъекта");
	ТаблицаНесопоставленных.Колонки.Добавить("ФронтСистема");
	ТаблицаНесопоставленных.Колонки.Добавить("Код");
	ТаблицаНесопоставленных.Колонки.Добавить("НаименованиеНаФронте");
   
	НачалоДня = НачалоДня(День);
	КонецДня  = КонецДня(День);
   
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	| &ТипКасса КАК ТипОбъекта,
	| Соответствие.ФронтСистема КАК ФронтСистема,
	| Чек.ПЛ_КодТочкиПродажи КАК Код,
	| Соответствие.НаименованиеКнопки КАК НаименованиеНаФронте
	|ИЗ
	| Документ.питДанныеПродажФронта КАК Чек
	|  ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПЛ_СоответствиеСФронтСистемами КАК Соответствие
	|  ПО Соответствие.ТипОбъекта = &ТипКасса
	|   И Соответствие.Код = Чек.ПЛ_КодТочкиПродажи
	|ГДЕ
	| Чек.Дата МЕЖДУ &НачалоДня И &КонецДня
	| И Чек.Склад В (&МассивСкладов)
	| И НЕ Чек.ПометкаУдаления
	| И Чек.ПЛ_КодТочкиПродажи <> """"
	| И (ЕСТЬNULL(Соответствие.Код, """") = """"
	|   ИЛИ ЕСТЬNULL(Соответствие.Объект, ЗНАЧЕНИЕ(Справочник.КассыККМ.ПустаяСсылка))
	|    = ЗНАЧЕНИЕ(Справочник.КассыККМ.ПустаяСсылка))
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	| &ТипНоменклатура,
	| Соответствие.ФронтСистема,
	| ТоварыЧеков.ПЛ_КодКнопки,
	| Соответствие.НаименованиеКнопки
	|ИЗ
	| Документ.питДанныеПродажФронта.Товары КАК ТоварыЧеков
	|  ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПЛ_СоответствиеСФронтСистемами КАК Соответствие
	|  ПО Соответствие.ТипОбъекта = &ТипНоменклатура
	|   И Соответствие.Код = ТоварыЧеков.ПЛ_КодКнопки
	|ГДЕ
	| ТоварыЧеков.Ссылка.Дата МЕЖДУ &НачалоДня И &КонецДня
	| И ТоварыЧеков.Ссылка.Склад В (&МассивСкладов)
	| И НЕ ТоварыЧеков.Ссылка.ПометкаУдаления
	| И ТоварыЧеков.ПЛ_КодКнопки <> """"
	| И (ЕСТЬNULL(Соответствие.Код, """") = """"
	|   ИЛИ ЕСТЬNULL(Соответствие.Объект, ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка))
	|    = ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка))";
   
	Запрос.УстановитьПараметр("ТипКасса",        ПланыВидовХарактеристик.ПЛ_ТипыОбъектовФронтСистем.КассаККМ);
	Запрос.УстановитьПараметр("ТипНоменклатура", ПланыВидовХарактеристик.ПЛ_ТипыОбъектовФронтСистем.Номенклатура);
	Запрос.УстановитьПараметр("НачалоДня",       НачалоДня);
	Запрос.УстановитьПараметр("КонецДня",        КонецДня);
	Запрос.УстановитьПараметр("МассивСкладов",   МассивСкладов);
   
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
   
	Пока Выборка.Следующий() Цикл
	 НоваяСтрока = ТаблицаНесопоставленных.Добавить();
	 НоваяСтрока.ТипОбъекта          = Выборка.ТипОбъекта;
	 НоваяСтрока.ФронтСистема        = Выборка.ФронтСистема;
	 НоваяСтрока.Код                 = Выборка.Код;
	 НоваяСтрока.НаименованиеНаФронте = Выборка.НаименованиеНаФронте;
	КонецЦикла;
   
	Если ТаблицаНесопоставленных.Количество() > 0 Тогда
	 Результат.Статус = "НеПройден";
	КонецЕсли;
   
	Возврат Результат;
   
   КонецФункции

// Вычисляет статус шага «Сверка чеков» для выбранного дня и складов.
// Возвращает структуру с полным состоянием шага.
//
// Параметры:
//  День           - Дата - выбранный день
//  МассивСкладов  - Массив из СправочникСсылка.Склады - выбранные склады
//  ПараметрыКасс - ТаблицаЗначений, Неопределено - выбранные кассы для ограничения запросов
//
// Возвращаемое значение:
//  Структура:
//   - Статус - Строка - «Пройден» / «НеПройден» / «НетДанных»
//   - Строки - ТаблицаЗначений - строки отклонений
//
Функция СтатусШагаСверка(День, МассивСкладов, ПараметрыКасс = Неопределено) Экспорт

	Результат = Новый Структура;
	Результат.Вставить("Статус", "Пройден");
	Результат.Вставить("Строки", Новый ТаблицаЗначений);

	КассыККМ = КассыККМИзПараметров(ПараметрыКасс);
	Если КассыККМ.Количество() = 0 Тогда
		Результат.Статус = "НетДанных";
		Возврат Результат;
	КонецЕсли;

	// Проверяем наличие документов за день
	НачалоДня = НачалоДня(День);
	КонецДня  = КонецДня(День);

	ЗапросНаличияЧеков = Новый Запрос;
	ЗапросНаличияЧеков.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Чек.Ссылка) КАК КоличествоЧеков
	|ИЗ
	|	Документ.питДанныеПродажФронта КАК Чек
	|ГДЕ
	|	Чек.Дата МЕЖДУ &НачалоДня И &КонецДня
	|	И Чек.Склад В (&МассивСкладов)
	|	И Чек.КассаККМ В (&КассыККМ)
	|	И НЕ Чек.ПометкаУдаления";

	ЗапросНаличияЧеков.УстановитьПараметр("НачалоДня",     НачалоДня);
	ЗапросНаличияЧеков.УстановитьПараметр("КонецДня",      КонецДня);
	ЗапросНаличияЧеков.УстановитьПараметр("МассивСкладов", МассивСкладов);
	ЗапросНаличияЧеков.УстановитьПараметр("КассыККМ",      КассыККМ);

	РезультатЗапроса = ЗапросНаличияЧеков.Выполнить();
	ВыборкаНаличияЧеков = РезультатЗапроса.Выбрать();
	ВыборкаНаличияЧеков.Следующий();

	Если ВыборкаНаличияЧеков.КоличествоЧеков = 0 Тогда
		Результат.Статус = "НетДанных";
		Возврат Результат;
	КонецЕсли;

	// Получаем отклонения и заполняем таблицу
	ТаблицаОтклонений = ПолучитьОтклоненияСверки(День, МассивСкладов, ПараметрыКасс);

	Если ТаблицаОтклонений.Количество() > 0 Тогда
		Результат.Статус = "НеПройден";
	КонецЕсли;

	Результат.Строки = ТаблицаОтклонений;

	Возврат Результат;

КонецФункции

// Запускает (пере)загрузку чеков за выбранный день по обеим фронт-системам.
// Вызывается точечным действием на шагах «Сопоставление» и «Сверка».
//
// Параметры:
//  День          - Дата - день, за который требуется перезагрузить чеки
//  ПараметрыКасс - ТаблицаЗначений, Неопределено - выбранные кассы
//
Процедура ПерезагрузитьЧекиЗаДень(День, ПараметрыКасс = Неопределено) Экспорт

	НачалоДня = НачалоДня(День);
	КонецДня  = КонецДня(День);
	ОшибкиПерезагрузки = Новый Массив;
	ПараметрыКассTNG = ПараметрыКассДляФронтСистемы(
		ПараметрыКасс,
		Перечисления.ПЛ_ТипыФронтСистем.TNG);
	ПараметрыКассMicros = ПараметрыКассДляФронтСистемы(
		ПараметрыКасс,
		Перечисления.ПЛ_ТипыФронтСистем.Micros);

	// TNG
	Если ПараметрыКассTNG.Количество() > 0 Тогда
		Попытка
			MRS_МенеджерОбменаTNG.ВыполнитьЗагрузкуДанныхTNG(
				Перечисления.ПЛ_ТипыФронтСистем.TNG,
				НачалоДня,
				КонецДня,
				ПараметрыКассTNG,
				Неопределено);
		Исключение
			ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ОшибкиПерезагрузки.Добавить(СтрШаблон(НСтр("ru = 'TNG: %1'"), ТекстОшибки));
			ЗаписьЖурналаРегистрации(
				НСтр("ru = 'MRS.ПомощникЗакрытияСмены.ПерезагрузкаЧеков.ОшибкаTNG'"),
				УровеньЖурналаРегистрации.Ошибка,
				,
				,
				ТекстОшибки);
		КонецПопытки;
	КонецЕсли;

	// Micros
	Если ПараметрыКассMicros.Количество() > 0 Тогда
		Попытка
			MRS_МенеджерОбменаMicros.ВыполнитьЗагрузкуДанныхMicros(
				Перечисления.ПЛ_ТипыФронтСистем.Micros,
				НачалоДня,
				КонецДня,
				ПараметрыКассMicros,
				Неопределено);
		Исключение
			ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ОшибкиПерезагрузки.Добавить(СтрШаблон(НСтр("ru = 'Micros: %1'"), ТекстОшибки));
			ЗаписьЖурналаРегистрации(
				НСтр("ru = 'MRS.ПомощникЗакрытияСмены.ПерезагрузкаЧеков.ОшибкаMicros'"),
				УровеньЖурналаРегистрации.Ошибка,
				,
				,
				ТекстОшибки);
		КонецПопытки;
	КонецЕсли;

	Если ОшибкиПерезагрузки.Количество() > 0 Тогда
		ВызватьИсключение СтрСоединить(ОшибкиПерезагрузки, Символы.ПС);
	КонецЕсли;

КонецПроцедуры

// Проверяет наличие неактуальных записей в регистре питУчетДанныхПродаж
// для выбранного дня и склада.
//
// Параметры:
//  День          - Дата
//  Склад         - СправочникСсылка.Склады
//  ПараметрыКасс - ТаблицаЗначений, Неопределено - выбранные кассы
//
// Возвращаемое значение:
//  Булево - Истина, если есть записи с ОбновленПриемник = Ложь
//
Функция ЕстьНеактуальныеВыпуски(День, Склад) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	УчетДанныхПродаж.ДокументРегистратор КАК Документ
	|ИЗ
	|	РегистрСведений.питУчетДанныхПродаж КАК УчетДанныхПродаж
	|ГДЕ
	|	УчетДанныхПродаж.Дата = &ВыбранныйДень
	|	И УчетДанныхПродаж.КассовыйУзел.СкладПриготовления = &Склад
	|	И НЕ УчетДанныхПродаж.ОбновленПриемник";

	Запрос.УстановитьПараметр("ВыбранныйДень", День);
	Запрос.УстановитьПараметр("Склад",         Склад);

	Выборка = Запрос.Выполнить().Выбрать();

	Возврат Выборка.Следующий();

КонецФункции

// Формирует целевые документы (питВыпускБлюд) для выбранного дня и склада.
// Выполняет полный цикл: пометка чеков к пересозданию → заполнение параметров
// обработки → запуск ВыполнитьЗагрузкуДанных().
//
// Параметры:
//  День            - Дата
//  Склад           - СправочникСсылка.Склады
//  АдресРезультата - Строка - адрес во временном хранилище для размещения результата
//
Процедура СформироватьЦелевыеДокументы(День, Склад, АдресРезультата) Экспорт

	Результат = Новый Структура;
	Результат.Вставить("ДокументВыпуска", Неопределено);
	Результат.Вставить("СообщенияОбОшибках", "");
	Результат.Вставить("Успешно", Ложь);

	Попытка
		// Шаг 1: пометить чеки к пересозданию
		ПометитьЧекиКПересозданию(День, Склад);

		// Шаг 2: создать и заполнить обработку
		ОбработкаОбъект = Обработки.питЗагрузкаИзДанныхПродажФронта.Создать();
		ЗаполнитьПараметрыЗагрузкиОбработки(ОбработкаОбъект, День, Склад);

		// Шаг 3: запустить формирование
		ОбработкаОбъект.ВыполнитьЗагрузкуДанных();

		// Собрать результат
		Результат.МассивСохраненныхДокументов = ОбработкаОбъект.МассивСохраненныхДокументов;
		Результат.СообщенияОбОшибках = ПолучитьСообщенияПользователю(Истина);
		Результат.Успешно = Истина;

	Исключение
		Результат.СообщенияОбОшибках = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписьЖурналаРегистрации(
			НСтр("ru = 'MRS.ПомощникЗакрытияСмены.ФормированиеДокументов.Ошибка'"),
			УровеньЖурналаРегистрации.Ошибка,
			,
			,
			Результат.СообщенияОбОшибках);
		ВызватьИсключение;
	КонецПопытки;

	ПоместитьВоВременноеХранилище(Результат, АдресРезультата);

КонецПроцедуры

// Вычисляет статус шага «Формирование целевых документов» для выбранного дня и склада.
// Проверяет: полноту загрузки, актуальность выпусков, отклонения сверки чеков/выпусков,
// ошибки формирования, документы открытых цен.
//
// Параметры:
//  День          - Дата
//  Склад         - СправочникСсылка.Склады
//  ПараметрыКасс - ТаблицаЗначений, Неопределено - выбранные кассы
//
// Возвращаемое значение:
//  Структура:
//   - Статус                 - Строка - «Пройден» / «НеПройден»
//   - ЗагрузкаНеПолная        - Булево
//   - НуженДиалогАктуальности - Булево
//   - ОтклоненияВыпуска       - ТаблицаЗначений
//   - ОшибкиФормирования      - ТаблицаЗначений
//   - ДокументыОткрытыеЦены   - ТаблицаЗначений
//
Функция СтатусШагаФормирование(День, Склад, ПараметрыКасс = Неопределено) Экспорт

	Результат = Новый Структура;
	Результат.Вставить("Статус",                  "Пройден");
	Результат.Вставить("ЗагрузкаНеПолная",        Ложь);
	Результат.Вставить("НуженДиалогАктуальности", Ложь);
	Результат.Вставить("ОтклоненияВыпуска",       Новый ТаблицаЗначений);
	Результат.Вставить("ОшибкиФормирования",      Новый ТаблицаЗначений);
	Результат.Вставить("ДокументыОткрытыеЦены",   Новый ТаблицаЗначений);

	// 1. Предусловие: полнота загрузки чеков
	Если НЕ ЧекиЗагруженыПолностью(День, Склад, ПараметрыКасс) Тогда
		Результат.Статус           = "НеПройден";
		Результат.ЗагрузкаНеПолная = Истина;
		Возврат Результат;
	КонецЕсли;

	// 2. Проверка актуальности выпусков
	Если ЕстьНеактуальныеВыпуски(День, Склад) Тогда
		Результат.НуженДиалогАктуальности = Истина;
	КонецЕсли;

	// 3. Сверка чеков и выпусков
	ТаблицаОтклоненийВыпуска = ПолучитьОтклоненияВыпуска(День, Склад, ПараметрыКасс);
	Результат.ОтклоненияВыпуска = ТаблицаОтклоненийВыпуска;

	// Проверяем блокирующие строки (отрицательные отклонения)
	Для Каждого Строка Из ТаблицаОтклоненийВыпуска Цикл
		Если Строка.Разница < 0 Тогда
			Результат.Статус = "НеПройден";
			Прервать;
		КонецЕсли;
	КонецЦикла;

	// 4. Ошибки формирования
	Результат.ОшибкиФормирования = ПолучитьОшибкиФормирования(День, Склад);
	Если Результат.ОшибкиФормирования.Количество() > 0 Тогда
		Результат.Статус = "НеПройден";
	КонецЕсли;

	// 5. Документы открытых цен (непроведённые)
	Результат.ДокументыОткрытыеЦены = ПолучитьДокументыОткрытыеЦены(День, Склад);
	Если Результат.ДокументыОткрытыеЦены.Количество() > 0 Тогда
		Результат.Статус = "НеПройден";
	КонецЕсли;

	Возврат Результат;

КонецФункции

// Вычисляет статус шага «Формирование целевых документов» по всем выбранным складам.
//
// Параметры:
//  День          - Дата
//  МассивСкладов - Массив из СправочникСсылка.Склады
//  ПараметрыКасс - ТаблицаЗначений, Неопределено - выбранные кассы
//
// Возвращаемое значение:
//  Структура - сводный результат СтатусШагаФормирование
//
Функция СтатусШагаФормированиеПоСкладам(День, МассивСкладов, ПараметрыКасс = Неопределено) Экспорт

	Результат = Новый Структура;
	Результат.Вставить("Статус",                  "Пройден");
	Результат.Вставить("ЗагрузкаНеПолная",        Ложь);
	Результат.Вставить("НуженДиалогАктуальности", Ложь);
	Результат.Вставить("ОтклоненияВыпуска",       Новый ТаблицаЗначений);
	Результат.Вставить("ОшибкиФормирования",      Новый ТаблицаЗначений);
	Результат.Вставить("ДокументыОткрытыеЦены",   Новый ТаблицаЗначений);

	Для Каждого Склад Из МассивСкладов Цикл

		РезультатСклада = СтатусШагаФормирование(День, Склад, ПараметрыКасс);

		Если РезультатСклада.Статус <> "Пройден" Тогда
			Результат.Статус = "НеПройден";
		КонецЕсли;

		Если РезультатСклада.ЗагрузкаНеПолная Тогда
			Результат.ЗагрузкаНеПолная = Истина;
		КонецЕсли;

		Если РезультатСклада.НуженДиалогАктуальности Тогда
			Результат.НуженДиалогАктуальности = Истина;
		КонецЕсли;

		ДобавитьСтрокиТаблицыЗначений(Результат.ОтклоненияВыпуска, РезультатСклада.ОтклоненияВыпуска);
		ДобавитьСтрокиТаблицыЗначений(Результат.ОшибкиФормирования, РезультатСклада.ОшибкиФормирования);
		ДобавитьСтрокиТаблицыЗначений(Результат.ДокументыОткрытыеЦены, РезультатСклада.ДокументыОткрытыеЦены);

	КонецЦикла;

	Возврат Результат;

КонецФункции

// Вычисляет статус шага «Анализ отрицательных остатков» для выбранного дня и склада.
//
// Параметры:
//  День   - Дата
//  Склад  - СправочникСсылка.Склады
//
// Возвращаемое значение:
//  Структура:
//   - Статус  - Строка - «Пройден» / «НеПройден»
//   - Строки  - ТаблицаЗначений - строки отрицательных остатков
//
Функция СтатусШагаОстатки(День, Склад) Экспорт

	Результат = Новый Структура;
	Результат.Вставить("Статус", "Пройден");
	Результат.Вставить("Строки", Новый ТаблицаЗначений);

	ТаблицаОстатков = ПолучитьОтрицательныеОстатки(День, Склад);

	Если ТаблицаОстатков.Количество() > 0 Тогда
		Результат.Статус = "НеПройден";
	КонецЕсли;

	Результат.Строки = ТаблицаОстатков;

	Возврат Результат;

КонецФункции

// Вычисляет рекомендуемый день для начала работы мастера -
// самый ранний день с хотя бы одним непройденным шагом.
//
// Параметры:
//  МассивСкладов - Массив из СправочникСсылка.Склады
//  ПараметрыКасс - ТаблицаЗначений, Неопределено - выбранные кассы
//
// Возвращаемое значение:
//  Дата - рекомендуемый день, либо Дата(1,1,1), если все дни закрыты
//
Функция РекомендуемыйДень(МассивСкладов, ПараметрыКасс = Неопределено) Экспорт

	СекундВСутках = 86400;

	// Определяем границу: от максимальной даты запрета до вчерашнего дня
	МаксДатаЗапрета = Дата(1, 1, 1);

	ЗапросМаксимальнойДатыЗапрета = Новый Запрос;
	ЗапросМаксимальнойДатыЗапрета.Текст =
	"ВЫБРАТЬ МАКСИМУМ(ДатыЗапретаИзменения.ДатаЗапрета) КАК МаксДата
	|ИЗ
	|	РегистрСведений.ДатыЗапретаИзменения КАК ДатыЗапретаИзменения";

	ВыборкаДатЗапрета = ЗапросМаксимальнойДатыЗапрета.Выполнить().Выбрать();
	Если ВыборкаДатЗапрета.Следующий() Тогда
		Если ЗначениеЗаполнено(ВыборкаДатЗапрета.МаксДата) Тогда
			МаксДатаЗапрета = ВыборкаДатЗапрета.МаксДата;
		КонецЕсли;
	КонецЕсли;

	ДатаНачала = МаксДатаЗапрета;
	ДатаКонца  = ТекущаяДатаСеанса() - СекундВСутках; // вчера

	Если ДатаНачала > ДатаКонца Тогда
		Возврат Дата(1, 1, 1);
	КонецЕсли;

	// Пакетный запрос по диапазону дат - ищем самый ранний день с непройденными шагами
	// Упрощённо: перебираем даты от начала к концу и проверяем каждый день
	// (полноценный пакетный запрос требует сложного объединения по всем доменам)
	ТекущаяДата = ДатаНачала;

	Пока ТекущаяДата <= ДатаКонца Цикл
		// Проверяем шаг «Сопоставление» - самый ранний индикатор
		СтатусСопоставление = СтатусШагаСопоставление(ТекущаяДата, МассивСкладов);

		Если СтатусСопоставление.Статус = "НеПройден" Тогда
			Возврат ТекущаяДата;
		КонецЕсли;

		// Проверяем шаг «Сверка»
		СтатусСверка = СтатусШагаСверка(ТекущаяДата, МассивСкладов, ПараметрыКасс);

		Если СтатусСверка.Статус <> "Пройден" Тогда
			Возврат ТекущаяДата;
		КонецЕсли;

		// Проверяем шаги «Формирование» и «Остатки» по каждому складу
		Для Каждого Склад Из МассивСкладов Цикл
			СтатусФормирование = СтатусШагаФормирование(ТекущаяДата, Склад, ПараметрыКасс);

			Если СтатусФормирование.Статус <> "Пройден" Тогда
				Возврат ТекущаяДата;
			КонецЕсли;

			СтатусОстатки = СтатусШагаОстатки(ТекущаяДата, Склад);

			Если СтатусОстатки.Статус <> "Пройден" Тогда
				Возврат ТекущаяДата;
			КонецЕсли;
		КонецЦикла;

		ТекущаяДата = ТекущаяДата + СекундВСутках;
	КонецЦикла;

	Возврат Дата(1, 1, 1); // все дни закрыты

КонецФункции

// Рассчитывает рекомендуемый день в фоне.
//
// Параметры:
//  МассивСкладов  - Массив из СправочникСсылка.Склады - выбранные склады
//  ПараметрыКасс  - ТаблицаЗначений, Неопределено - выбранные кассы
//  АдресРезультата - Строка - адрес временного хранилища результата
//
Процедура РекомендуемыйДеньВФоне(МассивСкладов, ПараметрыКасс, АдресРезультата) Экспорт

	Результат = РекомендуемыйДень(МассивСкладов, ПараметрыКасс);
	ПоместитьВоВременноеХранилище(Результат, АдресРезультата);

КонецПроцедуры

// Формирует СКД-отчет «ПЛ_СверкаПродажСЧеками» по выбранному дню и складам.
//
// Параметры:
//  День          - Дата - выбранный день отработки
//  МассивСкладов - Массив из СправочникСсылка.Склады - выбранные склады
//
// Возвращаемое значение:
//  ТабличныйДокумент - отчет сверки продаж с чеками
//
Функция СформироватьОтчетСверкиЧеков(День, МассивСкладов) Экспорт

	СхемаКомпоновкиДанных = Отчеты.ПЛ_СверкаПродажСЧеками.ПолучитьМакет("ОсновнаяСхемаКомпоновкиДанных");
	Настройки = СхемаКомпоновкиДанных.НастройкиПоУмолчанию;

	НастроитьВыводСКДБезСлужебнойШапки(Настройки);
	УстановитьПараметрСКД(Настройки, "Период", СтандартныйПериодДня(День));
	ДобавитьОтборСКД(Настройки, "Склад", МассивСкладов, ВидСравненияКомпоновкиДанных.ВСписке);

	РезультатОтчета = СформироватьТабличныйДокументСКД(СхемаКомпоновкиДанных, Настройки);
	ОформитьТабличныйДокументОтчета(РезультатОтчета.Отчет);
	УстановитьШириныОтчетаСверкиЧеков(РезультатОтчета.Отчет);

	Возврат РезультатОтчета.Отчет;

КонецФункции

// Формирует табличный отчет сверки чеков с документами выпуска по выбранным складам.
//
// Параметры:
//  День          - Дата - выбранный день отработки
//  МассивСкладов - Массив из СправочникСсылка.Склады - выбранные склады
//  ПараметрыКасс - ТаблицаЗначений, Неопределено - выбранные кассы
//
// Возвращаемое значение:
//  ТабличныйДокумент - отчет с отклонениями сверки выпусков
//
Функция СформироватьОтчетСверкиВыпусков(День, МассивСкладов, ПараметрыКасс = Неопределено) Экспорт

	ТаблицаОтчета = НоваяТаблицаОтчетаСверкиВыпусков();
	РезультатФормирования = СтатусШагаФормированиеПоСкладам(День, МассивСкладов, ПараметрыКасс);
	ДобавитьСтрокиТаблицыЗначений(ТаблицаОтчета, РезультатФормирования.ОтклоненияВыпуска);

	Если ТаблицаОтчета.Количество() > 0 Тогда
		ТаблицаОтчета.Сортировать("Блокирует Убыв, Склад, Номенклатура, Характеристика");
	КонецЕсли;

	Заголовок = СтрШаблон(
		"Сверка чеков с выпусками за %1",
		Формат(День, "ДФ=dd.MM.yyyy"));

	Возврат СформироватьТабличныйОтчетПоТаблице(Заголовок, ТаблицаОтчета);

КонецФункции

// Формирует СКД-ведомость по товарам на складах с отрицательными остатками.
//
// Параметры:
//  День                       - Дата - выбранный день отработки
//  МассивСкладов              - Массив из СправочникСсылка.Склады - выбранные склады
//  УникальныйИдентификаторФормы - УникальныйИдентификатор - идентификатор формы
//
// Возвращаемое значение:
//  Структура:
//   * Отчет                   - ТабличныйДокумент
//   * АдресДанныхРасшифровки  - Строка
//
Функция СформироватьВедомостьОтрицательныхОстатков(
	День,
	МассивСкладов,
	УникальныйИдентификаторФормы) Экспорт

	СхемаКомпоновкиДанных = Отчеты.ВедомостьПоТоварамНаСкладах.ПолучитьМакет("ОсновнаяСхемаКомпоновкиДанных");
	Настройки = СхемаКомпоновкиДанных.НастройкиПоУмолчанию;

	НастроитьВыводСКДБезСлужебнойШапки(Настройки);
	УстановитьПараметрСКД(Настройки, "Период", СтандартныйПериодДня(День));
	ДобавитьОтборСКД(Настройки, "Склад", МассивСкладов, ВидСравненияКомпоновкиДанных.ВСписке);
	ДобавитьОтборСКД(Настройки, "КонечныйОстаток", 0, ВидСравненияКомпоновкиДанных.Меньше);

	Возврат СформироватьТабличныйДокументСКД(
		СхемаКомпоновкиДанных,
		Настройки,
		Неопределено,
		УникальныйИдентификаторФормы);

КонецФункции

// Формирует анализ отрицательных остатков по выбранным складам.
//
// Параметры:
//  День          - Дата - выбранный день отработки
//  МассивСкладов - Массив из СправочникСсылка.Склады - выбранные склады
//  Номенклатура  - СправочникСсылка.Номенклатура, Неопределено - отбор для расшифровки
//
// Возвращаемое значение:
//  ТабличныйДокумент - результат анализа отрицательных остатков
//
Функция СформироватьАнализОтрицательныхОстатков(
	День,
	МассивСкладов,
	Номенклатура = Неопределено) Экспорт

	ТабличныйДокумент = Новый ТабличныйДокумент;

	Если МассивСкладов.Количество() = 0 Тогда
		ТабличныйДокумент.Область(1, 1).Текст = НСтр("ru = 'Не выбраны склады для анализа.'");
		Возврат ТабличныйДокумент;
	КонецЕсли;

	Запрос = Новый Запрос;
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ТоварыНаСкладахОстаткиИОбороты.Склад КАК Склад,
	|	ТоварыНаСкладахОстаткиИОбороты.Номенклатура КАК Номенклатура,
	|	ТоварыНаСкладахОстаткиИОбороты.Характеристика КАК Характеристика,
	|	ТоварыНаСкладахОстаткиИОбороты.ВНаличииКонечныйОстаток КАК КонечныйОстаток
	|ИЗ
	|	РегистрНакопления.ТоварыНаСкладах.ОстаткиИОбороты(
	|		,
	|		&КонецПериода,
	|		Регистратор,
	|		,
	|		Склад В (&МассивСкладов)) КАК ТоварыНаСкладахОстаткиИОбороты
	|ГДЕ
	|	ТоварыНаСкладахОстаткиИОбороты.ВНаличииКонечныйОстаток < 0";

	Если ЗначениеЗаполнено(Номенклатура) Тогда
		ТекстЗапроса = ТекстЗапроса + "
		|	И ТоварыНаСкладахОстаткиИОбороты.Номенклатура = &Номенклатура";
		Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	КонецЕсли;

	Запрос.Текст = ТекстЗапроса;

	Запрос.УстановитьПараметр("КонецПериода", КонецДня(День));
	Запрос.УстановитьПараметр("МассивСкладов", МассивСкладов);

	РезультатЗапроса = Запрос.Выполнить();

	Анализ = Новый АнализДанных;
	Анализ.ТипАнализа = Тип("АнализДанныхОбщаяСтатистика");
	Анализ.ИсточникДанных = РезультатЗапроса;

	РезультатАнализа = Анализ.Выполнить();

	Построитель = Новый ПостроительОтчетаАнализаДанных;
	Построитель.ТипАнализа = Тип("АнализДанныхОбщаяСтатистика");
	Построитель.Макет = Неопределено;
	Построитель.Вывести(РезультатАнализа, ТабличныйДокумент);

	Возврат ТабличныйДокумент;

КонецФункции

// Вычисляет статус шага помощника в фоне и помещает результат во временное хранилище.
//
// Параметры:
//  ПараметрыСтатуса - Структура:
//   * ТекущаяСтраница - Строка
//   * ВыбранныйДень   - Дата
//   * МассивСкладов   - Массив из СправочникСсылка.Склады
//   * ТекущийСклад    - СправочникСсылка.Склады
//   * ПараметрыКасс   - ТаблицаЗначений
//  АдресРезультата - Строка - адрес во временном хранилище
//
Процедура СтатусШагаВФоне(ПараметрыСтатуса, АдресРезультата) Экспорт

	ТекущаяСтраница = ПараметрыСтатуса.ТекущаяСтраница;
	День            = ПараметрыСтатуса.ВыбранныйДень;
	МассивСкладов   = ПараметрыСтатуса.МассивСкладов;
	ТекущийСклад    = ПараметрыСтатуса.ТекущийСклад;
	ПараметрыКасс   = ПараметрыСтатуса.ПараметрыКасс;

	Если НЕ ЗначениеЗаполнено(ТекущийСклад) И МассивСкладов.Количество() > 0 Тогда
		ТекущийСклад = МассивСкладов[0];
	КонецЕсли;

	РезультатФона = Новый Структура;
	РезультатФона.Вставить("ТекущаяСтраница", ТекущаяСтраница);
	РезультатФона.Вставить("Результат", Неопределено);
	РезультатФона.Вставить("ОбщийСтатус", "");

	Если ТекущаяСтраница = "СтраницаСопоставления" Тогда

		РезультатФона.Результат = СтатусШагаСопоставление(День, МассивСкладов);
		РезультатФона.ОбщийСтатус = РезультатФона.Результат.Статус;

	ИначеЕсли ТекущаяСтраница = "СтраницаСверка" Тогда

		РезультатФона.Результат = СтатусШагаСверка(День, МассивСкладов, ПараметрыКасс);
		РезультатФона.ОбщийСтатус = РезультатФона.Результат.Статус;

	ИначеЕсли ТекущаяСтраница = "СтраницаФормирование" Тогда

		РезультатФона.Результат = СтатусШагаФормированиеПоСкладам(День, МассивСкладов, ПараметрыКасс);
		РезультатФона.ОбщийСтатус = РезультатФона.Результат.Статус;

	ИначеЕсли ТекущаяСтраница = "СтраницаОстатки" Тогда

		РезультатФона.Результат = СтатусШагаОстатки(День, ТекущийСклад);
		РезультатФона.ОбщийСтатус = ОбщийСтатусОстатков(День, МассивСкладов);

	КонецЕсли;

	ПоместитьВоВременноеХранилище(РезультатФона, АдресРезультата);

КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Формирует построчную таблицу отклонений сверки чеков между данными фронта и 1С.
// Вызывает live-запросы к Oracle через MRS_МенеджерОбменаTNG/Micros.
//
// Параметры:
//  День           - Дата
//  МассивСкладов  - Массив из СправочникСсылка.Склады
//  ПараметрыКасс  - ТаблицаЗначений, Неопределено - выбранные кассы
//
// Возвращаемое значение:
//  ТаблицаЗначений с колонками:
//   - ФронтСистема, НомерЧека, КодТочкиПродаж, Номенклатура,
//   - СуммаПоФронту, СуммаПоЧеку1С, ОтклонениеСуммы,
//   - СкидкаПоФронту, СкидкаПоЧеку1С, ОтклонениеСкидки,
//   - КатегорияОтклонения (Строка: «Сумма», «Скидка», «АлкогольМарка», «СуммаИСкидка»)
//
Функция ПолучитьОтклоненияСверки(День, МассивСкладов, ПараметрыКасс = Неопределено) Экспорт

	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("ФронтСистема");
	Результат.Колонки.Добавить("НомерЧека");
	Результат.Колонки.Добавить("КодТочкиПродаж");
	Результат.Колонки.Добавить("Номенклатура");
	Результат.Колонки.Добавить("СуммаПоФронту");
	Результат.Колонки.Добавить("СуммаПоЧеку1С");
	Результат.Колонки.Добавить("ОтклонениеСуммы");
	Результат.Колонки.Добавить("СкидкаПоФронту");
	Результат.Колонки.Добавить("СкидкаПоЧеку1С");
	Результат.Колонки.Добавить("ОтклонениеСкидки");
	Результат.Колонки.Добавить("КатегорияОтклонения");

	НачалоДня = НачалоДня(День);
	КонецДня  = КонецДня(День);
	ПараметрыКассTNG = ПараметрыКассДляФронтСистемы(
		ПараметрыКасс,
		Перечисления.ПЛ_ТипыФронтСистем.TNG);
	ПараметрыКассMicros = ПараметрыКассДляФронтСистемы(
		ПараметрыКасс,
		Перечисления.ПЛ_ТипыФронтСистем.Micros);

	// Обработка TNG
	Если ПараметрыКассTNG.Количество() > 0 Тогда
		Попытка
			ТаблицаTNG = MRS_МенеджерОбменаTNG.ВыполнитьПолучениеДанныхTNG(
				Перечисления.ПЛ_ТипыФронтСистем.TNG,
				НачалоДня,
				КонецДня,
				ПараметрыКассTNG,
				Неопределено);

			Если ТаблицаTNG <> Неопределено Тогда
				ОбработатьСтрокиСверки(Результат, ТаблицаTNG, "TNG");
			КонецЕсли;
		Исключение
			ЗаписьЖурналаРегистрации(
				НСтр("ru = 'MRS.ПомощникЗакрытияСмены.Сверка.ОшибкаTNG'"),
				УровеньЖурналаРегистрации.Ошибка,
				,
				,
				ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		КонецПопытки;
	КонецЕсли;

	// Обработка Micros
	Если ПараметрыКассMicros.Количество() > 0 Тогда
		Попытка
			ТаблицаMicros = MRS_МенеджерОбменаMicros.ВыполнитьПолучениеДанныхMicros(
				Перечисления.ПЛ_ТипыФронтСистем.Micros,
				НачалоДня,
				КонецДня,
				ПараметрыКассMicros,
				Неопределено);

			Если ТаблицаMicros <> Неопределено Тогда
				ОбработатьСтрокиСверки(Результат, ТаблицаMicros, "Micros");
			КонецЕсли;
		Исключение
			ЗаписьЖурналаРегистрации(
				НСтр("ru = 'MRS.ПомощникЗакрытияСмены.Сверка.ОшибкаMicros'"),
				УровеньЖурналаРегистрации.Ошибка,
				,
				,
				ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		КонецПопытки;
	КонецЕсли;

	Возврат Результат;

КонецФункции

// Проверяет, загружены ли все чеки за день для указанного склада.
// Сравнивает множество номеров чеков фронта с загруженными в 1С.
//
// Параметры:
//  День          - Дата
//  Склад         - СправочникСсылка.Склады
//  ПараметрыКасс - ТаблицаЗначений, Неопределено - выбранные кассы
//
// Возвращаемое значение:
//  Булево - Истина, если все чеки фронта присутствуют среди загруженных
//
Функция ЧекиЗагруженыПолностью(День, Склад, ПараметрыКасс = Неопределено) Экспорт

	НачалоДня = НачалоДня(День);
	КонецДня  = КонецДня(День);
	КассыККМ = КассыККМИзПараметров(ПараметрыКасс);
	Если КассыККМ.Количество() = 0 Тогда
		Возврат Ложь;
	КонецЕсли;

	ПараметрыКассTNG = ПараметрыКассДляФронтСистемы(
		ПараметрыКасс,
		Перечисления.ПЛ_ТипыФронтСистем.TNG);
	ПараметрыКассMicros = ПараметрыКассДляФронтСистемы(
		ПараметрыКасс,
		Перечисления.ПЛ_ТипыФронтСистем.Micros);

	// Собираем номера чеков из загруженных документов
	ЗапросЗагруженныхЧеков = Новый Запрос;
	ЗапросЗагруженныхЧеков.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	Чек.НомерЧека КАК НомерЧека
	|ИЗ
	|	Документ.питДанныеПродажФронта КАК Чек
	|ГДЕ
	|	Чек.Дата МЕЖДУ &НачалоДня И &КонецДня
	|	И Чек.Склад = &Склад
	|	И Чек.КассаККМ В (&КассыККМ)
	|	И НЕ Чек.ПометкаУдаления";

	ЗапросЗагруженныхЧеков.УстановитьПараметр("НачалоДня", НачалоДня);
	ЗапросЗагруженныхЧеков.УстановитьПараметр("КонецДня",  КонецДня);
	ЗапросЗагруженныхЧеков.УстановитьПараметр("Склад",     Склад);
	ЗапросЗагруженныхЧеков.УстановитьПараметр("КассыККМ",  КассыККМ);

	РезультатЗапроса = ЗапросЗагруженныхЧеков.Выполнить();
	ВыборкаЗагруженныхЧеков = РезультатЗапроса.Выбрать();

	НомераЗагруженныхЧеков = Новый Соответствие;
	Пока ВыборкаЗагруженныхЧеков.Следующий() Цикл
		НомераЗагруженныхЧеков.Вставить(ВыборкаЗагруженныхЧеков.НомерЧека, Истина);
	КонецЦикла;

	Если НомераЗагруженныхЧеков.Количество() = 0 Тогда
		Возврат Ложь; // нет загруженных чеков вообще
	КонецЕсли;

	// Получаем данные фронта и сравниваем номера чеков
	Если ПараметрыКассTNG.Количество() > 0 Тогда
		Попытка
			ТаблицаФронта = MRS_МенеджерОбменаTNG.ВыполнитьПолучениеДанныхTNG(
				Перечисления.ПЛ_ТипыФронтСистем.TNG,
				НачалоДня,
				КонецДня,
				ПараметрыКассTNG,
				Неопределено);

			Если ТаблицаФронта = Неопределено
				ИЛИ НЕ ВсеЧекиФронтаЗагружены(ТаблицаФронта, НомераЗагруженныхЧеков) Тогда

				Возврат Ложь;
			КонецЕсли;
		Исключение
			ЗаписьЖурналаРегистрации(
				НСтр("ru = 'MRS.ПомощникЗакрытияСмены.ПолнотаЗагрузки.Ошибка'"),
				УровеньЖурналаРегистрации.Предупреждение,
				,
				,
				ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			Возврат Ложь;
		КонецПопытки;
	КонецЕсли;

	Если ПараметрыКассMicros.Количество() > 0 Тогда
		Попытка
			ТаблицаФронта = MRS_МенеджерОбменаMicros.ВыполнитьПолучениеДанныхMicros(
				Перечисления.ПЛ_ТипыФронтСистем.Micros,
				НачалоДня,
				КонецДня,
				ПараметрыКассMicros,
				Неопределено);

			Если ТаблицаФронта = Неопределено
				ИЛИ НЕ ВсеЧекиФронтаЗагружены(ТаблицаФронта, НомераЗагруженныхЧеков) Тогда

				Возврат Ложь;
			КонецЕсли;
		Исключение
			ЗаписьЖурналаРегистрации(
				НСтр("ru = 'MRS.ПомощникЗакрытияСмены.ПолнотаЗагрузки.Ошибка'"),
				УровеньЖурналаРегистрации.Предупреждение,
				,
				,
				ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			Возврат Ложь;
		КонецПопытки;
	КонецЕсли;

	Возврат Истина;

КонецФункции

// Проверяет, что каждый чек фронта есть среди загруженных чеков 1С.
//
// Параметры:
//  ТаблицаФронта          - ТаблицаЗначений - данные фронта
//  НомераЗагруженныхЧеков - Соответствие - номера чеков 1С
//
// Возвращаемое значение:
//  Булево - Истина, если отсутствующих чеков нет
//
Функция ВсеЧекиФронтаЗагружены(ТаблицаФронта, НомераЗагруженныхЧеков)

	Для Каждого СтрокаФронта Из ТаблицаФронта Цикл
		
		Если СтрокаФронта.СУММАЧЕКАORACLE = 0 и СтрокаФронта.СУММАСКИДКИORACLE = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		НомерЧека = СтрокаФронта.НОМЕРЧЕКАORACLE;
		Если ЗначениеЗаполнено(НомерЧека)
			И НомераЗагруженныхЧеков.Получить(НомерЧека) = Неопределено Тогда

			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;

	Возврат Истина;

КонецФункции

// Помечает чеки к пересозданию приёмника - эквивалент паттерна
// УстановитьВозможностьЗагрузкиНаСервере из Forms/ВозможностьЗагрузкиДПФ.
// Выполняет Записать() для документов питДанныеПродажФронта,
// у которых ОбновленПриемник ≠ Истина в указанных день+склад.
//
// Параметры:
//  День   - Дата
//  Склад  - СправочникСсылка.Склады
//
Процедура ПометитьЧекиКПересозданию(День, Склад) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	УчетДанныхПродаж.ДокументРегистратор КАК Документ
		|ИЗ
		|	РегистрСведений.питУчетДанныхПродаж КАК УчетДанныхПродаж
		|ГДЕ
		|	УчетДанныхПродаж.Дата = &День
		|	И УчетДанныхПродаж.КассовыйУзел.СкладПриготовления = &Склад";

	Запрос.УстановитьПараметр("День",  День);
	Запрос.УстановитьПараметр("Склад", Склад);

	Выборка = Запрос.Выполнить().Выбрать();

	Пока Выборка.Следующий() Цикл
		// Паттерн из УстановитьВозможностьЗагрузкиНаСервере (ВозможностьЗагрузкиДПФ):
		// запись одиночных документов в цикле с индивидуальной обработкой ошибок
		Попытка
			ДокументОбъект = Выборка.Документ.ПолучитьОбъект();
			ДокументОбъект.Записать();
		Исключение
			ЗаписьЖурналаРегистрации(
				НСтр("ru = 'MRS.ПомощникЗакрытияСмены.ПометкаЧеков.Ошибка'"),
				УровеньЖурналаРегистрации.Ошибка,
				,
				Выборка.Документ,
				ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		КонецПопытки;
	КонецЦикла;

КонецПроцедуры

// Заполняет реквизиты обработки питЗагрузкаИзДанныхПродажФронта
// значениями по умолчанию и ограничивает отбор выбранным днём и складом.
//
// Параметры:
//  Обработка - ОбработкаОбъект.питЗагрузкаИзДанныхПродажФронта
//  День      - Дата
//  Склад     - СправочникСсылка.Склады
//
Процедура ЗаполнитьПараметрыЗагрузкиОбработки(Обработка, День, Склад) Экспорт

	// Воспроизводим дефолты Инициализация() формы питЗагрузкаИзДанныхПродажФронта
	Обработка.ДатаЦелевыхДокументов      = 1;
	Обработка.ГруппироватьПоНомеруСмены  = Истина;
	Обработка.ПереходящаяСмена           = Истина;
	Обработка.ДнейВпередДляАнализаПерехода = 1;
	Обработка.ДнейНазадДляАнализаПерехода  = 1;

	// Ограничиваем отбор строго выбранным днём
	Обработка.ДатаНачалаОтбора = День;
	Обработка.ДатаКонцаОтбора  = День;

	// Заполняем ТЧ ПараметрыКасс только кассами выбранного склада
	ЗапросКасс = Новый Запрос;
	ЗапросКасс.Текст =
	"ВЫБРАТЬ
	|	КассыККМ.Ссылка КАК Касса
	|ИЗ
	|	Справочник.КассыККМ КАК КассыККМ
	|ГДЕ
	|	КассыККМ.питКассовыйУзел.СкладПриготовления = &Склад";

	ЗапросКасс.УстановитьПараметр("Склад", Склад);

	ВыборкаКасс = ЗапросКасс.Выполнить().Выбрать();

	Пока ВыборкаКасс.Следующий() Цикл
		НоваяСтрока = Обработка.ПараметрыКасс.Добавить();
		НоваяСтрока.КассаККМ 										= ВыборкаКасс.Касса;
		НоваяСтрока.СкладПриготовления 								= Склад;
		НоваяСтрока.СкладРеализации 								= Склад;
		НоваяСтрока.Использовать 									= Истина;
		НоваяСтрока.ДанныеМодифицированы 							= Истина;
		НоваяСтрока.ЗагружатьТоварыВВыпускСПеремещением				= Ложь;
		НоваяСтрока.ЗагрузкаДанныхПродажВПроизводственныеДокументы	= Истина;
		НоваяСтрока.ЗапретитьПовторнуюЗагрузкуДанныхПродаж 			= Ложь;
		НоваяСтрока.ОрганизацияКассовогоУзла 						= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Склад, "ПЛ_Организация");
		НоваяСтрока.ОрганизацияЦелевыхДокументовИзКассыККМ 			= Ложь;
		НоваяСтрока.ОформлятьДокументыЕГАИС 						= Ложь;
		НоваяСтрока.ОформлятьДокументыИСМП  						= Ложь;
		НоваяСтрока.ПодразделениеКассовогоУзла 						= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Склад, "Подразделение");
		НоваяСтрока.ПроводитьЗагружаемыеДокументы 					= Истина;
		НоваяСтрока.РазрешитьНедовложения 							= Ложь;
		НоваяСтрока.СпособОпределенияСкладаПриготовления			= 0;
		НоваяСтрока.СпособОпределенияСкладаРеализации				= 0;
		НоваяСтрока.УменьшатьСуммыТоваровНаСуммуБонусов				= Ложь;
		НоваяСтрока.УчитыватьВозвратыПриЗагрузкеПродаж				= Истина; 
		НоваяСтрока.УчитыватьОстаткиБлюдНаСкладе 					= Ложь;
	КонецЦикла;
	
КонецПроцедуры

// Формирует таблицу отклонений между агрегатами по чекам и по проведённым
// документам питВыпускБлюд для выбранного дня и склада.
//
// Параметры:
//  День   - Дата
//  Склад  - СправочникСсылка.Склады
//
// Возвращаемое значение:
//  ТаблицаЗначений с колонками:
//   - Номенклатура, Характеристика, Склад,
//   - КоличествоПоЧекам, КоличествоПоВыпуску, Разница,
//   - Блокирует (Булево - Истина при Разница < 0)
//
Функция ПолучитьОтклоненияВыпуска(День, Склад, ПараметрыКасс = Неопределено) Экспорт

	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("Номенклатура");
	Результат.Колонки.Добавить("Характеристика");
	Результат.Колонки.Добавить("Склад");
	Результат.Колонки.Добавить("КоличествоПоЧекам", Новый ОписаниеТипов("Число"));
	Результат.Колонки.Добавить("КоличествоПоВыпуску", Новый ОписаниеТипов("Число"));
	Результат.Колонки.Добавить("Разница", Новый ОписаниеТипов("Число"));
	Результат.Колонки.Добавить("Блокирует", Новый ОписаниеТипов("Булево"));

	НачалоДня = НачалоДня(День);
	КонецДня  = КонецДня(День);
	КассыККМ = КассыККМИзПараметров(ПараметрыКасс);
	Если КассыККМ.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ТоварыЧеков.Номенклатура КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА ТоварыЧеков.Номенклатура.питПродажаПоСвободнойЦене
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)
	|		ИНАЧЕ ТоварыЧеков.Характеристика
	|	КОНЕЦ КАК Характеристика,
	|	ТоварыЧеков.Ссылка.Склад КАК Склад,
	|	СУММА(ТоварыЧеков.Количество
	|		* ВЫБОР
	|			КОГДА ТоварыЧеков.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.питХозяйственныеОперации.ДанныеПродажФронтаВозврат)
	|				ТОГДА -1
	|			ИНАЧЕ 1
	|		КОНЕЦ
	|		* ВЫБОР
	|			КОГДА ЕСТЬNULL(Соответствие.Количество, 0) = 0
	|				ТОГДА 1
	|			ИНАЧЕ Соответствие.Количество
	|		КОНЕЦ) КАК КоличествоПоЧекам
	|ПОМЕСТИТЬ ОжидаетсяПоЧекам
	|ИЗ
	|	Документ.питДанныеПродажФронта.Товары КАК ТоварыЧеков
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПЛ_СоответствиеСФронтСистемами КАК СоответствиеКассы
	|		ПО СоответствиеКассы.ТипОбъекта = &ТипКасса
	|			И СоответствиеКассы.Код = ТоварыЧеков.Ссылка.ПЛ_КодТочкиПродажи
	|			И СоответствиеКассы.Объект = ТоварыЧеков.Ссылка.КассаККМ
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПЛ_СоответствиеСФронтСистемами КАК Соответствие
	|		ПО Соответствие.ТипОбъекта = &ТипНоменклатура
	|			И Соответствие.ФронтСистема = СоответствиеКассы.ФронтСистема
	|			И Соответствие.Код = ТоварыЧеков.ПЛ_КодКнопки
	|ГДЕ
	|	ТоварыЧеков.Ссылка.Дата МЕЖДУ &НачалоДня И &КонецДня
	|	И ТоварыЧеков.Ссылка.Склад = &Склад
	|	И ТоварыЧеков.Ссылка.КассаККМ В (&КассыККМ)
	|	И НЕ ТоварыЧеков.Ссылка.ПометкаУдаления
	|СГРУППИРОВАТЬ ПО
	|	ТоварыЧеков.Номенклатура,
	|	ВЫБОР
	|		КОГДА ТоварыЧеков.Номенклатура.питПродажаПоСвободнойЦене
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)
	|		ИНАЧЕ ТоварыЧеков.Характеристика
	|	КОНЕЦ,
	|	ТоварыЧеков.Ссылка.Склад
	|
	|ИНДЕКСИРОВАТЬ ПО Номенклатура, Характеристика, Склад
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ТоварыВыпуска.Номенклатура КАК Номенклатура,
	|	ТоварыВыпуска.Характеристика КАК Характеристика,
	|	ТоварыВыпуска.Ссылка.Склад КАК Склад,
	|	СУММА(ТоварыВыпуска.Количество) КАК КоличествоПоВыпуску
	|ПОМЕСТИТЬ ФактПоВыпускам
	|ИЗ
	|	Документ.питВыпускБлюд.Товары КАК ТоварыВыпуска
	|ГДЕ
	|	ТоварыВыпуска.Ссылка.Дата МЕЖДУ &НачалоДня И &КонецДня
	|	И ТоварыВыпуска.Ссылка.Склад = &Склад
	|	И ТоварыВыпуска.Ссылка.Проведен
	|	И НЕ ТоварыВыпуска.Ссылка.ПометкаУдаления
	|СГРУППИРОВАТЬ ПО
	|	ТоварыВыпуска.Номенклатура,
	|	ТоварыВыпуска.Характеристика,
	|	ТоварыВыпуска.Ссылка.Склад
	|
	|ИНДЕКСИРОВАТЬ ПО Номенклатура, Характеристика, Склад
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЕСТЬNULL(ОжидаетсяПоЧекам.Номенклатура, ФактПоВыпускам.Номенклатура) КАК Номенклатура,
	|	ЕСТЬNULL(ОжидаетсяПоЧекам.Характеристика, ФактПоВыпускам.Характеристика) КАК Характеристика,
	|	ЕСТЬNULL(ОжидаетсяПоЧекам.Склад, ФактПоВыпускам.Склад) КАК Склад,
	|	ЕСТЬNULL(ОжидаетсяПоЧекам.КоличествоПоЧекам, 0) КАК КоличествоПоЧекам,
	|	ЕСТЬNULL(ФактПоВыпускам.КоличествоПоВыпуску, 0) КАК КоличествоПоВыпуску,
	|	ЕСТЬNULL(ФактПоВыпускам.КоличествоПоВыпуску, 0) - ЕСТЬNULL(ОжидаетсяПоЧекам.КоличествоПоЧекам, 0) КАК Разница
	|ИЗ
	|	ОжидаетсяПоЧекам КАК ОжидаетсяПоЧекам
	|		ПОЛНОЕ СОЕДИНЕНИЕ ФактПоВыпускам КАК ФактПоВыпускам
	|		ПО ОжидаетсяПоЧекам.Номенклатура = ФактПоВыпускам.Номенклатура
	|		И ОжидаетсяПоЧекам.Характеристика = ФактПоВыпускам.Характеристика
	|		И ОжидаетсяПоЧекам.Склад = ФактПоВыпускам.Склад
	|ГДЕ
	|	ЕСТЬNULL(ФактПоВыпускам.КоличествоПоВыпуску, 0) - ЕСТЬNULL(ОжидаетсяПоЧекам.КоличествоПоЧекам, 0) <> 0";

	Запрос.УстановитьПараметр("НачалоДня", НачалоДня);
	Запрос.УстановитьПараметр("КонецДня",  КонецДня);
	Запрос.УстановитьПараметр("Склад",     Склад);
	Запрос.УстановитьПараметр("КассыККМ",  КассыККМ);
	Запрос.УстановитьПараметр("ТипКасса",
		ПланыВидовХарактеристик.ПЛ_ТипыОбъектовФронтСистем.КассаККМ);
	Запрос.УстановитьПараметр("ТипНоменклатура",
		ПланыВидовХарактеристик.ПЛ_ТипыОбъектовФронтСистем.Номенклатура);

	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();

	Пока Выборка.Следующий() Цикл
		НоваяСтрока = Результат.Добавить();
		НоваяСтрока.Номенклатура        = Выборка.Номенклатура;
		НоваяСтрока.Характеристика      = Выборка.Характеристика;
		НоваяСтрока.Склад               = Выборка.Склад;
		НоваяСтрока.КоличествоПоЧекам   = Выборка.КоличествоПоЧекам;
		НоваяСтрока.КоличествоПоВыпуску = Выборка.КоличествоПоВыпуску;
		НоваяСтрока.Разница             = Выборка.Разница;
		НоваяСтрока.Блокирует           = Выборка.Разница < 0;
	КонецЦикла;

	Возврат Результат;

КонецФункции

// Классифицирует сообщения об ошибках, полученные после формирования документов.
// Категории: нехватка марок/акта, нехватка ингредиентов,
// отрицательные остатки после выпуска, прочие.
//
// Параметры:
//  День   - Дата
//  Склад  - СправочникСсылка.Склады
//
// Возвращаемое значение:
//  ТаблицаЗначений с колонками: Категория, ТекстОшибки
//
Функция ПолучитьОшибкиФормирования(День, Склад) Экспорт

	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("Категория");
	Результат.Колонки.Добавить("ТекстОшибки");

	// Проверяем сформированные документы питВыпускБлюд за день/склад
	НачалоДня = НачалоДня(День);
	КонецДня  = КонецДня(День);

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВыпускБлюд.Ссылка КАК Документ
	|ИЗ
	|	Документ.питВыпускБлюд КАК ВыпускБлюд
	|ГДЕ
	|	ВыпускБлюд.Дата МЕЖДУ &НачалоДня И &КонецДня
	|	И ВыпускБлюд.Склад = &Склад
	|	И НЕ ВыпускБлюд.Проведен
	|	И НЕ ВыпускБлюд.ПометкаУдаления";

	Запрос.УстановитьПараметр("НачалоДня", НачалоДня);
	Запрос.УстановитьПараметр("КонецДня",  КонецДня);
	Запрос.УстановитьПараметр("Склад",     Склад);

	Выборка = Запрос.Выполнить().Выбрать();

	Пока Выборка.Следующий() Цикл
		// Классифицируем ошибки по тексту (уточняется на реальных данных)
		// Для каждого непроведённого документа пытаемся определить причину
		НоваяСтрока = Результат.Добавить();
		НоваяСтрока.Категория   = "Прочие";
		НоваяСтрока.ТекстОшибки = СтрШаблон("Документ %1 не проведён", Выборка.Документ);
	КонецЦикла;

	Возврат Результат;

КонецФункции

// Возвращает список документов питВыпускБлюд по «открытым ценам»
// (с заполненным ПЛ_Номенклатура), которые не проведены.
//
// Параметры:
//  День   - Дата
//  Склад  - СправочникСсылка.Склады
//
// Возвращаемое значение:
//  ТаблицаЗначений с колонками: Документ, НоменклатураОткрытойЦены
//
Функция ПолучитьДокументыОткрытыеЦены(День, Склад) Экспорт

	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("Документ");
	Результат.Колонки.Добавить("НоменклатураОткрытойЦены");

	НачалоДня = НачалоДня(День);
	КонецДня  = КонецДня(День);

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВыпускБлюд.Ссылка         КАК Документ,
	|	ВыпускБлюд.ПЛ_Номенклатура КАК НоменклатураОткрытойЦены
	|ИЗ
	|	Документ.питВыпускБлюд КАК ВыпускБлюд
	|ГДЕ
	|	ВыпускБлюд.Дата МЕЖДУ &НачалоДня И &КонецДня
	|	И ВыпускБлюд.Склад = &Склад
	|	И ВыпускБлюд.ПЛ_Номенклатура <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|	И НЕ ВыпускБлюд.Проведен
	|	И НЕ ВыпускБлюд.ПометкаУдаления";

	Запрос.УстановитьПараметр("НачалоДня", НачалоДня);
	Запрос.УстановитьПараметр("КонецДня",  КонецДня);
	Запрос.УстановитьПараметр("Склад",     Склад);

	Выборка = Запрос.Выполнить().Выбрать();

	Пока Выборка.Следующий() Цикл
		НоваяСтрока = Результат.Добавить();
		НоваяСтрока.Документ                 = Выборка.Документ;
		НоваяСтрока.НоменклатураОткрытойЦены = Выборка.НоменклатураОткрытойЦены;
	КонецЦикла;

	Возврат Результат;

КонецФункции

// Возвращает строки отрицательных остатков по регистру ТоварыНаСкладах
// для выбранного дня и склада.
//
// Параметры:
//  День   - Дата
//  Склад  - СправочникСсылка.Склады
//
// Возвращаемое значение:
//  ТаблицаЗначений с колонками: Склад, Номенклатура, Характеристика, КонечныйОстаток
//
Функция ПолучитьОтрицательныеОстатки(День, Склад) Экспорт

	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("Склад");
	Результат.Колонки.Добавить("Номенклатура");
	Результат.Колонки.Добавить("Характеристика");
	Результат.Колонки.Добавить("КонечныйОстаток", Новый ОписаниеТипов("Число"));

	МассивСкладов = Новый Массив;
	МассивСкладов.Добавить(Склад);

	КонецПериода = КонецДня(День);

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТоварыНаСкладахОстаткиИОбороты.Склад             КАК Склад,
	|	ТоварыНаСкладахОстаткиИОбороты.Номенклатура        КАК Номенклатура,
	|	ТоварыНаСкладахОстаткиИОбороты.Характеристика      КАК Характеристика,
	|	ТоварыНаСкладахОстаткиИОбороты.ВНаличииКонечныйОстаток КАК КонечныйОстаток
	|ИЗ
	|	РегистрНакопления.ТоварыНаСкладах.ОстаткиИОбороты(
	|		,
	|		&КонецПериода,
	|		Регистратор,
	|		,
	|		Склад В (&МассивСкладов)) КАК ТоварыНаСкладахОстаткиИОбороты
	|ГДЕ
	|	ТоварыНаСкладахОстаткиИОбороты.ВНаличииКонечныйОстаток < 0";

	Запрос.УстановитьПараметр("КонецПериода",  КонецПериода);
	Запрос.УстановитьПараметр("МассивСкладов", МассивСкладов);

	Выборка = Запрос.Выполнить().Выбрать();

	Пока Выборка.Следующий() Цикл
		НоваяСтрока = Результат.Добавить();
		НоваяСтрока.Склад          = Выборка.Склад;
		НоваяСтрока.Номенклатура   = Выборка.Номенклатура;
		НоваяСтрока.Характеристика = Выборка.Характеристика;
		НоваяСтрока.КонечныйОстаток = Выборка.КонечныйОстаток;
	КонецЦикла;

	Возврат Результат;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Возвращает структуру результата формирования табличного отчета.
//
// Возвращаемое значение:
//  Структура:
//   * Отчет                  - ТабличныйДокумент
//   * АдресДанныхРасшифровки - Строка
//
Функция НовыйРезультатТабличногоОтчета()

	Результат = Новый Структура;
	Результат.Вставить("Отчет", Новый ТабличныйДокумент);
	Результат.Вставить("АдресДанныхРасшифровки", "");

	Возврат Результат;

КонецФункции

// Возвращает стандартный период для выбранного дня.
//
// Параметры:
//  День - Дата
//
// Возвращаемое значение:
//  СтандартныйПериод
//
Функция СтандартныйПериодДня(День)

	Период = Новый СтандартныйПериод;
	Период.ДатаНачала = НачалоДня(День);
	Период.ДатаОкончания = КонецДня(День);

	Возврат Период;

КонецФункции

// Отключает служебную шапку СКД для встроенных отчетов помощника.
//
// Параметры:
//  Настройки - НастройкиКомпоновкиДанных
//
Процедура НастроитьВыводСКДБезСлужебнойШапки(Настройки)

	Настройки.ПараметрыВывода.УстановитьЗначениеПараметра(
		"ВыводитьЗаголовок",
		ТипВыводаТекстаКомпоновкиДанных.НеВыводить);
	Настройки.ПараметрыВывода.УстановитьЗначениеПараметра(
		"ВыводитьПараметрыДанных",
		ТипВыводаТекстаКомпоновкиДанных.НеВыводить);
	Настройки.ПараметрыВывода.УстановитьЗначениеПараметра(
		"ВыводитьОтбор",
		ТипВыводаТекстаКомпоновкиДанных.НеВыводить);

КонецПроцедуры

// Устанавливает параметр данных СКД, если он есть в настройках.
//
// Параметры:
//  Настройки     - НастройкиКомпоновкиДанных
//  ИмяПараметра  - Строка
//  Значение      - Произвольный
//
Процедура УстановитьПараметрСКД(Настройки, ИмяПараметра, Значение)

	Параметр = Настройки.ПараметрыДанных.НайтиЗначениеПараметра(
		Новый ПараметрКомпоновкиДанных(ИмяПараметра));

	Если Параметр = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Параметр.Значение = Значение;
	Параметр.Использование = Истина;

КонецПроцедуры

// Добавляет отбор СКД в настройки.
//
// Параметры:
//  Настройки     - НастройкиКомпоновкиДанных
//  ИмяПоля       - Строка
//  Значение      - Произвольный
//  ВидСравнения  - ВидСравненияКомпоновкиДанных
//
Процедура ДобавитьОтборСКД(Настройки, ИмяПоля, Значение, ВидСравнения)

	ЭлементОтбора = Настройки.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(ИмяПоля);
	ЭлементОтбора.ВидСравнения = ВидСравнения;
	ЭлементОтбора.ПравоеЗначение = Значение;
	ЭлементОтбора.Использование = Истина;

КонецПроцедуры

// Выполняет компоновку СКД в табличный документ.
//
// Параметры:
//  СхемаКомпоновкиДанных        - СхемаКомпоновкиДанных
//  Настройки                    - НастройкиКомпоновкиДанных
//  ВнешнийНаборДанных           - Структура, Неопределено
//  УникальныйИдентификаторФормы - УникальныйИдентификатор, Неопределено
//
// Возвращаемое значение:
//  Структура:
//   * Отчет                  - ТабличныйДокумент
//   * АдресДанныхРасшифровки - Строка
//
Функция СформироватьТабличныйДокументСКД(
	СхемаКомпоновкиДанных,
	Настройки,
	ВнешнийНаборДанных = Неопределено,
	УникальныйИдентификаторФормы = Неопределено)

	Результат = НовыйРезультатТабличногоОтчета();
	ДанныеРасшифровки = Новый ДанныеРасшифровкиКомпоновкиДанных;

	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновки = КомпоновщикМакета.Выполнить(
		СхемаКомпоновкиДанных,
		Настройки,
		ДанныеРасшифровки,
		,
		Тип("ГенераторМакетаКомпоновкиДанных"));

	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	Если ВнешнийНаборДанных = Неопределено Тогда
		ПроцессорКомпоновки.Инициализировать(МакетКомпоновки, , ДанныеРасшифровки, Истина);
	Иначе
		ПроцессорКомпоновки.Инициализировать(МакетКомпоновки, ВнешнийНаборДанных, ДанныеРасшифровки, Истина);
	КонецЕсли;

	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
	ПроцессорВывода.УстановитьДокумент(Результат.Отчет);
	ПроцессорВывода.Вывести(ПроцессорКомпоновки);

	Если УникальныйИдентификаторФормы <> Неопределено Тогда
		Результат.АдресДанныхРасшифровки = ПоместитьВоВременноеХранилище(
			ДанныеРасшифровки,
			УникальныйИдентификаторФормы);
	КонецЕсли;

	Возврат Результат;

КонецФункции

// Возвращает пустую таблицу отчета сверки выпусков.
//
// Возвращаемое значение:
//  ТаблицаЗначений
//
Функция НоваяТаблицаОтчетаСверкиВыпусков()

	ТаблицаОтчета = Новый ТаблицаЗначений;
	ТаблицаОтчета.Колонки.Добавить("Склад");
	ТаблицаОтчета.Колонки.Добавить("Номенклатура");
	ТаблицаОтчета.Колонки.Добавить("Характеристика");
	ТаблицаОтчета.Колонки.Добавить("КоличествоПоЧекам", Новый ОписаниеТипов("Число"));
	ТаблицаОтчета.Колонки.Добавить("КоличествоПоВыпуску", Новый ОписаниеТипов("Число"));
	ТаблицаОтчета.Колонки.Добавить("Разница", Новый ОписаниеТипов("Число"));
	ТаблицаОтчета.Колонки.Добавить("Блокирует", Новый ОписаниеТипов("Булево"));

	Возврат ТаблицаОтчета;

КонецФункции

// Добавляет строки таблицы-источника в таблицу-приемник.
//
// Параметры:
//  Приемник - ТаблицаЗначений
//  Источник - ТаблицаЗначений, Неопределено
//
Процедура ДобавитьСтрокиТаблицыЗначений(Приемник, Источник)

	Если Источник = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если Приемник.Колонки.Количество() = 0 Тогда
		Для Каждого КолонкаИсточник Из Источник.Колонки Цикл
			Приемник.Колонки.Добавить(КолонкаИсточник.Имя, КолонкаИсточник.ТипЗначения);
		КонецЦикла;
	КонецЕсли;

	Для Каждого СтрокаИсточник Из Источник Цикл
		НоваяСтрока = Приемник.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаИсточник);
	КонецЦикла;

КонецПроцедуры

// Формирует простой табличный документ по таблице значений.
//
// Параметры:
//  Заголовок     - Строка
//  ТаблицаОтчета - ТаблицаЗначений
//
// Возвращаемое значение:
//  ТабличныйДокумент
//
Функция СформироватьТабличныйОтчетПоТаблице(Заголовок, ТаблицаОтчета)

	ТабличныйДокумент = Новый ТабличныйДокумент;
	ОформитьТабличныйДокументОтчета(ТабличныйДокумент);
	ТабличныйДокумент.Область(1, 1).Текст = Заголовок;
	ТабличныйДокумент.Область(2, 1).Текст = СтрШаблон(
		"Строк: %1, блокирующих: %2",
		ТаблицаОтчета.Количество(),
		КоличествоБлокирующихСтрокОтчета(ТаблицаОтчета));

	Если ТаблицаОтчета.Количество() = 0 Тогда
		ТабличныйДокумент.Область(4, 1).Текст = НСтр("ru = 'Отклонений не обнаружено.'");
		Возврат ТабличныйДокумент;
	КонецЕсли;

	СтрокаОтчета = 4;
	КолонкаОтчета = 1;
	Для Каждого КолонкаТаблицы Из ТаблицаОтчета.Колонки Цикл
		ТабличныйДокумент.Область(СтрокаОтчета, КолонкаОтчета).Текст =
			ПредставлениеКолонкиТабличногоОтчета(КолонкаТаблицы.Имя);
		ТабличныйДокумент.Область(, КолонкаОтчета, , КолонкаОтчета).ШиринаКолонки =
			ШиринаКолонкиТабличногоОтчета(КолонкаТаблицы.Имя);
		КолонкаОтчета = КолонкаОтчета + 1;
	КонецЦикла;

	Для Каждого СтрокаТаблицы Из ТаблицаОтчета Цикл

		СтрокаОтчета = СтрокаОтчета + 1;
		КолонкаОтчета = 1;

		Для Каждого КолонкаТаблицы Из ТаблицаОтчета.Колонки Цикл
			ЗначениеЯчейки = СтрокаТаблицы[КолонкаТаблицы.Имя];
			ОбластьЯчейки = ТабличныйДокумент.Область(СтрокаОтчета, КолонкаОтчета);
			ЗаполнитьЯчейкуТабличногоОтчета(ОбластьЯчейки, ЗначениеЯчейки);
			КолонкаОтчета = КолонкаОтчета + 1;
		КонецЦикла;

	КонецЦикла;

	Возврат ТабличныйДокумент;

КонецФункции

// Заполняет ячейку табличного отчета текстом и расшифровкой для ссылочных значений.
//
// Параметры:
//  ОбластьЯчейки - ОбластьЯчеекТабличногоДокумента
//  ЗначениеЯчейки - Произвольный
//
Процедура ЗаполнитьЯчейкуТабличногоОтчета(ОбластьЯчейки, ЗначениеЯчейки)

	ОбластьЯчейки.Текст = ПредставлениеЗначенияТабличногоОтчета(ЗначениеЯчейки);

	Если ЗначениеЯчейки <> Неопределено
		И ОбщегоНазначения.ЗначениеСсылочногоТипа(ЗначениеЯчейки) Тогда

		ОбластьЯчейки.Расшифровка = ЗначениеЯчейки;
	КонецЕсли;

КонецПроцедуры

// Применяет общие параметры отображения табличного документа на форме.
//
// Параметры:
//  ТабличныйДокумент - ТабличныйДокумент
//
Процедура ОформитьТабличныйДокументОтчета(ТабличныйДокумент)

	ТабличныйДокумент.АвтоМасштаб = Истина;
	ТабличныйДокумент.ОтображатьСетку = Ложь;
	ТабличныйДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;

КонецПроцедуры

// Устанавливает ширины колонок отчета сверки продаж с чеками.
//
// Параметры:
//  ТабличныйДокумент - ТабличныйДокумент
//
Процедура УстановитьШириныОтчетаСверкиЧеков(ТабличныйДокумент)

	ШириныКолонок = Новый Массив;
	ШириныКолонок.Добавить(26);
	ШириныКолонок.Добавить(28);

	КоличествоКолонок = 0;
	Пока КоличествоКолонок < 3 Цикл
		ШириныКолонок.Добавить(40);
		КоличествоКолонок = КоличествоКолонок + 1;
	КонецЦикла;

	КоличествоКолонок = 0;
	Пока КоличествоКолонок < 6 Цикл
		ШириныКолонок.Добавить(14);
		КоличествоКолонок = КоличествоКолонок + 1;
	КонецЦикла;

	УстановитьШириныКолонокТабличногоДокумента(ТабличныйДокумент, ШириныКолонок);

КонецПроцедуры

// Устанавливает ширины колонок табличного документа, не выходя за его фактическую ширину.
//
// Параметры:
//  ТабличныйДокумент - ТабличныйДокумент
//  ШириныКолонок     - Массив из Число
//
Процедура УстановитьШириныКолонокТабличногоДокумента(ТабличныйДокумент, ШириныКолонок)

	Для НомерКолонки = 1 По Мин(ТабличныйДокумент.ШиринаТаблицы, ШириныКолонок.Количество()) Цикл
		ТабличныйДокумент.Область(, НомерКолонки, , НомерКолонки).ШиринаКолонки =
			ШириныКолонок[НомерКолонки - 1];
	КонецЦикла;

КонецПроцедуры

// Возвращает представление колонки табличного отчета.
//
// Параметры:
//  ИмяКолонки - Строка
//
// Возвращаемое значение:
//  Строка
//
Функция ПредставлениеКолонкиТабличногоОтчета(ИмяКолонки)

	Если ИмяКолонки = "КоличествоПоЧекам" Тогда
		Возврат НСтр("ru = 'Кол-во по чекам'");
	ИначеЕсли ИмяКолонки = "КоличествоПоВыпуску" Тогда
		Возврат НСтр("ru = 'Кол-во в выпусках'");
	ИначеЕсли ИмяКолонки = "Разница" Тогда
		Возврат НСтр("ru = 'Разница'");
	ИначеЕсли ИмяКолонки = "Блокирует" Тогда
		Возврат НСтр("ru = 'Блокирует'");
	ИначеЕсли ИмяКолонки = "НоменклатураОткрытойЦены" Тогда
		Возврат НСтр("ru = 'Номенклатура открытой цены'");
	Иначе
		Возврат ИмяКолонки;
	КонецЕсли;

КонецФункции

// Возвращает ширину колонки табличного отчета.
//
// Параметры:
//  ИмяКолонки - Строка
//
// Возвращаемое значение:
//  Число
//
Функция ШиринаКолонкиТабличногоОтчета(ИмяКолонки)

	Если ИмяКолонки = "Склад" Тогда
		Возврат 32;
	ИначеЕсли ИмяКолонки = "Номенклатура" Тогда
		Возврат 42;
	ИначеЕсли ИмяКолонки = "Характеристика" Тогда
		Возврат 26;
	ИначеЕсли ИмяКолонки = "КоличествоПоЧекам" Тогда
		Возврат 15;
	ИначеЕсли ИмяКолонки = "КоличествоПоВыпуску" Тогда
		Возврат 17;
	ИначеЕсли ИмяКолонки = "Разница" Тогда
		Возврат 12;
	ИначеЕсли ИмяКолонки = "Блокирует" Тогда
		Возврат 11;
	Иначе
		Возврат 18;
	КонецЕсли;

КонецФункции

// Возвращает представление значения ячейки табличного отчета.
//
// Параметры:
//  ЗначениеЯчейки - Произвольный
//
// Возвращаемое значение:
//  Строка
//
Функция ПредставлениеЗначенияТабличногоОтчета(ЗначениеЯчейки)

	Если ЗначениеЯчейки = Неопределено Тогда
		Возврат "";
	ИначеЕсли ТипЗнч(ЗначениеЯчейки) = Тип("Булево") Тогда
		Возврат ?(ЗначениеЯчейки, НСтр("ru = 'Да'"), НСтр("ru = 'Нет'"));
	ИначеЕсли ТипЗнч(ЗначениеЯчейки) = Тип("Число") Тогда
		Возврат Формат(ЗначениеЯчейки, "ЧГ=0; ЧДЦ=3");
	Иначе
		Возврат Строка(ЗначениеЯчейки);
	КонецЕсли;

КонецФункции

// Возвращает количество блокирующих строк отчета.
//
// Параметры:
//  ТаблицаОтчета - ТаблицаЗначений
//
// Возвращаемое значение:
//  Число
//
Функция КоличествоБлокирующихСтрокОтчета(ТаблицаОтчета)

	Если ТаблицаОтчета.Колонки.Найти("Блокирует") = Неопределено Тогда
		Возврат 0;
	КонецЕсли;

	Результат = 0;
	Для Каждого СтрокаОтчета Из ТаблицаОтчета Цикл
		Если СтрокаОтчета.Блокирует Тогда
			Результат = Результат + 1;
		КонецЕсли;
	КонецЦикла;

	Возврат Результат;

КонецФункции

// Возвращает строки параметров касс для указанной фронт-системы.
//
// Параметры:
//  ПараметрыКасс - ТаблицаЗначений, Неопределено - исходные параметры касс
//  ФронтСистема  - ПеречислениеСсылка.ПЛ_ТипыФронтСистем
//
// Возвращаемое значение:
//  ТаблицаЗначений - параметры касс выбранной фронт-системы
//
Функция ПараметрыКассДляФронтСистемы(ПараметрыКасс, ФронтСистема)

	Результат = НоваяТаблицаПараметровКасс();

	Если ПараметрыКасс = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;

	Для Каждого СтрокаПараметров Из ПараметрыКасс Цикл

		Если НЕ СтрокаПараметров.Использовать Тогда
			Продолжить;
		КонецЕсли;

		Если СтрокаПараметров.ФронтСистема <> ФронтСистема Тогда
			Продолжить;
		КонецЕсли;

		Если НЕ ЗначениеЗаполнено(СтрокаПараметров.КодТочкиПродаж) Тогда
			Продолжить;
		КонецЕсли;

		НоваяСтрока = Результат.Добавить();
		НоваяСтрока.Использовать            = Истина;
		НоваяСтрока.КассаККМ                = СтрокаПараметров.КассаККМ;
		НоваяСтрока.ФронтСистема            = СтрокаПараметров.ФронтСистема;
		НоваяСтрока.КодТочкиПродаж          = СтрокаПараметров.КодТочкиПродаж;
		НоваяСтрока.НаименованиеТочкиПродаж = СтрокаПараметров.НаименованиеТочкиПродаж;

	КонецЦикла;

	Возврат Результат;

КонецФункции

// Возвращает выбранные кассы из параметров фронт-систем.
//
// Параметры:
//  ПараметрыКасс - ТаблицаЗначений, Неопределено - исходные параметры касс
//
// Возвращаемое значение:
//  Массив из СправочникСсылка.КассыККМ - выбранные кассы
//
Функция КассыККМИзПараметров(ПараметрыКасс)

	Результат = Новый Массив;
	ИндексКасс = Новый Соответствие;

	Если ПараметрыКасс = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;

	Для Каждого СтрокаПараметров Из ПараметрыКасс Цикл

		Если НЕ СтрокаПараметров.Использовать
			ИЛИ НЕ ЗначениеЗаполнено(СтрокаПараметров.КассаККМ) Тогда

			Продолжить;
		КонецЕсли;

		Если ИндексКасс.Получить(СтрокаПараметров.КассаККМ) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;

		ИндексКасс.Вставить(СтрокаПараметров.КассаККМ, Истина);
		Результат.Добавить(СтрокаПараметров.КассаККМ);

	КонецЦикла;

	Возврат Результат;

КонецФункции

// Создает таблицу параметров касс в формате обработки загрузки фронт-данных.
//
// Возвращаемое значение:
//  ТаблицаЗначений - параметры касс
//
Функция НоваяТаблицаПараметровКасс()

	ПараметрыКасс = Новый ТаблицаЗначений;
	ПараметрыКасс.Колонки.Добавить("Использовать", Новый ОписаниеТипов("Булево"));
	ПараметрыКасс.Колонки.Добавить("КассаККМ", Новый ОписаниеТипов("СправочникСсылка.КассыККМ"));
	ПараметрыКасс.Колонки.Добавить("ФронтСистема", Новый ОписаниеТипов("ПеречислениеСсылка.ПЛ_ТипыФронтСистем"));
	ПараметрыКасс.Колонки.Добавить("КодТочкиПродаж", Новый ОписаниеТипов("Строка"));
	ПараметрыКасс.Колонки.Добавить("НаименованиеТочкиПродаж", Новый ОписаниеТипов("Строка"));

	Возврат ПараметрыКасс;

КонецФункции

// Возвращает агрегированный статус формирования по складам.
//
// Параметры:
//  День          - Дата
//  МассивСкладов - Массив из СправочникСсылка.Склады
//  ПараметрыКасс - ТаблицаЗначений
//
// Возвращаемое значение:
//  Строка - «Пройден» / «НеПройден»
//
Функция ОбщийСтатусФормирования(День, МассивСкладов, ПараметрыКасс)

	Для Каждого Склад Из МассивСкладов Цикл

		Результат = СтатусШагаФормирование(День, Склад, ПараметрыКасс);
		Если Результат.Статус <> "Пройден" Тогда
			Возврат "Не Пройден";
		КонецЕсли;

	КонецЦикла;

	Возврат "Пройден";

КонецФункции

// Возвращает агрегированный статус остатков по складам.
//
// Параметры:
//  День          - Дата
//  МассивСкладов - Массив из СправочникСсылка.Склады
//
// Возвращаемое значение:
//  Строка - «Пройден» / «НеПройден»
//
Функция ОбщийСтатусОстатков(День, МассивСкладов)

	Для Каждого Склад Из МассивСкладов Цикл

		Результат = СтатусШагаОстатки(День, Склад);
		Если Результат.Статус <> "Пройден" Тогда
			Возврат "Не Пройден";
		КонецЕсли;

	КонецЦикла;

	Возврат "Пройден";

КонецФункции

// Обрабатывает строки результата сверки от одной фронт-системы:
// пропускает строки с незаполненным ЧекОбщепита (чеки, не загруженные в 1С),
// сравнивает суммы и скидки, добавляет отклонения в результирующую таблицу.
//
// Параметры:
//  Результат     - ТаблицаЗначений - результирующая таблица отклонений
//  ТаблицаДанных - ТаблицаЗначений - данные от ВыполнитьПолучениеДанныхTNG/Micros
//  ИмяСистемы    - Строка - «TNG» или «Micros»
//
Процедура ОбработатьСтрокиСверки(Результат, ТаблицаДанных, ИмяСистемы)

	Для Каждого СтрокаДанных Из ТаблицаДанных Цикл
		// Пропускаем строки, где чек ещё не подгружен в 1С
		Если НЕ ЗначениеЗаполнено(СтрокаДанных.ЧекОбщепита) Тогда
			Продолжить;
		КонецЕсли;

		ОтклонениеСуммы  = 0;
		ОтклонениеСкидки = 0;
        Категория = "";
		
		// Сравниваем суммы (колонки могут отличаться в зависимости от фронт-системы)
		СуммаФронта = СтрокаДанных.СУММАЧЕКАORACLE; 
		Сумма1С = СтрокаДанных.СуммаДокументаЧекОбщепита; 	
		ОтклонениеСуммы = Сумма1С - СуммаФронта;
		СкидкаФронта = СтрокаДанных.СУММАСКИДКИORACLE;  
		Скидка1С = СтрокаДанных.СуммаСкидкиЧекОбщепита;
		ОтклонениеСкидки = Скидка1С - СкидкаФронта;

		// Категория отклонения
		//Категория = "";
		//Если ОтклонениеСуммы <> 0 И ОтклонениеСкидки <> 0 Тогда
		//	Категория = "СуммаИСкидка";
		//ИначеЕсли ОтклонениеСуммы <> 0 Тогда
		//	Категория = "Сумма";
		//ИначеЕсли ОтклонениеСкидки <> 0 Тогда
		//	Категория = "Скидка";
		//КонецЕсли;
		
		Если ОтклонениеСуммы <> 0 Тогда
			
			Если ОтклонениеСуммы > -0.02 И ОтклонениеСуммы < 0.02 Тогда
				
				Категория = "Сумма";
				
			КонецЕсли;	
		КонецЕсли;
	
		// Проверка на алкоголь и марки
		Если Категория <> "" Тогда
			СтруктураАлкоголь = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СтрокаДанных.НоменклатураORACLE ,"АлкогольнаяПродукция, АлкогольнаяПродукцияВоВскрытойТаре");
			Если СтруктураАлкоголь.АлкогольнаяПродукция и НЕ СтруктураАлкоголь.АлкогольнаяПродукцияВоВскрытойТаре Тогда
				Попытка
					Марка = MRS_ЗагрузкаЕГАИСФронт.ПолучитьАкцизнуюМаркуПоНомеруЧека(СтрокаДанных.НОМЕРЧЕКАORACLE);
					Если НЕ ЗначениеЗаполнено(Марка) Тогда
						Категория = "Алкоголь Марка";
					КонецЕсли;
				Исключение
					Категория = "Алкоголь Марка";
					ЗаписьЖурналаРегистрации(
						НСтр("ru = 'MRS.ПомощникЗакрытияСмены.Сверка.МаркаАлкоголя.Ошибка'"),
						УровеньЖурналаРегистрации.Предупреждение,
						,
						,
						ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
				КонецПопытки;
			КонецЕсли;
		КонецЕсли;

		Если Категория <> "" Тогда
			НоваяСтрока = Результат.Добавить();
			НоваяСтрока.ФронтСистема    	= ИмяСистемы;
			НоваяСтрока.НомерЧека 			= СтрокаДанных.НОМЕРЧЕКАORACLE;
			НоваяСтрока.КодТочкиПродаж 		= СтрокаДанных.НОМЕРТОЧКИПРОДАЖORACLE;
			НоваяСтрока.Номенклатура 		= СтрокаДанных.НоменклатураORACLE;
			НоваяСтрока.СуммаПоФронту   	= СуммаФронта;
			НоваяСтрока.СуммаПоЧеку1С   	= Сумма1С;
			НоваяСтрока.ОтклонениеСуммы 	= ОтклонениеСуммы;
			НоваяСтрока.СкидкаПоФронту  	= СкидкаФронта;
			НоваяСтрока.СкидкаПоЧеку1С  	= Скидка1С;
			НоваяСтрока.ОтклонениеСкидки 	= ОтклонениеСкидки;
			НоваяСтрока.КатегорияОтклонения = Категория;
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

#КонецОбласти
