Процедура ТоварыПередУдалением(Элемент, Отказ)
	
	// удаление модификаторов
	ТекДанные = Элементы.Товары.ТекущиеДанные;
	Если НЕ ТекДанные = Неопределено Тогда
		НайденныеМодификаторы = Объект.Модификаторы.НайтиСтроки(Новый Структура("ИдентификаторСтроки", ТекДанные.ИдентификаторСтроки));
		Для каждого ТекМодификатор Из НайденныеМодификаторы Цикл
			Объект.Модификаторы.Удалить(ТекМодификатор);
		КонецЦикла;
		
		//>>Швецов. 19.03.2025 ERP-4858 Розничные продажи алкоголя 
		НайденныеСерии = Объект.ТоварыСерии.НайтиСтроки(Новый Структура("Номенклатура", ТекДанные.Номенклатура));
		Для каждого ТекСтрока Из НайденныеСерии Цикл
			Объект.ТоварыСерии.Удалить(ТекСтрока);
		КонецЦикла;
		//<<
		
	КонецЕсли;
	
	ОбновитьКешированныеЗначенияДляУчетаСерий("Товары", Элемент, КэшированныеЗначения, Ложь);
