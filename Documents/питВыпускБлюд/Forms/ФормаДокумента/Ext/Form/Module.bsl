	ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
	ПолеЭлемента = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.Ингредиенты.Имя);
	ОтборЭлемента = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Ингредиенты.ИзмененФакт");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Истина;
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("Шрифт", Новый Шрифт(,,,Истина,,,));
	//-ИзменениеФактаВПроизводстве
	
	//<< Портал-Юг, Баринов, 2019.09.12 [Исправление]
	// Требует заполнять аналитику даже там, где она не обязательна
//	ПланыВидовХарактеристик.СтатьиРасходов.УстановитьУсловноеОформлениеАналитик(УсловноеОформление);
	//>> Портал-Юг, Баринов, 2019.09.12
	
КонецПроцедуры

&НаКлиенте
Процедура ВидОперацииПриИзменении(Элемент)
	
	ВидОперацииПриИзмененииНаСервере(); 
	
	//<<Портал-Юг, Давиденко 2019.03.11 [4.2.3 Вид операции «Заборный лист» в документе «Выпуск блюд»]
	ЦенаВключаетНДСПриИзменении(Элементы.ЦенаВключаетНДС);
	//>>Портал-Юг, Давиденко 2019.03.11
	
КонецПроцедуры

//// Параметры производства

&НаКлиенте
Процедура РежимРасчетаСписанияВПроизводствоПриИзменении(Элемент)
	Если Объект.РежимРасчетаСписанияВПроизводство = ПредопределенноеЗначение("Перечисление.питРежимыРасчетаСписанияВПроизводство.ПоФакту") Тогда
		Объект.РазрешитьНедовложения = Ложь;
	КонецЕсли;
	РежимРасчетаСписанияВПроизводствоУстановка(ЭтаФорма);
	УстановитьЗаголовокФормы();
КонецПроцедуры

&НаКлиенте
Процедура РежимИспользованияАналоговПриИзменении(Элемент)
	Если Объект.РежимИспользованияАналогов=ПредопределенноеЗначение("Перечисление.питРежимыИспользованияАналогов.Запретить") Тогда
		// Замены не используются, погасим закладку замен.
		Если Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаЗамены Тогда
			Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаТовары;
		КонецЕсли;	
		Элементы.ГруппаЗамены.Видимость = Ложь;
	Иначе
		Элементы.ГруппаЗамены.Видимость = Истина;
	КонецЕсли;	
КонецПроцедуры


