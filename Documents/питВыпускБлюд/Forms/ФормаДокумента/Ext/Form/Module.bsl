		// Продолжаем
	КонецЕсли;
	
	//+АвтовыборНоменклатуры
	Объект.УточненияАвтовыбора.Очистить();
	//+АвтовыборНоменклатуры
	
	ЗаполнитьПроизводства();
	
	ИзмененыТовары = Ложь;
	УправлениеФормой(ЭтаФорма);
	БлюдаПриАктивизацииСтроки(Неопределено);
	
	// Перезаполнили производство, взводим флаг модифицированности формы.
	Модифицированность = Истина;
	
КонецПроцедуры


