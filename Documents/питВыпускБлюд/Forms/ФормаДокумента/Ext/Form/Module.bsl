#Область ИзменениеФактаВПроизводстве

&НаСервере
Функция УпаковатьУточненияАвтовыбора()
	Возврат ПоместитьВоВременноеХранилище(Объект.УточненияАвтовыбора.Выгрузить());
КонецФункции

&НаСервере
Функция РаспаковатьУточненияАвтовыбора(Адрес)
	Возврат ПолучитьИзВременногоХранилища(Адрес);
КонецФункции

&НаКлиенте
Процедура УточнитьХарактеристики(Команда)
	
	Если НЕ НайденыОшибкиАвтовыбора Тогда
		ПоказатьПредупреждение(Новый ОписаниеОповещения, "Уточнение характеристик не требуется");
		Возврат;
	КонецЕсли;
	
	СтруктураПараметров = Новый Структура();
	СтруктураПараметров.Вставить("АдресУточненияАвтовыбора"	, УпаковатьУточненияАвтовыбора());
	СтруктураПараметров.Вставить("Ссылка"					, Объект.Ссылка);
	СтруктураПараметров.Вставить("Организация"				, Объект.Организация);
	СтруктураПараметров.Вставить("Подразделение"			, Объект.Подразделение);
	СтруктураПараметров.Вставить("Дата"						, Объект.Дата);
	СтруктураПараметров.Вставить("Склад"					, Объект.Склад);
	СтруктураПараметров.Вставить("ВидПроизводства"			, Объект.ВидПроизводства);
	
	ОткрытьФорму("ОбщаяФорма.питФормаПодбораХарактеристик", СтруктураПараметров, ЭтаФорма,,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаВыбораПодборХарактеристикНаСервере(ВыбранноеЗначение)
	
	Объект.УточненияАвтовыбора.Загрузить(РаспаковатьУточненияАвтовыбора(ВыбранноеЗначение));
	НайденыОшибкиАвтовыбора = питУправлениеДаннымиОбИзделиях.ЗаполнитьНайденыОшибкиАвтовыбора(Объект.УточненияАвтовыбора);
	//Если НЕ НайденыОшибкиАвтовыбора Тогда
		ЗаполнитьПроизводства();
	//КонецЕсли;
	
КонецПроцедуры

