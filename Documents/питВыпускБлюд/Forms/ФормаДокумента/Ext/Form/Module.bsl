#Область СлужебныеПроцедурыИФункции

&НаКлиентеНаСервереБезКонтекста
Функция ДанныеФормыКоллекцияВМассив(Коллекция, КолонкиСтрокой)
	
	Результат = Новый Массив;
	
	Для Каждого ТекСтрока Из Коллекция Цикл
		НоваяСтрока = Новый Структура(КолонкиСтрокой);
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока);
		Результат.Добавить(НоваяСтрока);
	КонецЦикла;
	
	Возврат Результат;
КонецФункции

&НаСервереБезКонтекста
Функция ПроверитьЕстьБлюдаБезТоваров(Товары, Блюда)
	
	Результат = Ложь;
	СтруктураПоиска = Новый Структура("Номенклатура, Характеристика, Упаковка");
	Для каждого ТекСтрокаБлюда Из Блюда Цикл
		Если ТекСтрокаБлюда.Автопередел Тогда
			Продолжить;
		КонецЕсли;
		ТоварНайден = Ложь;
		Для каждого СтрокаТоваров Из Товары Цикл
			Если СтрокаТоваров.Номенклатура = ТекСтрокаБлюда.Номенклатура
				И СтрокаТоваров.Характеристика = ТекСтрокаБлюда.Характеристика
				И СтрокаТоваров.Упаковка = ТекСтрокаБлюда.УпаковкаНоменклатуры Тогда
				ТоварНайден = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		Если НЕ ТоварНайден Тогда
			ПредставлениеНоменклатуры = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекСтрокаБлюда.Номенклатура, "Наименование");
			ПредставлениеХарактеристики = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекСтрокаБлюда.Характеристика, "Наименование");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
				СтрШаблон("Не найдены товары для блюда %1; %2", ПредставлениеНоменклатуры, ПредставлениеХарактеристики)
			);
			Результат = Истина;
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область ПолучитьВес

&НаКлиенте
Процедура ПолучитьВес(Команда)
	
	ТекущаяСтрока = МенеджерОборудованияУТКлиент.ТекущаяСтрока(ЭтаФорма);
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	МенеджерОборудованияКлиент.НачатьПолученияВесаСЭлектронныхВесов(
		Новый ОписаниеОповещения("ПолучитьВесЗавершение", ЭтотОбъект, ТекущаяСтрока),
		УникальныйИдентификатор);
	
КонецПроцедуры

&НаКлиенте
Процедура ПолучитьВесЗавершение(РезультатВыполнения, ТекущаяСтрока) Экспорт
	
	Если РезультатВыполнения.Результат Тогда
		ТекущаяСтрока.КоличествоУпаковок = РезультатВыполнения.Вес;
		
		СтруктураДействий = Новый Структура;
		ДобавитьВСтруктуруДействияПриИзмененииКоличестваУпаковок("Товары", СтруктураДействий);
		
		ОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, КэшированныеЗначения);
		
		//РассчитатьИтоговыеПоказателиПоступления(ЭтаФорма);
	Иначе
		МенеджерОборудованияУТКлиент.СообщитьОбОшибке(РезультатВыполнения);
	КонецЕсли;
	
КонецПроцедуры

// << MRS #ERP-5312 ДенисламовАД <Adel.Denislamov@mriyaresort.com> 23.07.25, ()
&НаСервере
Процедура УстановитьОрганизациюПоСкладу(ТекДействие)
	
	Если ЗначениеЗаполнено(Объект.Склад) Тогда
		ОрганизацияСклада 				= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Склад, "ПЛ_Организация");
		ПодразделениеСклада 			= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Склад, "Подразделение");
		ОрганизацияСкладаЗаполнена 	= ЗначениеЗаполнено(ОрганизацияСклада);

		Если ОрганизацияСклада <> Объект.Организация И НЕ Объект.Проведен И ТекДействие = "Изменение" Тогда
			Объект.Организация = ОрганизацияСклада;
			ЭтаФорма.Модифицированность = Истина;
			ОбщегоНазначения.СообщитьПользователю("В документе автоматически была изменена Организация, из настроек выбранного склада!");
			Если НЕ ОрганизацияСкладаЗаполнена Тогда
				ОбщегоНазначения.СообщитьПользователю("В выбранном складе не указана организация, заполните Организацию в ручном выборе!");
			КонецЕсли;
		ИначеЕсли ЗначениеЗаполнено(Объект.Организация) И ОрганизацияСкладаЗаполнена И ОрганизацияСклада <> Объект.Организация И (Объект.Проведен ИЛИ ТекДействие = "Чтение") Тогда
			ОбщегоНазначения.СообщитьПользователю("ВНИМАНИЕ! В документе различается организация склада с организацией в документе!");
		ИначеЕсли НЕ ЗначениеЗаполнено(Объект.Организация) Тогда
			Объект.Организация 				= ОрганизацияСклада;
			Объект.Подразделение 				= ПодразделениеСклада;
			ЭтаФорма.Модифицированность 	= Истина;
		КонецЕсли;
				
		Если Объект.Подразделение <> ПодразделениеСклада И НЕ Объект.Проведен И ТекДействие = "Изменение" Тогда
			Объект.Подразделение = ПодразделениеСклада;
			ОбщегоНазначения.СообщитьПользователю("В документе автоматически было изменено Подразделение, из настроек выбранного склада!");
			ЭтаФорма.Модифицированность = Истина;
		ИначеЕсли ЗначениеЗаполнено(Объект.Подразделение) И ЗначениеЗаполнено(ПодразделениеСклада) И Объект.Подразделение <> ПодразделениеСклада И (Объект.Проведен ИЛИ ТекДействие = "Чтение") Тогда
			ОбщегоНазначения.СообщитьПользователю("ВНИМАНИЕ! В документе различается Подразделение склада с Подразделением в документе!");
		КонецЕсли;
		
		// Параметры:
		//  ЭлементыФормы - ВсеЭлементыФормы - элементы формы, среди которых содержится искомый элемент.
		//  ИмяЭлемента   - Строка - имя искомого элемента.
		//  ИмяСвойства   - Строка - имя свойства, для которого будет устанавливаться значение.
		//  Значение      - Произвольный - значение, которое будет установлено
		//  УстанавливатьДляПодчиненных - Булево - установить аналогичное свойство для подчиненных элементов искомого элемента.
		ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"Организация",
		"Доступность",
		НЕ ОрганизацияСкладаЗаполнена И НЕ Объект.Проведен);
	КонецЕсли;
	
КонецПроцедуры
