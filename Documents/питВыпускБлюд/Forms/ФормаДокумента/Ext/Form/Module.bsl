&НаКлиенте
Процедура МодификаторыПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	Если НоваяСтрока И НЕ Копирование Тогда
		ТекСтрока = Элемент.ТекущиеДанные;
		
		ТекДанные = Элементы.Товары.ТекущиеДанные;
		Если ТекДанные <> Неопределено Тогда
			
			Если ПустаяСтрока(ТекДанные.ИдентификаторСтроки) Тогда
				ТекДанные.ИдентификаторСтроки = Новый УникальныйИдентификатор;
			КонецЕсли;
			
			Элемент.ТекущиеДанные.ИдентификаторСтроки = ТекДанные.ИдентификаторСтроки;
			
			ОбновитьОтборСтрокВТаблицеМодификаторов();
			
		КонецЕсли;
		
	КонецЕсли;
	ОбновитьКешированныеЗначенияДляУчетаСерий("Модификаторы", Элемент, КэшированныеЗначения, Копирование);
КонецПроцедуры

&НаКлиенте
Процедура МодификаторыПриИзменении(ИмяРеквизита = "")
	
	Перем ДанныеМодификатора, ТекДанные;
	
	ТекДанные = Элементы.Модификаторы.ТекущиеДанные;
	Если НЕ ТекДанные = Неопределено 
		И ЗначениеЗаполнено(ТекДанные.Модификатор) Тогда
		ДанныеМодификатора = ПолучитьДанныеМодификатора(ТекДанные.Модификатор);
		
		Если ИмяРеквизита = "" Тогда
			ТекДанные.Номенклатура						= ДанныеМодификатора.ДопНоменклатура;
			ТекДанные.Цена								= ДанныеМодификатора.Цена;
			ТекДанные.Сумма								= ДанныеМодификатора.Цена * ТекДанные.Количество;
			ТекДанные.УпаковкаНоменклатуры				= ДанныеМодификатора.ЕдиницаИзмеренияНоменклатуры;
			ТекДанные.КоличествоНоменклатуры			= ДанныеМодификатора.КоличествоНоменклатуры * ТекДанные.Количество;
			ТекДанные.КоличествоУпаковокНоменклатуры	= ДанныеМодификатора.КоличествоУпаковокНоменклатуры * ТекДанные.Количество;
		КонецЕсли;
		
		ДатаРецептуры = ?(ЗначениеЗаполнено(Объект.Ссылка), Объект.Дата, КонецДня(Объект.Дата));
		ТекДанные.Рецептура = питПроизводство.ВернутьОсновнуюРецептуру(ТекДанные.Номенклатура,ТекДанные.Характеристика, ДанныеМодификатора.РежимПриготовление,
		ДатаРецептуры, СпособРасчетаРецептуры, , Объект.Организация,,,Объект.Подразделение);
		
	КонецЕсли;

КонецПроцедуры

&НаСервере
Функция ПолучитьДанныеМодификатора(Модификатор)
	
	ДанныеМодификатора = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Модификатор, "ДопНоменклатура, КоличествоНоменклатуры, КоличествоУпаковокНоменклатуры, Цена, ЕдиницаИзмеренияНоменклатуры");
	ДанныеМодификатора.Вставить("РежимПриготовление", Перечисления.питХозяйственныеОперации.РецептураПриготовление);
	
	Возврат ДанныеМодификатора;
	
КонецФункции

