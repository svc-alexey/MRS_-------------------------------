#Область Печать

&НаКлиенте
Процедура ВыполнитьКомандуПечатиЗавершение(Результат, Команда) Экспорт
	
	ИдентификаторКоманды = Неопределено;
	Если ТипЗнч(Команда) = Тип("КомандаФормы") Тогда
		ОписаниеКоманды = ПодключаемыеКомандыКлиентПовтИсп.ОписаниеКоманды(Команда.Имя, Этаформа.ПараметрыПодключаемыхКоманд.АдресТаблицыКоманд);
		ИдентификаторКоманды = ОписаниеКоманды.Идентификатор;
	КонецЕсли;
	
	Если НЕ ОписаниеКоманды.Свойство("ДополнительныеПараметры") Тогда
		ОписаниеКоманды.Вставить("ДополнительныеПараметры", Новый Структура());
	КонецЕсли;
	
	Если Результат = Неопределено ИЛИ ТипЗнч(Результат) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	Если ИдентификаторКоманды ="питОП1_СПараметрами" ИЛИ ИдентификаторКоманды ="питОП1_ТБ_СПараметрами" Тогда
		ОписаниеКоманды.ДополнительныеПараметры.ДополнительныеПараметры.Вставить("СтруктураПараметровОП1", Результат);
	Иначе
		Возврат;
	КонецЕсли;
	
	ПодключаемыеКомандыКлиент.ВыполнитьКоманду(ЭтотОбъект, Команда, Объект);
	
КонецПроцедуры

// СтандартныеПодсистемы.ПодключаемыеКоманды
&НаКлиенте
Процедура Подключаемый_ВыполнитьКоманду(Команда)
	
	ИдентификаторКоманды = Неопределено;
	Если ТипЗнч(Команда) = Тип("КомандаФормы") Тогда
		ОписаниеКоманды = ПодключаемыеКомандыКлиентПовтИсп.ОписаниеКоманды(Команда.Имя, Этаформа.ПараметрыПодключаемыхКоманд.АдресТаблицыКоманд);
		ИдентификаторКоманды = ОписаниеКоманды.Идентификатор;
	КонецЕсли;
	
	ИмяФормыПараметровПечати = "";
	
	СтруктураПараметровПечати = Новый Структура;
	
	// Устанавливаем заголовок формы печати, если требуется(например для указания, каким образом была получена суммовая оценка).
	Если ОписаниеКоманды.ДополнительныеПараметры.Свойство("ЗаголовокФормы") Тогда
		ОписаниеКоманды.ДополнительныеПараметры.ЗаголовокФормы = питОтчеты.ПолучитьЗаголовокПечатнойФормыОбщепит(ИдентификаторКоманды, Объект.Ссылка, ОписаниеКоманды.Представление);
	КонецЕсли;
	
	Если ИдентификаторКоманды ="питОП1_ТБ" Или ИдентификаторКоманды ="питОП1_ТБ_СПараметрами" Тогда
		СтрокаБлюда = Новый Структура("Ссылка,Номенклатура,Упаковка,Количество,КоличествоУпаковок,Рецептура,Цена,Сумма");
		СтрокаБлюда.Ссылка = Объект.Ссылка;
		Если Элементы.Товары.ТекущиеДанные = Неопределено Тогда
			ПоказатьПредупреждение(,"Не выбрана строка блюда");
			Возврат;
		КонецЕсли;
		 
		ЗаполнитьЗначенияСвойств(СтрокаБлюда, Элементы.Товары.ТекущиеДанные);
		ОписаниеКоманды.ДополнительныеПараметры.ДополнительныеПараметры.Вставить("ТекущаяСтрокаДляПечати", СтрокаБлюда);
		
	КонецЕсли;
	
	Если ИдентификаторКоманды ="питОП1_СПараметрами" Или ИдентификаторКоманды ="питОП1_ТБ_СПараметрами" Тогда
		ИмяФормыПараметровПечати = "Документ.питВыпускБлюд.Форма.ФормаПараметрыПечатиОП1";
	КонецЕсли;
	
	Если ИмяФормыПараметровПечати <> "" Тогда
		ОбъектыПечати = питОтчетыКлиент.ОбъектыПечати(Объект);
		ПараметрыФормы = Новый Структура("МассивОбъектов", ОбъектыПечати);  //Команда.ОбъектыПечати);
		
		Оповещение = Новый ОписаниеОповещения("ВыполнитьКомандуПечатиЗавершение", ЭтотОбъект, Команда);
		ОткрытьФорму(ИмяФормыПараметровПечати, ПараметрыФормы,,,ВариантОткрытияОкна.ОтдельноеОкно,,Оповещение);
		
	Иначе
		
		ПодключаемыеКомандыКлиент.ВыполнитьКоманду(ЭтотОбъект, Команда, Объект);
		
	КонецЕсли;
	
КонецПроцедуры

