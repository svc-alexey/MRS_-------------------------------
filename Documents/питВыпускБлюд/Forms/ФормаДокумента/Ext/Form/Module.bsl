//
&НаКлиенте
Процедура ОбновитьОтборСтрокВТаблицеПобочныхИзделий()
	
	Перем ТекДанные;
	
	ТекДанные = Элементы.БлюдаПобочныеИзделия.ТекущиеДанные;
	Если ТекДанные <>  Неопределено Тогда
		Элементы.ПобочныеИзделия.ОтборСтрок = Новый ФиксированнаяСтруктура("ИдентификаторБлюда", ТекДанные.ИдентификаторСтроки);
	Иначе
		Элементы.ПобочныеИзделия.ОтборСтрок = Новый ФиксированнаяСтруктура("ИдентификаторБлюда", "xxx");/// Скроем
	КонецЕсли;

КонецПроцедуры

