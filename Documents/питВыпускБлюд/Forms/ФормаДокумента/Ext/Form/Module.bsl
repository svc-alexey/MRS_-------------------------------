&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если ПараметрыЗаписи.Свойство("ПовторныйВызов") И ПараметрыЗаписи.ПовторныйВызов Тогда	
		Возврат;
	КонецЕсли;
	
	Для каждого ТекСтрока Из Объект.Товары Цикл
		ТекСтрока.ПриготовлениеЗапрещено = НЕ ТекСтрока.ПриготовлениеРазрешено;
	КонецЦикла;
	
	Если Объект.РежимРасчетаСписанияВПроизводство = ПредопределенноеЗначение("Перечисление.питРежимыРасчетаСписанияВПроизводство.ПоФакту")
		И ПроверитьЕстьБлюдаБезТоваров(
			ДанныеФормыКоллекцияВМассив(Объект.Товары, "Номенклатура, Характеристика, Упаковка"), 
			ДанныеФормыКоллекцияВМассив(Объект.Блюда, "Номенклатура, Характеристика, УпаковкаНоменклатуры, Автопередел")
		) Тогда
		Режим = РежимДиалогаВопрос.ДаНетОтмена;
		Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопросаПередЗаписью", ЭтаФорма, Параметры);
		ПоказатьВопрос(
			Оповещение, 
			"Найдены блюда, по которым отсутствуют товары в таблице товаров, перезаполнить производство?", 
			Режим, 
			0
		);
		Отказ = Истина;
	КонецЕсли;
	
	//>>Швецов
	Если НЕ Объект.Проведен Тогда
		РезультатОбработки = MRS_ЗагрузкаЕГАИСФронт.ПроверитьОстаткиСерийПоДокументы(
				Объект.Ссылка,
				Объект.Склад, 
				ДанныеФормыКоллекцияВМассив(Объект.ТоварыСерии, "Номенклатура, Серия, Количество, КоличествоУпаковок") 
			);
		
		Если РезультатОбработки = Ложь Тогда
        	Возврат;
    	КонецЕсли;
    
	    // Если РезультатОбработки - строка, обрабатываем
	    Если ТипЗнч(РезультатОбработки) = Тип("Строка") Тогда
	        Режим = РежимДиалогаВопрос.ДаНетОтмена;
	        Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопросаПередЗаписьюПроверкиСерий", ЭтаФорма, ПараметрыЗаписи);
	        ПоказатьВопрос(
	            Оповещение,
	            РезультатОбработки, // Используем строку как текст вопроса
	            Режим,
	            0
	        );
	        Отказ = Истина;
		КонецЕсли;
		
	КонецЕсли;
	//<<
	
КонецПроцедуры

