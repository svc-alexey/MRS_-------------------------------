&НаКлиенте
Процедура ТаблицаНоменклатураПриИзменении(ИмяТЧ, ИмяСклад = Неопределено, ТекущаяСтрока = Неопределено)
	
	КэшированныеЗначенияЛокальные = ОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
	
	Если ТекущаяСтрока = Неопределено Тогда
		ТекущаяСтрока = Элементы[ИмяТЧ].ТекущиеДанные;
	КонецЕсли;
	
	СтруктураДействий = Новый Структура;
											
	Если ИмяТЧ = "Модификаторы" Тогда
		ДобавитьВСтруктуруДействияПриИзмененииНоменклатуры(ИмяТЧ, ТекущаяСтрока, ЭтаФорма, СтруктураДействий, "УпаковкаНоменклатуры");
	Иначе
		ДобавитьВСтруктуруДействияПриИзмененииНоменклатуры(ИмяТЧ, ТекущаяСтрока, ЭтаФорма, СтруктураДействий);
	КонецЕсли;
	
	Если ИмяТЧ <> "Модификаторы" Тогда
		ДобавитьВСтруктуруДействияПриИзмененииКоличестваУпаковок(ИмяТЧ, СтруктураДействий);
	КонецЕсли;
	
	//+Серии
	Если ИмяТЧ <> "Ингредиенты" И ИмяТЧ <> "Замены" 
		И ИмяТЧ <> "Модификаторы" Тогда // Заглушка
		Если ИмяСклад = Неопределено Тогда
			ДобавитьВСтруктуруДействияПоСериям(СтруктураДействий, Объект.Склад, ПараметрыУказанияСерий[ИмяТЧ]);
		Иначе
			ДобавитьВСтруктуруДействияПоСериям(СтруктураДействий, ТекущаяСтрока[ИмяСклад], ПараметрыУказанияСерий[ИмяТЧ]);
		КонецЕсли;
	КонецЕсли;
	//-Серии
	
	Если ИмяТЧ = "Товары" И ЭтоРозница И ТекущаяСтрока.Цена = 0 Тогда
		ПараметрыОбъекта = Новый Структура;
		ПараметрыОбъекта.Вставить("Дата", Объект.Дата);
		ПараметрыОбъекта.Вставить("Валюта", Объект.Валюта);
		ПараметрыОбъекта.Вставить("ВидЦены", РозничныйВидЦены(Объект.СкладПолучатель));
		СтруктураДействий.Вставить("ЗаполнитьЦенуПродажи", ОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруЗаполненияЦеныРозницаВСтрокеТЧ(ПараметрыОбъекта));
	КонецЕсли;
	
	ОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, КэшированныеЗначенияЛокальные);
	
	Если ИмяТЧ = "ВыходныеИзделия"
		ИЛИ ИмяТЧ = "ПобочныеИзделия" Тогда
		
		Если ИмяТЧ = "ВыходныеИзделия" Тогда
			ТекущаяСтрока.Получатель = ПолучательПоУмолчанию(ТекущаяСтрока);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция РозничныйВидЦены(Склад)
	Возврат ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Склад, "РозничныйВидЦены");
КонецФункции

&НаКлиенте
Процедура ТаблицаКоличествоУпаковокПриИзменении(ИмяТЧ)
	
	КэшированныеЗначенияЛокальные = ОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
	
	ТекущаяСтрока = Элементы[ИмяТЧ].ТекущиеДанные;

	СтруктураДействий = Новый Структура;
	
	ДобавитьВСтруктуруДействияПриИзмененииКоличестваУпаковок(ИмяТЧ, СтруктураДействий);
	
	Если ИмяТЧ = "ПобочныеИзделия" Тогда
		СтруктураДействий.Вставить("ПересчитатьСумму");
	КонецЕсли;
	
	ОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, КэшированныеЗначенияЛокальные);
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаУпаковкаПриИзменении(ИмяТЧ)
	
	КэшированныеЗначенияЛокальные = ОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
	
	ТекущаяСтрока = Элементы[ИмяТЧ].ТекущиеДанные;
	
	СтруктураДействий = Новый Структура;
	
	ДобавитьВСтруктуруДействияПриИзмененииКоличестваУпаковок(ИмяТЧ, СтруктураДействий);
	
	ОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, КэшированныеЗначенияЛокальные);
	
КонецПроцедуры

