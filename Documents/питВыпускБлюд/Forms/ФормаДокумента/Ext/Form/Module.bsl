&НаКлиенте
Процедура ТоварыНоменклатураПриИзменении(Элемент)
	
	
	ДанныеСтрокаТаблицы = Новый Структура("Ссылка, Номенклатура, ЭтоУслуга, ЭтоБлюдо, ПриготовлениеРазрешено, Иконка, Рецептура, Характеристика, ИзмененФактБлюда, РецептураПред");
	
	//<<Портал-Юг, Давиденко 2019.02.22 [4.2.7 Нулевая цена и аналитика продаж в отчёте о розничных продажах и выпуске блюд]
	ДанныеСтрокаТаблицы.Вставить("ПЛ_Договор");
	//>>Портал-Юг, Давиденко 2019.02.22
	
	ЗаполнитьЗначенияСвойств(ДанныеСтрокаТаблицы, Элементы.Товары.ТекущиеДанные);
	
	ПараметрыОбъекта = Новый Структура();
	
	ПараметрыОбъекта = Новый Структура("ХозяйственнаяОперация, Организация, Дата, Ссылка, Подразделение, Склад");
	ЗаполнитьЗначенияСвойств(ПараметрыОбъекта, ЭтаФорма);
	ЗаполнитьЗначенияСвойств(ПараметрыОбъекта, Объект);
	ПараметрыОбъекта.Вставить("СпособРасчетаРецептуры", СпособРасчетаРецептуры);
	
	ПараметрыОбъекта.Вставить("Валюта", Объект.Валюта);
	ПараметрыОбъекта.Вставить("Подразделение", Объект.Подразделение);
	ПараметрыОбъекта.Вставить("Склад", Объект.Склад);
	ПараметрыОбъекта.Вставить("ВосприниматьБлюдоБезРецептурыКакТовар", ВосприниматьБлюдоБезРецептурыКакТовар);
	
	ТоварыНоменклатураПриИзмененииНаСервере(ДанныеСтрокаТаблицы, ПараметрыОбъекта);
	
	//<< Портал-Юг, Баринов, 2019.08.22 [9.09. Обособление продаж по открытой цене]	
	Если ЭтотОбъект.ПЛ_ЭтоОткрытаяЦена Тогда 
	// Для открытой цены замена номенклатуры обычное дело, договор тут должен сохраниться из чека.
		ДанныеСтрокаТаблицы.ПЛ_Договор = Элементы.Товары.ТекущиеДанные.ПЛ_Договор;
	КонецЕсли;	
	//>> Портал-Юг, Баринов, 2019.08.22
	
	ЗаполнитьЗначенияСвойств(Элементы.Товары.ТекущиеДанные, ДанныеСтрокаТаблицы);
	
	ТаблицаНоменклатураПриИзменении("Товары");
	
	//>>Швецов.11.02.2025. Розничные продажи алкоголя. 
	//По заборному листу разбиваем серийный алкоголь и все остальное на ОРП и ВН "списание на расходы"
	НеобходимаСтатья = ПроверитьНеобходимостьСтатьиСписания(ДанныеСтрокаТаблицы);
	УправлениеФормой(ЭтаФорма, НеобходимаСтатья);
	//<<Швецов.11.02.2025. Розничные продажи алкоголя. 

КонецПроцедуры

&НаКлиенте
Процедура ТоварыНазначениеПриИзменении(Элемент)
	ТекДанные = Элементы.Товары.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(ТекДанные.НазначениеИнгредиентов) Тогда
		ТекДанные.НазначениеИнгредиентов = ТекДанные.Назначение;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	УправлениеСвойствами.ПриЧтенииНаСервере(ЭтаФорма, ТекущийОбъект);
	
	// СтандартныеПодсистемы.УправлениеДоступом
	Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.УправлениеДоступом") Тогда
		МодульУправлениеДоступом = ОбщегоНазначения.ОбщийМодуль("УправлениеДоступом");
		МодульУправлениеДоступом.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	КонецЕсли;
	// Конец СтандартныеПодсистемы.УправлениеДоступом
	
	ВосприниматьБлюдоБезРецептурыКакТовар = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питВосприниматьБлюдоБезРецептурыКакТовар");
	
	Если ОбщегоНазначенияУТКлиентСервер.АвторизованВнешнийПользователь() Тогда
		ТребуетсяОткрытиеПечатнойФормы = Истина;
		Возврат;
	КонецЕсли;
	
	//+Серии
	ПриЧтенииСозданииНаСервере();
	//+Серии
	
	// Обработчик механизма "ДатыЗапретаИзменения"
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтаФорма, ТекущийОбъект);
	
	//ПриЧтенииСозданииНаСервере();
	
	УправлениеСвойствами.ПриЧтенииНаСервере(ЭтаФорма, ТекущийОбъект);
	
	СобытияФорм.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	
	ПодготовитьФормуНаСервере();
	
	ЗаполнитьДобавленныеКолонкиТаблицыТовары();
	ЗаполнитьДобавленныеКолонкиТаблицыИнгредиентов();
	
	// Выбор статей и аналитик.
	ПараметрыВыбораСтатейИАналитик = Документы.питВыпускБлюд.ПараметрыВыбораСтатейИАналитик(Объект.ХозяйственнаяОперация);
	ДоходыИРасходыСервер.ПриЧтенииНаСервере(ЭтотОбъект, ПараметрыВыбораСтатейИАналитик);
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	//+Серии
	ЗаполнитьПараметрыУказанияСерий();
	УстановитьВидимостьЭлементовСерий();
	//-Серии
	
	УстановитьЗаголовокФормы();
	
	ЗаполнитьДобавленныеКолонкиТаблицыТовары();
	ЗаполнитьДобавленныеКолонкиТаблицыИнгредиентов();
	ЗаполнитьСлужебныеРеквизитыПоНоменклатуре();
	
	Если ЭтоРеализация Тогда
		Если ОбщегоНазначения.ПодсистемаСуществует("ИнтернетПоддержкаПользователей.РаботаСКонтрагентами") Тогда
			МодульПроверкаКонтрагентов = ОбщегоНазначения.ОбщийМодуль("ПроверкаКонтрагентов");
			// СтандартныеПодсистемы.РаботаСКонтрагентами
			МодульПроверкаКонтрагентов.ПослеЗаписиНаСервере(ЭтотОбъект, ТекущийОбъект);
			// Конец СтандартныеПодсистемы.РаботаСКонтрагентами
		КонецЕсли;
	КонецЕсли;
	
	УправлениеФормой(ЭтаФорма);
	
	Если ЭтоРеализация Тогда
		
		ПродажиСервер.УстановитьОтметкуНезаполненногоДоговора(Элементы, "Договор");
		ПродажиСервер.УстановитьДоступностьДоговора(Объект, Элементы.Договор.Доступность, Элементы.ГруппаДоговор.Видимость);
		//Элементы.ГруппаНадписьДоговор.Видимость = Элементы.ГруппаДоговор.Видимость;
		
	КонецЕсли;
	
	ОбновитьИконкиМодификаторов();
	
	//+ИзменениеФактаВПроизводстве
	ОбновитьФактЗаменВТаблицеИнгредиентов();
	//-ИзменениеФактаВПроизводстве
	
	НастроитьЭлементыФормы(ЭтаФорма);
	
	// Выбор статей и аналитик.
	ДоходыИРасходыСервер.ПослеЗаписиНаСервере(ЭтотОбъект);
	
//	
КонецПроцедуры

&НаКлиенте
Процедура ИнгредиентыИнгредиентПриИзменении(Элемент)
	
	ДанныеСтрокаТаблицы = Новый Структура("Ингредиент, Характеристика, ЭтоУслуга, ЭтоБлюдо, ПриготовлениеРазрешено, Иконка, Специя, РецептураАвтопередела, СтатьяКалькуляции, ИзАвтопеределов");
	ЗаполнитьЗначенияСвойств(ДанныеСтрокаТаблицы, Элементы.Ингредиенты.ТекущиеДанные);
	
	ПараметрыОбъекта = Новый Структура("ХозяйственнаяОперация, Организация, Дата, Ссылка, Подразделение, Склад");
	ЗаполнитьЗначенияСвойств(ПараметрыОбъекта, ЭтаФорма);
	ЗаполнитьЗначенияСвойств(ПараметрыОбъекта, Объект);
	ПараметрыОбъекта.Вставить("СпособРасчетаРецептуры", СпособРасчетаРецептуры);
	
	//+ИзменениеФактаВПроизводстве
	питИзменениеФактаВПроизводствеВызовСервера.ИнгредиентыИнгредиентПриИзмененииНаСервере(ДанныеСтрокаТаблицы, ПараметрыОбъекта);
	//-ИзменениеФактаВПроизводстве
	
	ЗаполнитьЗначенияСвойств(Элементы.Ингредиенты.ТекущиеДанные, ДанныеСтрокаТаблицы);
	
	ТаблицаНоменклатураПриИзменении("Ингредиенты");
	
КонецПроцедуры


