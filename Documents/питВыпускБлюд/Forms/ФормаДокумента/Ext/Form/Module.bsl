//<<Портал-Юг, Давиденко 2019.02.26 [4.2.3 Вид операции «Заборный лист» в документе «Выпуск блюд»]
&НаСервере
Процедура ПЛ_СкладПолучательПриИзмененииНаСервере()
	
	Если Не ЗначениеЗаполнено(Объект.СкладПолучатель) Тогда
		Возврат;
	КонецЕсли;
	
	// определение Кассы ККМ
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	КассыККМ.Ссылка КАК КассаККМ
	|ИЗ
	|	Справочник.КассыККМ КАК КассыККМ
	|ГДЕ
	|	КассыККМ.Склад = &Склад
	|	И КассыККМ.Владелец = &Организация
	|	И НЕ КассыККМ.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	Запрос.УстановитьПараметр("Склад", Объект.СкладПолучатель);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если не РезультатЗапроса.Пустой() Тогда	
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		ВыборкаДетальныеЗаписи.Следующий(); 
		Объект.КассаККМ = ВыборкаДетальныеЗаписи.КассаККМ;  
	Иначе
		Объект.КассаККМ = Справочники.КассыККМ.ПустаяСсылка();  
	КонецЕсли;
	
	// определение вида цен
	Стр = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.СкладПолучатель, "РозничныйВидЦены, РозничныйВидЦены.ЦенаВключаетНДС");
	Объект.ТипЦен = Стр.РозничныйВидЦены;
	Объект.ЦенаВключаетНДС = Стр.РозничныйВидЦеныЦенаВключаетНДС;
	Объект.СуммаВключаетНДС = Объект.ЦенаВключаетНДС;
	
КонецПроцедуры//>>Портал-Юг, Давиденко 2019.02.26

//<<Портал-Юг, Давиденко 2019.02.26 [4.2.3 Вид операции «Заборный лист» в документе «Выпуск блюд»]
