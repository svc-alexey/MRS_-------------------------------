	Объект = Форма.Объект;
	
	Инициализация = ПустаяСтрока(СписокРеквизитов);
	СтруктураРеквизитов = Новый Структура(СписокРеквизитов);
	
	//УстановитьПараметрыВыбораНазначенияПродукции(Форма, Элементы.ТоварыНазначение, ?(ЗначениеЗаполнено(Объект.СкладПолучатель), Объект.СкладПолучатель, Объект.Склад));
	//УстановитьПараметрыВыбораНазначенияПродукции(Форма, Элементы.ТоварыНазначениеИнгредиентов, Объект.Склад);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьПараметрыВыбораНазначенияПродукции(Форма, ПолеНазначение, Склад)
	
	Элементы = Форма.Элементы;
	Объект = Форма.Объект;
	
	НовыйМассив = Новый Массив();
	
	НовыйПараметрВыбора = Новый ПараметрВыбора("РежимВыбораНазначений", "Расширенный");
	НовыйМассив.Добавить(НовыйПараметрВыбора);
	
	НовыйПараметрВыбора = Новый ПараметрВыбора("ВключатьЗаказыДавальцев", Истина);
	НовыйМассив.Добавить(НовыйПараметрВыбора);
	
	НовыйПараметрВыбора = Новый ПараметрВыбора("СкладПолучатель", Склад);
	НовыйМассив.Добавить(НовыйПараметрВыбора);
	
	НовыеПараметрыВыбора = Новый ФиксированныйМассив(НовыйМассив);
	ПолеНазначение.ПараметрыВыбора = НовыеПараметрыВыбора;
	
КонецПроцедуры

