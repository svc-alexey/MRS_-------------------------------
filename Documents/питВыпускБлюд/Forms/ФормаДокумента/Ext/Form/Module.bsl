&НаСервере
Процедура СкладПриИзмененииНаСервере()
	ЗаполнитьНалогообложениеНДС();
	Если ЗначениеЗаполнено(Объект.Склад) Тогда
		РеквизитыСклада = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.Склад, "ЦеховаяКладовая, Подразделение");
		Если РеквизитыСклада.ЦеховаяКладовая 
			И Объект.Подразделение <> РеквизитыСклада.Подразделение Тогда
			Объект.Подразделение = РеквизитыСклада.Подразделение;
			ПодразделениеОрганизацииПриИзмененииНаСервере();
		КонецЕсли;
	КонецЕсли;
	// << MRS #ERP-5312 ДенисламовАД <Adel.Denislamov@mriyaresort.com> 23.07.25, ()
	УстановитьОрганизациюПоСкладу("Изменение");
	// >> MRS #ERP-5312 ДенисламовАД <Adel.Denislamov@mriyaresort.com> 23.07.25, ()
