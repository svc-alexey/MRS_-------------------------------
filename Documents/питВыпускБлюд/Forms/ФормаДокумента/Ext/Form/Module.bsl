&НаКлиенте
Процедура ЗаменыПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	Если Не Копирование И НоваяСтрока Тогда
		ТекданныеБлюдо = Элементы.ВыпущеннаяПродукцияЗамены.ТекущиеДанные;
		Если НЕ ТекданныеБлюдо = Неопределено Тогда
			Элемент.ТекущиеДанные.Блюдо = ТекданныеБлюдо.Номенклатура;
			Элемент.ТекущиеДанные.Рецептура = ТекданныеБлюдо.Рецептура;
			Элемент.ТекущиеДанные.Автопередел = ТекданныеБлюдо.Автопередел;
			Элемент.ТекущиеДанные.ХарактеристикаБлюда = ТекданныеБлюдо.Характеристика;
		КонецЕсли;
	КонецЕсли;
	//ОбновитьКешированныеЗначенияДляУчетаСерий("Замены", Элемент, КэшированныеЗначения, Копирование);
КонецПроцедуры

&НаКлиенте
Процедура БлюдаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ТекДанные = Элемент.ТекущиеДанные;
	Если НЕ ТекДанные = Неопределено 
		И НЕ Элемент.ТекущийЭлемент = Неопределено
		И Элемент.ТекущийЭлемент = Элементы.БлюдаРецептура 
		//+ИзменениеФактаВПроизводстве
		И Объект.РежимРасчетаСписанияВПроизводство = ПредопределенноеЗначение("Перечисление.питРежимыРасчетаСписанияВПроизводство.ПоНорме") Тогда
		//-ИзменениеФактаВПроизводстве
		
		СтандартнаяОбработка = Ложь;
		Попытка
			ПоказатьЗначение(, ТекДанные.Рецептура);
		Исключение
		КонецПопытки;
	КонецЕсли;
КонецПроцедуры

