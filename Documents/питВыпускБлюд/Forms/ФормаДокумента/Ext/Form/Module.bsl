&НаСервере
// Заполнение колонок "Товары.Всего", "Товары.ЭтоУслуга", "Товары.ЭтоБлюдо", "Товары.СчетУчетаЗабалансовый"
Процедура ЗаполнитьДобавленныеКолонкиТаблицыТовары()
	// Процедура из документа ОтчетОРозничныхПродажах
	
	ТаблицаТовары = Объект.Товары.Выгрузить(, "Номенклатура,СчетУчета");
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВЫРАЗИТЬ(Таб.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура
	|ПОМЕСТИТЬ ВТ_ТаблицаУслуг
	|ИЗ
	|	&ТаблицаТовары КАК Таб
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Таб.Номенклатура КАК Номенклатура,
	|	Таб.Номенклатура.питВидНоменклатуры КАК ВидНоменклатуры
	|ПОМЕСТИТЬ ТаблицаУслуг
	|ИЗ
	|	ВТ_ТаблицаУслуг КАК Таб
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаУслуг.Номенклатура КАК Номенклатура,
	|	ТаблицаУслуг.ВидНоменклатуры КАК ВидНоменклатуры,
	|	ТаблицаУслуг.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.питВидыНоменклатуры.Услуга) КАК ЭтоУслуга,
	|	ТаблицаУслуг.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.питВидыНоменклатуры.Блюдо) КАК ЭтоБлюдо
	|ИЗ
	|	ТаблицаУслуг КАК ТаблицаУслуг";
	Запрос.УстановитьПараметр("ТаблицаТовары", ТаблицаТовары);
	
	ТаблицаУслуг = Запрос.Выполнить().Выгрузить();
	ТаблицаУслуг.Индексы.Добавить("Номенклатура");
	
	ПодразделениеПроизводстваПолуфабрикатов = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питПодразделениеПроизводстваПолуфабрикатов");
	
	Для каждого СтрокаДокумента Из Объект.Товары Цикл
		// Заполняем колонки "ЭтоУслуга" и "ЭтоБлюдо"
		СтрокаУслуги = ТаблицаУслуг.Найти(СтрокаДокумента.Номенклатура, "Номенклатура");
		СтрокаДокумента.ЭтоУслуга = СтрокаУслуги.ЭтоУслуга;
		СтрокаДокумента.ЭтоБлюдо  = СтрокаУслуги.ЭтоБлюдо;
		ПодразделениеРазрешено = питПроизводствоПовтИсп.ПодразделениеРазрешено(СтрокаДокумента.Рецептура, Объект.Подразделение, Объект.Склад,,,ПодразделениеПроизводстваПолуфабрикатов);
		СтрокаДокумента.ПриготовлениеРазрешено = ?(ЗначениеЗаполнено(СтрокаДокумента.Рецептура), ПодразделениеРазрешено, НЕ ВосприниматьБлюдоБезРецептурыКакТовар);
		СтрокаДокумента.Всего = СтрокаДокумента.Сумма + ?(Объект.ЦенаВключаетНДС, 0, СтрокаДокумента.СуммаНДС);
		СтрокаДокумента.Иконка = питДокументы.ОпределитьНомерИконкиНоменклатуры(СтрокаУслуги.ВидНоменклатуры, Ложь, СтрокаДокумента.ПриготовлениеРазрешено);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДобавленныеКолонкиТаблицыИнгредиентов()
	// Процедура из документа ОтчетОРозничныхПродажах
	
	ТаблицаТовары = Объект.Ингредиенты.Выгрузить(, "Ингредиент");
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВЫРАЗИТЬ(Таб.Ингредиент КАК Справочник.Номенклатура) КАК Номенклатура
	|ПОМЕСТИТЬ ВТ_ТаблицаУслуг
	|ИЗ
	|	&ТаблицаТовары КАК Таб
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Таб.Номенклатура КАК Номенклатура,
	|	Таб.Номенклатура.питВидНоменклатуры КАК ВидНоменклатуры
	|ПОМЕСТИТЬ ТаблицаУслуг
	|ИЗ
	|	ВТ_ТаблицаУслуг КАК Таб
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаУслуг.Номенклатура КАК Номенклатура,
	|	ТаблицаУслуг.ВидНоменклатуры КАК ВидНоменклатуры,
	|	ТаблицаУслуг.ВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.питВидыНоменклатуры.Блюдо) КАК ЭтоБлюдо
	|ИЗ
	|	ТаблицаУслуг КАК ТаблицаУслуг";
	Запрос.УстановитьПараметр("ТаблицаТовары", ТаблицаТовары);
	
	ТаблицаУслуг = Запрос.Выполнить().Выгрузить();
	ТаблицаУслуг.Индексы.Добавить("Номенклатура");
	
	ПодразделениеПроизводстваПолуфабрикатов = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питПодразделениеПроизводстваПолуфабрикатов");
	
	Для каждого СтрокаДокумента Из Объект.Ингредиенты Цикл
		// Заполняем колонки "ЭтоУслуга" и "ЭтоБлюдо"
		СтрокаУслуги = ТаблицаУслуг.Найти(СтрокаДокумента.Ингредиент, "Номенклатура");
		СтрокаДокумента.ЭтоБлюдо  = СтрокаУслуги.ЭтоБлюдо;
		СтрокаДокумента.ПриготовлениеРазрешено = питПроизводствоПовтИсп.ПодразделениеРазрешено(СтрокаДокумента.РецептураАвтопередела, Объект.Подразделение, Объект.Склад,,,ПодразделениеПроизводстваПолуфабрикатов);
		СтрокаДокумента.Иконка = питДокументы.ОпределитьНомерИконкиНоменклатуры(СтрокаУслуги.ВидНоменклатуры, СтрокаДокумента.Специя, СтрокаДокумента.ПриготовлениеРазрешено);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьЗаголовокФормы()
	
	ТекстЗаголовка = НСтр("ru = 'Выпуск блюд'");
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ТекстЗаголовка = ТекстЗаголовка + СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru=' %1 от %2'"), Объект.Номер, Формат(Объект.Дата, "ДЛФ=D"));
	Иначе
		ТекстЗаголовка = ТекстЗаголовка + НСтр("ru = ' (создание)'");
	КонецЕсли;
	
	//<<Портал-Юг, Давиденко 2019.02.14 [4.2.3 Вид операции «Заборный лист» в документе «Выпуск блюд»]
	//Заголовок = ТекстЗаголовка + " (" + Строка(Объект.ХозяйственнаяОперация) +". "+ Строка(Объект.РежимРасчетаСписанияВПроизводство) + ")";
