&НаКлиенте
Процедура ПодборПоМеню(Команда)
		
	Отказ = Ложь;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Документ",        Объект.Ссылка);
	ПараметрыФормы.Вставить("Склад",      Объект.Склад);
	ПараметрыФормы.Вставить("Дата",       Объект.Дата);
	ПараметрыФормы.Вставить("РежимПодбораИспользоватьСкладыВТабличнойЧасти", Истина);
	ПараметрыФормы.Вставить("РежимПодбораИсключитьГруппыДоступныеВЗаказах",  Истина);
	
	
	ОткрытьФорму("Обработка.питПодборТоваровПоМеню.Форма", ПараметрыФормы, ЭтаФорма, УникальныйИдентификатор);
	

КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)  
	
	// << MRS #VINE-72 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 05.06.25, (Массовая загрузка марок в Акт внутреннее потребление)
	Если ИнтеграцияИСКлиент.ЭтоЗагрузкаКодовМаркировки(ИсточникВыбора, ЭтотОбъект) Тогда
		Для Каждого ТекШтрихкод Из ВыбранноеЗначение Цикл 
			ОбработатьШтрихкоды(ТекШтрихкод);
		КонецЦикла;
	КонецЕсли;
	// >> MRS #VINE-72 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 05.06.25, (Массовая загрузка марок в Акт внутреннее потребление)
	
	Если НоменклатураКлиент.ЭтоУказаниеСерий(ИсточникВыбора) Тогда
		
		НоменклатураКлиент.ОбработатьУказаниеСерии(ЭтаФорма, ПараметрыУказанияСерий[ВыбранноеЗначение.ИмяТЧ], ВыбранноеЗначение);
		
	КонецЕсли;
	
	Если Окно <> Неопределено Тогда
		Окно.Активизировать();
	КонецЕсли;
	
	Если ИсточникВыбора.ИмяФормы = "Обработка.питПодборТоваровПоМеню.Форма.Форма" Тогда
		
		ОбработкаВыбораПодборНаСервере(ВыбранноеЗначение);
		
	ИначеЕсли ИсточникВыбора.ИмяФормы = "Обработка.ПодборТоваровВДокументПродажи.Форма.Форма" Тогда
		
		//+ИзменениеФактаВПроизводстве
		Если СтрНайти(ИсточникВыбора.Заголовок, "товар") Тогда
			ОбработкаВыбораПодборТоваровНаСервере(ВыбранноеЗначение);
		ИначеЕсли СтрНайти(ИсточникВыбора.Заголовок, "ингредиент") Тогда
			ИдентификаторСтрокиБлюда = Элементы.Блюда.ТекущаяСтрока;
			ОбработкаВыбораПодборИнгредиентовНаСервере(ИдентификаторСтрокиБлюда, ВыбранноеЗначение);
		КонецЕсли;
		//-ИзменениеФактаВПроизводстве
		
	ИначеЕсли ИсточникВыбора.ИмяФормы = "ОбщаяФорма.питФормаПодбораХарактеристик" Тогда
		//+АвтовыборНоменклатуры
		ОбработкаВыбораПодборХарактеристикНаСервере(ВыбранноеЗначение);
		УправлениеФормой(ЭтаФорма);
		//-АвтовыборНоменклатуры
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаВыбораПодборНаСервере(ВыбранноеЗначение)
	
	ТаблицаТоваров = ПолучитьИзВременногоХранилища(ВыбранноеЗначение.АдресТоваровВХранилище);
	
	//<<Портал-Юг, Давиденко 2019.02.19 [4.2.7 Нулевая цена и аналитика продаж в отчёте о розничных продажах и выпуске блюд]
	ПЛ_Сервер.ДополнитьТаблицуТоварыДоговором(ТаблицаТоваров);
	//>>Портал-Юг, Давиденко 2019.02.19
	
	Для каждого СтрокаТовара Из ТаблицаТоваров Цикл
		
		ТекущаяСтрока = Объект.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(ТекущаяСтрока, СтрокаТовара);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаВыбораПодборТоваровНаСервере(ВыбранноеЗначение)
	
	ТаблицаТоваров = ПолучитьИзВременногоХранилища(ВыбранноеЗначение.АдресТоваровВХранилище);
	//<<Портал-Юг, Давиденко 2019.02.19 [4.2.7 Нулевая цена и аналитика продаж в отчёте о розничных продажах и выпуске блюд]
	ПЛ_Сервер.ДополнитьТаблицуТоварыДоговором(ТаблицаТоваров);
	//>>Портал-Юг, Давиденко 2019.02.19
	Для каждого СтрокаТовара Из ТаблицаТоваров Цикл
		
		ТекущаяСтрока = Объект.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(ТекущаяСтрока, СтрокаТовара);
		
		// Дозаполним еще реквизиты, такие как "Рецептура", "ЭтоБлюдо", "ЭтоТовар" и т.д.
		СписокСвойствСтрокой = "Номенклатура, Характеристика, ЭтоУслуга, ЭтоБлюдо, ПриготовлениеРазрешено, ЭтоТовар, Иконка, Рецептура, ИзмененФактБлюда, РецептураПред";
		//<<Портал-Юг, Гребенюк 2023.05.12 [Обновление на 2.5, перенос доработки 4.2.7 Нулевая цена и аналитика продаж в отчёте о розничных продажах и выпуске блюд]
		СписокСвойствСтрокой = СписокСвойствСтрокой + ", ПЛ_Договор";
		//>>Портал-Юг, Гребенюк 2023.05.12
		ДанныеСтрокаТаблицы = Новый Структура(СписокСвойствСтрокой);
		ЗаполнитьЗначенияСвойств(ДанныеСтрокаТаблицы, ТекущаяСтрока);
		
		СвойстваПараметрыОбъектаСтрокой = "ХозяйственнаяОперация, Организация, Дата, Ссылка, Подразделение, Склад";
		ПараметрыОбъекта = Новый Структура();
		ПараметрыОбъекта = Новый Структура(СвойстваПараметрыОбъектаСтрокой);
		ПараметрыОбъекта.Вставить("СпособРасчетаРецептуры", СпособРасчетаРецептуры);
		ПараметрыОбъекта.Вставить("ВосприниматьБлюдоБезРецептурыКакТовар", ВосприниматьБлюдоБезРецептурыКакТовар);
		ЗаполнитьЗначенияСвойств(ПараметрыОбъекта, ЭтаФорма);
		ЗаполнитьЗначенияСвойств(ПараметрыОбъекта, Объект);
		
		ТоварыНоменклатураПриИзмененииНаСервере(ДанныеСтрокаТаблицы, ПараметрыОбъекта);
		
		ЗаполнитьЗначенияСвойств(ТекущаяСтрока, ДанныеСтрокаТаблицы);
		
	КонецЦикла;
	
КонецПроцедуры

