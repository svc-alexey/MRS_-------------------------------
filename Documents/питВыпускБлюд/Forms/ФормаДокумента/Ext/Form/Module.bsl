&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	//<<<<<Мажутко
	Элементы.ИнгредиентыУпаковкаИнгредиента.Доступность = ЛОЖЬ;
	//<<<<<Мажутко

	питИзменениеОтраслевыхФормСервер.ПриСозданииНаСервереВНачале(ЭтаФорма, Отказ, СтандартнаяОбработка);
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Объект", Объект);
	ДополнительныеПараметры.Вставить("ИмяЭлементаДляРазмещения", "ГруппаДополнительныеРеквизиты");
	УправлениеСвойствами.ПриСозданииНаСервере(ЭтотОбъект, ДополнительныеПараметры);
	
	//+АвтовыборНоменклатуры
	НайденыОшибкиАвтовыбора = питУправлениеДаннымиОбИзделиях.ЗаполнитьНайденыОшибкиАвтовыбора(Объект.УточненияАвтовыбора);
	//+АвтовыборНоменклатуры
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) И ЗначениеЗаполнено(Объект.ДокументОснование) Тогда
	
		РезультатЗапроса = Документы.питВыпускБлюд.РезультатЗапросаСвязанныеВыпускиБлюд(Объект.ДокументОснование);
		ПредставленияВыпусковБлюд.Очистить();
		ПредставлениеПланаМеню = "";
		Если НЕ РезультатЗапроса.Пустой() Тогда
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				ПредставлениеПланаМеню = ВыборкаДетальныеЗаписи.ПредставлениеПланаМеню;
				НовСтрокаПредставление = ПредставленияВыпусковБлюд.Добавить();
				НовСтрокаПредставление.ВыпускБлюд = ВыборкаДетальныеЗаписи.ВыпускБлюд;
				НовСтрокаПредставление.Представление = ВыборкаДетальныеЗаписи.Представление;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	ИспользоватьСоглашенияСКлиентами                  = ПолучитьФункциональнуюОпцию("ИспользоватьСоглашенияСКлиентами");
	
	ВосприниматьБлюдоБезРецептурыКакТовар = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питВосприниматьБлюдоБезРецептурыКакТовар");
	
	ИзмененыТовары = Ложь;
	
	//ЕРП
	УстановитьУсловноеОформление();
	Если Параметры.Свойство("АвтоТест") Тогда // Возврат при получении формы для анализа.
		Возврат;
	КонецЕсли;
	ОбновлениеИнформационнойБазы.ПроверитьОбъектОбработан(Объект, ЭтотОбъект);
	
	// Обработчик механизма "Назначения"
	Справочники.Назначения.ФормаДокументаПриСозданииНаСервере(ЭтаФорма);
	//ЕРП
	
	//+Серии
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		
		ПриЧтенииСозданииНаСервере();
		
	КонецЕсли;
	//-Серии
	
	ПоСоглашениюИспользуютсяДоговорыКонтрагентов = ЗначениеЗаполнено(Объект.Соглашение) И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Соглашение, "ИспользуютсяДоговорыКонтрагентов");
	УправлениеСвязямиПараметровВыбораРеквизитовФормы();
	
	ЗаполнитьНалогообложениеНДС();

	
	ФормироватьДокументыПроизводства22 = Константы.питФормироватьДокументыПроизводства22.Получить();
	Если ФормироватьДокументыПроизводства22 Тогда
		
		//// Склад
		//Элементы.Склад.Заголовок = "Цеховая кладовая";
		//НовыйПараметр = Новый ПараметрВыбора("Отбор.ЦеховаяКладовая", Истина);
		//НовыйМассив = Новый Массив();
		//НовыйМассив.Добавить(НовыйПараметр);
		//НовыеПараметры = Новый ФиксированныйМассив(НовыйМассив);
		//Элементы.Склад.ПараметрыВыбора = НовыеПараметры;
		//
		//// Склад
		//НовыйПараметр = Новый СвязьПараметраВыбора("Отбор.Подразделение", "Объект.Подразделение");
		//НовыйМассив = Новый Массив();
		//НовыйМассив.Добавить(НовыйПараметр);
		//НовыеПараметры = Новый ФиксированныйМассив(НовыйМассив);
		//Элементы.Склад.СвязиПараметровВыбора = НовыеПараметры;
		
		
		// Касса ККМ
		//НовыйПараметр = Новый СвязьПараметраВыбора("Отбор.Склад", "Объект.СкладПолучатель");
		//НовыйМассив = Новый Массив();
		//НовыйМассив.Добавить(НовыйПараметр);
		//НовыеПараметры = Новый ФиксированныйМассив(НовыйМассив);
		//Элементы.КассаККМ.СвязиПараметровВыбора = НовыеПараметры;
		
	Иначе
		Элементы.Склад.Заголовок = "Склад";
		
		// Касса ККМ
		//НовыйПараметр = Новый СвязьПараметраВыбора("Отбор.Склад", "Объект.Склад");
		//НовыйМассив = Новый Массив();
		//НовыйМассив.Добавить(НовыйПараметр);
		//НовыеПараметры = Новый ФиксированныйМассив(НовыйМассив);
		//Элементы.КассаККМ.СвязиПараметровВыбора = НовыеПараметры;
		
	КонецЕсли;

	
	//<<Портал-Юг, Давиденко 2019.02.13 [4.2.3 Вид операции «Заборный лист» в документе «Выпуск блюд»]
	//Для динамического размещения реквизитов на форму
	СобытияФорм.ПриСозданииНаСервере(ЭтаФорма, Отказ, СтандартнаяОбработка);
	//>>Портал-Юг, Давиденко 2019.02.13
	
	УстановитьЗаголовокФормы();
	УправлениеФормой(ЭтаФорма);
	
	ПродажиСервер.УстановитьОтметкуНезаполненногоДоговора(Элементы, "Договор");
	ПродажиСервер.УстановитьДоступностьДоговора(Объект, Элементы.Договор.Доступность, Элементы.ГруппаДоговор.Видимость);
	//Элементы.ГруппаНадписьДоговор.Видимость = Элементы.ГруппаДоговор.Видимость;
	
	// СтандартныеПодсистемы.ВерсионированиеОбъектов
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов
	
	//>>Швецов. 18.12.2024. Розничные продажи алкоголя. Вызов события сканирования штрихкода
	ОбщегоНазначенияУТ.НастроитьПодключаемоеОборудование(ЭтаФорма);
	//<<Швецов. 18.12.2024. Розничные продажи алкоголя. Вызов события сканирования штрихкода
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	Если ОбщегоНазначения.ПодсистемаСуществует("ИнтернетПоддержкаПользователей.РаботаСКонтрагентами") Тогда
		МодульПроверкаКонтрагентов = ОбщегоНазначения.ОбщийМодуль("ПроверкаКонтрагентов");
		МодульПроверкаКонтрагентовВызовСервераПереопределяемыйУТ = ОбщегоНазначения.ОбщийМодуль("ПроверкаКонтрагентовВызовСервераПереопределяемыйУТ");
		// СтандартныеПодсистемы.РаботаСКонтрагентами
		МодульПроверкаКонтрагентов.ПриСозданииНаСервереДокумент(ЭтотОбъект, Параметры);
		МодульПроверкаКонтрагентовВызовСервераПереопределяемыйУТ.ФормаДокументаПриСозданииНаСервере(ЭтотОбъект);
		// Конец СтандартныеПодсистемы.РаботаСКонтрагентами
	КонецЕсли;
	
	ПараметрыВыбораСтатейИАналитик = Документы.питВыпускБлюд.ПараметрыВыбораСтатейИАналитик(Объект.ХозяйственнаяОперация);
	ДоходыИРасходыСервер.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыВыбораСтатейИАналитик);
	
	Если Параметры.Ключ.Пустая() Тогда
		ПодготовитьФормуНаСервере();
		// Для нового документа
		Объект.питОтложитьОплату = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("ОтложитьОплату");
		Если НЕ ЗначениеЗаполнено(Объект.СтатьяКалькуляции) Тогда
			Объект.СтатьяКалькуляции = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("СтатьяКалькуляцииПоУмолчанию");
		КонецЕсли;
	Иначе
		Объект.СуммаВключаетНДС = Объект.ЦенаВключаетНДС;
	КонецЕсли;
	
	УстановитьВидимостьКомандПечати();
	
	ЗаполнитьСлужебныеРеквизитыПоНоменклатуре();
	
	ОбновитьИконкиМодификаторов();
	
	//+ИзменениеФактаВПроизводстве
	ОбновитьФактЗаменВТаблицеИнгредиентов();
	питИзменениеФактаВПроизводстве.ИнициализироватьИменаКолонокРеквизитов(ЭтаФорма);
	//-ИзменениеФактаВПроизводстве 
	
	// << MRS #VINE-72 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 05.06.25, (Массовая загрузка марок в Акт внутреннее потребление)
	НоваяКоманда = ЭтаФорма.Команды.Добавить("MRS_ЗагрузитьИзВнешнегоФайла");
	НоваяКоманда.Заголовок = "Загрузить из внешнего файла (MRS)";
	НоваяКоманда.Действие = "MRS_ЗагрузитьИзВнешнегоФайла"; //указываем только имя процедуры
	НоваяКоманда.Картинка = БиблиотекаКартинок.ЗагрузкаИзВнешнегоИсточника;   
	
	НовыйЭлемент = ЭтаФорма.Элементы.Добавить("MRS_ТоварыЗагрузитьИзВнешнегоФайла", Тип("КнопкаФормы"), Элементы.ТоварыКоманднаяПанель);
	НовыйЭлемент.Заголовок = "";
	НовыйЭлемент.ИмяКоманды = "MRS_ЗагрузитьИзВнешнегоФайла";
	НовыйЭлемент.Отображение = ОтображениеКнопки.Картинка;
	// >> MRS #VINE-72 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 05.06.25, (Массовая загрузка марок в Акт внутреннее потребление)
	
	/// << MRS #ERP-5312 ДенисламовАД <Adel.Denislamov@mriyaresort.com> 23.07.25, ()
	УстановитьОрганизациюПоСкладу("Чтение");
	// >> MRS #ERP-5312 ДенисламовАД <Adel.Denislamov@mriyaresort.com> 23.07.25, ()
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	//>>Швецов. 18.12.2024. Розничные продажи алкоголя. Вызов события сканирования штрихкода
	МенеджерОборудованияКлиент.НачатьПодключениеОборудованиеПриОткрытииФормы(Неопределено, ЭтаФорма, "СканерШтрихкода");
	//<<Швецов. 18.12.2024. Розничные продажи алкоголя. Вызов события сканирования штрихкода
	
	УправлениеСвойствамиКлиент.ПослеЗагрузкиДополнительныхРеквизитов(ЭтотОбъект);
	Для каждого ВыборкаДетальныеЗаписи Из ПредставленияВыпусковБлюд Цикл
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Обратите внимание, что по <"+ПредставлениеПланаМеню+">
		|уже создан <"+ВыборкаДетальныеЗаписи.Представление+">";
		Сообщение.КлючДанных = ВыборкаДетальныеЗаписи.ВыпускБлюд;
		Сообщение.ИдентификаторНазначения = ЭтаФорма.УникальныйИдентификатор;
		Сообщение.Сообщить();
	КонецЦикла;
	
	// << MRS # ВикторовАГ <Artem.Viktorov@mriyaresort.com> 15.05.25,
	Попытка
		СписокСообщенийСоздания = ЭтаФорма["MRS_СписокСообщенийСоздания"]
	Исключение
		СписокСообщенийСоздания = Новый Массив;
	КонецПопытки;

	Если СписокСообщенийСоздания.Количество() > 0 Тогда    
		СтрокаСообщения = "";
		Для Каждого ТекСообщение Из СписокСообщенийСоздания Цикл 
			СтрокаСообщения = СтрокаСообщения + ТекСообщение.Значение + "
																		|";
		КонецЦикла;
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = СтрокаСообщения;
		Сообщение.ИдентификаторНазначения = ЭтаФорма.УникальныйИдентификатор;
		Сообщение.Сообщить();
	КонецЕсли;   
	
	// << MRS #VINE-250 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 14.01.26, (Корректировка Выпусков блюд, с отправленными в ЕГАИС Актами списания)
	MRS_РазрешениеРедактированияВыпускаБлюд = MRS_Сервер.ПолучитьДопСведениеОбъекта(Объект.Ссылка, "MRS_РазрешениеРедактированияВыпускаБлюд");
	Если MRS_РазрешениеРедактированияВыпускаБлюд = Неопределено Тогда 
		MRS_РазрешениеРедактированияВыпускаБлюд = Ложь;
	КонецЕсли;
	
	Если ЭтотОбъект.ТолькоПросмотр И (MRS_Сервер.РольДоступнаВызовСервера("ПолныеПрава") ИЛИ  MRS_РазрешениеРедактированияВыпускаБлюд) Тогда
		ОписаниеОповещенияВопрос = Новый ОписаниеОповещения("MRS_ПослеВопросаОткрытияНаРедактирование", ЭтотОбъект);   
		ПоказатьВопрос(ОписаниеОповещенияВопрос,"Форма заблокирована по внутренним проверкам. Открыть?",РежимДиалогаВопрос.ДаНет, 0);
	КонецЕсли;
	// >> MRS #VINE-250 ВикторовАГ <Artem.Viktorov@mriyaresort.com> 14.01.26, (Корректировка Выпусков блюд, с отправленными в ЕГАИС Актами списания)
	
	// >> MRS # ВикторовАГ <Artem.Viktorov@mriyaresort.com> 15.05.25,
	
КонецПроцедуры

