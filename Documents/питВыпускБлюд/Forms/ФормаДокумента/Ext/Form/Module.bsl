Процедура УстановитьЗаголовкиКолонок()
	
	ЗаголовокЦена = ?(Объект.ЦенаВключаетНДС, НСтр("ru='Цена с НДС'"), НСтр("ru='Цена без НДС'"));
	ЗаголовокСумма = ?(Объект.ЦенаВключаетНДС, НСтр("ru='Сумма с НДС'"), НСтр("ru='Сумма без НДС'"));
	
	Элементы.ТоварыЦена.Заголовок = ЗаголовокЦена;
	Элементы.ТоварыСумма.Заголовок = ЗаголовокСумма;
	
	Элементы.УслугиЦена.Заголовок = ЗаголовокЦена;
	Элементы.УслугиСумма.Заголовок = ЗаголовокСумма;
	
	Элементы.АгентскиеУслугиЦена.Заголовок = ЗаголовокЦена;
	Элементы.АгентскиеУслугиСумма.Заголовок = ЗаголовокСумма;
	
