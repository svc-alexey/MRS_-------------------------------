&НаСервере
Процедура ПодготовитьФормуНаСервере()
	
	ЭтоРозница     = (Объект.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.ВыпускПродукцииСРозничнойРеализацией);
	ЭтоРеализация  = (Объект.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.ВыпускПродукцииСРеализацией);
	ЭтоПеремещение = (Объект.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.ВыпускПродукцииСПеремещением);
	ЭтоСписание    = (Объект.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.ВыпускПродукцииСоСписанием);
	
	///УстановитьФункциональныеОпцииФормы();   // все установится в подкладном документе.
	
	ВалютаРегламентированногоУчета = питПроизводствоПовтИсп.ПолучитьВалютуРегламентированногоУчета();
	
	ПоказыватьВДокументахСчетаУчета	= Истина;
	
	// Закладки производства
	//ЗаполнитьТаблицуВыпущеннаяПродукция();
	ВыпущеннаяПродукцияТекущаяСтрока = 0;
	
	// Рассчитываем только колонку ФактЗамены
	///***---питПроизводство.ЗаписатьВТаблицуПроизводствоФактЗанены(Объект.Производство, Объект.Замены);
	
	//СпособРасчетаРецептуры = Константы.питСпособРасчетаРецептур.Получить();
	СпособРасчетаРецептуры = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("СпособРасчетаРецептур");
	
	Если НЕ ЗначениеЗаполнено(Объект.РежимПриготовленияМодификаторов) Тогда
		Объект.РежимПриготовленияМодификаторов = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питВидыПроизводстваМодификаторов");
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.ВидПроизводства) Тогда
		Объект.ВидПроизводства = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питРежимПриготовленияПолуфабрикатов");
	КонецЕсли;
	
	СпособРасчетаРецептурыПоАктуальной = (СпособРасчетаРецептуры = Перечисления.питСпособРасчетаРецептур.ПоАктуальнойРецептуре);
	
	ТипСклада = ПолучитьТипСкладаНаСервере(Объект.Склад);
	
	ИскатьПоВсемОрганизациям = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("ИскатьРецептурыПоВсемОрганизациям");
	
	Если НЕ СпособРасчетаРецептурыПоАктуальной И НЕ ИскатьПоВсемОрганизациям Тогда
		НоваяСвязьПараметровВыбора = Новый СвязьПараметраВыбора("Отбор.Организация", "Объект.Организация");
		питОбщегоНазначения.ЗаменитьСвязьПараметровВыбора(Элементы.ТоварыРецептура, "Отбор.Организация", НоваяСвязьПараметровВыбора)
	КонецЕсли;
	
	УстановитьЗаголовокФормы();
	
	ЗаполнитьДобавленныеКолонкиТаблиц();
	УстановитьЗаголовкиКолонокНаСервере();
	
	// Для всех
	УправлениеФормой(ЭтаФорма);
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаОповещенияОбработкиТабличнойЧастиТоварыНаСервере(Параметры)
	
	ТаблицаОбработки = ПолучитьИзВременногоХранилища(Параметры.АдресОбработаннойТабличнойЧастиТоварыВХранилище);
	
	Для Каждого СтрокаТабличнойЧасти ИЗ ТаблицаОбработки Цикл
		
		РеквизитыНоменклатуры = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СтрокаТабличнойЧасти.Номенклатура, "питВидНоменклатуры");
		СтрокаТабличнойЧасти.ЭтоУслуга = (РеквизитыНоменклатуры.питВидНоменклатуры = Перечисления.питВидыНоменклатуры.Услуга);
		СтрокаТабличнойЧасти.ЭтоБлюдо  = (РеквизитыНоменклатуры.питВидНоменклатуры = Перечисления.питВидыНоменклатуры.Блюдо);
		
	КонецЦикла;
	
	ОбновитьИтоги(ЭтаФорма);
	
КонецПроцедуры

// Процедура обновляет отбор таблицы ингредиентов на форме по текущему значению идентификатора строки в таблице блюд.
//
&НаКлиенте
Процедура ОбновитьОтборСтрокВТаблицеИнгредиентов()
	
	Перем ТекДанные;
	
	ТекДанные = Элементы.Блюда.ТекущиеДанные;
	Если ТекДанные <>  Неопределено Тогда
		Если Элементы.ИнгредиентыТолькоИзмененные.Пометка Тогда
			Элементы.Ингредиенты.ОтборСтрок = Новый ФиксированнаяСтруктура("ИдентификаторБлюда, ИзмененФакт", ТекДанные.ИдентификаторСтроки, Истина);
		Иначе
			Элементы.Ингредиенты.ОтборСтрок = Новый ФиксированнаяСтруктура("ИдентификаторБлюда", ТекДанные.ИдентификаторСтроки);
		КонецЕсли;
	Иначе
		Элементы.Ингредиенты.ОтборСтрок = Новый ФиксированнаяСтруктура("ИдентификаторБлюда", "xxx");/// Скроем
	КонецЕсли;

КонецПроцедуры

