&НаКлиенте
Процедура ИнгредиентыПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	Если Не Копирование И НоваяСтрока Тогда
		ТекданныеБлюдо = Элементы.Блюда.ТекущиеДанные;
		Если НЕ ТекданныеБлюдо = Неопределено Тогда
			Элемент.ТекущиеДанные.ИдентификаторБлюда = ТекданныеБлюдо.ИдентификаторСтроки;
		КонецЕсли;
	КонецЕсли;
	//ОбновитьКешированныеЗначенияДляУчетаСерий("Ингредиенты", Элемент, КэшированныеЗначения, Копирование);
