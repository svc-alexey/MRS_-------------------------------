&НаКлиенте
Процедура МодификаторыПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Отказ = Истина;
	Если Копирование Тогда
		Возврат;
	КонецЕсли;
	
	// Должен быть установлен вид обработки.
	ТекДанныеТовары = Элементы.Товары.ТекущиеДанные;
	Если ТекДанныеТовары = Неопределено Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не установлен товар в списке товаров!");
		Возврат;
	КонецЕсли;
	
	// Открытие формы выбора.
	ТекДанныеОбъект = Новый Структура("Дата, Организация, Подразделение, СпособРасчетаРецептуры", Объект.Дата, Объект.Организация, Объект.Подразделение, СпособРасчетаРецептуры);
	СтрПараметры = Новый Структура("ТекущаяСтрокаТЧ, ТекДанныеОбъект", Новый Структура("Номенклатура, Характеристика, ИдентификаторСтроки", ТекДанныеТовары.Номенклатура, ТекДанныеТовары.Характеристика, ТекДанныеТовары.ИдентификаторСтроки),ТекДанныеОбъект);
	ФормаВыбора = ПолучитьФорму("Документ.питВыпускБлюд.Форма.ФормаПодбораМодификаторов",СтрПараметры,Элемент);
	ФормаВыбора.Открыть();
	
КонецПроцедуры

&НаКлиенте
Процедура МодификаторыОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	Если НЕ Элемент.ТекущийЭлемент = Неопределено
		И (Элемент.ТекущийЭлемент = Элементы.МодификаторыСтатусУказанияСерий
		ИЛИ Элемент.ТекущийЭлемент = Элементы.МодификаторыСерия
		ИЛИ Элемент.ТекущийЭлемент = Элементы.МодификаторыГруппаСерия) Тогда
		
		ТаблицаОбработкаВыбора("Модификаторы", ВыбранноеЗначение);
		
	Иначе
		
		// Из формы выбора модификаторов.
		
		ТекДанные = Элементы.Товары.ТекущиеДанные;
		Если НЕ ТекДанные = Неопределено Тогда
			
			Если ПустаяСтрока(ТекДанные.ИдентификаторСтроки) Тогда
				ТекДанные.ИдентификаторСтроки = Новый УникальныйИдентификатор;
			КонецЕсли;
			
			ДобавитьМодификаторы(ВыбранноеЗначение, ТекДанные.ИдентификаторСтроки);
			
			Для каждого ТекМод Из Объект.Модификаторы Цикл
				//ТекДанныеМод = Элементы.Модификаторы.Найти ТекМод.ПолучитьИдентификатор()
				ТаблицаНоменклатураПриИзменении("Модификаторы",,ТекМод);
			КонецЦикла;
			
			ОбновитьОтборСтрокВТаблицеМодификаторов();
			
			ПослеИзмененияСтрокТЧПрограммноНаСервере("Модификаторы");
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьМодификаторы(АдресТаблицы, ИдентификаторСтроки)
	
	ТаблицаДобавить = ПолучитьИзВременногоХранилища(АдресТаблицы);
	Для каждого ТекСтрокаДобавить Из ТаблицаДобавить Цикл
		НайденныеСтроки = Объект.Модификаторы.НайтиСтроки(Новый Структура("Модификатор, ИдентификаторСтроки", ТекСтрокаДобавить.Модификатор, ИдентификаторСтроки));
		Если НайденныеСтроки.Количество() Тогда
			
			ТекСтрокаМод = НайденныеСтроки[0];
			
			ТекСтрокаМод.Количество						= ТекСтрокаМод.Количество + ТекСтрокаДобавить.Количество;
			ТекСтрокаМод.КоличествоНоменклатуры			= ТекСтрокаМод.КоличествоНоменклатуры + ТекСтрокаДобавить.КоличествоНоменклатуры;
			ТекСтрокаМод.КоличествоУпаковокНоменклатуры	= ТекСтрокаМод.КоличествоУпаковокНоменклатуры + ТекСтрокаДобавить.КоличествоУпаковокНоменклатуры;
			
			ТекСтрокаМод.Сумма = ТекСтрокаМод.Сумма + (ТекСтрокаДобавить.Количество*ТекСтрокаМод.Цена);
			
		Иначе
			
			ТекСтрокаМод = Объект.Модификаторы.Добавить();
			ЗаполнитьЗначенияСвойств(ТекСтрокаМод, ТекСтрокаДобавить);
			ТекСтрокаМод.Номенклатура = ТекСтрокаДобавить.НоменклатураОсновнойПозиции;
			ТекСтрокаМод.Характеристика = ТекСтрокаДобавить.ХарактеристикаОсновнойПозиции;
			ТекСтрокаМод.УпаковкаНоменклатуры = ТекСтрокаДобавить.ЕдиницаИзмеренияНоменклатуры;
			ТекСтрокаМод.ИдентификаторСтроки = ИдентификаторСтроки;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура МодификаторыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекДанные = Элемент.ТекущиеДанные;
	Если НЕ ТекДанные = Неопределено 
		И НЕ Элемент.ТекущийЭлемент = Неопределено Тогда
		
		Если (Элемент.ТекущийЭлемент = Элементы.МодификаторыМодификатор) Тогда
			ИмяЭлемента = "Модификатор";
		ИначеЕсли Элемент.ТекущийЭлемент = Элементы.МодификаторыНоменклатура Тогда
			ИмяЭлемента = "Номенклатура";
		ИначеЕсли Элемент.ТекущийЭлемент = Элементы.МодификаторыРецептура Тогда
			ИмяЭлемента = "Рецептура";
		КонецЕсли;
		
		Если НЕ ПустаяСтрока(ИмяЭлемента) Тогда
			СтандартнаяОбработка = Ложь;
			Попытка
				ПоказатьЗначение(, ТекДанные[ИмяЭлемента]);
			Исключение
			КонецПопытки;
		КонецЕсли;
	КонецЕсли;
	
	Если (Поле = Элементы["МодификаторыСерия"] 
				ИЛИ Поле = Элементы["МодификаторыСтатусУказанияСерий"]) Тогда
		ТаблицаВыборСерии("Модификаторы", Поле, Элемент, СтандартнаяОбработка);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьИконкиМодификаторов()
	
	ВидыНоменклатуры = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(Объект.Модификаторы.Выгрузить(,"Номенклатура").ВыгрузитьКолонку("Номенклатура"),"питВидНоменклатуры");
	
	Для каждого ТекМодификатор Из Объект.Модификаторы Цикл
		ТекМодификатор.Иконка = питДокументы.ОпределитьНомерИконкиНоменклатуры(ВидыНоменклатуры[ТекМодификатор.Номенклатура], Ложь, Истина, Истина);
	КонецЦикла;
	
