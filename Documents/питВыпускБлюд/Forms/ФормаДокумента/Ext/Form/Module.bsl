&НаКлиентеНаСервереБезКонтекста
Процедура ДобавитьВСтруктуруДействияПриИзмененииКоличестваУпаковок(ИмяТЧ, СтруктураДействий)
	
	ПараметрыПересчета = Новый Структура("НужноОкруглять", Ложь);
	СтруктураДействий.Вставить("ПересчитатьКоличествоЕдиниц", ПараметрыПересчета);
	Если ИмяТЧ = "ПобочныеИзделия" Тогда
		СтруктураДействий.Вставить("ПересчитатьСумму");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ДобавитьВСтруктуруДействияПриИзмененииНоменклатуры(ИмяТЧ, ТекущаяСтрока, Форма, СтруктураДействий, ИмяРеквизитаУпаковка = "Упаковка")

	Объект = Форма.Объект;
	
	// << MRS # ВикторовАГ <Artem.Viktorov@mriyaresort.com> 19.05.25, (Единицы измерения в документы по умолчанию)
	//Если Не ТекущаяСтрока = Неопределено Тогда
	//	СтруктураДействий.Вставить("ПроверитьЗаполнитьУпаковкуПоВладельцу", ТекущаяСтрока[ИмяРеквизитаУпаковка]);
	//Иначе
	//	СтруктураДействий.Вставить("ПроверитьЗаполнитьУпаковкуПоВладельцу");
	//КонецЕсли;                                                                                                    
	СтруктураДействий.Вставить("MRS_ЗаполнитьЕдиницуИзмеренияВДокументыПоУмолчанию");
	// >> MRS # ВикторовАГ <Artem.Viktorov@mriyaresort.com> 19.05.25, (Единицы измерения в документы по умолчанию)
	
	Если ИмяТЧ = "Товары" Тогда
		СтруктураДействий.Вставить("ЗаполнитьСтавкуНДС", Новый Структура("НалогообложениеНДС, Дата, Организация", Форма.НалогообложениеНДС, Объект.Дата, Объект.Организация));
		СтруктураДействий.Вставить("ПересчитатьСуммуНДС", ОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ(Объект));
		СтруктураДействий.Вставить("ПересчитатьСумму");
		//<< Портал-Юг, Баринов, 2019.09.06 [б/н исправление]
		// При изменении номенклатуры сумма пересчитываестя без учёта скидки
		СтруктураДействий.Вставить("ПересчитатьСуммуРучнойСкидки");
		СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомРучнойСкидки", Новый Структура("Очищать", Ложь));
		//>> Портал-Юг, Баринов, 2019.09.06
	КонецЕсли;
	
	Если ИмяТЧ <> "Ингредиенты" И ИмяТЧ <> "Замены" Тогда
		СтруктураДействий.Вставить("ЗаполнитьПризнакХарактеристикиИспользуются",
		Новый Структура("Номенклатура", "ХарактеристикиИспользуются"));
		СтруктураДействий.Вставить("ЗаполнитьПризнакАртикул",
		Новый Структура("Номенклатура", "Артикул"));
		СтруктураДействий.Вставить("ЗаполнитьПризнакТипНоменклатуры",
		Новый Структура("Номенклатура", "ТипНоменклатуры"));
	КонецЕсли;
	
	СтруктураДействий.Вставить("НоменклатураПриИзмененииПереопределяемый", Новый Структура("ИмяФормы, ИмяТабличнойЧасти",
		Форма.ИмяФормы, ИмяТЧ));
	
	Если ИмяТЧ = "Замены" Тогда
		Если Форма.Элементы[ИмяТЧ].ТекущийЭлемент = Форма.Элементы.ЗаменыИнгредиентИсходный Тогда
			СтруктураДействий.Вставить("ЗаполнитьПризнакХарактеристикиИспользуются",
			Новый Структура("ИнгредиентИсходный", "ХарактеристикиИнгредиентаИсходногоИспользуются"));
		Иначе
			СтруктураДействий.Вставить("ЗаполнитьПризнакХарактеристикиИспользуются",
			Новый Структура("ИнгредиентЗамена", "ХарактеристикиИнгредиентаЗаменаИспользуются"));
		КонецЕсли;
	КонецЕсли;
	
	Если ИмяТЧ = "Ингредиенты" Тогда
		СтруктураДействий.Вставить("ЗаполнитьПризнакХарактеристикиИспользуются",
		Новый Структура("Ингредиент", "ХарактеристикиИспользуются"));
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ПолучательПоУмолчанию(ТекСтрока)
	
	СтруктураСтроки = Новый Структура("НаправлениеВыпуска, Получатель");
	ЗаполнитьЗначенияСвойств(СтруктураСтроки, ТекСтрока);
	СтруктураСтроки.НаправлениеВыпуска = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ВыпускПродукцииНаСклад");
	
	Возврат ПолучательПоУмолчаниюНаСервере(СтруктураСтроки);
	
КонецФункции

&НаСервере
Функция ПолучательПоУмолчаниюНаСервере(ТекСтрока)
	
	Если ТекСтрока.НаправлениеВыпуска = Перечисления.ХозяйственныеОперации.ВыпускПродукцииВПодразделение
		И Не ЗначениеЗаполнено(ТекСтрока.Получатель) Тогда
		Возврат Объект.Подразделение;
	ИначеЕсли ТекСтрока.НаправлениеВыпуска = Перечисления.ХозяйственныеОперации.ВыпускПродукцииНаСклад Тогда
		Если ТипЗнч(ТекСтрока.Получатель) = Тип("СправочникСсылка.Склады")
			И Не ТекСтрока.Получатель.Подразделение = Объект.Подразделение Тогда
			ТекСтрока.Получатель = Неопределено;
		КонецЕсли;
		Возврат ЗначениеНастроекПовтИсп.ПолучитьЦеховуюКладовуюПоУмолчанию(Объект.Подразделение, ТекСтрока.Получатель);
	Иначе
		Возврат ТекСтрока.Получатель;
	КонецЕсли;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьСлужебныеРеквизитыПоНоменклатуре()
	
	ПараметрыЗаполненияРеквизитов = Новый Структура;
	ПараметрыЗаполненияРеквизитов.Вставить("ЗаполнитьПризнакХарактеристикиИспользуются",
											Новый Структура("Номенклатура", "ХарактеристикиИспользуются"));
	ПараметрыЗаполненияРеквизитов.Вставить("ЗаполнитьПризнакАртикул",
											Новый Структура("Номенклатура", "Артикул"));
	ПараметрыЗаполненияРеквизитов.Вставить("ЗаполнитьПризнакТипНоменклатуры",
											Новый Структура("Номенклатура", "ТипНоменклатуры"));
											
	НоменклатураСервер.ЗаполнитьСлужебныеРеквизитыПоНоменклатуреВКоллекции(Объект.ПобочныеИзделия,	ПараметрыЗаполненияРеквизитов);
	
	ПараметрыЗаполненияРеквизитов = Новый Структура;
	ПараметрыЗаполненияРеквизитов.Вставить("ЗаполнитьПризнакХарактеристикиИспользуются",
											Новый Структура("Номенклатура", "ХарактеристикиИспользуются"));
	ПараметрыЗаполненияРеквизитов.Вставить("ЗаполнитьПризнакАртикул",
											Новый Структура("Номенклатура", "Артикул"));
	ПараметрыЗаполненияРеквизитов.Вставить("ЗаполнитьПризнакТипНоменклатуры",
											Новый Структура("Номенклатура", "ТипНоменклатуры"));
											
	НоменклатураСервер.ЗаполнитьСлужебныеРеквизитыПоНоменклатуреВКоллекции(Объект.Товары,	ПараметрыЗаполненияРеквизитов);
	
	ПараметрыЗаполненияРеквизитов = Новый Структура;
	ПараметрыЗаполненияРеквизитов.Вставить("ЗаполнитьПризнакХарактеристикиИспользуются",
	Новый Структура("Блюдо", "ХарактеристикиБлюдаИспользуются"));
	НоменклатураСервер.ЗаполнитьСлужебныеРеквизитыПоНоменклатуреВКоллекции(Объект.Замены,	ПараметрыЗаполненияРеквизитов);
	ПараметрыЗаполненияРеквизитов.Вставить("ЗаполнитьПризнакХарактеристикиИспользуются",
	Новый Структура("ИнгредиентИсходный", "ХарактеристикиИнгредиентаИсходногоИспользуются"));
	НоменклатураСервер.ЗаполнитьСлужебныеРеквизитыПоНоменклатуреВКоллекции(Объект.Замены,	ПараметрыЗаполненияРеквизитов);
	ПараметрыЗаполненияРеквизитов.Вставить("ЗаполнитьПризнакХарактеристикиИспользуются",
	Новый Структура("ИнгредиентЗамена", "ХарактеристикиИнгредиентаЗаменаИспользуются"));
	
	НоменклатураСервер.ЗаполнитьСлужебныеРеквизитыПоНоменклатуреВКоллекции(Объект.Замены,	ПараметрыЗаполненияРеквизитов);
	
	ПараметрыЗаполненияРеквизитов = Новый Структура;
	ПараметрыЗаполненияРеквизитов.Вставить("ЗаполнитьПризнакХарактеристикиИспользуются",
											Новый Структура("Номенклатура", "ХарактеристикиИспользуются"));
	ПараметрыЗаполненияРеквизитов.Вставить("ЗаполнитьПризнакТипНоменклатуры",
											Новый Структура("Номенклатура", "ТипНоменклатуры"));
	НоменклатураСервер.ЗаполнитьСлужебныеРеквизитыПоНоменклатуреВКоллекции(Объект.Блюда,	ПараметрыЗаполненияРеквизитов);
	
	ПараметрыЗаполненияРеквизитов = Новый Структура;
	ПараметрыЗаполненияРеквизитов.Вставить("ЗаполнитьПризнакХарактеристикиИспользуются",
											Новый Структура("Ингредиент", "ХарактеристикиИспользуются"));
	НоменклатураСервер.ЗаполнитьСлужебныеРеквизитыПоНоменклатуреВКоллекции(Объект.Ингредиенты,	ПараметрыЗаполненияРеквизитов);
	//+ИзменениеФактаВПроизводстве
	Для каждого ТекИнгредиент Из Объект.Ингредиенты Цикл
		ТекИнгредиент.КоличествоУпаковокИнгредиентаФактПред = ТекИнгредиент.КоличествоУпаковокИнгредиентаФакт;
		ТекИнгредиент.КоличествоИнгредиентаФактПред = ТекИнгредиент.КоличествоИнгредиентаФакт;
		ТекИнгредиент.РецептураАвтопеределаПред = ТекИнгредиент.РецептураАвтопередела;
	КонецЦикла;
	Для каждого ТекБлюдо Из Объект.Блюда Цикл
		ТекБлюдо.РецептураПред = ТекБлюдо.Рецептура;
	КонецЦикла;
	Для каждого ТекТовар Из Объект.Товары Цикл
		ТекТовар.РецептураПред = ТекТовар.Рецептура;
	КонецЦикла;
	//-ИзменениеФактаВПроизводстве
	
	//+Модификаторы
	ПараметрыЗаполненияРеквизитов = Новый Структура;
	ПараметрыЗаполненияРеквизитов.Вставить("ЗаполнитьПризнакХарактеристикиИспользуются",
											Новый Структура("Номенклатура", "ХарактеристикиИспользуются"));
	ПараметрыЗаполненияРеквизитов.Вставить("ЗаполнитьПризнакАртикул",
											Новый Структура("Номенклатура", "Артикул"));
	ПараметрыЗаполненияРеквизитов.Вставить("ЗаполнитьПризнакТипНоменклатуры",
											Новый Структура("Номенклатура", "ТипНоменклатуры"));
											
	НоменклатураСервер.ЗаполнитьСлужебныеРеквизитыПоНоменклатуреВКоллекции(Объект.Модификаторы,	ПараметрыЗаполненияРеквизитов);
	//-Модификаторы
	
	
КонецПроцедуры

