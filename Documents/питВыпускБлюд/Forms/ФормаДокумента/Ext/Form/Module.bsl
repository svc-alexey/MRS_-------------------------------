//<< Портал-Юг, Баринов, 2019.08.21 [Интерфейс]
&НаКлиенте
Процедура Подключаемый_ПЛ_ЗаполнитьВремя()
	
	ПолеТовары = Элементы.Товары;
	ИмяКолонки = ПолеТовары.ТекущийЭлемент.Имя;
	
	Если СтрНайти(ИмяКолонки, "ПЛ_ВремяПриготовления") = 0 Тогда
		ТекстСообщения = НСтр("ru = 'Должна быть выделена колонка с временем.'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли; 
	
	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("ИмяКолонки", ИмяКолонки); 
	ДопПараметры.Вставить("Строки", ПолеТовары.ВыделенныеСтроки); 
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПЛ_ЗаполнитьВремяЗавершение", ЭтотОбъект, ДопПараметры);
	ПоказатьВводДаты(ОписаниеОповещения,,НСтр("ru = 'Укажите время'"), ЧастиДаты.Время); 
	
КонецПроцедуры //>> Портал-Юг, Баринов, 2019.08.21

//<< Портал-Юг, Баринов, 2019.08.21 [9.03 Заполнение способа обеспечения у ТМЦ на основе подразделений рецептов]
&НаКлиенте
Процедура ПЛ_ЗаполнитьВремяЗавершение(ВведеннаяДата, ДопПараметры) Экспорт

	Если Не ЗначениеЗаполнено(ВведеннаяДата) Тогда
		Возврат;
	КонецЕсли; 
	
	Для каждого текСтрока Из ДопПараметры.Строки Цикл
		ДанныеСтроки = Объект.Товары.НайтиПоИдентификатору(текСтрока);
		Если ДанныеСтроки <> Неопределено Тогда
			ДанныеСтроки[ДопПараметры.ИмяКолонки] = ВведеннаяДата;
		КонецЕсли; 
	КонецЦикла; 
	
КонецПроцедуры//>> Портал-Юг, Баринов, 2019.08.21

