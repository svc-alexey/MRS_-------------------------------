//// ПРОЦЕДУРЫ И ФУНКЦИИ ОБЩЕГО НАЗНАЧЕНИЯ
////

&НаСервере
Процедура ЗаполнитьПроизводства()
	
	//Проверка незаполненных рецептур выходных изделий
	НезаполненныеРецептуры = Объект.Товары.НайтиСтроки(Новый Структура("Рецептура, ЭтоБлюдо, ПриготовлениеРазрешено",Документы.питРецептура.ПустаяСсылка(),Истина, Истина));
	Если НезаполненныеРецептуры.Количество() Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось заполнить производства! Есть незаполненные рецептуры в таблице выходных изделий!");
		ОчиститьПроизводствоСервер();
		Возврат;
	КонецЕсли;
	
	//<<Портал-Юг, Давиденко 2019.03.12 [6.2.10 Отражение производства услуг по СКЛ]
	// необходимо иметь возможность вводить дубли	
	//Если НЕ Документы.питВыпускБлюд.ПроверитьТоварыНаДубли(Объект) Тогда
	//	Возврат;
	//КонецЕсли;
	//>>Портал-Юг, Давиденко 2019.03.12	
	
	//+ИзменениеФактаВПроизводстве
	//<<=== ПорталЮгКрым Плотникова Н. после обновления ERP 03.06.2021 
	//ЕстьИзмененныеБлюда = питИзменениеФактаВПроизводстве.ЕстьИзмененныеБлюдаТовары(Неопределено, Объект.Товары);
	ЕстьИзмененныеБлюда = Истина;	
	//>>=== ПорталЮгКрым Плотникова Н. после обновления ERP 03.06.2021
	//-ИзменениеФактаВПроизводстве
	
	ДокументОбъект = РеквизитФормыВЗначение("Объект",Тип("ДокументОбъект.питВыпускБлюд"));
	// Заполним нормативным составом
	
	//+АвтовыборНоменклатуры
	МассивДеревьевСостава = Новый Массив;
	//+АвтовыборНоменклатуры
	ТаблицаПроизводства = питПроизводство.ЗаполнитьПроизводственныеТаблицыПоРецептуре(ДокументОбъект, ЕстьИзмененныеБлюда,,,МассивДеревьевСостава,Объект.УточненияАвтовыбора);
	
	//+АвтовыборНоменклатуры
	питУправлениеДаннымиОбИзделиях.ЗаполнитьУточненияАвтовыбора(МассивДеревьевСостава, Объект.УточненияАвтовыбора);
	НайденыОшибкиАвтовыбора = питУправлениеДаннымиОбИзделиях.ЗаполнитьНайденыОшибкиАвтовыбора(Объект.УточненияАвтовыбора);
	//+АвтовыборНоменклатуры
	
	//+РазрешенныеПодразделения
	Объект.Товары.Загрузить(питПроизводство.УстановитьЗапрещенныеТовары(ТаблицаПроизводства, Объект.Товары.Выгрузить()));
	//-РазрешенныеПодразделения
	
	ТаблицаПроизводства.Колонки.Добавить("ФактЗамены", новый ОписаниеТипов("Число"));
	
	ОписаниеТиповСтрока = Новый ОписаниеТипов("Строка");
	
	Объект.Замены.Очистить();
	СтруктураПараметров = Новый Структура("МоментВремени, СчитатьФактВТаблицеЗамен, Склад, Организация, Подразделение, РежимИспользованияАналогов, ОрганизацияПрименяетУСН");
	СтруктураПараметров.МоментВремени  = питПроизводство.ПолучитьМоментВремениКонтроляОстатковВыпуска(ДокументОбъект);
	СтруктураПараметров.СчитатьФактВТаблицеЗамен = Ложь;
	СтруктураПараметров.Склад = Объект.Склад;
	СтруктураПараметров.Организация = Объект.Организация;
	СтруктураПараметров.Подразделение = Объект.Подразделение;
	СтруктураПараметров.РежимИспользованияАналогов = Объект.РежимИспользованияАналогов;
	СтруктураПараметров.ОрганизацияПрименяетУСН = Ложь;////ОбщептЕРП!!!
	СтруктураПараметров.Вставить("СсылкаНаДокумент", ?(ДокументОбъект.Ссылка.Пустая(), Неопределено, ДокументОбъект.Ссылка));
	СтруктураПараметров.Вставить("ВидПроизводства", ДокументОбъект.ВидПроизводства);
	
	питПроизводство.ЗаполнитьПроизводственныеТаблицыФактическимКоличеством(ТаблицаПроизводства,Объект.Замены , СтруктураПараметров);
	
	Если НЕ Объект.РазрешитьНедовложения Тогда
		// Остаточную нехватку пишем в КоличествоФакт, и заполняем колонку ФактЗамены
		питПроизводство.ЗаписатьОстаточныеНехваткиВКоличествоФакт(ТаблицаПроизводства, Объект.Замены);
	Иначе
		// Рассчитываем только колонку ФактЗамены
		питПроизводство.ЗаписатьВТаблицуПроизводствоФактЗанены(ТаблицаПроизводства, Объект.Замены);
	КонецЕсли;
	
	// Заполняем таблицу производства
	Если ТаблицаПроизводства <> Неопределено Тогда
		
		Объект.Блюда.Очистить();
		Объект.Ингредиенты.Очистить();

		ТаблицаПроизводства.Колонки.ЕдиницаИзмеренияНоменклатуры.Имя = "УпаковкаНоменклатуры";
		ТаблицаПроизводства.Колонки.ЕдиницаИзмеренияИнгредиента.Имя  = "УпаковкаИнгредиента";
		
		ТаблБлюд = ТаблицаПроизводства.Скопировать(,"Номенклатура,Характеристика,Серия,Назначение,УпаковкаНоменклатуры,Рецептура,Автопередел,КоличествоНоменклатуры,КоличествоУпаковокНоменклатуры,Порядок");
		ТаблБлюд.Свернуть("Номенклатура,Характеристика,Серия,Назначение,Рецептура,УпаковкаНоменклатуры,Автопередел,КоличествоНоменклатуры, КоличествоУпаковокНоменклатуры,Порядок");
		ТаблБлюд.Колонки.Добавить("ИдентификаторСтроки", ОписаниеТиповСтрока, ,36);
		
		ТаблицаПроизводства.Колонки.Добавить("ИдентификаторБлюда", ОписаниеТиповСтрока, ,36);
		
		
		Для Каждого Стр из ТаблБлюд Цикл
			
			Стр.ИдентификаторСтроки = Новый УникальныйИдентификатор;
			
			МассивСтрокингредиентов = ТаблицаПроизводства.НайтиСтроки(Новый Структура("Номенклатура,Характеристика,Серия,Назначение,УпаковкаНоменклатуры,Рецептура,Автопередел",Стр.Номенклатура,Стр.Характеристика,Стр.Серия,Стр.Назначение,Стр.УпаковкаНоменклатуры,Стр.Рецептура, Стр.Автопередел ) );
			
			Для Каждого СтрИнгр из МассивСтрокингредиентов Цикл
				
				НовСтрТаблИнгредиентов = Объект.Ингредиенты.Добавить();
				ЗаполнитьЗначенияСвойств(НовСтрТаблИнгредиентов, СтрИнгр);
				НовСтрТаблИнгредиентов.ИдентификаторБлюда = Стр.ИдентификаторСтроки;
				НовСтрТаблИнгредиентов.Блюдо = Стр.Номенклатура;
				
				НовСтрТаблИнгредиентов.Характеристика = СтрИнгр.ХарактеристикаИнгредиента;
				НовСтрТаблИнгредиентов.Назначение = СтрИнгр.НазначениеИнгредиента;
				НовСтрТаблИнгредиентов.Серия = Справочники.СерииНоменклатуры.ПустаяСсылка();
	
			КонецЦикла;
			
			// >> ERP-5928. Швецов. 30.06.2026.
			// В питЛицнзировании по какой-то причине не заполняет ед.измерения,
			// в последствии дублирует строки в производстве
			Если НЕ ЗначениеЗаполнено(Стр.УпаковкаНоменклатуры) Тогда
				Стр.УпаковкаНоменклатуры = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Стр.Номенклатура,"ЕдиницаИзмерения"); 	
			КонецЕсли;
			// <<
			
		КонецЦикла;
		//ТаблИнгредиентов = ТаблицаПроизводства.Скопировать(,"ИдентификаторБлюда,Ингредиент,УпаковкаИнгредиента,КоличествоИнгредиентаНорма,КоличествоУпаковокИнгредиентаНорма,СезонныйПроцент,КоличествоИнгредиентаФакт,ИзАвтопеределов,РецептураАвтопередела,Специя,ЗапретитьЗамены,Замена,КоэффициентЗамены,СчетУчета,Субконто,СчетЗатрат,ОтражениеВУСН,Порядок");
		Объект.Блюда.Загрузить(ТаблБлюд);
		
		ДополнительныеТаблицыВыпускаПоТаблицеБлюд = питПроизводство.ПолучитьДополнительныеТаблицыВыпускаПоТаблицеБлюд(ТаблБлюд,";0;1;");
		Объект.Трудозатраты.Загрузить(ДополнительныеТаблицыВыпускаПоТаблицеБлюд[0]);
		Объект.ПобочныеИзделия.Загрузить(ДополнительныеТаблицыВыпускаПоТаблицеБлюд[1]);
		
		// Заполнение серии в ТЧ "Ингредиенты".
		СтрокиАвтопеределов = Объект.Ингредиенты.НайтиСтроки(Новый Структура("ИзАвтопеределов", Истина));
		Для каждого ТекАвтопередел Из СтрокиАвтопеределов Цикл
			СтрокиБлюдо = Объект.Блюда.НайтиСтроки(Новый Структура("Номенклатура,Характеристика,Рецептура,Автопередел", ТекАвтопередел.Ингредиент, ТекАвтопередел.Характеристика, ТекАвтопередел.РецептураАвтопередела, Истина));
			Если СтрокиБлюдо.Количество() Тогда
				СтрокаБлюдо = СтрокиБлюдо[0];
				ТекАвтопередел.Серия = СтрокаБлюдо.Серия;
			КонецЕсли;
		КонецЦикла;
		
		//+ИзменениеФактаВПроизводстве
		Для каждого ТекТовар Из Объект.Блюда Цикл
			ТекТовар.ИзмененФактБлюда = Ложь;
		КонецЦикла;
		//-ИзменениеФактаВПроизводстве
		
	КонецЕсли;
	
	Для каждого ТекСтрокаИнгредиент Из Объект.Ингредиенты Цикл
		Если НЕ ЗначениеЗаполнено(ТекСтрокаИнгредиент.КоличествоИнгредиентаНорма) И ЗначениеЗаполнено(ТекСтрокаИнгредиент.КоличествоУпаковокИнгредиентаНорма) Тогда
			ТекСтрокаИнгредиент.КоличествоИнгредиентаНорма = ТекСтрокаИнгредиент.КоличествоУпаковокИнгредиентаНорма * питОбщегоНазначения.ПолучитьКоэффициентУпаковки(ТекСтрокаИнгредиент.Ингредиент, ТекСтрокаИнгредиент.УпаковкаИнгредиента);
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(ТекСтрокаИнгредиент.КоличествоИнгредиентаФакт) И ЗначениеЗаполнено(ТекСтрокаИнгредиент.КоличествоУпаковокИнгредиентаФакт) Тогда
			ТекСтрокаИнгредиент.КоличествоИнгредиентаФакт = ТекСтрокаИнгредиент.КоличествоУпаковокИнгредиентаФакт * питОбщегоНазначения.ПолучитьКоэффициентУпаковки(ТекСтрокаИнгредиент.Ингредиент, ТекСтрокаИнгредиент.УпаковкаИнгредиента);
		КонецЕсли;
	КонецЦикла;
	
	ЗаполнитьДобавленныеКолонкиТаблицыИнгредиентов();
	ЗаполнитьСлужебныеРеквизитыПоНоменклатуре();
	ПослеИзмененияСтрокТЧПрограммноНаСервере("Блюда");
	ПослеИзмененияСтрокТЧПрограммноНаСервере("Ингредиенты");
	ПослеИзмененияСтрокТЧПрограммноНаСервере("Замены");
	ПослеИзмененияСтрокТЧПрограммноНаСервере("Модификаторы");
	
	Документы.питВыпускБлюд.ПроверитьМодификаторы(Объект.Модификаторы);
	
КонецПроцедуры

//// Серверная обработка изменения реквизитов:

&НаСервере
Процедура ВидОперацииПриИзмененииНаСервере()
	
	//<<Загребалов И., Апрель-Софт, 25.02.2022.SD72585 утилизация ШЛ
	ВыполнятьПересчет = Истина;
	
	ВыпускБлюдСоСписанием = Перечисления.питХозяйственныеОперации.ВыпускПродукцииСоСписанием;
	Если Объект.ПЛ_ХозяйственнаяОперация = ВыпускБлюдСоСписанием Тогда 
		БылиИзменения = Ложь;
		
		Для Каждого СтрокаТовары Из Объект.Товары Цикл
			СтрокаТовары.ПЛ_Передано = СтрокаТовары.ПЛ_Возвращено;
			СтрокаТовары.КоличествоУпаковок = СтрокаТовары.ПЛ_Передано;
			СтрокаТовары.ПЛ_Возвращено = 0;
			БылиИзменения = Истина;
		КонецЦикла;
		
		Если БылиИзменения Тогда
			СтруктураДействий = Новый Структура;
			СтруктураДействий.Вставить("ПересчитатьКоличествоЕдиниц");
			ОбработкаТабличнойЧастиСервер.ОбработатьТЧ(Объект.Товары, СтруктураДействий, Неопределено);
		КонецЕсли;
	ИначеЕсли Объект.ХозяйственнаяОперация = ВыпускБлюдСоСписанием Тогда
		Объект.Товары.Загрузить(Объект.Ссылка.Товары.Выгрузить());
		Если Объект.ПЛ_ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.питХозяйственныеОперации.ПЛ_ЗаборныйЛист") Тогда
			Объект.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.ВыпускПродукцииСРозничнойРеализацией;
		Иначе
			Объект.ХозяйственнаяОперация = Объект.ПЛ_ХозяйственнаяОперация;
		КонецЕсли;
		Элементы.Товары.Обновить();
		ВыполнятьПересчет = Ложь;
	КонецЕсли;	
	//>>
	
	//<<Портал-Юг, Давиденко 2019.02.13 [4.2.3 Вид операции «Заборный лист» в документе «Выпуск блюд»]
	Если Объект.ПЛ_ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.питХозяйственныеОперации.ПЛ_ЗаборныйЛист") Тогда
		Объект.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.ВыпускПродукцииСРозничнойРеализацией;
		//<<Загребалов И., Апрель-Софт, 25.02.2022.SD72585 утилизация ШЛ
		Если ВыполнятьПересчет Тогда
		//>>
		//<<Портал-Юг, Давиденко 2019.03.02 [4.2.7 Нулевая цена и аналитика продаж в отчёте о розничных продажах и выпуске блюд]
		// пересчет колонки "передано"
		Для Каждого СтрокаТовары Из Объект.Товары Цикл
			СтрокаТовары.ПЛ_Передано = СтрокаТовары.КоличествоУпаковок - СтрокаТовары.ПЛ_Возвращено;
		КонецЦикла;
		//>>Портал-Юг, Давиденко 2019.03.02
		//<<Загребалов И., Апрель-Софт, 25.02.2022.SD72585 утилизация ШЛ
		КонецЕсли;
		//>>
	Иначе
		Объект.ХозяйственнаяОперация = Объект.ПЛ_ХозяйственнаяОперация;
	КонецЕсли;
	//>>Портал-Юг, Давиденко 2019.02.13
	
	ВидОперацииОбработатьИзменение();
	
	Если ЭтоРеализация Тогда
		Если ОбщегоНазначения.ПодсистемаСуществует("ИнтернетПоддержкаПользователей.РаботаСКонтрагентами") Тогда
			МодульПроверкаКонтрагентов = ОбщегоНазначения.ОбщийМодуль("ПроверкаКонтрагентов");
			// СтандартныеПодсистемы.РаботаСКонтрагентами
			МодульПроверкаКонтрагентов.ПриСозданииНаСервереДокумент(ЭтотОбъект, Параметры);
			// Конец СтандартныеПодсистемы.РаботаСКонтрагентами
		КонецЕсли;
	КонецЕсли;
	
	Если ЭтоСписание Тогда
		ПараметрыВыбораСтатейИАналитик = Документы.питВыпускБлюд.ПараметрыВыбораСтатейИАналитик(Объект.ХозяйственнаяОперация);
		ДоходыИРасходыСервер.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыВыбораСтатейИАналитик);
	КонецЕсли;
	
	УправлениеФормой(ЭтаФорма);
	
КонецПроцедуры

&НаСервере
Процедура ВидОперацииОбработатьИзменение()
	
	УстановитьЗаголовокФормы();
	
	Если НЕ ЗначениеЗаполнено(Объект.ХозяйственнаяОперация) Тогда
		Объект.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.ВыпускПродукции;
	КонецЕсли;
	
	ЭтоРозница     = (Объект.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.ВыпускПродукцииСРозничнойРеализацией);
	ЭтоРеализация  = (Объект.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.ВыпускПродукцииСРеализацией);
	ЭтоПеремещение = (Объект.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.ВыпускПродукцииСПеремещением);
	ЭтоСписание    = (Объект.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.ВыпускПродукцииСоСписанием);
	
	Если НЕ (ЭтоРеализация) Тогда
		// если это отгрузка и др.
		Объект.Услуги.Очистить();
		Объект.АгентскиеУслуги.Очистить();
		
	КонецЕсли;
	
	//<<Портал-Юг, Давиденко 2019.03.02 [4.2.7 Нулевая цена и аналитика продаж в отчёте о розничных продажах и выпуске блюд]
	ПЛ_СкладПолучательПриИзмененииНаСервере();
	//>>Портал-Юг, Давиденко 2019.03.02

	УправлениеФормой(ЭтаФорма);
	
КонецПроцедуры

&НаСервере
Процедура ОрганизацияПриИзмененииНаСервере()
	
	Если ЭтоРеализация Тогда
		
		ПродажиСервер.УстановитьОтметкуНезаполненногоДоговора(Элементы, "Договор");
		ПродажиСервер.УстановитьДоступностьДоговора(Объект, Элементы.Договор.Доступность, Элементы.ГруппаДоговор.Видимость);
		//Элементы.ГруппаНадписьДоговор.Видимость = Элементы.ГруппаДоговор.Видимость;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ТоварыНоменклатураПриИзмененииНаСервере(СтрокаТабличнойЧасти, Знач ПараметрыОбъекта)
	
	РеквизитыНоменклатуры = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СтрокаТабличнойЧасти.Номенклатура, "питВидНоменклатуры");
	СтрокаТабличнойЧасти.ЭтоБлюдо = (РеквизитыНоменклатуры.питВидНоменклатуры = Перечисления.питВидыНоменклатуры.Блюдо);
	СтрокаТабличнойЧасти.ЭтоУслуга = (РеквизитыНоменклатуры.питВидНоменклатуры = Перечисления.питВидыНоменклатуры.Услуга);
	
	Если СтрокаТабличнойЧасти.ЭтоБлюдо Тогда
		ДатаРецептуры = ?(ЗначениеЗаполнено(ПараметрыОбъекта.Ссылка), ПараметрыОбъекта.Дата, КонецДня(ПараметрыОбъекта.Дата));
		СтрокаТабличнойЧасти.Рецептура = питПроизводство.ВернутьОсновнуюРецептуру(СтрокаТабличнойЧасти.Номенклатура,СтрокаТабличнойЧасти.Характеристика, Перечисления.питХозяйственныеОперации.РецептураПриготовление,
			ДатаРецептуры, ПараметрыОбъекта.СпособРасчетаРецептуры, , ПараметрыОбъекта.Организация,,,ПараметрыОбъекта.Подразделение);
			//Если НЕ ЗначениеЗаполнено(СтрокаТабличнойЧасти.Рецептура) Тогда
			//	СтрокаТабличнойЧасти.ПриготовлениеЗапрещено = Истина;
			//КонецЕсли;
	Иначе
		СтрокаТабличнойЧасти.Рецептура = Неопределено;
	КонецЕсли;
	
	ПодразделениеРазрешено = питПроизводствоПовтИсп.ПодразделениеРазрешено(СтрокаТабличнойЧасти.Рецептура, ПараметрыОбъекта.Подразделение, ПараметрыОбъекта.Склад);
	СтрокаТабличнойЧасти.ПриготовлениеРазрешено = ?(ЗначениеЗаполнено(СтрокаТабличнойЧасти.Рецептура), ПодразделениеРазрешено, НЕ ПараметрыОбъекта.ВосприниматьБлюдоБезРецептурыКакТовар);
	СтрокаТабличнойЧасти.Иконка = питДокументы.ОпределитьНомерИконкиНоменклатуры(РеквизитыНоменклатуры.питВидНоменклатуры, Ложь, СтрокаТабличнойЧасти.ПриготовлениеРазрешено);
	
	//+ИзменениеФактаВПроизводстве
	СтрокаТабличнойЧасти.ИзмененФактБлюда = Ложь;
	СтрокаТабличнойЧасти.РецептураПред = СтрокаТабличнойЧасти.Рецептура;
	//-ИзменениеФактаВПроизводстве
	
	//<<Портал-Юг, Давиденко 2019.02.22 [4.2.7 Нулевая цена и аналитика продаж в отчёте о розничных продажах и выпуске блюд]
	Если НЕ (ЗначениеЗаполнено(СтрокаТабличнойЧасти.ПЛ_Договор) 
		И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаТабличнойЧасти.ПЛ_Договор, "ПЛ_ВидАналитикиПродаж") <> ПланыВидовХарактеристик.ПЛ_АналитикиПродаж.ШведскаяЛиния) Тогда
		СтрокаТабличнойЧасти.ПЛ_Договор = ПЛ_Сервер.ПолучитьДоговорДляНоменклатуры(СтрокаТабличнойЧасти.Номенклатура);
	КонецЕсли;	
	//>>Портал-Юг, Давиденко 2019.02.22
	
КонецПроцедуры

//>>Швецов.11.02.2025. Розничные продажи алкоголя.
&НаСервере
Функция ПроверитьНеобходимостьСтатьиСписания(СтрокаТабличнойЧасти)
	
	АлкогольнаяПродукция = СтрокаТабличнойЧасти.Номенклатура.АлкогольнаяПродукция и НЕ СтрокаТабличнойЧасти.Номенклатура.АлкогольнаяПродукцияВоВскрытойТаре;
	
	Возврат АлкогольнаяПродукция;
КонецФункции 

//>>Швецов.11.02.2025. Функция проверки наличия алкогольной продукции в товарах
&НаСервере
Функция ПроверитьНаличиеАлкогольнойПродукцииВТоварах(ТоварыТаблица)
  
  Если ТоварыТаблица.Количество() = 0 Тогда
    Возврат Ложь;
  КонецЕсли;
  
  СписокНоменклатуры = Новый Массив;
  Для Каждого СтрокаТовара Из ТоварыТаблица Цикл
    Если ЗначениеЗаполнено(СтрокаТовара.Номенклатура) Тогда
      СписокНоменклатуры.Добавить(СтрокаТовара.Номенклатура);
    КонецЕсли;
  КонецЦикла;
  
  Если СписокНоменклатуры.Количество() = 0 Тогда
    Возврат Ложь;
  КонецЕсли;
  
  Запрос = Новый Запрос;
  Запрос.Текст = 
  "ВЫБРАТЬ ПЕРВЫЕ 1
  |  Номенклатура.Ссылка КАК Номенклатура
  |ИЗ
  |  Справочник.Номенклатура КАК Номенклатура
  |ГДЕ
  |  Номенклатура.Ссылка В (&СписокНоменклатуры)
  |  И Номенклатура.АлкогольнаяПродукция = ИСТИНА
  |  И Номенклатура.АлкогольнаяПродукцияВоВскрытойТаре = ЛОЖЬ";
  
  Запрос.УстановитьПараметр("СписокНоменклатуры", СписокНоменклатуры);
  
  Результат = Запрос.Выполнить();
  
  Возврат НЕ Результат.Пустой();
  
КонецФункции

//>>Швецов.11.02.2025. Серверная обертка для управления формой с проверкой алкогольной продукции
&НаСервере
Процедура УправлениеФормойНаСервере(ГруппаСписаниеВидимость = Неопределено)
  
  // Для заборного листа проверяем наличие алкогольной продукции
  ПЛ_ЭтоЗаборныйЛист = (Объект.ПЛ_ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.питХозяйственныеОперации.ПЛ_ЗаборныйЛист"));
  
  Если ПЛ_ЭтоЗаборныйЛист И ГруппаСписаниеВидимость = Неопределено Тогда
    ГруппаСписаниеВидимость = ПроверитьНаличиеАлкогольнойПродукцииВТоварах(Объект.Товары);
  КонецЕсли;
  
  УправлениеФормой(ЭтаФорма, ГруппаСписаниеВидимость);
  
КонецПроцедуры
//<<Швецов.11.02.2025. Розничные продажи алкоголя.

&НаКлиентеНаСервереБезКонтекста
Процедура РежимРасчетаСписанияВПроизводствоУстановка(Форма)
	
	Элементы = Форма.Элементы;
	Объект = Форма.Объект;
	
	Если Объект.РежимРасчетаСписанияВПроизводство = ПредопределенноеЗначение("Перечисление.питРежимыРасчетаСписанияВПроизводство.ПоНорме") Тогда
		Элементы.Блюда.ТолькоПросмотр = Истина;
		Элементы.Ингредиенты.ТолькоПросмотр = Истина;
		Элементы.Замены.ТолькоПросмотр       = Истина;
		Элементы.Ингредиенты.Подсказка      = "В режиме 'По норме' состав ингредиентов не редактируется";
		Элементы.Замены.Подсказка            = "В режиме 'По норме' замены не редактируются";
		
		Элементы.Трудозатраты.ТолькоПросмотр = Истина;
		Элементы.Трудозатраты.Подсказка = "В режиме 'По норме' трудозатраты не редактируются";
		
		Элементы.ПобочныеИзделия.ТолькоПросмотр = Истина;
		Элементы.ПобочныеИзделия.Подсказка = "В режиме 'По норме' побочные изделия не редактируются";
		
		//+ИзменениеФактаВПроизводстве
		//<<=== ПорталЮгКрым Плотникова Н. 03.06.2021 после обновления ERP
		//Элементы.ТоварыРецептура.ТолькоПросмотр = Истина;
		Элементы.ТоварыРецептура.ТолькоПросмотр = Ложь;
		//>>=== ПорталЮгКрым Плотникова Н. 03.06.2021 после обновления ERP
		//-ИзменениеФактаВПроизводстве
		
	Иначе
		Элементы.Блюда.ТолькоПросмотр = Ложь;
		Элементы.Ингредиенты.ТолькоПросмотр = Ложь;
		Элементы.Замены.ТолькоПросмотр       = Ложь;
		Элементы.Ингредиенты.Подсказка      = "";
		Элементы.Замены.Подсказка            = "";
		
		Элементы.Трудозатраты.ТолькоПросмотр = Ложь;
		Элементы.Трудозатраты.Подсказка = "";
		
		Элементы.ПобочныеИзделия.ТолькоПросмотр = Ложь;
		Элементы.ПобочныеИзделия.Подсказка = "";
		
		//+ИзменениеФактаВПроизводстве
		Элементы.ТоварыРецептура.ТолькоПросмотр = Ложь;
		//-ИзменениеФактаВПроизводстве
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ВидимостьВозвратнойТары()
	Возврат Ложь;
КонецФункции


&НаКлиентеНаСервереБезКонтекста
Процедура УправлениеФормой(Форма, ГруппаСписаниеВидимость = Неопределено)
	
	Элементы = Форма.Элементы;
	Объект   = Форма.Объект;
	
	Элементы.ПодразделениеОрганизации.Доступность = ЗначениеЗаполнено(Объект.Организация);
	
	РежимРасчетаСписанияВПроизводствоУстановка(Форма);
	
	Элементы.ГруппаЗамены.Видимость = НЕ (Объект.РежимИспользованияАналогов=ПредопределенноеЗначение("Перечисление.питРежимыИспользованияАналогов.Запретить"));
	
	Элементы.ГруппаТовары.Заголовок = "Товары";
	
	ТоварыНоменклатураПараметрыВыбора = Новый Массив;
	ТоварыНоменклатураПараметрыВыбора.Добавить(Новый ПараметрВыбора("Заголовок", Элементы.ГруппаТовары.Заголовок)); 
	Элементы.ТоварыНоменклатура.ПараметрыВыбора	= Новый ФиксированныйМассив(ТоварыНоменклатураПараметрыВыбора);
	
	// Параметры выбора направления деятельности.
	НаправлениеДеятельностиПараметрыВыбора = Новый Массив;
	НаправлениеДеятельностиПараметрыВыбора.Добавить(Новый ПараметрВыбора("УчетЗатрат", Истина));
	НаправлениеДеятельностиПараметрыВыбора.Добавить(Новый ПараметрВыбора("Статус", ПредопределенноеЗначение("Перечисление.СтатусыНаправленияДеятельности.Используется")));
	Элементы.НаправлениеДеятельности.ПараметрыВыбора = Новый ФиксированныйМассив(НаправлениеДеятельностиПараметрыВыбора);
	
	Элементы.СкладПолучатель.Видимость       = Форма.ЭтоПеремещение ИЛИ Форма.ЭтоРозница ИЛИ Форма.ЭтоРеализация;
	Элементы.СкладПолучатель.Заголовок       = ?(Форма.ЭтоПеремещение, "Склад получатель", "Склад реализации");
	Элементы.СкладПолучатель.Подсказка       = ?(Форма.ЭтоПеремещение, "Склад компании, на который перемещаются товары", "Склад компании, на котором реализуется выпущенная продукция");
	//Элементы.СкладПолучатель.Доступность     = ?(ЗначениеЗаполнено(Объект.ДокументОснование),Ложь,Истина);
	
	Элементы.ТоварыПроцентРучнойСкидки.Видимость = Форма.ЭтоРозница ИЛИ Форма.ЭтоРеализация;
	Элементы.ТоварыСуммаРучнойСкидки.Видимость = Форма.ЭтоРозница ИЛИ Форма.ЭтоРеализация;
	
	Элементы.ГруппаРозница.Видимость         = Форма.ЭтоРозница;
	Элементы.ГруппаНачислениеБонусныхБаллов.Видимость          = Форма.ЭтоРозница ИЛИ Форма.ЭтоРеализация;
	Элементы.ГруппаОплатаБонуснымиБаллами.Видимость          = Форма.ЭтоРозница;
	Элементы.ГруппаПодарочныеСертификаты.Видимость          = Форма.ЭтоРозница;
	Элементы.ГруппаИтогСуммаБезнал.Видимость = Форма.ЭтоРозница;
	Элементы.ГруппаОплата.Видимость          = Форма.ЭтоРозница;
	Элементы.ТоварыНазначение.Видимость       = НЕ Форма.ЭтоРозница;
	
	Элементы.ГруппаРеализация.Видимость      = Форма.ЭтоРеализация;
	
	Элементы.АгентскиеУслугиПеренестиВУслуги.Видимость = Форма.ЭтоРеализация;
	
	
	//<<Швецов.11.02.2025. Розничные продажи алкоголя.
	//<<Портал-Юг, Давиденко 2019.02.13 [4.2.3 Вид операции «Заборный лист» в документе «Выпуск блюд»]
	ПЛ_ЭтоЗаборныйЛист = (Объект.ПЛ_ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.питХозяйственныеОперации.ПЛ_ЗаборныйЛист"));
	
	Если ГруппаСписаниеВидимость <> Неопределено Тогда
		
		Элементы.ГруппаСписание.Видимость = ?(Элементы.ГруппаСписание.Видимость, Истина, ГруппаСписаниеВидимость); 
	
	ИначеЕсли ПЛ_ЭтоЗаборныйЛист И Объект.Товары.Количество() = 0 Тогда
		
		Элементы.ГруппаСписание.Видимость        = Форма.ЭтоСписание;
		
	ИначеЕсли ПЛ_ЭтоЗаборныйЛист И Объект.Товары.Количество() <> 0 И Элементы.ГруппаСписание.Видимость Тогда 
	Иначе
		
		Элементы.ГруппаСписание.Видимость        = Форма.ЭтоСписание;

	КонецЕсли;
	
	// Управление видимостью элемента СтатьяРасходов для заборного листа
	Если ПЛ_ЭтоЗаборныйЛист Тогда
		// Если передан параметр ГруппаСписаниеВидимость, используем его
		Если ГруппаСписаниеВидимость <> Неопределено Тогда
			ЕстьАлкогольнаяПродукция = ГруппаСписаниеВидимость;
		Иначе
			// Иначе проверяем алкогольную продукцию самостоятельно
			ЕстьАлкогольнаяПродукция = Ложь;
		КонецЕсли;

		Элементы.питСтатьяРасходов.Видимость = ЕстьАлкогольнаяПродукция;
		Элементы.АналитикаРасходов.Видимость = ЕстьАлкогольнаяПродукция;
	Иначе
		Элементы.питСтатьяРасходов.Видимость = НЕ Форма.ЭтоРозница;
		Элементы.АналитикаРасходов.Видимость = НЕ Форма.ЭтоРозница;
	КонецЕсли;
	//<<Швецов.11.02.2025. Розничные продажи алкоголя.
	
	Элементы.ИтогиВсегоНДС.Видимость = НЕ Объект.ДокументБезНДС;
	
	Элементы.ТоварыСпособУчетаНДС.Заголовок = ?(Форма.ЭтоПеремещение, "Способ учета НДС получ.", "Способ учета НДС");
	
	Элементы.ДекорацияПерезаполнениеТаблиц1.Видимость = Форма.ИзмененыТовары;
	
	//+АвтовыборНоменклатуры
	Элементы.ДекорацияУточнениеХарактеристик.Видимость = Форма.НайденыОшибкиАвтовыбора И НЕ Форма.ИзмененыТовары;
	//+АвтовыборНоменклатуры
	
	Элементы.АналитикаРасходов.ОтметкаНезаполненного = Форма.АналитикаРасходовОбязательна;
	
	УправлениеФормойТрудозатраты(Объект, Элементы);
		
	//<< Портал-Юг, Баринов, 2019.10.04 [9.09 Обособление продаж по открытой цене]
	//ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПЛ_Номенклатура", "Видимость", ПЛ_ЭтоЗаборныйЛист);
	//<< Портал-Юг, Баринов, 2019.11.28 [9.14. Обособление шведской линии и банкетов по номенклатурным группам в БП]
	//ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПЛ_Номенклатура", "Видимость", ПЛ_ЭтоЗаборныйЛист ИЛИ Форма.ПЛ_ЭтоОткрытаяЦена);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПЛ_Номенклатура", "Видимость", Форма.ЭтоРозница);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПЛ_Номенклатура", "АвтоОтметкаНезаполненного", ПЛ_ЭтоЗаборныйЛист);
	//>> Портал-Юг, Баринов, 2019.11.28
	Если Форма.ПЛ_ЭтоОткрытаяЦена Тогда
		// Этот признак документа не изменяется просто так. Тут как раз блокироуем реквизит, отвечающий за этот признак.
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПЛ_Номенклатура", "ТолькоПросмотр", Истина);
	КонецЕсли; 
	//>> Портал-Юг, Баринов, 2019.10.04
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПЛ_Передано", "Видимость", ПЛ_ЭтоЗаборныйЛист); 
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПЛ_Возвращено", "Видимость", ПЛ_ЭтоЗаборныйЛист); 
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПЛ_ВремяПриготовления", "Видимость", ПЛ_ЭтоЗаборныйЛист); 
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПЛ_ВремяПриготовления2", "Видимость", ПЛ_ЭтоЗаборныйЛист); 
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПЛ_ВремяПриготовления3", "Видимость", ПЛ_ЭтоЗаборныйЛист); 
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТоварыЦена", "Видимость", Не ПЛ_ЭтоЗаборныйЛист); 
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТоварыПроцентРучнойСкидки", "Видимость", Не ПЛ_ЭтоЗаборныйЛист И Форма.ЭтоРозница); 
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТоварыСуммаРучнойСкидки", "Видимость", Не ПЛ_ЭтоЗаборныйЛист И Форма.ЭтоРозница); 
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТоварыСумма", "Видимость", Не ПЛ_ЭтоЗаборныйЛист); 
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТоварыСтавкаНДС", "Видимость", Не ПЛ_ЭтоЗаборныйЛист); 
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТоварыСуммаНДС", "Видимость", Не ПЛ_ЭтоЗаборныйЛист); 
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТоварыВсего", "Видимость", Не ПЛ_ЭтоЗаборныйЛист); 
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТоварыСуммаСНДС", "Видимость", Не ПЛ_ЭтоЗаборныйЛист); 
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаПодарочныеСертификаты", "Видимость", Не ПЛ_ЭтоЗаборныйЛист И Форма.ЭтоРозница); 
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаНачислениеБонусныхБаллов", "Видимость", Не ПЛ_ЭтоЗаборныйЛист И Форма.ЭтоРозница); 
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаОплатаБонуснымиБаллами", "Видимость", Не ПЛ_ЭтоЗаборныйЛист И Форма.ЭтоРозница); 
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаИтоги", "Видимость", Не ПЛ_ЭтоЗаборныйЛист И Форма.ЭтоРозница); 
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТоварыКоличествоУпаковок", "ТолькоПросмотр", ПЛ_ЭтоЗаборныйЛист); 
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ВидОперации", "Видимость", Ложь);
	//>>Портал-Юг, Давиденко 2019.02.13

	
	СформироватьНадписьЦеныИВалюта(Форма);
	//<<Портал-Юг, Давиденко 2019.02.18 [4.2.3 Вид операции «Заборный лист» в документе «Выпуск блюд»]
	Если Не ПЛ_ЭтоЗаборныйЛист Тогда
	//>>Портал-Юг, Давиденко 2019.02.18
	ОбновитьИтоги(Форма);
	//<<Портал-Юг, Давиденко 2019.02.18 [4.2.3 Вид операции «Заборный лист» в документе «Выпуск блюд»]
	КонецЕсли;
	//>>Портал-Юг, Давиденко 2019.02.18	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ОбновитьИтоги(Форма)
	
	Объект = Форма.Объект;
	
	Форма.ИтогиВсего    = Объект.Товары.Итог("Всего");
	Форма.ИтогиВсегоНДС = Объект.Товары.Итог("СуммаНДС");
	
	Если Форма.ЭтоРеализация Тогда
		Форма.ИтогиВсего = Форма.ИтогиВсего
			+ Объект.Услуги.Итог("Всего")
			+ Объект.АгентскиеУслуги.Итог("Всего");
		Форма.ИтогиВсегоНДС = Форма.ИтогиВсегоНДС
			+ Объект.Услуги.Итог("СуммаНДС")
			+ Объект.АгентскиеУслуги.Итог("СуммаНДС");
	ИначеЕсли Форма.ЭтоРозница Тогда
		Форма.ИтогиВсего = Форма.ИтогиВсего
			+ Объект.АгентскиеУслуги.Итог("Всего");
		Форма.ИтогиВсегоНДС = Форма.ИтогиВсегоНДС
			+ Объект.АгентскиеУслуги.Итог("СуммаНДС");
	КонецЕсли;
	
	Форма.ОтметкаНезаполненногоСклад = Объект.Товары.Количество() > 0;
	
КонецПроцедуры

