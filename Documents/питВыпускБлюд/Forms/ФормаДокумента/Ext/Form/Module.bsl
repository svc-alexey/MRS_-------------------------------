		МодульПроверкаКонтрагентовКлиент = ОбщегоНазначенияКлиент.ОбщийМодуль("ПроверкаКонтрагентовКлиент");
		// СтандартныеПодсистемы.РаботаСКонтрагентами
		МодульПроверкаКонтрагентовКлиент.ОбработатьРезультатПроверкиКонтрагентовВДокументе(ЭтотОбъект);
		// Конец СтандартныеПодсистемы.РаботаСКонтрагентами
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура КонтрагентПриИзмененииСервер()
	
	ПродажиСервер.УстановитьДоступностьДоговора(Объект, Элементы.Договор.Доступность, Элементы.ГруппаДоговор.Видимость, Объект.Договор);
	
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
		ЗаполнитьДоговорПоУмолчанию();
		//ПродажиСервер.ПартнерПриИзменении(Объект);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДоговорПоУмолчанию()
	
	ХозяйственнаяОперацияДоговора = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.РеализацияКлиенту");
	Договор = ПродажиСервер.ПолучитьДоговорПоУмолчанию(Объект, 
		ХозяйственнаяОперацияДоговора, 
		Объект.Валюта);
	
КонецПроцедуры
	
&НаКлиенте
Процедура СоглашениеПриИзменении(Элемент)
	
	СоглашениеПриИзмененииСервер();
	
КонецПроцедуры

&НаСервере
Процедура СоглашениеПриИзмененииСервер()
	
	ПоСоглашениюИспользуютсяДоговорыКонтрагентов = ЗначениеЗаполнено(Объект.Соглашение) И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Соглашение, "ИспользуютсяДоговорыКонтрагентов");
	
	Если ЭтоРеализация Тогда
		
		ПродажиСервер.УстановитьОтметкуНезаполненногоДоговора(Элементы, "Договор");
		ПродажиСервер.УстановитьДоступностьДоговора(Объект, Элементы.Договор.Доступность, Элементы.ГруппаДоговор.Видимость);
		//Элементы.ГруппаНадписьДоговор.Видимость = Элементы.ГруппаДоговор.Видимость;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СоглашениеНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ПараметрыВыбораСоглашения = ПродажиКлиент.ПараметрыНачалаВыбораСоглашенияСКлиентом();
	
	ПараметрыВыбораСоглашения.Элемент                     = Элемент;
	ПараметрыВыбораСоглашения.Партнер                     = Объект.Партнер;
	ПараметрыВыбораСоглашения.Документ                    = Объект.Соглашение;
	ПараметрыВыбораСоглашения.ДатаДокумента               = Объект.Дата;
	ПараметрыВыбораСоглашения.ДанныеФормыСтруктура        = Объект;
	
	ПродажиКлиент.НачалоВыбораСоглашенияСКлиентом(ПараметрыВыбораСоглашения, СтандартнаяОбработка);
	
КонецПроцедуры

&НаСервере
Процедура УправлениеСвязямиПараметровВыбораРеквизитовФормы()
	
	//Договор, добавляем связь с реквизитом формы ПоСоглашениюИспользуютсяДоговорыКонтрагентов
	ЭлементФормы = Элементы.Договор;
	НовыеСвязиПараметровВыбора = Новый Массив;
	Для Каждого СвязьПараметровВыбора Из ЭлементФормы.СвязиПараметровВыбора Цикл
		Если Не СвязьПараметровВыбора.Имя = "ПоСоглашениюИспользуютсяДоговорыКонтрагентов" Тогда
			НовыеСвязиПараметровВыбора.Добавить(СвязьПараметровВыбора);
		КонецЕсли;
	КонецЦикла;
	ПараметрВыбора = Новый СвязьПараметраВыбора("ПоСоглашениюИспользуютсяДоговорыКонтрагентов", "ПоСоглашениюИспользуютсяДоговорыКонтрагентов", РежимИзмененияСвязанногоЗначения.НеИзменять);
	НовыеСвязиПараметровВыбора.Добавить(ПараметрВыбора);
	ЭлементФормы.СвязиПараметровВыбора = Новый ФиксированныйМассив(НовыеСвязиПараметровВыбора);
	
КонецПроцедуры

&НаКлиенте
Процедура ОплатаСуммаОплатыПриИзменении(Элемент)
	
	Строка = Элементы.Оплата.ТекущиеДанные;
	
	Если Строка.СуммаОплаты < 0 Тогда
		Строка.СуммаОплаты = 0;
	КонецЕсли;
	
КонецПроцедуры

#Область КопированиеВставкаСтрок

&НаКлиенте
Процедура СкопироватьСтроки(Команда)
	
	ИмяТаблицы = ПолучитьИмяТекущейТабличнойЧасти();
	Если ПустаяСтрока(ИмяТаблицы) Тогда
		Возврат;
	КонецЕсли;
	
	КоличествоСтрок = Элементы[ИмяТаблицы].ВыделенныеСтроки.Количество();
	Если КоличествоСтрок = 0 Тогда
		Возврат;
	КонецЕсли;
	
	СкопироватьСтрокиНаСервере(ИмяТаблицы);
	
	РаботаСТабличнымиЧастямиКлиент.ОповеститьПользователяОКопированииСтрок(КоличествоСтрок);
	
КонецПроцедуры

&НаСервере
Процедура СкопироватьСтрокиНаСервере(ИмяТаблицы)
	
	РаботаСТабличнымиЧастями.СкопироватьСтрокиВБуферОбмена(Объект[ИмяТаблицы], Элементы[ИмяТаблицы].ВыделенныеСтроки);
	
КонецПроцедуры

&НаКлиенте
Процедура ВставитьСтроки(Команда)
	
	ИмяТаблицы = ПолучитьИмяТекущейТабличнойЧасти();
	Если ПустаяСтрока(ИмяТаблицы) Тогда
		Возврат;
	КонецЕсли;
	КоличествоТоваровДоВставки = Объект[ИмяТаблицы].Количество();
	ПолучитьСтрокиИзБуфераОбмена(ИмяТаблицы);
	КоличествоСтрок = Объект.Товары.Количество()-КоличествоТоваровДоВставки;
	РаботаСТабличнымиЧастямиКлиент.ОповеститьПользователяОВставкеСтрок(КоличествоСтрок);
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьСтрокиИзБуфераОбмена(ИмяТаблицы)
	
	ТаблицаТоваров = РаботаСТабличнымиЧастями.СтрокиИзБуфераОбмена();
	Если Не ЗначениеЗаполнено(ТаблицаТоваров) Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураДействий = Новый Структура;
	ДобавитьВСтруктуруДействияПриИзмененииКоличестваУпаковок(ИмяТаблицы, СтруктураДействий);
	КэшированныеЗначения = ОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
	
	Для Каждого СтрокаТовара Из ТаблицаТоваров Цикл
		
		ТекущаяСтрока = Объект[ИмяТаблицы].Добавить();
		ЗаполнитьЗначенияСвойств(ТекущаяСтрока, СтрокаТовара);
		ОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, КэшированныеЗначения);
		
		// Дозаполним еще реквизиты, такие как "Рецептура", "ЭтоБлюдо", "ЭтоТовар" и т.д.
		СписокСвойствСтрокой = "Номенклатура, Характеристика, ЭтоУслуга, ЭтоБлюдо, ПриготовлениеРазрешено, ЭтоТовар, Иконка, Рецептура, ИзмененФактБлюда, РецептураПред";
		ДанныеСтрокаТаблицы = Новый Структура(СписокСвойствСтрокой);
		//<<Портал-Юг, Давиденко 2019.02.22 [4.2.7 Нулевая цена и аналитика продаж в отчёте о розничных продажах и выпуске блюд]
		ДанныеСтрокаТаблицы.Вставить("ПЛ_Договор");
		//>>Портал-Юг, Давиденко 2019.02.22

		ЗаполнитьЗначенияСвойств(ДанныеСтрокаТаблицы, ТекущаяСтрока);
		
		СвойстваПараметрыОбъектаСтрокой = "ХозяйственнаяОперация, Организация, Дата, Ссылка, Подразделение, Склад";
		ПараметрыОбъекта = Новый Структура();
		ПараметрыОбъекта = Новый Структура(СвойстваПараметрыОбъектаСтрокой);
		ПараметрыОбъекта.Вставить("СпособРасчетаРецептуры", СпособРасчетаРецептуры);
		ПараметрыОбъекта.Вставить("ВосприниматьБлюдоБезРецептурыКакТовар", ВосприниматьБлюдоБезРецептурыКакТовар);
		ЗаполнитьЗначенияСвойств(ПараметрыОбъекта, ЭтаФорма);
		ЗаполнитьЗначенияСвойств(ПараметрыОбъекта, Объект);
		
		ТоварыНоменклатураПриИзмененииНаСервере(ДанныеСтрокаТаблицы, ПараметрыОбъекта);
		
		ЗаполнитьЗначенияСвойств(ТекущаяСтрока, ДанныеСтрокаТаблицы);
		
	КонецЦикла;
	ЗаполнитьСлужебныеРеквизитыПоНоменклатуре();
	
	НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(Объект,ПараметрыУказанияСерий[ИмяТаблицы]);
	
	
КонецПроцедуры

&НаКлиенте
Функция ПолучитьИмяТекущейТабличнойЧасти()
	
	ИмяТекущейСтраницы = Элементы.ГруппаСтраницы.ТекущаяСтраница.Имя;
	ИмяТаблицы = "";
	Если ИмяТекущейСтраницы = "ГруппаТовары" Тогда
		
		ИмяТаблицы = "Товары";
		
	КонецЕсли;
	
	Возврат ИмяТаблицы;
	
КонецФункции

#КонецОбласти

#Область ИзменениеФактаВПроизводстве

#Область ОбработчикиСобытийБлюда

// Обработчики

&НаКлиенте
Процедура БлюдаРецептураПриИзменении(Элемент)
	ТекущееБлюдо = Элементы.Блюда.ТекущиеДанные;
	Если НЕ ТекущееБлюдо = Неопределено Тогда
		
		Если ТекущееБлюдо.Рецептура = ТекущееБлюдо.РецептураПред Тогда
			Возврат;
		КонецЕсли;
		
		Если ТекущееБлюдо.ИзмененФактБлюда Тогда
			ПоказатьВопрос(Новый ОписаниеОповещения("ВопросОбИзмененииРецептурыБлюдаЗавершение", ЭтотОбъект, Новый Структура),
				"Существуют измененные ингредиенты/полуфабрикаты для текущего блюда, изменение приведет к их пересчету, продолжить?", 
				РежимДиалогаВопрос.ДаНет);
		Иначе
			БлюдаРецептураПриИзмененииНаСервере(Элементы.Блюда.ТекущаяСтрока);
		КонецЕсли;
		
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура БлюдаПередУдалением(Элемент, Отказ)
	Отказ = Истина; // Блюда запрещено удалять неконтекстно, даже в режиме "По факту".
КонецПроцедуры

&НаКлиенте
Процедура БлюдаПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Отказ = Истина; // Блюда запрещено добавлять неконтекстно, даже в режиме "По факту".
КонецПроцедуры

// Клиентские вызовы

&НаКлиенте
Процедура ВопросОбИзмененииРецептурыБлюдаЗавершение(Результат, Параметры) Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда
		БлюдаРецептураПриИзмененииНаСервере(Элементы.Блюда.ТекущаяСтрока);
	Иначе
		// Пользовтаель не захотел делать пересчет, откатываем значение рецептуры на предыдущее.
		ТекущееБлюдо = Элементы.Блюда.ТекущиеДанные;
		Если НЕ ТекущееБлюдо = Неопределено Тогда
			ТекущееБлюдо.Рецептура = ТекущееБлюдо.РецептураПред;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

// Серверные вызовы

&НаСервере
Процедура БлюдаРецептураПриИзмененииНаСервере(ИдентификаторСтроки)
	ТекущееБлюдо = Объект.Блюда.НайтиПоИдентификатору(ИдентификаторСтроки);
	Если ТекущееБлюдо = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТекущееБлюдо.Автопередел Тогда
		// Получение ингредиентов в ТЧ "Ингредиенты", которые соответствуют текущему блюду.
		ИнгредиентыИзАвтопеределов = питИзменениеФактаВПроизводстве.НайтиИнгредиентыИзАвтопеределовПоБлюду(ЭтаФорма, Объект.Ингредиенты, ТекущееБлюдо);
		Для каждого СтрокаИнгредиент Из ИнгредиентыИзАвтопеределов Цикл
			// Изменяем рецептуру автопередела у найденных ингредиентов
			СтрокаИнгредиент.РецептураАвтопередела = ТекущееБлюдо.Рецептура;
		КонецЦикла;
	Иначе
		// Получение товара, соответствующего текущему блюду.
		НайденныйТовар = питИзменениеФактаВПроизводстве.НайтиТоварПоБлюду(ЭтаФорма, Объект.Товары, ТекущееБлюдо);
		НайденныйТовар.Рецептура = ТекущееБлюдо.Рецептура;
	КонецЕсли;
	
	// Вызываем рекурсивную обработку изменения факта блюда / автопередела.
	питИзменениеФактаВПроизводстве.ОбработатьИзменениеФактаИнгредиентаИзАвтопеределовБлюда(ЭтаФорма, Неопределено, ТекущееБлюдо);
	
	// Служебный обработчик, который обновляет статусы укзаания серий.
	ПослеИзмененияСтрокТЧПрограммноНаСервере("Ингредиенты");
	
	// Устанавливаем изменение факта блюда.
	питИзменениеФактаВПроизводстве.УстановитьИзенениеФактаБлюда(ЭтаФорма, ТекущееБлюдо);
	
	// Предыдущую рецептуру обновляем на текущуюю
	ТекущееБлюдо.РецептураПред = ТекущееБлюдо.Рецептура;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийИнгредиенты

// Обработчики

&НаКлиенте
Процедура ИнгредиентыКоличествоУпаковокИнгредиентаФактПриИзменении(Элемент)
	
	ПосчитатьВединицахХранения_ИнгредиентыФакт();
	
	ТекущиеДанные = Элементы.Ингредиенты.ТекущиеДанные;
	Если НЕ ТекущиеДанные = Неопределено Тогда
		// Дополнительная серверная обработка строки.
		ТекущаяСтрока = Элементы.Ингредиенты.ТекущаяСтрока;
		
		ИнгредиентыКоличествоУпаковокИнгредиентаФактПриИзмененииНаСервере(ТекущаяСтрока);
		
		ТекущиеДанные.КоличествоУпаковокИнгредиентаФактПред	= ТекущиеДанные.КоличествоУпаковокИнгредиентаФакт;
		ТекущиеДанные.КоличествоИнгредиентаФактПред			= ТекущиеДанные.КоличествоИнгредиентаФакт;
		ТекущиеДанные.РецептураАвтопеределаПред				= ТекущиеДанные.РецептураАвтопеределаПред;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ИнгредиентыПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	
	Отказ = Истина;
	Если Копирование Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанныеБлюда = Элементы.Блюда.ТекущиеДанные;
	Если ТекущиеДанныеБлюда = Неопределено Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не выбрано блюдо/полуфабрикат для добавления ингредиента");
		Возврат;
	КонецЕсли;
	
	ПараметрыПодбора = ПолучитьПараметрыПодбора("Ингредиенты");
	ОткрытьФорму("Обработка.ПодборТоваровВДокументПродажи.Форма", ПараметрыПодбора, ЭтаФорма, УникальныйИдентификатор);
	
КонецПроцедуры

&НаКлиенте
Процедура ИнгредиентыПередУдалением(Элемент, Отказ)
	ТекущийИнгредиент = Элементы.Ингредиенты.ТекущиеДанные;
	Если НЕ ТекущийИнгредиент = Неопределено Тогда
		
		// Ингредиенты, которые являются полуфабрикатами не удаляем.
		Отказ = Истина;
		
		// Вместо этого обнуляем их количество факт.
		ТекущийИнгредиент.КоличествоУпаковокИнгредиентаФакт	= 0;
		ТекущийИнгредиент.КоличествоИнгредиентаФакт			= 0;
		
		// Вызываем обработку изменения количества факт.
		ИнгредиентыКоличествоУпаковокИнгредиентаФактПриИзменении(Неопределено);
		
	КонецЕсли;
КонецПроцедуры

// Серверные вызовы

&НаСервере
Процедура ИнгредиентыКоличествоУпаковокИнгредиентаФактПриИзмененииНаСервере(ИдентификаторСтроки)
	
	СтрокаИнгредиент = Объект.Ингредиенты.НайтиПоИдентификатору(ИдентификаторСтроки);
	Если НЕ СтрокаИнгредиент = Неопределено Тогда
		
		питИзменениеФактаВПроизводстве.ОбработатьИзменениеФактаИнгредиентаИзАвтопеределовБлюда(ЭтаФорма, СтрокаИнгредиент, Неопределено);
		
		ПослеИзмененияСтрокТЧПрограммноНаСервере("Ингредиенты");
		
		// Установка флага, что факт строки был изменен.
		СтрокаИнгредиент.ИзмененФакт = Истина;
		
		// Поиск блюда ингредиента
		БлюдоИнгредиента = питИзменениеФактаВПроизводстве.НайтиБлюдоИнгредиента(Объект.Блюда, СтрокаИнгредиент);
		
		// Устанавливаем изменение факта блюда.
		питИзменениеФактаВПроизводстве.УстановитьИзенениеФактаБлюда(ЭтаФорма, БлюдоИнгредиента);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаВыбораПодборИнгредиентовНаСервере(ИдентификаторСтрокиБлюда, ВыбранноеЗначение)
	
	// Получение текущей строки блюда.
	СтрокаБлюдо = Объект.Блюда.НайтиПоИдентификатору(ИдентификаторСтрокиБлюда);
	Если СтрокаБлюдо = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаТоваров = ПолучитьИзВременногоХранилища(ВыбранноеЗначение.АдресТоваровВХранилище);
	
	Для каждого СтрокаТовара Из ТаблицаТоваров Цикл
		
		// Новая строка не была среди найденных, значит ее не было раньше. Добавляем.
		СтруктураДанных = Новый Структура;
		СтруктураДанных.Вставить("ИдентификаторБлюда",					СтрокаБлюдо.ИдентификаторСтроки);
		СтруктураДанных.Вставить("Номенклатура",						СтрокаТовара.Номенклатура);
		СтруктураДанных.Вставить("Характеристика",						СтрокаТовара.Характеристика);
		СтруктураДанных.Вставить("Ингредиент",							СтрокаТовара.Номенклатура);
		СтруктураДанных.Вставить("УпаковкаИнгредиента",					?(ЗначениеЗаполнено(СтрокаТовара.Упаковка), СтрокаТовара.Упаковка, СтрокаТовара.Номенклатура.ЕдиницаИзмерения));
		СтруктураДанных.Вставить("КоличествоУпаковокИнгредиентаНорма",	0);
		СтруктураДанных.Вставить("КоличествоИнгредиентаНорма",			0);
		СтруктураДанных.Вставить("КоличествоУпаковокИнгредиентаФакт",	СтрокаТовара.КоличествоУпаковок);
		СтруктураДанных.Вставить("КоличествоИнгредиентаФакт",			СтрокаТовара.Количество);
		СтруктураДанных.Вставить("Серия",								СтрокаТовара.Серия);
		СтруктураДанных.Вставить("ЗапретитьЗамены",						Ложь);
		СтруктураДанных.Вставить("СезонныйПроцент",						0);
		
		// Ищем ингредиент среди уже добавленных.
		ТекущийИнгредиент = питИзменениеФактаВПроизводстве.НайтиИнгредиентПоСтруктуреДанных(Объект.Ингредиенты, СтруктураДанных);
		Если ТекущийИнгредиент = Неопределено Тогда
			// Не нашли ингредиент, добавляем новый.
			ТекущийИнгредиент = питИзменениеФактаВПроизводстве.ДобавитьИнгредиентПоСтруктуреДанных(ЭтаФорма, Объект.Ингредиенты, СтруктураДанных);
		Иначе
			// Нашли ингредиент, обновляем фактическое количество.
			ТекущийИнгредиент.КоличествоУпаковокИнгредиентаФакт	= ТекущийИнгредиент.КоличествоУпаковокИнгредиентаФакт + СтруктураДанных.КоличествоУпаковокИнгредиентаФакт;
			ТекущийИнгредиент.КоличествоИнгредиентаФакт			= ТекущийИнгредиент.КоличествоИнгредиентаФакт + СтруктураДанных.КоличествоИнгредиентаФакт;
		КонецЕсли;
		
		Если питИзменениеФактаВПроизводствеКлиентСервер.ТекущийИнгредиентЯвляетсяПолуфабрикатом(ТекущийИнгредиент) Тогда
			// Поиск блюда по добавленному ингредиенту и его добавление, если не найдено.
			питИзменениеФактаВПроизводстве.НайтиДобавитьБлюдоПоИнгредиенту(ЭтаФорма, ТекущийИнгредиент);
			// Обновление порядка в таблице блюд.
			питИзменениеФактаВПроизводстве.ОбновитьПорядокБлюдПоИнгредиенту(ЭтаФорма, ТекущийИнгредиент, СтрокаБлюдо.Порядок);
			// Обрабатываем рекурсивно изменение количества ингредиента, который является полуфабрикатом.
			питИзменениеФактаВПроизводстве.ОбработатьИзменениеФактаИнгредиентаИзАвтопеределовБлюда(ЭтаФорма, ТекущийИнгредиент, Неопределено);
		КонецЕсли;
		
	КонецЦикла;
	
	ПослеИзмененияСтрокТЧПрограммноНаСервере("Ингредиенты");
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийТовары

// Обработчики

&НаКлиенте
Процедура ТоварыРецептураПриИзменении(Элемент)
	ТекущийТовар = Элементы.Товары.ТекущиеДанные;
	Если НЕ ТекущийТовар = Неопределено Тогда
		
		Если ТекущийТовар.Рецептура = ТекущийТовар.РецептураПред Тогда
			Возврат;
		КонецЕсли;
		
		Если ТекущийТовар.ИзмененФактБлюда Тогда
			ПоказатьВопрос(Новый ОписаниеОповещения("ТоварыРецептураПриИзмененииЗавершение", ЭтотОбъект, Новый Структура),
				"Существуют измененные ингредиенты/полуфабрикаты для текущего блюда, изменение приведет к их пересчету, продолжить?", 
				РежимДиалогаВопрос.ДаНет);
		Иначе
			ТоварыРецептураПриИзмененииНаСервере(Элементы.Товары.ТекущаяСтрока);
		КонецЕсли;
		
	КонецЕсли;
КонецПроцедуры

// Клиентские вызовы

&НаКлиенте
Процедура ТоварыРецептураПриИзмененииЗавершение(Результат, Параметры) Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда
		ТоварыРецептураПриИзмененииНаСервере(Элементы.Товары.ТекущаяСтрока);
	Иначе
		// Пользовтаель не захотел делать пересчет, откатываем значение рецептуры на предыдущее.
		ТекущийТовар = Элементы.Товары.ТекущиеДанные;
		Если НЕ ТекущийТовар = Неопределено Тогда
			ТекущийТовар.Рецептура = ТекущийТовар.РецептураПред;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

// Серверные вызовы

&НаСервере
Процедура ТоварыРецептураПриИзмененииНаСервере(ИдентификаторСтроки)
	
	СтрокаТовар = Объект.Товары.НайтиПоИдентификатору(ИдентификаторСтроки);
	Если СтрокаТовар = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Изменен факт для товара.
	СтрокаТовар.ИзмененФактБлюда = Истина;
	
	ТекущееБлюдо = питИзменениеФактаВПроизводстве.НайтиБлюдоПоТовару(ЭтаФорма, Объект.Блюда, СтрокаТовар);
	Если ТекущееБлюдо = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ТекущееБлюдо.Рецептура = СтрокаТовар.Рецептура;
	
	// Вызываем рекурсивную обработку изменения факта блюда / автопередела.
	питИзменениеФактаВПроизводстве.ОбработатьИзменениеФактаИнгредиентаИзАвтопеределовБлюда(ЭтаФорма, Неопределено, ТекущееБлюдо);
	
	// Служебный обработчик, который обновляет статусы укзаания серий.
	ПослеИзмененияСтрокТЧПрограммноНаСервере("Ингредиенты");
	
	// Устанавливаем изменение факта блюда.
	питИзменениеФактаВПроизводстве.УстановитьИзенениеФактаБлюда(ЭтаФорма, ТекущееБлюдо);
	
	// Устанавливаем предыдущее значение рецептуры.
	СтрокаТовар.РецептураПред	= СтрокаТовар.Рецептура;
	ТекущееБлюдо.РецептураПред	= ТекущееБлюдо.Рецептура;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЗамены

// Обработчики

&НаКлиенте
Процедура ЗаменыИнгредиентИсходныйПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.Замены.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные.УпаковкаИнгредиентаИсходный = Неопределено;
	ПосчитатьВединицахХранения_ЗаменыИсходный();
	
	ЗаменыИнгредиентИсходныйПриИзмененииНаСервере(Элементы.Замены.ТекущаяСтрока);
	
	ТаблицаНоменклатураПриИзменении("Замены");
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаменыЕдиницаИзмеренияИнгредиентаИсходныйПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.Замены.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПосчитатьВединицахХранения_ЗаменыИсходный();
	
	ЗаменыИсходноеКоличествоЕдиницаПриИзмененииНаСервере(Элементы.Замены.ТекущаяСтрока);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаменыКоличествоУпаковокИнгредиентаИсходныйПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.Замены.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПосчитатьВединицахХранения_ЗаменыИсходный();
	
	ЗаменыИсходноеКоличествоЕдиницаПриИзмененииНаСервере(Элементы.Замены.ТекущаяСтрока);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаменыПередУдалением(Элемент, Отказ)
	
	ТекущиеДанные = Элементы.Замены.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные.КоличествоУпаковокИнгредиентаИсходный = 0;
	
	ЗаменыИсходноеКоличествоЕдиницаПриИзмененииНаСервере(Элементы.Замены.ТекущаяСтрока);
	
КонецПроцедуры

// Серверные вызовы

&НаСервере
Процедура ЗаменыИсходноеКоличествоЕдиницаПриИзмененииНаСервере(ИдентификаторСтроки)
	
	ТекущаяСтрока = Объект.Замены.НайтиПоИдентификатору(ИдентификаторСтроки);
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОбновитьФактЗаменПоСтрокеЗамены(ТекущаяСтрока);
	
КонецПроцедуры

&НаСервере
Процедура ЗаменыИнгредиентИсходныйПриИзмененииНаСервере(ИдентификаторСтроки)
	
	ТекущаяСтрока = Объект.Замены.НайтиПоИдентификатору(ИдентификаторСтроки);
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Устанавливаем единицу измерения на непустую.
	ТекущаяСтрока.УпаковкаИнгредиентаИсходный = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекущаяСтрока.ИнгредиентИсходный, "ЕдиницаИзмерения");
	
	ОбновитьФактЗаменПоСтрокеЗамены(ТекущаяСтрока);
	
КонецПроцедуры

#КонецОбласти

&НаКлиенте
Процедура ТолькоИзмененные(Команда)
	Элементы.ИнгредиентыТолькоИзмененные.Пометка = НЕ Элементы.ИнгредиентыТолькоИзмененные.Пометка;
	ОбновитьОтборСтрокВТаблицеИнгредиентов();
КонецПроцедуры

&НаСервере
Процедура ОбновитьФактЗаменВТаблицеИнгредиентов()
	
	// "Обнуляем" факт замены.
	Для каждого ТекущийИнгредиент Из Объект.Ингредиенты Цикл
		ТекущийИнгредиент.ФактЗамены = 0;
	КонецЦикла;
	
	// Обход замен, поиск соответствующего ингредиента и инкремент "ФактЗамены".
	Для каждого ТекЗамена Из Объект.Замены Цикл
		ОбновитьФактЗаменПоСтрокеЗамены(ТекЗамена);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьФактЗаменПоСтрокеЗамены(СтрокаЗамена)
	
	// Поиск ингредиента, соответствующего текущей замене.
	НайденныйИнгредиент	= питИзменениеФактаВПроизводстве.НайтиИнгредиентПоЗамене(Объект.Ингредиенты, Объект.Блюда, СтрокаЗамена);
	Если НайденныйИнгредиент = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Инкремент факта замены.
	НайденныйИнгредиент.ФактЗамены = НайденныйИнгредиент.ФактЗамены + СтрокаЗамена.КоличествоУпаковокИнгредиентаИсходный;
	
	// Установка флага измененности.
	НайденныйИнгредиент.ИзмененФакт = Истина;
	
	// Поиск блюда ингредиента
	БлюдоИнгредиента = питИзменениеФактаВПроизводстве.НайтиБлюдоИнгредиента(Объект.Блюда, НайденныйИнгредиент);
	
	// Устанавливаем изменение факта блюда.
	питИзменениеФактаВПроизводстве.УстановитьИзенениеФактаБлюда(ЭтаФорма, БлюдоИнгредиента);
	
КонецПроцедуры

#КонецОбласти

