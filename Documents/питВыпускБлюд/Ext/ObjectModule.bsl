	|	ВТ_ПроизводствоИнгр.ИнгредиентВидНоменклатуры,
	|	ВТ_ПроизводствоИнгр.Автопередел,
	|	ВТ_ПроизводствоИнгр.ИзАвтопеределов,
	|	питВыпускБлюдЗамены.ИнгредиентЗамена,
	|	питВыпускБлюдЗамены.ХарактеристикаИнгредиентаЗамена,
	|	ЕСТЬNULL(питВыпускБлюдЗамены.КоличествоИнгредиентаЗамена, 0) КАК КоличествоИнгредиентаЗамена,
	|	ЕСТЬNULL(питВыпускБлюдЗамены.КоличествоИнгредиентаИсходный, 0) КАК КоличествоИнгредиентаИсходный,
	|	ЕСТЬNULL(питВыпускБлюдЗамены.КоличествоУпаковокИнгредиентаЗамена, 0) КАК КоличествоУпаковокИнгредиентаЗамена,
	|	ВЫБОР
	|		КОГДА питВыпускБлюдЗамены.УпаковкаИнгредиентаЗамена = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|			ТОГДА питВыпускБлюдЗамены.ИнгредиентЗамена.ЕдиницаИзмерения
	|		ИНАЧЕ питВыпускБлюдЗамены.УпаковкаИнгредиентаЗамена
	|	КОНЕЦ КАК УпаковкаИнгредиентаЗамена,
	|	питВыпускБлюдЗамены.ИнгредиентЗамена.питВидНоменклатуры КАК ЗаменаВидНоменклатуры
	|ПОМЕСТИТЬ ВТ_ПроизводствоЗамены
	|ИЗ
	|	ВТ_ПроизводствоИнгр КАК ВТ_ПроизводствоИнгр
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.питВыпускБлюд.Замены КАК питВыпускБлюдЗамены
	|		ПО ВТ_ПроизводствоИнгр.Блюдо = питВыпускБлюдЗамены.Блюдо
	|			И ВТ_ПроизводствоИнгр.Характеристика = питВыпускБлюдЗамены.ХарактеристикаБлюда
	|			И ВТ_ПроизводствоИнгр.Ингредиент = питВыпускБлюдЗамены.ИнгредиентИсходный
	|			И ВТ_ПроизводствоИнгр.ХарактеристикаИнгредиента = питВыпускБлюдЗамены.ХарактеристикаИнгредиентаИсходного
	|			И ВТ_ПроизводствоИнгр.Рецептура = питВыпускБлюдЗамены.Рецептура
	|ГДЕ
	|	питВыпускБлюдЗамены.Ссылка = &Ссылка
	|";
	ТекстЗапроса2 = "
