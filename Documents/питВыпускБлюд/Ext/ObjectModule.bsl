	|	ВТ_ПроизводствоИнгр.ХарактеристикаИнгредиента,
	|	ВТ_ПроизводствоИнгр.УпаковкаИнгредиента,
	|	ВТ_ПроизводствоИнгр.Период,
	|	ВТ_ПроизводствоИнгр.Склад,
	|	ВТ_ПроизводствоИнгр.Организация,
	|	ВТ_ПроизводствоИнгр.Рецептура,
	|	ВТ_ПроизводствоИнгр.Подразделение,
	|	ВТ_ПроизводствоИнгр.КоличествоБлюда,
	|	ВТ_ПроизводствоИнгр.КоличествоИнгредиента,
	|	ВТ_ПроизводствоИнгр.КоличествоИнгредиентаНорма КАК КоличествоИнгредиентаНорма,
	|	ВТ_ПроизводствоИнгр.ИнгредиентВидНоменклатуры,
	|	ВТ_ПроизводствоИнгр.Автопередел,
	|	ВТ_ПроизводствоИнгр.ИзАвтопеределов,
	|	ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка) КАК ИнгредиентИсходный,
	|	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка) ХарактеристикаИнгредиентаИсходного,
	|	0 КАК КоличествоИнгредиентаИсходного,
	|	ВТ_ПроизводствоИнгр.КоличествоНедовложения КАК КоличествоНедовложения,
	|	ЕСТЬNULL(&ТекстЗапросаКоэффициентУпаковки1, 1) КАК К1,
	|	ЕСТЬNULL(&ТекстЗапросаКоэффициентУпаковки1, 1) КАК К2,
	|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена,
	|	ВТ_ПроизводствоИнгр.КоличествоУпаковокИнгредиента * ЦеныНоменклатурыСрезПоследних.Цена / ЕСТЬNULL(&ТекстЗапросаКоэффициентУпаковки1, 1) * ЕСТЬNULL(&ТекстЗапросаКоэффициентУпаковки2, 1) * ВЫБОР
	|		КОГДА &Валюта <> ЦеныНоменклатурыСрезПоследних.Валюта
	|			ТОГДА ВЫБОР
	|					КОГДА ЕСТЬNULL(КурсыВалютыЦены.Кратность, 0) > 0
	|							И ЕСТЬNULL(КурсыВалютыЦены.Курс, 0) > 0
	|							И ЕСТЬNULL(КурсыВалюты.Кратность, 0) > 0
	|							И ЕСТЬNULL(КурсыВалюты.Курс, 0) > 0
	|						ТОГДА КурсыВалютыЦены.Курс * КурсыВалюты.Кратность / (КурсыВалюты.Курс * КурсыВалютыЦены.Кратность)
	|					ИНАЧЕ 0
	|				КОНЕЦ
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК Сумма
	|ИЗ
	|	ВТ_ПроизводствоИнгр КАК ВТ_ПроизводствоИнгр
	|		ЛЕВОЕ СОЕДИНЕНИЕ втЦеныНоменклатуры КАК ЦеныНоменклатурыСрезПоследних
	|		ПО ВТ_ПроизводствоИнгр.Ингредиент = ЦеныНоменклатурыСрезПоследних.Номенклатура
	|			И ВТ_ПроизводствоИнгр.ХарактеристикаИнгредиента = ЦеныНоменклатурыСрезПоследних.Характеристика
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют.СрезПоследних(&НаДату, ) КАК КурсыВалютыЦены
	|		ПО (ЦеныНоменклатурыСрезПоследних.Валюта = КурсыВалютыЦены.Валюта)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют.СрезПоследних(&НаДату, Валюта = &Валюта) КАК КурсыВалюты
	|		ПО (ИСТИНА)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВТ_ПроизводствоЗамены.Блюдо,
	|	ВТ_ПроизводствоЗамены.Характеристика,
	|	ВТ_ПроизводствоЗамены.ИнгредиентЗамена,
	|	ВТ_ПроизводствоЗамены.ХарактеристикаИнгредиентаЗамена,
	|	ВТ_ПроизводствоЗамены.УпаковкаИнгредиентаЗамена,
	|	ВТ_ПроизводствоЗамены.Период,
	|	ВТ_ПроизводствоЗамены.Склад,
	|	ВТ_ПроизводствоЗамены.Организация,
	|	ВТ_ПроизводствоЗамены.Рецептура,
	|	ВТ_ПроизводствоЗамены.Подразделение,
	|	ВТ_ПроизводствоЗамены.КоличествоБлюда,
	|	ВТ_ПроизводствоЗамены.КоличествоИнгредиентаЗамена,
	|	0,
	|	ВТ_ПроизводствоЗамены.ЗаменаВидНоменклатуры,
	|	ВТ_ПроизводствоЗамены.Автопередел,
	|	ВТ_ПроизводствоЗамены.ИзАвтопеределов,
	|	ВТ_ПроизводствоЗамены.Ингредиент,
	|	ВТ_ПроизводствоЗамены.ХарактеристикаИнгредиента,
	|	ВТ_ПроизводствоЗамены.КоличествоИнгредиентаИсходный,
	|	0,
	|	0,
	|	0,
	|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена,
	|	ВТ_ПроизводствоЗамены.КоличествоУпаковокИнгредиентаЗамена * ЦеныНоменклатурыСрезПоследних.Цена / ЕСТЬNULL(&ТекстЗапросаКоэффициентУпаковки1, 1) * ЕСТЬNULL(&ТекстЗапросаКоэффициентУпаковки3, 1) * ВЫБОР
	|		КОГДА &Валюта <> ЦеныНоменклатурыСрезПоследних.Валюта
	|			ТОГДА ВЫБОР
	|					КОГДА ЕСТЬNULL(КурсыВалютыЦены.Кратность, 0) > 0
	|							И ЕСТЬNULL(КурсыВалютыЦены.Курс, 0) > 0
	|							И ЕСТЬNULL(КурсыВалюты.Кратность, 0) > 0
	|							И ЕСТЬNULL(КурсыВалюты.Курс, 0) > 0
	|						ТОГДА КурсыВалютыЦены.Курс * КурсыВалюты.Кратность / (КурсыВалюты.Курс * КурсыВалютыЦены.Кратность)
	|					ИНАЧЕ 0
	|				КОНЕЦ
	|		ИНАЧЕ 1
	|	КОНЕЦ
	|ИЗ
	|	ВТ_ПроизводствоЗамены КАК ВТ_ПроизводствоЗамены
	|		ЛЕВОЕ СОЕДИНЕНИЕ втЦеныНоменклатуры КАК ЦеныНоменклатурыСрезПоследних
	|		ПО ВТ_ПроизводствоЗамены.ИнгредиентЗамена = ЦеныНоменклатурыСрезПоследних.Номенклатура
	|			И ВТ_ПроизводствоЗамены.ХарактеристикаИнгредиентаЗамена = ЦеныНоменклатурыСрезПоследних.Характеристика
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют.СрезПоследних(&НаДату, ) КАК КурсыВалютыЦены
	|		ПО (ЦеныНоменклатурыСрезПоследних.Валюта = КурсыВалютыЦены.Валюта)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют.СрезПоследних(&НаДату, Валюта = &Валюта) КАК КурсыВалюты
	|		ПО (ИСТИНА)";
	
	
	// +пит
	ТекстЗапросаШаблон = 
		"%1
		|;
		|%2
		|;
		|%3";
	ТекстЦеныКомплексныйОтбор = 
		питЦеныНоменклатуры.ПреобразоватьТекстКомплексногоОтбора(Дата, "(Номенклатура, Характеристика) В
		|						(ВЫБРАТЬ
		|							ВТ_ПроизводствоИнгр.Ингредиент,
		|							ВТ_ПроизводствоИнгр.ХарактеристикаИнгредиента
		|						ИЗ
		|							ВТ_ПроизводствоИнгр КАК ВТ_ПроизводствоИнгр
		|						ОБЪЕДИНИТЬ ВСЕ
		|						ВЫБРАТЬ
		|							ВТ_ПроизводствоЗамены.ИнгредиентЗамена,
		|							ВТ_ПроизводствоЗамены.ХарактеристикаИнгредиентаЗамена
		|						ИЗ
		|							ВТ_ПроизводствоЗамены КАК ВТ_ПроизводствоЗамены)");
	ТекстЗапросаЦены = питЦеныНоменклатуры.ТекстЗапросаЦеныНоменклатуры(Дата, 
		"втЦеныНоменклатуры", "НаДату", "", "", "ВидЦен", ТекстЦеныКомплексныйОтбор);
	ТекстЗапроса2 = СтрЗаменить(ТекстЗапроса2,
		"ВТ_ПроизводствоЗамены.ХарактеристикаИнгредиентаЗамена = ЦеныНоменклатурыСрезПоследних.Характеристика",
		питЦеныНоменклатуры.УсловиеСоединенияХарактеристика(Дата, 
			"ВТ_ПроизводствоЗамены", "ХарактеристикаИнгредиентаЗамена", "ЦеныНоменклатурыСрезПоследних"));
	ТекстЗапроса2 = СтрЗаменить(ТекстЗапроса2,
		"ВТ_ПроизводствоИнгр.ХарактеристикаИнгредиента = ЦеныНоменклатурыСрезПоследних.Характеристика",
		питЦеныНоменклатуры.УсловиеСоединенияХарактеристика(Дата, 
			"ВТ_ПроизводствоИнгр", "ХарактеристикаИнгредиента", "ЦеныНоменклатурыСрезПоследних"));
	ТекстЗапроса = СтрШаблон(ТекстЗапросаШаблон, ТекстЗапроса1, ТекстЗапросаЦены, ТекстЗапроса2);
	// -пит
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса,
	"&ТекстЗапросаКоэффициентУпаковки1",
	Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаКоэффициентаУпаковки(
	"ЦеныНоменклатурыСрезПоследних.Упаковка",
	"ЦеныНоменклатурыСрезПоследних.Номенклатура"));
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса,
	"&ТекстЗапросаКоэффициентУпаковки2",
	Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаКоэффициентаУпаковки(
	"ВТ_ПроизводствоИнгр.УпаковкаИнгредиента",
	"ВТ_ПроизводствоИнгр.Ингредиент"));
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса,
	"&ТекстЗапросаКоэффициентУпаковки3",
	Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаКоэффициентаУпаковки(
	"ВТ_ПроизводствоЗамены.УпаковкаИнгредиентаЗамена",
	"ВТ_ПроизводствоЗамены.ИнгредиентЗамена"));
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("НаДату", МоментВремени());
	Запрос.УстановитьПараметр("ВидЦен", Константы.питНормативнаяЦена.Получить());
	Запрос.УстановитьПараметр("Валюта", Константы.ВалютаРегламентированногоУчета.Получить());
	
	Запрос.Текст = ТекстЗапроса;	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Движения.питПроизводство.Записывать = Истина;
	ДвиженияПроизводство = Движения.питПроизводство;
	
	Пока Выборка.Следующий() Цикл
		НоваяЗапись = ДвиженияПроизводство.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяЗапись, Выборка);
		
		Если Выборка.ИнгредиентВидНоменклатуры = Перечисления.питВидыНоменклатуры.Товар Или НЕ ЗначениеЗаполнено(Выборка.ИнгредиентВидНоменклатуры) Тогда
			Если Выборка.Автопередел И НЕ Выборка.ИзАвтопеределов Тогда 
				НоваяЗапись.ВидПроизводственногоДвижения = Перечисления.питВидыПроизводственногоДвижения.ТоварВЗаготовке
			ИначеЕсли НЕ Выборка.Автопередел И НЕ Выборка.ИзАвтопеределов Тогда 
				НоваяЗапись.ВидПроизводственногоДвижения = Перечисления.питВидыПроизводственногоДвижения.ТоварВБлюде
			КонецЕсли
		ИначеЕсли Выборка.ИнгредиентВидНоменклатуры = Перечисления.питВидыНоменклатуры.Блюдо Тогда
			Если Выборка.Автопередел И НЕ Выборка.ИзАвтопеределов Тогда 
				НоваяЗапись.ВидПроизводственногоДвижения = Перечисления.питВидыПроизводственногоДвижения.ЗаготовкаВЗаготовке
			ИначеЕсли НЕ Выборка.Автопередел И НЕ Выборка.ИзАвтопеределов Тогда 
				НоваяЗапись.ВидПроизводственногоДвижения = Перечисления.питВидыПроизводственногоДвижения.ЗаготовкаВБлюде
			ИначеЕсли Выборка.Автопередел И Выборка.ИзАвтопеределов Тогда 
				НоваяЗапись.ВидПроизводственногоДвижения = Перечисления.питВидыПроизводственногоДвижения.ЗаготовкаВЗаготовкеАвтопередел
			ИначеЕсли НЕ Выборка.Автопередел И Выборка.ИзАвтопеределов Тогда 
				НоваяЗапись.ВидПроизводственногоДвижения = Перечисления.питВидыПроизводственногоДвижения.ЗаготовкаВБлюдеАвтопередел
			КонецЕсли
		ИначеЕсли Выборка.ИнгредиентВидНоменклатуры = Перечисления.питВидыНоменклатуры.ТехнологическийИнгредиент Тогда // Технический ингредиент
			Если Выборка.Автопередел И НЕ Выборка.ИзАвтопеределов Тогда 
				НоваяЗапись.ВидПроизводственногоДвижения = Перечисления.питВидыПроизводственногоДвижения.ТехнологическийОтходВЗаготовке
			ИначеЕсли НЕ Выборка.Автопередел И НЕ Выборка.ИзАвтопеределов Тогда 
				НоваяЗапись.ВидПроизводственногоДвижения = Перечисления.питВидыПроизводственногоДвижения.ТехнологическийОтходВБлюде
			КонецЕсли
		КонецЕсли;
		
	КонецЦикла;
	
	// Сбросим в БезИзменения реквизит ОбщепитСпособРасчетаЦеныРеализацииПродукции,
	// если настройка НеИзменятьРанееРассчитаннуюЦенуТоваровИБлюд установлена в Истина
	текРежимРасчетаСписанияВПроизводство = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("РежимРасчетаСписанияВПроизводство");
	текНеИзменятьРежимСписанияВПроизводство = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("НеИзменятьРежимСписанияВПроизводствоПоНастройке");
	
	Если НЕ текНеИзменятьРежимСписанияВПроизводство Тогда ///***--- И НЕ СтандартныеПодсистемыСервер.ЭтоБазоваяВерсияКонфигурации()
		Если НЕ ЗначениеЗаполнено(текРежимРасчетаСписанияВПроизводство) Тогда
			// Заменим режим проведения на "По Факту", для того, чтобы при дальнейших регламентных проведениях
			// всегда гарантированно получать один и тот же результат.
			РежимРасчетаСписанияВПроизводство = Перечисления.питРежимыРасчетаСписанияВПроизводство.ПоФакту;
		Иначе
			РежимРасчетаСписанияВПроизводство = текРежимРасчетаСписанияВПроизводство;
		КонецЕсли;
	КонецЕсли;
	
	Если РежимРасчетаСписанияВПроизводство = Перечисления.питРежимыРасчетаСписанияВПроизводство.ПоФакту И НЕ РазрешитьНедовложения = Ложь Тогда
		РазрешитьНедовложения = Ложь;
	КонецЕсли;
	
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	ЭтотОбъект.ДокументОснование = Неопределено;
КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	ПроведениеДокументов.ПриЗаписиДокумента(ЭтотОбъект, Отказ);
	
	//+ОтложенноеПроведение
	Если ДополнительныеСвойства.Свойство("питИспользоватьОтложенноеПроведениеВыпускаБлюд") Тогда
		питТекущийПриоритетДействияОтложенногоПроведения = 0;
		Если ДополнительныеСвойства.питИспользоватьОтложенноеПроведениеВыпускаБлюд
			И НЕ ДополнительныеСвойства.Свойство("питВыполнениеДействияОтложенногоПроведения") Тогда
			
			ТекстОшибки = "";
			
			Отказ = НЕ питТиповыеДокументы.УдалитьДействияОтложенногоПроведенияПоДокументуОбщепит(Ссылка, ТекстОшибки);
			Если Отказ Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
				Возврат;
			КонецЕсли;
			
			Если ДополнительныеСвойства.СтараяПометкаУдаления = Ложь И ПометкаУдаления = Истина Тогда
				ТекДействие = Перечисления.питДействияОтложенногоПроведения.ПометитьНаУдалениеДокументОбщепит;
			ИначеЕсли ДополнительныеСвойства.СтараяПометкаУдаления = Истина И ПометкаУдаления = Ложь Тогда
				ТекДействие = Перечисления.питДействияОтложенногоПроведения.СнятьПометкуУдаленияДокументОбщепит;
			Иначе
				ТекДействие = питТиповыеДокументы.ПолучитьТекущееДействиеПоРежимузаписиДокументаОбщепит(ДополнительныеСвойства.РежимЗаписи);
			КонецЕсли;
			Отказ = НЕ питТиповыеДокументы.ДобавитьДействиеОтложенногоПроведения(Ссылка, ТекДействие, Неопределено, 0,ТекстОшибки);
			
			Если Отказ Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
			КонецЕсли;
			
			Возврат;
		КонецЕсли;
	КонецЕсли;
	//-ОтложенноеПроведение
	
	Если НЕ Отказ Тогда
		питЦентрМониторинга.ЗаписатьОперацииБизнесСтатистики(ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры

Функция МассивОднотипный(МассивДляПроверки)
	
	Результат = Истина;
	Счетчик = 0;
	ТекущийТип = Неопределено;
	Для каждого ЭлементМассива Из МассивДляПроверки Цикл
		Если Счетчик = 0 Тогда
			ТекущийТип = ТипЗнч(ЭлементМассива);
			Продолжить;
		КонецЕсли;
		Если НЕ ТекущийТип = ТипЗнч(ЭлементМассива) Тогда
