Процедура ЗаполнитьДокументНаОснованииПланаМеню(Знач ДокументОснование, Знач СУчетомПроизведенных = Ложь)
	
	ФормироватьДокументыПроизводства22 = Константы.питФормироватьДокументыПроизводства22.Получить();
	
	Запрос = Новый Запрос;
	ТекстЗапроса = "ВЫБРАТЬ
	|	питПланМеню.Ссылка КАК ДокументОснование,
	|	питПланМеню.Организация,
	|	питПланМеню.Подразделение,
	|	питПланМеню.Валюта,
	|	питПланМеню.КурсКонвертации,
	|	питПланМеню."+?(ФормироватьДокументыПроизводства22, "ЦеховаяКладовая", "Склад")+" КАК Склад,
	|	питПланМеню.СкладРеализации КАК СкладПолучатель,
	|	питПланМеню.ТипЦен,
	|	питПланМеню.СуммаДокумента,
	|	питПланМеню.РежимИспользованияАналогов,
	|	питПланМеню.РазрешитьНедовложения,
	|	питПланМеню.ВидПроизводства,
	|	питПланМеню.УчитыватьОстаткиБлюдНаСкладе,
	|	питПланМеню.ПроцентНаценки,
	|	питПланМеню.РасчетСебестоимости,
	|	питПланМеню.НеИспользоватьСезонныеПроценты,
	|	питПланМеню.ИсполнительТрудозатрат,
	|	питПланМеню.Товары.(
	|		Номенклатура,
	//<<Портал-Юг, Давиденко 2019.02.19 [4.2.7 Нулевая цена и аналитика продаж в отчёте о розничных продажах и выпуске блюд]
	|		НомерСтроки,
	//>>Портал-Юг, Давиденко 2019.02.19
	|		Характеристика,
	|		КоличествоУпаковок,
	|		Количество,
	|		Упаковка,
	|		Себестоимость,
	|		ПроцентНаценки,
	|		Цена,
	|		ЦенаЗаЕдиницуУдадлить,
	|		Сумма,
	|		СтавкаНДС,
	|		СуммаНДС,
	|		СуммаВсего,
	|		Характеристика,
	|		Рецептура,
	|		СкидкаНаТовар,
	|		ПроцентСкидки,
	|		ПроцентСкидкиСтроки,
	|		СуммаСкидки,
	|		СуммаСкидкиСтроки,
	|		ИдентификаторСтроки,
	|		Назначение,
	|		НазначениеИнгредиентов,
	|		ИзмененФактБлюда
	|	),
	|	питПланМеню.Блюда.(
	|		ИдентификаторСтроки,
	|		Номенклатура,
	|		Характеристика,
	|		Назначение,
	|		Рецептура,
	|		Автопередел,
	|		КоличествоУпаковокНоменклатуры,
	|		УпаковкаНоменклатуры,
	|		КоличествоНоменклатуры,
	|		СтатьяКалькуляции,
	|		ИзмененФактБлюда,
	|		Порядок
	|	),
	|	питПланМеню.Ингредиенты.(
	|		Ингредиент,
	|		Характеристика,
	|		Назначение,
	|		ИдентификаторБлюда,
	|		УпаковкаИнгредиента,
	|		КоличествоУпаковокИнгредиентаНорма,
	|		КоличествоУпаковокИнгредиентаФакт,
	|		ИзАвтопеределов,
	|		КоличествоИнгредиентаНорма,
	|		КоличествоИнгредиентаФакт,
	|		РецептураАвтопередела,
	|		Специя,
	|		ЗапретитьЗамены,
	|		СтатьяКалькуляции,
	|		СезонныйПроцент,
	|		Себестоимость,
	|		СпособУчетаНДС,
	|		ИзмененФакт
	|	),
	|	питПланМеню.Замены.(
	|		Ссылка,
	|		НомерСтроки,
	|		Блюдо,
	|		ХарактеристикаБлюда,
	|		Рецептура,
	|		Автопередел,
	|		ИнгредиентИсходный,
	|		ХарактеристикаИнгредиентаИсходного,
	|		НазначениеИнгредиентаИсходного,
	|		КоличествоИнгредиентаИсходный,
	|		КоличествоУпаковокИнгредиентаИсходный,
	|		УпаковкаИнгредиентаИсходный,
	|		ИнгредиентЗамена,
	|		ХарактеристикаИнгредиентаЗамена,
	|		НазначениеИнгредиентаЗамена,
	|		КоличествоИнгредиентаЗамена,
	|		КоличествоУпаковокИнгредиентаЗамена,
	|		УпаковкаИнгредиентаЗамена,
	|		СчетУчета,
	|		ОтражениеВУСН,
	|		ДокументОприходования,
	|		Себестоимость,
	|		СпособУчетаНДС,
	|		СтатьяКалькуляции
	|	),
	|	питПланМеню.Трудозатраты.(
	|		Ссылка,
	|		НомерСтроки,
	|		ИдентификаторБлюда,
	|		Подразделение,
	|		ВидРабот,
	|		Количество,
	|		СтатьяКалькуляции
	|	),
	|	питПланМеню.ПобочныеИзделия.(
	|		Ссылка,
	|		НомерСтроки,
	|		ИдентификаторБлюда,
	|		Подразделение,
	|		Получатель,
	|		Номенклатура,
	|		Характеристика,
	|		Серия,
	|		СтатусУказанияСерий,
	|		КоличествоУпаковок,
	|		Количество,
	|		Упаковка,
	|		Цена,
	|		Сумма,
	|		СтатьяКалькуляции,
	|		Назначение
	|	)
	|ИЗ
	|	Документ.питПланМеню КАК питПланМеню
	|ГДЕ
	|	питПланМеню.Ссылка = &ДокументОснование";
	
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("ДокументОснование",ДокументОснование);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Выборка.Следующий();
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, Выборка);
	//<<Портал-Юг, Давиденко 2019.02.19 [4.2.7 Нулевая цена и аналитика продаж в отчёте о розничных продажах и выпуске блюд]
	// запрос не расширить малыми потерями, поэтому добавим колонку "Договор" в отдельной процедуре и загрузим ТЗ в Документ
	//Товары.Загрузить(Выборка.Товары.Выгрузить());
	ТЗТовары = Выборка.Товары.Выгрузить();
	ПЛ_Сервер.ДополнитьТаблицуТоварыДоговором(ТЗТовары);
	Товары.Загрузить(ТЗТовары);
	//>>Портал-Юг, Давиденко 2019.02.19
	Блюда.Загрузить(Выборка.Блюда.Выгрузить());
	Ингредиенты.Загрузить(Выборка.Ингредиенты.Выгрузить());
	Замены.Загрузить(Выборка.Замены.Выгрузить());
	Трудозатраты.Загрузить(Выборка.Трудозатраты.Выгрузить());
	ПобочныеИзделия.Загрузить(Выборка.ПобочныеИзделия.Выгрузить());
	
	Если ЗначениеЗаполнено(Выборка.СкладПолучатель) И НЕ (Выборка.Склад = Выборка.СкладПолучатель) Тогда
		ЭтотОбъект.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.ВыпускПродукцииСПеремещением;
	КонецЕсли;
	
	Если СУчетомПроизведенных Тогда
		Запрос = Новый Запрос;
		Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	питПланМенюТовары.Номенклатура КАК Номенклатура,
		|	питПланМенюТовары.Характеристика КАК Характеристика,
		|	питПланМенюТовары.Упаковка КАК Упаковка,
		|	питПланМенюТовары.КоличествоУпаковок КАК КоличествоУпаковок,
		|	питПланМенюТовары.Количество КАК Количество
		|ПОМЕСТИТЬ втПлан
		|ИЗ
		|	Документ.питПланМеню.Товары КАК питПланМенюТовары
		|ГДЕ
		|	питПланМенюТовары.Ссылка = &ДокументОснование
		|
		|;
		|
		|ВЫБРАТЬ
		|	питВыпускБлюдТовары.Номенклатура,
		|	питВыпускБлюдТовары.Характеристика,
		|	питВыпускБлюдТовары.Упаковка,
		|	питВыпускБлюдТовары.КоличествоУпаковок,
		|	питВыпускБлюдТовары.Количество
		|ПОМЕСТИТЬ втФакт
		|ИЗ
		|	Документ.питВыпускБлюд.Товары КАК питВыпускБлюдТовары
		|ГДЕ
		|	питВыпускБлюдТовары.Ссылка.Проведен
		|	И питВыпускБлюдТовары.Ссылка.ДокументОснование = &ДокументОснование
		|";
		Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование);
		РезультатЗапроса = Запрос.Выполнить();
		ТаблицаДельта = питПерепланирование.РазностьТаблицТоваровЗапрос(Запрос, "втФакт", "втПлан",,Истина);
		
		СтруктураПоиска = Новый Структура("Номенклатура, Характеристика");
		СтрокиУдалить = Новый Массив;
		КэшированныеЗначенияУпаковок = Неопределено;
		Для каждого СтрокаДельта Из ТаблицаДельта Цикл
			ЗаполнитьЗначенияСвойств(СтруктураПоиска, СтрокаДельта);
			НайденныеСтроки = Товары.НайтиСтроки(СтруктураПоиска);
			Для каждого ТекущаяСтрока Из НайденныеСтроки Цикл
				Если СтрокаДельта.Количество <= 0 Тогда
					СтрокиУдалить.Добавить(ТекущаяСтрока);
					Продолжить;
				КонецЕсли;
				Если ТекущаяСтрока.Количество >= СтрокаДельта.Количество Тогда
					ТекущаяСтрока.Количество = СтрокаДельта.Количество;
					ТекущаяСтрока.КоличествоУпаковок = СтрокаДельта.Количество * питОбщегоНазначения.ПолучитьКоэффициентУпаковки(ТекущаяСтрока.Номенклатура, ТекущаяСтрока.Упаковка, КэшированныеЗначенияУпаковок);
				КонецЕсли;
				СтрокаДельта.Количество = СтрокаДельта.Количество - ТекущаяСтрока.Количество;
			КонецЦикла;
		КонецЦикла;
		Для каждого ТекущаяСтрокаУдалить Из СтрокиУдалить Цикл
			Товары.Удалить(ТекущаяСтрокаУдалить);
		КонецЦикла;
	КонецЕсли;
	
	//+ИзменениеФактаВПроизводстве
	// Установка режима по норме или по факту в зависимости от того, были ли изменены блюда в плане-меню.
	ИзмененыБлюда = питИзменениеФактаВПроизводстве.ЕстьИзмененныеБлюдаТовары(Блюда, Товары);
	РежимРасчетаСписанияВПроизводство = ?(ИзмененыБлюда, Перечисления.питРежимыРасчетаСписанияВПроизводство.ПоФакту, Перечисления.питРежимыРасчетаСписанияВПроизводство.ПоНорме);
	//-ИзменениеФактаВПроизводстве
	
	// +питПриоритетыПриготовления
	питПриоритетыПриготовления.СортироватьТабличнуюЧастьОбъектаПоПриоритетуПриготовления(ЭтотОбъект, "Товары", Склад);
	// -питПриоритетыПриготовления
	
	Если СУчетомПроизведенных Тогда
		ЗаполнитьПроизводства(Истина);
	КонецЕсли;
	
	ЭтотОбъект.Комментарий = "Выпуск создан на основании документа План-меню: <"+ДокументОснование+">";
	
КонецПроцедуры

Процедура ЗаполнитьДокументНаОснованииТиповыхДокументов(Знач МассивДокументовОснований)
	
	Если НЕ МассивДокументовОснований.Количество() Тогда
		Возврат;
	КонецЕсли;
	
	ДокументОснованиеГлавный = МассивДокументовОснований[0];
	
	ИмяДокументаВнутреннееПотребление = питОбратнаяСовместимостьПовтИсп.ИмяДокументаВнутреннееПотребление();
	
	СпособРасчетаРецептурыПоАктуальной= (питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("СпособРасчетаРецептур") = Перечисления.питСпособРасчетаРецептур.ПоАктуальнойРецептуре);
	
	Запрос = Новый Запрос;
	ТекстЗапроса = "ВЫБРАТЬ
	|	ДокОснование.Ссылка КАК ДокументОснование,
	|	ДокОснование.Организация КАК Организация,
	|	ДокОснование.Подразделение КАК Подразделение,
	|	ДокОснование.Склад КАК Склад,
	|	ДокОснование.Комментарий КАК Комментарий,
	|	ДокОснование.Автор КАК Ответственный,
	|	НЕОПРЕДЕЛЕНО КАК СкладПолучатель,
	|	НЕОПРЕДЕЛЕНО КАК ЦенаВключаетНДС,
	|	НЕОПРЕДЕЛЕНО КАК ТипЦен,
	|	НЕОПРЕДЕЛЕНО КАК Контрагент,
	|	НЕОПРЕДЕЛЕНО КАК Партнер,
	|	НЕОПРЕДЕЛЕНО КАК Договор,
	|	НЕОПРЕДЕЛЕНО КАК НаправлениеДеятельности,
	|	НЕОПРЕДЕЛЕНО КАК Валюта,
	|	НЕОПРЕДЕЛЕНО КАК КассаККМ
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК ДокОснование
	|ГДЕ
	|	ДокОснование.Ссылка = &ДокументОснование
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТабличнаяЧастьТовары.Номенклатура КАК Номенклатура,
	|	ТабличнаяЧастьТовары.Характеристика КАК Характеристика,
	|	ТабличнаяЧастьТовары.Серия КАК Серия,
	|	ТабличнаяЧастьТовары.СтатусУказанияСерий КАК СтатусУказанияСерий,
	|	СУММА(ТабличнаяЧастьТовары.КоличествоУпаковок) КАК КоличествоУпаковок,
	|	СУММА(ТабличнаяЧастьТовары.Количество) КАК Количество,
	|	ТабличнаяЧастьТовары.Упаковка КАК Упаковка,
	|	ТабличнаяЧастьТовары.Номенклатура.питВидНоменклатуры КАК питВидНоменклатуры,
	|	ЗНАЧЕНИЕ(Документ.питРецептура.ПустаяСсылка) КАК Рецептура
	|ПОМЕСТИТЬ втТовары
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК ТабличнаяЧастьТовары
	|ГДЕ
	|	ТабличнаяЧастьТовары.Ссылка В (&МассивДокументовОснований)
	|
	|СГРУППИРОВАТЬ ПО
	|	ТабличнаяЧастьТовары.Номенклатура,
	|	ТабличнаяЧастьТовары.Характеристика,
	|	ТабличнаяЧастьТовары.Упаковка,
	|	ТабличнаяЧастьТовары.Номенклатура.питВидНоменклатуры,
	|	ТабличнаяЧастьТовары.Серия,
	|	ТабличнаяЧастьТовары.СтатусУказанияСерий
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТабличнаяЧастьСерии.Серия КАК Серия,
	|	ТабличнаяЧастьСерии.Количество КАК Количество,
	|	ТабличнаяЧастьСерии.Номенклатура КАК Номенклатура,
	|	ТабличнаяЧастьСерии.Характеристика КАК Характеристика,
	|	ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка) КАК Назначение
	|ПОМЕСТИТЬ втСерии
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Серии КАК ТабличнаяЧастьСерии
	|ГДЕ
	|	ТабличнаяЧастьСерии.Ссылка В (&МассивДокументовОснований)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втТовары.Номенклатура КАК Номенклатура,
	|	втТовары.Характеристика КАК Характеристика,
	|	втТовары.КоличествоУпаковок КАК КоличествоУпаковок,
	|	втТовары.Количество КАК Количество,
	|	втТовары.Упаковка КАК Упаковка,
	|	втТовары.питВидНоменклатуры КАК питВидНоменклатуры,
	|	втТовары.Серия КАК Серия,
	|	втТовары.СтатусУказанияСерий КАК СтатусУказанияСерий,
	|	втТовары.Рецептура КАК Рецептура,
	|	ЕСТЬNULL(втСерии.Серия, ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)) КАК СерияТЧ,
	|	ЕСТЬNULL(втСерии.Количество, 0) КАК СерияКоличествоТЧ,
	|	ВЫБОР
	|		КОГДА втСерии.Серия ЕСТЬ NULL
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК СерияВТЧ
	|ИЗ
	|	втТовары КАК втТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ втСерии КАК втСерии
	|		ПО втТовары.Номенклатура = втСерии.Номенклатура
	|			И втТовары.Характеристика = втСерии.Характеристика";
	Если ТипЗнч(ДокументОснованиеГлавный) = Тип("ДокументСсылка.ОтчетОРозничныхПродажах") Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Документ.РеализацияТоваровУслуг", "Документ.ОтчетОРозничныхПродажах");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ДокОснование.Автор КАК Ответственный", "ДокОснование.Ответственный КАК Ответственный");
	ИначеЕсли ТипЗнч(ДокументОснованиеГлавный) = Тип(СтрШаблон("ДокументСсылка.%1", ИмяДокументаВнутреннееПотребление)) Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Документ.РеализацияТоваровУслуг", СтрШаблон("Документ.%1", ИмяДокументаВнутреннееПотребление));
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ДокОснование.Автор КАК Ответственный", "ДокОснование.Ответственный КАК Ответственный");
	ИначеЕсли ТипЗнч(ДокументОснованиеГлавный) = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Документ.РеализацияТоваровУслуг", "Документ.ВозвратТоваровОтКлиента");
	ИначеЕсли ТипЗнч(ДокументОснованиеГлавный) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Документ.РеализацияТоваровУслуг", "Документ.ПеремещениеТоваров");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ДокОснование.Склад КАК Склад", "ДокОснование.СкладОтправитель КАК Склад");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ДокОснование.Автор КАК Ответственный", "ДокОснование.Ответственный КАК Ответственный");
	ИначеЕсли ТипЗнч(ДокументОснованиеГлавный) = Тип("ДокументСсылка.ДвижениеПродукцииИМатериалов") Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Документ.РеализацияТоваровУслуг", "Документ.ДвижениеПродукцииИМатериалов");
		УсловиеСклад = 
		"ВЫБОР 
		|	КОГДА ДокОснование.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПередачаПродукцииИзКладовой)
		|		ТОГДА ДокОснование.Отправитель 
		|	КОГДА ДокОснование.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПередачаМатериаловВКладовую)
		|		ТОГДА ДокОснование.Получатель 
		|	ИНАЧЕ НЕОПРЕДЕЛЕНО 
		|КОНЕЦ КАК Склад";
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ДокОснование.Склад КАК Склад", УсловиеСклад);
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ДокОснование.Автор КАК Ответственный", "ДокОснование.Ответственный КАК Ответственный");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ДокОснование.Подразделение КАК Подразделение", "НЕОПРЕДЕЛЕНО КАК Подразделение");
	КонецЕсли;
	
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("ДокументОснование", ДокументОснованиеГлавный);
	Запрос.УстановитьПараметр("МассивДокументовОснований", МассивДокументовОснований);
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	// Шапка.
	Выборка = РезультатЗапроса[0].Выбрать();
	Выборка.Следующий();
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, Выборка);
	
	// Для упаковок.
	КэшированныеЗначения = ОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
	
	// ТЧ "Товары"
	ТаблицаТоварыВыборка = РезультатЗапроса[3].Выбрать();
	Пока ТаблицаТоварыВыборка.Следующий() Цикл
		// Если это не блюдо, то не считаем
		Если ТаблицаТоварыВыборка.питВидНоменклатуры <> Перечисления.питВидыНоменклатуры.Блюдо Тогда
			Продолжить;
		КонецЕсли;
		
		НовСтрокаТовары = Товары.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтрокаТовары, ТаблицаТоварыВыборка);
		
		Если СпособРасчетаРецептурыПоАктуальной Тогда
			// Определяем актуальную рецептуру
			НовСтрокаТовары.Рецептура = питПроизводство.ВернутьОсновнуюРецептуру(НовСтрокаТовары.Номенклатура, НовСтрокаТовары.Характеристика, Перечисления.питХозяйственныеОперации.РецептураПриготовление,Дата,СпособРасчетаРецептурыПоАктуальной,,ЭтотОбъект.Организация,,,ЭтотОбъект.Подразделение);
		КонецЕсли;
		
		Если ТаблицаТоварыВыборка.СерияВТЧ Тогда
			НовСтрокаТовары.Серия				= ТаблицаТоварыВыборка.СерияТЧ;
			НовСтрокаТовары.Количество			= ТаблицаТоварыВыборка.СерияКоличествоТЧ;
			НовСтрокаТовары.КоличествоУпаковок	= питОбщегоНазначения.ПолучитьКоэффициентУпаковки(НовСтрокаТовары.Номенклатура, НовСтрокаТовары.Упаковка, КэшированныеЗначения) / ТаблицаТоварыВыборка.СерияКоличествоТЧ;
		КонецЕсли;
		
	КонецЦикла;
	
	// +питПриоритетыПриготовления
	питПриоритетыПриготовления.СортироватьТабличнуюЧастьОбъектаПоПриоритетуПриготовления(ЭтотОбъект, "Товары", Склад);
	// -питПриоритетыПриготовления
	
	ЭтотОбъект.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.ВыпускПродукции;
	ЭтотОбъект.Комментарий = "Выпуск создан на основании документа ""Реализация товаров и услуг"": <"+ДокументОснование+">";
	
КонецПроцедуры

Процедура ИнициализироватьДокумент(ДанныеЗаполнения = Неопределено)
	
	Менеджер                  = Пользователи.ТекущийПользователь();
	Валюта                    = питПроизводствоПовтИсп.ПолучитьВалютуРегламентированногоУчета(Валюта);
	Организация               = ЗначениеНастроекПовтИсп.ПолучитьОрганизациюПоУмолчанию(Организация);
	
	Склад                     = ЗначениеНастроекПовтИсп.ПолучитьСкладПоУмолчанию(Склад, Ложь, Истина);
	СтатьяКалькуляции         = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("СтатьяКалькуляцииПоУмолчанию");
	
	Если НЕ ЗначениеЗаполнено(РежимПриготовленияМодификаторов) Тогда
		РежимПриготовленияМодификаторов = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питВидыПроизводстваМодификаторов");
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("Массив") Тогда
		ДанныеЗаполненияМассив = ДанныеЗаполнения;
	Иначе
		ДанныеЗаполненияМассив = Новый Массив;
		ДанныеЗаполненияМассив.Добавить(ДанныеЗаполнения);
	КонецЕсли;
	Если НЕ ДанныеЗаполненияМассив.Количество() Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не найдено данные для заполнения документа!");
		Возврат;
	КонецЕсли;
	Если НЕ МассивОднотипный(ДанныеЗаполненияМассив) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Данные для заполнения документа не однотипны. Выберите документы одинакового типа");
		Возврат;
	КонецЕсли;
	ДанныеЗаполненияГлавный = ДанныеЗаполненияМассив[0];
	
	ИмяДокументаВнутреннееПотребление = питОбратнаяСовместимостьПовтИсп.ИмяДокументаВнутреннееПотребление();
	
	Если ОбщегоНазначения.ПодсистемаСуществует("РегламентированныйУчетПодсистемы") Тогда
		МодульЗаполнениеДокументов = ОбщегоНазначения.ОбщийМодуль("ЗаполнениеДокументов");
		МодульЗаполнениеДокументов.Заполнить(ЭтотОбъект, ДанныеЗаполненияГлавный, Ложь);
	КонецЕсли; 
	
	ИнициализироватьДокумент();
	
	Если ТипЗнч(ДанныеЗаполненияГлавный) = тип("ДокументСсылка.питПланМеню") Тогда
		
		ЗаполнитьДокументНаОснованииПланаМеню(ДанныеЗаполненияГлавный);
		
	ИначеЕсли ТипЗнч(ДанныеЗаполненияГлавный) = тип("Структура")
		И ДанныеЗаполненияГлавный.Свойство("ДокументОснование")
		И ТипЗнч(ДанныеЗаполненияГлавный.ДокументОснование) = тип("ДокументСсылка.питПланМеню") Тогда
		ЗаполнитьДокументНаОснованииПланаМеню(ДанныеЗаполненияГлавный.ДокументОснование, ДанныеЗаполненияГлавный.Свойство("СУчетомПроизведенных"));
		
	ИначеЕсли ТипЗнч(ДанныеЗаполненияГлавный) = тип("ДокументСсылка.ОтчетОРозничныхПродажах") 
		ИЛИ ТипЗнч(ДанныеЗаполненияГлавный) = тип("ДокументСсылка.РеализацияТоваровУслуг") 
		ИЛИ ТипЗнч(ДанныеЗаполненияГлавный) = тип(СтрШаблон("ДокументСсылка.%1", ИмяДокументаВнутреннееПотребление)) 
		ИЛИ ТипЗнч(ДанныеЗаполненияГлавный) = тип("ДокументСсылка.ВозвратТоваровОтКлиента")
		ИЛИ ТипЗнч(ДанныеЗаполненияГлавный) = тип("ДокументСсылка.ДвижениеПродукцииИМатериалов")
		ИЛИ ТипЗнч(ДанныеЗаполненияГлавный) = тип("ДокументСсылка.ПеремещениеТоваров") Тогда
		
		ЗаполнитьДокументНаОснованииТиповыхДокументов(ДанныеЗаполненияМассив);
		
	Иначе
		
		//+25
		//ЗаполнениеСвойствПоСтатистикеСервер.ЗаполнитьСвойстваОбъекта(ЭтотОбъект, ДанныеЗаполнения);
		ЗаполнениеОбъектовПоСтатистике.ЗаполнитьРеквизитыОбъекта(ЭтотОбъект, ДанныеЗаполненияГлавный);
		//-25
		
		// Предлагаем использовать или нет сезонные коэффициенты
		НеИспользоватьСезонныеПроценты = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питНеИспользоватьСезонныеПроценты");
		
		ВидПроизводства = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питРежимПриготовленияПолуфабрикатов");
		
	КонецЕсли;
	
		//<<Портал-Юг, Давиденко 2019.03.01 [4.2.3 Вид операции «Заборный лист» в документе «Выпуск блюд»]
	Если ПЛ_ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.питХозяйственныеОперации.ПЛ_ЗаборныйЛист") Тогда
		Для Каждого СтрокаТовары Из Товары Цикл
			СтрокаТовары.ПЛ_Передано = СтрокаТовары.КоличествоУпаковок - СтрокаТовары.ПЛ_Возвращено;
		КонецЦикла;

	КонецЕсли;
		ПЛ_ХозяйственнаяОперация = ХозяйственнаяОперация;
	//>>Портал-Юг, Давиденко 2019.03.01			
	
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	// +питПриоритетыПриготовления
	Если ДополнительныеСвойства.Свойство("питСортироватьПоПриоритетуПриготовления") Тогда
		питПриоритетыПриготовления.СортироватьТабличнуюЧастьОбъектаПоПриоритетуПриготовления(ЭтотОбъект, "Товары", Склад);
	КонецЕсли;
	// -питПриоритетыПриготовления
	
	ПроведениеДокументов.ПередЗаписьюДокумента(ЭтотОбъект, РежимЗаписи, РежимПроведения);
	
	//<< Портал-Юг, Баринов, 2019.09.15 [9.20 Настройка доступа к документу «Выпуск блюд» для супервайзеров и поваров]
	Если НЕ ЭтоНовый() И НЕ ПравоДоступа("Проведение", Метаданные()) Тогда
		// Не должно быть возможности изменить вид операции на "Выпуск с розничной реализацией" и в реализации менять значение реквизита "ПЛ_Номенклатура"
		РеквизитыДоЗаписи = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Ссылка, "ПЛ_ХозяйственнаяОперация, ПЛ_Номенклатура");
		Если ПЛ_ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.ВыпускПродукцииСРозничнойРеализацией 
			ИЛИ РеквизитыДоЗаписи.ПЛ_ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.ВыпускПродукцииСРозничнойРеализацией Тогда
			
			НарушениеПрав = ПЛ_ХозяйственнаяОперация <> РеквизитыДоЗаписи.ПЛ_ХозяйственнаяОперация
				ИЛИ ПЛ_Номенклатура <> РеквизитыДоЗаписи.ПЛ_Номенклатура;
			
			Если НарушениеПрав Тогда
				Отказ = Истина;
				ТекстОшибки = НСтр("ru = 'У пользователя недостаточно прав на исполнение операции над базой данных'");
				ВызватьИсключение ТекстОшибки;
			КонецЕсли; 	
		КонецЕсли;
	КонецЕсли; 
	//>> Портал-Юг, Баринов, 2019.09.15
	
	// Эти два флага должны совпадать
	СуммаВключаетНДС = ЦенаВключаетНДС;
	
	ЭтоРозница     = (ХозяйственнаяОперация=Перечисления.питХозяйственныеОперации.ВыпускПродукцииСРозничнойРеализацией);
	ЭтоРеализация  = (ХозяйственнаяОперация=Перечисления.питХозяйственныеОперации.ВыпускПродукцииСРеализацией);
	
	Если ЭтоРозница ИЛИ ЭтоРеализация Тогда
		СуммаДокумента = ЦенообразованиеКлиентСервер.ПолучитьСуммуДокумента(Товары, ЦенаВключаетНДС);
		Для каждого СтрокаТовары Из Товары Цикл
			СтрокаТовары.Назначение = Неопределено;
		КонецЦикла;
	Иначе
		СуммаДокумента = 0;
	КонецЕсли;
	
	//+ОтложенноеПроведение
	Если НЕ ДополнительныеСвойства.Свойство("питИспользоватьОтложенноеПроведениеВыпускаБлюд") Тогда
		ДополнительныеСвойства.Вставить("питИспользоватьОтложенноеПроведениеВыпускаБлюд", питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питИспользоватьОтложенноеПроведениеВыпускаБлюд"));
	КонецЕсли;
	Если ДополнительныеСвойства.питИспользоватьОтложенноеПроведениеВыпускаБлюд
		И НЕ ДополнительныеСвойства.Свойство("питВыполнениеДействияОтложенногоПроведения") Тогда
		ДополнительныеСвойства.Вставить("РежимЗаписи", РежимЗаписи);
		ДополнительныеСвойства.Вставить("СтараяПометкаУдаления", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ссылка, "ПометкаУдаления"));
		Возврат;
	КонецЕсли;
	//-ОтложенноеПроведение
	
	//<<Портал-Юг, Каунов, 2019.11.11 [запрет записи выпусков в конце дня] - формирует документы следующим днём
	Если Дата = КонецДня(Дата) Тогда
		Дата = Дата-1;
	КонецЕсли; 
	//>>Портал-Юг, Каунов, 2019.11.11
	
	Если РежимЗаписи <> РежимЗаписиДокумента.Проведение Тогда
		Возврат;
	КонецЕсли;
	
	//+Серии
	ПараметрыУказанияСерий = НоменклатураСервер.ПараметрыУказанияСерий(ЭтотОбъект,Документы.питВыпускБлюд);
	НоменклатураСервер.ОчиститьНеиспользуемыеСерии(ЭтотОбъект, ПараметрыУказанияСерий.Товары);
	НоменклатураСервер.ОчиститьНеиспользуемыеСерии(ЭтотОбъект, ПараметрыУказанияСерий.ПобочныеИзделия);
	НоменклатураСервер.ОчиститьНеиспользуемыеСерии(ЭтотОбъект, ПараметрыУказанияСерий.Блюда);
	НоменклатураСервер.ОчиститьНеиспользуемыеСерии(ЭтотОбъект, ПараметрыУказанияСерий.Ингредиенты);
	НоменклатураСервер.ОчиститьНеиспользуемыеСерии(ЭтотОбъект, ПараметрыУказанияСерий.Модификаторы);
	//-Серии
	
	ДополнительныеСвойства.Вставить("РежимЗаписи", РежимЗаписи);
	
	Если ПометкаУдаления Тогда
		Возврат;
	КонецЕсли;
	
	// Прежде, чем пересчитывать таблицы производства, обновим рецептуры в ТЧ товары
	ТекстОшибки = "";
	//<< Портал-Юг, Баринов, 2019.10.21 [Перенесено из релиза 2.4.10.56]
	//ПроверкаАктуальностиРецептур(Отказ, РежимЗаписи, ТекстОшибки);
	//<< Портал-Юг, Баринов, 2019.11.25 [Перепроведение без пересчёта]
	Если Не ПЛ_КлиентСервер.ЗначениеСвойства(ДополнительныеСвойства, "ПЛ_ГрупповоеПерепроведение", Ложь) Тогда
	//>> Портал-Юг, Баринов, 2019.11.25
	ОбновитьАктуальныеРецептуры(Отказ, РежимЗаписи, ТекстОшибки);
	//<< Портал-Юг, Баринов, 2019.11.25 [Перепроведение без пересчёта]
	КонецЕсли; 
	//>> Портал-Юг, Баринов, 2019.11.25
	//>> Портал-Юг, Баринов, 2019.10.21
	Если Отказ Тогда
		ВызватьИсключение(ТекстОшибки);
		Возврат;
	КонецЕсли;
	
	//+Серии
	
	ПараметрыУказанияСерий = НоменклатураСервер.ПараметрыУказанияСерий(ЭтотОбъект, Документы.питВыпускБлюд);
	ТекстОшибки = "";
	
	// Автосоздание серий по товарам
	ВсеОк = питПроизводство.СоздатьСерииАвтоматически(ЭтотОбъект, ПараметрыУказанияСерий.Товары, ТекстОшибки);
	Если НЕ ВсеОк Тогда
		Отказ = Истина;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
		Возврат;
	КонецЕсли;
	// Автосоздание серий по побочным изделиям
	ВсеОк = питПроизводство.СоздатьСерииАвтоматически(ЭтотОбъект, ПараметрыУказанияСерий.ПобочныеИзделия, ТекстОшибки);
	Если НЕ ВсеОк Тогда
		Отказ = Истина;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
		Возврат;
	КонецЕсли;
	//-Серии
	
	//<<Портал-Юг, Давиденко 2019.03.12 [6.2.10 Отражение производства услуг по СКЛ]
	// необходимо иметь возможность ввода дублей
	//Отказ = НЕ Документы.питВыпускБлюд.ПроверитьТоварыНаДубли(ЭтотОбъект);
	//>>Портал-Юг, Давиденко 2019.03.1
	Если ЭтотОбъект.РежимРасчетаСписанияВПроизводство = Перечисления.питРежимыРасчетаСписанияВПроизводство.ПоНорме Тогда
		
		ОтключитьДополнительныеПроверки = Ложь;
		Если ДополнительныеСвойства.Свойство("ОтключитьДополнительныеПроверки") Тогда
			ОтключитьДополнительныеПроверки = ДополнительныеСвойства.ОтключитьДополнительныеПроверки;
		КонецЕсли;

		//<< Портал-Юг, Баринов, 2019.11.25 [Перепроведение без пересчёта]
		Если Не ПЛ_КлиентСервер.ЗначениеСвойства(ДополнительныеСвойства, "ПЛ_ГрупповоеПерепроведение", Ложь) Тогда
		//>> Портал-Юг, Баринов, 2019.11.25
		
		ЗаполнитьПроизводства(ОтключитьДополнительныеПроверки);

		//<< Портал-Юг, Баринов, 2019.11.25 [Перепроведение без пересчёта]
		КонецЕсли; 
		//>> Портал-Юг, Баринов, 2019.11.25			
	КонецЕсли;
	
	// Проверка заполненности рецептур в ТЧ "Товары".
	ТекстОшибки = "";
	//<< Портал-Юг, Баринов, 2019.11.25 [Перепроведение без пересчёта]
	Если Не ПЛ_КлиентСервер.ЗначениеСвойства(ДополнительныеСвойства, "ПЛ_ГрупповоеПерепроведение", Ложь) Тогда
	//>> Портал-Юг, Баринов, 2019.11.25
	ПроверкаЗаполненностиРецептур(Отказ, РежимЗаписи, ТекстОшибки);
	//<< Портал-Юг, Баринов, 2019.11.25 [Перепроведение без пересчёта]
	КонецЕсли; 
	//>> Портал-Юг, Баринов, 2019.11.25		
	Если Отказ Тогда
		ВызватьИсключение(ТекстОшибки);
		Возврат;
	КонецЕсли;
	
	//+Серии
	// Автосоздание серий по блюдам(п/ф)
	ВсеОк = питПроизводство.СоздатьСерииАвтоматически(ЭтотОбъект, ПараметрыУказанияСерий.Блюда, ТекстОшибки, Истина);
	Если НЕ ВсеОк Тогда
		Отказ = Истина;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
		Возврат;
	КонецЕсли;
	//-Серии
	
	//+Серии
	// Заполнение серии в ТЧ "Ингредиенты".
	СтрокиАвтопеределов = ЭтотОбъект.Ингредиенты.НайтиСтроки(Новый Структура("ИзАвтопеределов", Истина));
	Для каждого ТекАвтопередел Из СтрокиАвтопеределов Цикл
		СтрокиБлюдо = ЭтотОбъект.Блюда.НайтиСтроки(Новый Структура("Номенклатура,Характеристика,Рецептура,Автопередел", ТекАвтопередел.Ингредиент, ТекАвтопередел.Характеристика, ТекАвтопередел.РецептураАвтопередела, Истина));
		Если СтрокиБлюдо.Количество() Тогда
			СтрокаБлюдо = СтрокиБлюдо[0];
			ТекАвтопередел.Серия = СтрокаБлюдо.Серия;
		КонецЕсли;
	КонецЦикла;
	//-Серии
	
		// << MRS #ERP-5312 ДенисламовАД <Adel.Denislamov@mriyaresort.com> 23.07.25, ()
	ОргСклада = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Склад, "ПЛ_Организация");
	Если РежимЗаписи = РежимЗаписиДокумента.Проведение И ЗначениеЗаполнено(ОргСклада) И Организация <> ОргСклада Тогда
		Если НЕ MRS_Сервер.РольДоступнаВызовСервера("АдминистраторСистемы") Тогда
			ОбщегоНазначения.СообщитьПользователю("Запрещено проведение документа с организацией отличной от организации склада получателя!",,,,Отказ);
		Иначе
			СообщенияПользователюБЗК.СообщитьПользователю("Запрещено проведение документа с организацией отличной от организации склада получателя!, Но вы Админ, вам можно.");
		КонецЕсли;	
	КонецЕсли;
	// >> MRS #ERP-5312 ДенисламовАД <Adel.Denislamov@mriyaresort.com> 23.07.25, ()
	
	Документы.питВыпускБлюд.СвернутьМодификаторы(Модификаторы);
	Документы.питВыпускБлюд.ПроверитьМодификаторы(Модификаторы);
	
	ДополнительныеСвойства.Вставить("ЭтоНовый", ЭтоНовый());
	ДополнительныеСвойства.Вставить("РежимЗаписи", РежимЗаписи);
	
КонецПроцедуры

// Проверяет заполненность рецептур в ТЧ Товары.
Процедура ПроверкаЗаполненностиРецептур(Отказ=Ложь, РежимЗаписи = Неопределено, ТекстОшибки = "")
	Если РежимЗаписи = Неопределено Тогда
		РежимЗаписи = РежимЗаписиДокумента.Запись;
	КонецЕсли;
	
	питВосприниматьБлюдоБезРецептурыКакТовар = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питВосприниматьБлюдоБезРецептурыКакТовар");
	
	Если РежимРасчетаСписанияВПроизводство=Перечисления.питРежимыРасчетаСписанияВПроизводство.ПоНорме Тогда
		
		ЗаписыватьПриНеЗаполненнойРецептуре = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("ЗаписыватьПриНеЗаполненнойРецептуре");
		//СпособРасчетаРецептурыПоАктуальной = (Константы.питСпособРасчетаРецептур.Получить() = Перечисления.питСпособРасчетаРецептур.ПоАктуальнойРецептуре);
		СпособРасчетаРецептурыПоАктуальной= (питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("СпособРасчетаРецептур") = Перечисления.питСпособРасчетаРецептур.ПоАктуальнойРецептуре);
		СвойстваТоваров = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(Товары.ВыгрузитьКолонку("Номенклатура"),"питВидНоменклатуры");
		Если НЕ СпособРасчетаРецептурыПоАктуальной Тогда
			СвойстваРецептур = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(Товары.ВыгрузитьКолонку("Рецептура"),"Номенклатура");
		КонецЕсли;	
		
		Для Каждого СтрокаТовары Из Товары Цикл
			
			// Если это не блюдо, то не считаем
			Если СвойстваТоваров.Получить(СтрокаТовары.Номенклатура).питВидНоменклатуры <> Перечисления.питВидыНоменклатуры.Блюдо Тогда
				Продолжить;
			КонецЕсли;	
			
			Если СпособРасчетаРецептурыПоАктуальной Тогда
				// Определяем актуальную рецептуру
				Рецептура = питПроизводство.ВернутьОсновнуюРецептуру(СтрокаТовары.Номенклатура, СтрокаТовары.Характеристика, Перечисления.питХозяйственныеОперации.РецептураПриготовление,Дата,СпособРасчетаРецептурыПоАктуальной,,Организация,,,Подразделение);
			Иначе
				Рецептура = СтрокаТовары.Рецептура;
			КонецЕсли;
			
			Префикс = "Товары[" + Формат(СтрокаТовары.НомерСтроки - 1, "ЧН=0; ЧГ=") + "].";
			
			Если НЕ ЗначениеЗаполнено(Рецептура) И НЕ СтрокаТовары.ПриготовлениеЗапрещено И НЕ питВосприниматьБлюдоБезРецептурыКакТовар Тогда
				
				// Рецептуры нет, сообщим об этом
				Если СпособРасчетаРецептурыПоАктуальной Тогда
					ТекстСообщения = НСтр("ru = 'Нет актуальной рецептуры, на дату: %1.'");
					ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, Дата);
				Иначе
					ТекстСообщения = НСтр("ru = 'Не заполнена рецептура.'");
				КонецЕсли;	
				ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("Колонка", "Заполнение",
					НСтр("ru = 'Рецептура'"), СтрокаТовары.НомерСтроки, "Товары", ТекстСообщения);
				Поле = Префикс + "Рецептура";
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, Поле, "Объект", );
				ТекстОшибки = ТекстСообщения;
				Если НЕ ЗаписыватьПриНеЗаполненнойРецептуре ИЛИ РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
					Отказ = Истина;
				КонецЕсли;
				
			Иначе
				
				Если НЕ СпособРасчетаРецептурыПоАктуальной Тогда
					// Проверить правильность указания рецептуры
					Если СтрокаТовары.Номенклатура <> СвойстваРецептур.Получить(СтрокаТовары.Рецептура).Номенклатура Тогда
						
						ТекстСообщения = НСтр("ru = 'Неправильно указана рецептура, номенклатура в шапке рецептуры не равна номенклатуре в строке таблицы товаров.'");
						ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("Колонка", "Корректность",
							НСтр("ru = 'Рецептура'"), СтрокаТовары.НомерСтроки, "Товары", ТекстСообщения);
						Поле = Префикс + "Рецептура";
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, Поле, "Объект", );
						ТекстОшибки = ТекстСообщения;
						Если НЕ ЗаписыватьПриНеЗаполненнойРецептуре ИЛИ РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
							Отказ = Истина;
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

// Обновляет ТЧ Товары актуальными рецептурами
Процедура ОбновитьАктуальныеРецептуры(Отказ=Ложь, РежимЗаписи = Неопределено, ТекстОшибки = "")
	Если РежимЗаписи = Неопределено Тогда
		РежимЗаписи = РежимЗаписиДокумента.Запись;
	КонецЕсли;
	
	Если РежимРасчетаСписанияВПроизводство=Перечисления.питРежимыРасчетаСписанияВПроизводство.ПоНорме Тогда
		
		ЗаписыватьПриНеЗаполненнойРецептуре = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("ЗаписыватьПриНеЗаполненнойРецептуре");
		СпособРасчетаРецептурыПоАктуальной= (питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("СпособРасчетаРецептур") = Перечисления.питСпособРасчетаРецептур.ПоАктуальнойРецептуре);
		СвойстваТоваров = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(Товары.ВыгрузитьКолонку("Номенклатура"),"питВидНоменклатуры");
		Если НЕ СпособРасчетаРецептурыПоАктуальной Тогда
			СвойстваРецептур = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(Товары.ВыгрузитьКолонку("Рецептура"),"Номенклатура");
		КонецЕсли;	
		
		Для Каждого СтрокаТовары Из Товары Цикл
			
			// Если это не блюдо, то не считаем
			Если СвойстваТоваров.Получить(СтрокаТовары.Номенклатура).питВидНоменклатуры <> Перечисления.питВидыНоменклатуры.Блюдо Тогда
				Продолжить;
			КонецЕсли;	
			
			Если СпособРасчетаРецептурыПоАктуальной Тогда
				// Определяем актуальную рецептуру
				Рецептура = питПроизводство.ВернутьОсновнуюРецептуру(СтрокаТовары.Номенклатура, СтрокаТовары.Характеристика, Перечисления.питХозяйственныеОперации.РецептураПриготовление,Дата,СпособРасчетаРецептурыПоАктуальной,,Организация,,,Подразделение);
				Если СтрокаТовары.Рецептура<>Рецептура Тогда
					СтрокаТовары.Рецептура = Рецептура;
				КонецЕсли;
			КонецЕсли;
			
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	Если НЕ ЗначениеЗаполнено(РежимПриготовленияМодификаторов) Тогда
		РежимПриготовленияМодификаторов = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питВидыПроизводстваМодификаторов");
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ВидПроизводства) Тогда
		ВидПроизводства = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питРежимПриготовленияПолуфабрикатов");
	КонецЕсли;
	
	ЭтоВыпуск      = (ХозяйственнаяОперация=Перечисления.питХозяйственныеОперации.ВыпускПродукции);
	ЭтоРозница     = (ХозяйственнаяОперация=Перечисления.питХозяйственныеОперации.ВыпускПродукцииСРозничнойРеализацией);
	ЭтоРеализация  = (ХозяйственнаяОперация=Перечисления.питХозяйственныеОперации.ВыпускПродукцииСРеализацией);
	ЭтоСписание    = (ХозяйственнаяОперация=Перечисления.питХозяйственныеОперации.ВыпускПродукцииСоСписанием);
	ЭтоПеремещение = (ХозяйственнаяОперация=Перечисления.питХозяйственныеОперации.ВыпускПродукцииСПеремещением);
	///***---
	//РаздельныйУчетНДСДо2014Года = УчетнаяПолитика.РаздельныйУчетНДСДо2014Года(Организация, Дата);
	//РаздельныйУчетНДСНаСчете19 = УчетнаяПолитика.РаздельныйУчетНДСНаСчете19(Организация, Дата);
	РаздельныйУчетНДСДо2014Года = Ложь; //удалить
	РаздельныйУчетНДСНаСчете19 = Ложь;
	
	МассивНепроверяемыхРеквизитов = Новый Массив();
	
	// Не проверяем заполненность табличных частей (включая реквизиты), 
	// которые не используются при определенных видах операции и будут очищены в ПередЗаписью
