	Если ЭтоРозница Тогда
		
		// Проверка: сумма безналичных оплат не должна превышать сумму по реализации товаров и услуг
		СуммаВыручки = Товары.Итог("Сумма") + ?(СуммаВключаетНДС, 0, Товары.Итог("СуммаНДС"))
			+ АгентскиеУслуги.Итог("Сумма") + ?(СуммаВключаетНДС, 0, АгентскиеУслуги.Итог("СуммаНДС"));
		
		Если Оплата.Итог("СуммаОплаты") > СуммаВыручки  Тогда
			
			ТекстОписаниеОшибки = НСтр("ru = 'Сумма безналичных оплат превышает сумму выручки от реализации!'");
			ТекстСообщения      = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("Список", "Корректность",,, НСтр("ru = 'Безналичные оплаты'"), ТекстОписаниеОшибки);
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, "Оплата", "Объект", Отказ);
			
		КонецЕсли;
		
	КонецЕсли;
	
	#Область ПроверкаХарактеристик
	
	ПараметрыПроверкиХарактеристик = НоменклатураСервер.ПараметрыПроверкиЗаполненияХарактеристик();
	
	ПараметрыПроверкиХарактеристик.ИмяТЧ = "Товары";
	НоменклатураСервер.ПроверитьЗаполнениеХарактеристик(ЭтотОбъект, МассивНепроверяемыхРеквизитов, Отказ, ПараметрыПроверкиХарактеристик);
	
	ПараметрыПроверкиХарактеристик.ИмяТЧ = "Модификаторы";
	НоменклатураСервер.ПроверитьЗаполнениеХарактеристик(ЭтотОбъект, МассивНепроверяемыхРеквизитов, Отказ, ПараметрыПроверкиХарактеристик);
	
	ПараметрыПроверкиХарактеристик.ИмяТЧ = "ПобочныеИзделия";
	НоменклатураСервер.ПроверитьЗаполнениеХарактеристик(ЭтотОбъект, МассивНепроверяемыхРеквизитов, Отказ, ПараметрыПроверкиХарактеристик);
	
	ПараметрыПроверкиХарактеристик.ИмяТЧ = "Блюда";
	НоменклатураСервер.ПроверитьЗаполнениеХарактеристик(ЭтотОбъект, МассивНепроверяемыхРеквизитов, Отказ, ПараметрыПроверкиХарактеристик);
	
	МассивНепроверяемыхРеквизитов.Добавить("Замены.ХарактеристикаБлюда");
	МассивНепроверяемыхРеквизитов.Добавить("Замены.ХарактеристикаИнгредиентаИсходного");
	МассивНепроверяемыхРеквизитов.Добавить("Замены.ХарактеристикаИнгредиентаЗамена");
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"
		|ВЫБРАТЬ 
		|	ТЧЗамены.НомерСтроки,
		|	ТЧЗамены.Блюдо, 
		|	ТЧЗамены.ИнгредиентИсходный, 
		|	ТЧЗамены.ИнгредиентЗамена,
		|	ТЧЗамены.ХарактеристикаБлюда,
		|	ТЧЗамены.ХарактеристикаИнгредиентаЗамена,
		|	ТЧЗамены.ХарактеристикаИнгредиентаИсходного
		|ПОМЕСТИТЬ ВТЗамены 
		|ИЗ &ТЧЗамены КАК ТЧЗамены;
		|
		|ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА НЕ Блюда.ИспользованиеХарактеристик = ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать)
		|				И питВыпускБлюдЗамены.ХарактеристикаБлюда = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)
		|			ТОГДА ЛОЖЬ
		|		ИНАЧЕ ИСТИНА
		|	КОНЕЦ КАК ХарактеристикаБлюдаЗаполнена,
		|	питВыпускБлюдЗамены.НомерСтроки,
		|	ВЫБОР
		|		КОГДА НЕ ИнгредиентыЗамена.ИспользованиеХарактеристик = ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать)
		|				И питВыпускБлюдЗамены.ХарактеристикаИнгредиентаЗамена = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)
		|			ТОГДА ЛОЖЬ
		|		ИНАЧЕ ИСТИНА
		|	КОНЕЦ КАК ХарактеристикаЗаменыЗаполнена,
		|	ВЫБОР
		|		КОГДА НЕ ИнгредиентыИсходные.ИспользованиеХарактеристик = ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать)
		|				И питВыпускБлюдЗамены.ХарактеристикаИнгредиентаИсходного = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)
		|			ТОГДА ЛОЖЬ
		|		ИНАЧЕ ИСТИНА
		|	КОНЕЦ КАК ХарактеристикаИнгредиентаИсходногоЗаполнена
		|ИЗ
		|	ВТЗамены КАК питВыпускБлюдЗамены
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Блюда
		|		ПО питВыпускБлюдЗамены.Блюдо = Блюда.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК ИнгредиентыИсходные
		|		ПО питВыпускБлюдЗамены.ИнгредиентИсходный = ИнгредиентыИсходные.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК ИнгредиентыЗамена
		|		ПО питВыпускБлюдЗамены.ИнгредиентЗамена = ИнгредиентыЗамена.Ссылка";
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("ТЧЗамены", ЭтотОбъект.Замены.Выгрузить());
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	КлючДанных = ОбщегоНазначенияУТ.КлючДанныхДляСообщенияПользователю(ЭтотОбъект);
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если НЕ ВыборкаДетальныеЗаписи.ХарактеристикаБлюдаЗаполнена Тогда
			Отказ = Истина;
			Поле = ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти("Замены", ВыборкаДетальныеЗаписи.НомерСтроки, "ХарактеристикаБлюда");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнена характеристика блюда в строке "+ВыборкаДетальныеЗаписи.НомерСтроки+" таблицы ""Замены""!",,,,Отказ);
		КонецЕсли;
		Если НЕ ВыборкаДетальныеЗаписи.ХарактеристикаЗаменыЗаполнена Тогда
			Отказ = Истина;
			Поле = ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти("Замены", ВыборкаДетальныеЗаписи.НомерСтроки, "ХарактеристикаИнгредиентаЗамена");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнена характеристика замены в строке "+ВыборкаДетальныеЗаписи.НомерСтроки+" таблицы ""Замены""!",,,,Отказ);
		КонецЕсли;
		Если НЕ ВыборкаДетальныеЗаписи.ХарактеристикаЗаменыЗаполнена Тогда
			Отказ = Истина;
			Поле = ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти("Замены", ВыборкаДетальныеЗаписи.НомерСтроки, "ХарактеристикаИнгредиентаИсходного");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнена характеристика исходного ингредиента в строке "+ВыборкаДетальныеЗаписи.НомерСтроки+" таблицы ""Замены""!",,,,Отказ);
		КонецЕсли;
	КонецЦикла;
	
	МассивНепроверяемыхРеквизитов.Добавить("Ингредиенты.Характеристика");
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ 
	|	ТЧИнгредиенты.НомерСтроки, 
	|	ТЧИнгредиенты.Ингредиент,
	|	ТЧИнгредиенты.Характеристика
	|ПОМЕСТИТЬ ВТИнгредиенты 
	|ИЗ &ТЧИнгредиенты КАК ТЧИнгредиенты;
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА НЕ Ингредиенты.ИспользованиеХарактеристик = ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать)
	|				И питВыпускБлюдИнгредиенты.Характеристика = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ХарактеристикаЗаполнена,
	|	питВыпускБлюдИнгредиенты.НомерСтроки
	|ИЗ
	|	ВТИнгредиенты КАК питВыпускБлюдИнгредиенты
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Ингредиенты
	|		ПО питВыпускБлюдИнгредиенты.Ингредиент = Ингредиенты.Ссылка";
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("ТЧИнгредиенты", ЭтотОбъект.Ингредиенты.Выгрузить());
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	КлючДанных = ОбщегоНазначенияУТ.КлючДанныхДляСообщенияПользователю(ЭтотОбъект);
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если НЕ ВыборкаДетальныеЗаписи.ХарактеристикаЗаполнена Тогда
			Отказ = Истина;
			Поле = ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти("Ингредиенты", ВыборкаДетальныеЗаписи.НомерСтроки, "Характеристика");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнена характеристика ингредиента в строке "+ВыборкаДетальныеЗаписи.НомерСтроки+" таблицы ""Ингредиенты""!",,,,Отказ);
		КонецЕсли;
	КонецЦикла;
	
	#КонецОбласти
	
	#Область ПроверкаСерий
	
	ПараметрыУказанияСерий = НоменклатураСервер.ПараметрыУказанияСерий(ЭтотОбъект, Документы.питВыпускБлюд);
	СтатусыСерийСерияНеУказана = НоменклатураКлиентСервер.СтатусыСерийСерияНеУказана();
	
	// Товары
	ПараметрыУказанияСерий.Товары.ОтборПроверяемыхСтрок = Новый Массив;
	Для каждого ТекПроверяемаяСтрока Из ЭтотОбъект.Товары Цикл
		//>> Швецов. ERP-5431. 30.09.25. Проверка при проведениия на указание серии для алко
		//Если СтатусыСерийСерияНеУказана.Найти(ТекПроверяемаяСтрока.СтатусУказанияСерий) = Неопределено Тогда
		Если СтатусыСерийСерияНеУказана.Найти(ТекПроверяемаяСтрока.СтатусУказанияСерий) <> Неопределено Тогда
		//<<
			ПараметрыУказанияСерий.Товары.ОтборПроверяемыхСтрок.Добавить(ТекПроверяемаяСтрока);
		КонецЕсли;
	КонецЦикла;
	
	// ПобочныеИзделия
	ПараметрыУказанияСерий.ПобочныеИзделия.ОтборПроверяемыхСтрок = Новый Массив;
	Для каждого ТекПроверяемаяСтрока Из ЭтотОбъект.ПобочныеИзделия Цикл
		Если СтатусыСерийСерияНеУказана.Найти(ТекПроверяемаяСтрока.СтатусУказанияСерий) = Неопределено Тогда
			ПараметрыУказанияСерий.ПобочныеИзделия.ОтборПроверяемыхСтрок.Добавить(ТекПроверяемаяСтрока);
		КонецЕсли;
	КонецЦикла;
	
	// Блюда
	ПараметрыУказанияСерий.Блюда.ОтборПроверяемыхСтрок = Новый Массив;
	Для каждого ТекПроверяемаяСтрока Из ЭтотОбъект.Блюда Цикл
		Если СтатусыСерийСерияНеУказана.Найти(ТекПроверяемаяСтрока.СтатусУказанияСерий) = Неопределено Тогда
			ПараметрыУказанияСерий.Блюда.ОтборПроверяемыхСтрок.Добавить(ТекПроверяемаяСтрока);
		КонецЕсли;
	КонецЦикла;
	
	// Модификаторы
	ПараметрыУказанияСерий.Модификаторы.ОтборПроверяемыхСтрок = Новый Массив;
	Для каждого ТекПроверяемаяСтрока Из ЭтотОбъект.Модификаторы Цикл
		Если СтатусыСерийСерияНеУказана.Найти(ТекПроверяемаяСтрока.СтатусУказанияСерий) = Неопределено Тогда
			ПараметрыУказанияСерий.Модификаторы.ОтборПроверяемыхСтрок.Добавить(ТекПроверяемаяСтрока);
		КонецЕсли;
	КонецЦикла;
	
	НоменклатураСервер.ПроверитьЗаполнениеСерий(ЭтотОбъект, ПараметрыУказанияСерий.Товары, Отказ, МассивНепроверяемыхРеквизитов);
	НоменклатураСервер.ПроверитьЗаполнениеСерий(ЭтотОбъект, ПараметрыУказанияСерий.ПобочныеИзделия, Отказ, МассивНепроверяемыхРеквизитов);
	НоменклатураСервер.ПроверитьЗаполнениеСерий(ЭтотОбъект, ПараметрыУказанияСерий.Блюда, Отказ, МассивНепроверяемыхРеквизитов);
	НоменклатураСервер.ПроверитьЗаполнениеСерий(ЭтотОбъект, ПараметрыУказанияСерий.Модификаторы, Отказ, МассивНепроверяемыхРеквизитов);
	
	#КонецОбласти
	
	//+Бизнес ланчи
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(ТЧТовары.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	ТЧТовары.ИдентификаторСтроки КАК ИдентификаторСтроки,
	|	ТЧТовары.НомерСтроки
	|ПОМЕСТИТЬ ВТТовары
	|ИЗ
	|	&ТЧТовары КАК ТЧТовары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТЧМодификаторы.Номенклатура КАК Номенклатура,
	|	ТЧМодификаторы.ИдентификаторСтроки КАК ИдентификаторСтроки
	|ПОМЕСТИТЬ ВТМодификаторы
	|ИЗ
	|	&ТЧМодификаторы КАК ТЧМодификаторы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТТовары.Номенклатура КАК Номенклатура,
	|	ВТТовары.ИдентификаторСтроки КАК ИдентификаторСтроки,
	|	ВТТовары.НомерСтроки КАК НомерСтроки
	|ПОМЕСТИТЬ ВТБизнесЛанчи
	|ИЗ
	|	ВТТовары КАК ВТТовары
	|ГДЕ
	|	ВТТовары.Номенклатура.питВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.питВидыНоменклатуры.БизнесЛанч)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТБизнесЛанчи.Номенклатура КАК Номенклатура,
	|	ВТМодификаторы.Номенклатура КАК НоменклатураМодификатора,
	|	ВТБизнесЛанчи.НомерСтроки КАК НомерСтроки
	|ИЗ
	|	ВТБизнесЛанчи КАК ВТБизнесЛанчи
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТМодификаторы КАК ВТМодификаторы
	|		ПО ВТБизнесЛанчи.ИдентификаторСтроки = ВТМодификаторы.ИдентификаторСтроки
	|ГДЕ
	|	ВТМодификаторы.Номенклатура ЕСТЬ NULL";
	Запрос.УстановитьПараметр("ТЧТовары", ЭтотОбъект.Товары.Выгрузить());
	Запрос.УстановитьПараметр("ТЧМодификаторы", ЭтотОбъект.Модификаторы.Выгрузить());
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	КлючДанных = ОбщегоНазначенияУТ.КлючДанныхДляСообщенияПользователю(ЭтотОбъект);
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Отказ = Истина;
		Поле = ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти("Товары", ВыборкаДетальныеЗаписи.НомерСтроки, "Номенклатура");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнены модификаторы бизнес ланча в строке "+ВыборкаДетальныеЗаписи.НомерСтроки+" таблицы ""Товары""!",ЭтотОбъект,Поле,"Объект",Отказ);
	КонецЦикла;
	//-Бизнес ланчи
	
	Если НЕ Трудозатраты.Количество() Тогда
		МассивНепроверяемыхРеквизитов.Добавить("ИсполнительТрудозатрат");
	КонецЕсли;
	
	ОбщегоНазначения.УдалитьНепроверяемыеРеквизитыИзМассива(ПроверяемыеРеквизиты, МассивНепроверяемыхРеквизитов);
	
КонецПроцедуры

Процедура СообщитьОНекорректномЗначенииТаблицыОплата(НомерСтроки, ИмяПоля, ЗначениеПоля, ТекстОшибки, Отказ)
	
	ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("Колонка", "Корректность",
		ЗначениеПоля, НомерСтроки, НСтр("ru = 'Оплата'"), ТекстОшибки);
	
	Поле = "Оплата[" + Формат(НомерСтроки - 1, "ЧН=0; ЧГ=") + "]." + ИмяПоля;
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, Поле, "Объект", Отказ);
	
КонецПроцедуры

Процедура ЗаполнитьПроизводства(ОтключитьДополнительныеПроверки)
	
	//+АвтовыборНоменклатуры
	МассивДеревьевСостава = Новый Массив;
	//+АвтовыборНоменклатуры
	
	ТаблицаПроизводства = питПроизводство.ЗаполнитьПроизводственныеТаблицыПоРецептуре(ЭтотОбъект, Истина, ,ОтключитьДополнительныеПроверки, МассивДеревьевСостава, УточненияАвтовыбора);
	
	//+АвтовыборНоменклатуры
	питУправлениеДаннымиОбИзделиях.ЗаполнитьУточненияАвтовыбора(МассивДеревьевСостава, УточненияАвтовыбора);
	Если питУправлениеДаннымиОбИзделиях.ЗаполнитьНайденыОшибкиАвтовыбора(УточненияАвтовыбора) Тогда
		ОбщегоНазначения.СообщитьПользователю("Найдены неуточненные характеристики в таблице производства!");
	КонецЕсли;
	//+АвтовыборНоменклатуры
	
	//+РазрешенныеПодразделения
	Товары.Загрузить(питПроизводство.УстановитьЗапрещенныеТовары(ТаблицаПроизводства, Товары.Выгрузить()));
	//-РазрешенныеПодразделения
	
	ТаблицаПроизводства.Колонки.Добавить("ФактЗамены", новый ОписаниеТипов("Число"));
	
	ОписаниеТиповСтрока = Новый ОписаниеТипов("Строка");
	
	ЭтотОбъект.Замены.Очистить();
	СтруктураПараметров = Новый Структура("МоментВремени, СчитатьФактВТаблицеЗамен, Склад, Организация, Подразделение, РежимИспользованияАналогов, ОрганизацияПрименяетУСН");
	СтруктураПараметров.МоментВремени  = питПроизводство.ПолучитьМоментВремениКонтроляОстатковВыпуска(ЭтотОбъект);
	СтруктураПараметров.СчитатьФактВТаблицеЗамен = Ложь;
	СтруктураПараметров.Склад = ЭтотОбъект.Склад;
	СтруктураПараметров.Организация = ЭтотОбъект.Организация;
	СтруктураПараметров.Подразделение = ЭтотОбъект.Подразделение;
	СтруктураПараметров.РежимИспользованияАналогов = ЭтотОбъект.РежимИспользованияАналогов;
	СтруктураПараметров.ОрганизацияПрименяетУСН = Ложь;////ОбщептЕРП!!!
	СтруктураПараметров.Вставить("СсылкаНаДокумент", ?(ЭтотОбъект.Ссылка.Пустая(), Неопределено, ЭтотОбъект.Ссылка));
	СтруктураПараметров.Вставить("ВидПроизводства", ЭтотОбъект.ВидПроизводства);
	
	питПроизводство.ЗаполнитьПроизводственныеТаблицыФактическимКоличеством(ТаблицаПроизводства,ЭтотОбъект.Замены , СтруктураПараметров);
	
	Если НЕ ЭтотОбъект.РазрешитьНедовложения Тогда
		// Остаточную нехватку пишем в КоличествоФакт, и заполняем колонку ФактЗамены
		питПроизводство.ЗаписатьОстаточныеНехваткиВКоличествоФакт(ТаблицаПроизводства, ЭтотОбъект.Замены);
	Иначе
		// Рассчитываем только колонку ФактЗамены
		питПроизводство.ЗаписатьВТаблицуПроизводствоФактЗанены(ТаблицаПроизводства, ЭтотОбъект.Замены);
		
		питПроизводство.ОбнулитьФактическоеКоличествоПеределовПоСоставу(ТаблицаПроизводства);
		
	КонецЕсли;
	
	// Заполняем таблицу производства
	Если ТаблицаПроизводства <> Неопределено Тогда
		
		ЭтотОбъект.Блюда.Очистить();
		ЭтотОбъект.Ингредиенты.Очистить();

		ТаблицаПроизводства.Колонки.ЕдиницаИзмеренияНоменклатуры.Имя = "УпаковкаНоменклатуры";
		ТаблицаПроизводства.Колонки.ЕдиницаИзмеренияИнгредиента.Имя  = "УпаковкаИнгредиента";
		
		ТаблБлюд = ТаблицаПроизводства.Скопировать(,"Номенклатура,Характеристика,Серия,Назначение,УпаковкаНоменклатуры,Рецептура,Автопередел,КоличествоНоменклатуры,КоличествоУпаковокНоменклатуры, Порядок");
		ТаблБлюд.Свернуть("Номенклатура,Характеристика,Рецептура,Серия,Назначение,УпаковкаНоменклатуры,Автопередел,КоличествоНоменклатуры, КоличествоУпаковокНоменклатуры, Порядок");
		ТаблБлюд.Колонки.Добавить("ИдентификаторСтроки", ОписаниеТиповСтрока, ,36);
		
		ТаблицаПроизводства.Колонки.Добавить("ИдентификаторБлюда", ОписаниеТиповСтрока, ,36);
		
		
		Для Каждого Стр из ТаблБлюд Цикл
			
			Стр.ИдентификаторСтроки = Новый УникальныйИдентификатор;
			
			МассивСтрокингредиентов = ТаблицаПроизводства.НайтиСтроки(Новый Структура("Номенклатура,Характеристика,Серия,Назначение,УпаковкаНоменклатуры,Рецептура,Автопередел",Стр.Номенклатура,Стр.Характеристика,Стр.Серия,Стр.Назначение,Стр.УпаковкаНоменклатуры,Стр.Рецептура, Стр.Автопередел ) );
			
			Для Каждого СтрИнгр из МассивСтрокингредиентов Цикл
				
				НовСтрТаблИнгредиентов = ЭтотОбъект.Ингредиенты.Добавить();
				ЗаполнитьЗначенияСвойств(НовСтрТаблИнгредиентов, СтрИнгр);
				НовСтрТаблИнгредиентов.ИдентификаторБлюда = Стр.ИдентификаторСтроки;
				///НовСтрТаблИнгредиентов.Блюдо = Стр.Номенклатура;
				
				НовСтрТаблИнгредиентов.Характеристика = СтрИнгр.ХарактеристикаИнгредиента;
				НовСтрТаблИнгредиентов.Назначение = СтрИнгр.НазначениеИнгредиента;
				НовСтрТаблИнгредиентов.Серия = Справочники.СерииНоменклатуры.ПустаяСсылка();
					
			КонецЦикла;
			
		КонецЦикла;
		//ТаблИнгредиентов = ТаблицаПроизводства.Скопировать(,"ИдентификаторБлюда,Ингредиент,УпаковкаИнгредиента,КоличествоИнгредиентаНорма,КоличествоУпаковокИнгредиентаНорма,СезонныйПроцент,КоличествоИнгредиентаФакт,ИзАвтопеределов,РецептураАвтопередела,Специя,ЗапретитьЗамены,Замена,КоэффициентЗамены,СчетУчета,Субконто,СчетЗатрат,ОтражениеВУСН,Порядок");
		ЭтотОбъект.Блюда.Загрузить(ТаблБлюд);
		
		ДополнительныеТаблицыВыпускаПоТаблицеБлюд = питПроизводство.ПолучитьДополнительныеТаблицыВыпускаПоТаблицеБлюд(ТаблБлюд,";0;1;");
		ЭтотОбъект.Трудозатраты.Загрузить(ДополнительныеТаблицыВыпускаПоТаблицеБлюд[0]);
		ЭтотОбъект.ПобочныеИзделия.Загрузить(ДополнительныеТаблицыВыпускаПоТаблицеБлюд[1]);
		
		ПараметрыУказанияСерий = Новый ФиксированнаяСтруктура(НоменклатураСервер.ПараметрыУказанияСерий(ЭтотОбъект, Документы.питВыпускБлюд));
		НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(ЭтотОбъект, ПараметрыУказанияСерий["Блюда"]);
		НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(ЭтотОбъект, ПараметрыУказанияСерий["Ингредиенты"]);
		НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(ЭтотОбъект, ПараметрыУказанияСерий["Замены"]);
		
	КонецЕсли;
	
	Для каждого ТекСтрокаИнгредиент Из Ингредиенты Цикл
		Если НЕ ЗначениеЗаполнено(ТекСтрокаИнгредиент.КоличествоИнгредиентаНорма) И ЗначениеЗаполнено(ТекСтрокаИнгредиент.КоличествоУпаковокИнгредиентаНорма) Тогда
			ТекСтрокаИнгредиент.КоличествоИнгредиентаНорма = ТекСтрокаИнгредиент.КоличествоУпаковокИнгредиентаНорма * питОбщегоНазначения.ПолучитьКоэффициентУпаковки(ТекСтрокаИнгредиент.Ингредиент, ТекСтрокаИнгредиент.УпаковкаИнгредиента);
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(ТекСтрокаИнгредиент.КоличествоИнгредиентаФакт) И ЗначениеЗаполнено(ТекСтрокаИнгредиент.КоличествоУпаковокИнгредиентаФакт) Тогда
			ТекСтрокаИнгредиент.КоличествоИнгредиентаФакт = ТекСтрокаИнгредиент.КоличествоУпаковокИнгредиентаФакт * питОбщегоНазначения.ПолучитьКоэффициентУпаковки(ТекСтрокаИнгредиент.Ингредиент, ТекСтрокаИнгредиент.УпаковкаИнгредиента);
		КонецЕсли;
	КонецЦикла;
	
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	//+ОтложенноеПроведение
	Если НЕ ДополнительныеСвойства.Свойство("питИспользоватьОтложенноеПроведениеВыпускаБлюд") Тогда
		ДополнительныеСвойства.Вставить("питИспользоватьОтложенноеПроведениеВыпускаБлюд", питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питИспользоватьОтложенноеПроведениеВыпускаБлюд"));
	КонецЕсли;
	Если ДополнительныеСвойства.питИспользоватьОтложенноеПроведениеВыпускаБлюд
		И НЕ ДополнительныеСвойства.Свойство("питВыполнениеДействияОтложенногоПроведения") Тогда
		Возврат;
	КонецЕсли;
	//-ОтложенноеПроведение
	
	//+%ИзЕРП% Набор типовых процедур для обработки проведения документа.
	
	ПроведениеДокументов.ОбработкаПроведенияДокумента(ЭтотОбъект, Отказ);
	
	//-%ИзЕРП%
	
	Если РучнаяКорректировка Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	ТекстЗапроса1 = 
	"ВЫБРАТЬ
	|	питВыпускБлюдБлюда.Номенклатура КАК Блюдо,
	|	питВыпускБлюдБлюда.Характеристика КАК Характеристика,
	|	питВыпускБлюдИнгредиенты.Ингредиент КАК Ингредиент,
	|	питВыпускБлюдИнгредиенты.Характеристика КАК ХарактеристикаИнгредиента,
