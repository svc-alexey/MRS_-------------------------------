// Функция получает результат запроса по связанным с передаваемым планом-меню выпускам блюд.
//
// Параметры:
//  ДокументОснование	 - ДокументСсылка.питПланМеню - Ссылка на документ основание.
// 
// Возвращаемое значение:
//  РезультатЗапроса - РезультатЗапроса
//
Функция РезультатЗапросаСвязанныеВыпускиБлюд(ДокументОснование) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питВыпускБлюд.Ссылка КАК ВыпускБлюд,
	|	питВыпускБлюд.Представление КАК Представление,
	|	ВЫРАЗИТЬ(питВыпускБлюд.ДокументОснование КАК Документ.питПланМеню).Представление КАК ПредставлениеПланаМеню
	|ИЗ
	|	Документ.питВыпускБлюд КАК питВыпускБлюд
	|ГДЕ
	|	питВыпускБлюд.ДокументОснование = &ДокументОснование";
	Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование);
	Возврат Запрос.Выполнить();
	
КонецФункции

