//// ПОДГОТОВКА ПАРАМЕТРОВ ПРОВЕДЕНИЯ ДОКУМЕНТА

// Формирует печатную форму "ОП-1"
//
// Возвращаемое значение:
//  Табличный документ - печатная форма накладной
//
Функция ПечатьОП1(МассивОбъектов, ОбъектыПечати, ПараметрыПечати, ПоГосту = Ложь)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если ПараметрыПечати.Свойство("СтруктураПараметровОП1") Тогда
		СтруктураПараметров = ПараметрыПечати.СтруктураПараметровОП1;
	Иначе
		СтруктураПараметров = Новый Структура();
		СтруктураПараметров.Вставить("РецептурнаяЕдиница", Истина);
	КонецЕсли;
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.АвтоМасштаб			= Истина;
	ТабличныйДокумент.ПолеСверху = 0;
	ТабличныйДокумент.ПолеСлева  = 0;
	ТабличныйДокумент.ПолеСнизу  = 0;
	ТабличныйДокумент.ПолеСправа = 0;
	ТабличныйДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
	ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_Рецептура_ОП1";
	
	ПервыйДокумент = Истина;
	
	МассивРецептуры = Новый Массив; // для исключения дублирования блюд
	
	Для Каждого ДокументСсылка Из МассивОбъектов Цикл
		
		Если НЕ ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		
		ПервыйДокумент = Ложь;
		// Запомним номер строки, с которой начали выводить текущий документ.
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		МассивРецептуры = Новый Массив; // для исключения дублирования блюд
		ТекущаяСтрокаДляПечати = Неопределено;
		
		Для Каждого СтрокаТовары Из ДокументСсылка.Товары Цикл
			
			ЭтоБизнесЛанч = СтрокаТовары.Номенклатура.питВидНоменклатуры=Перечисления.питВидыНоменклатуры.БизнесЛанч;
			
			Если СтрокаТовары.Рецептура.Пустая() 
				И НЕ ЭтоБизнесЛанч Тогда
				Продолжить;
			КонецЕсли;
			Если МассивРецептуры.Найти(СтрокаТовары.Рецептура)<>Неопределено Тогда
				// эту рецептуру уже распечатали
				Продолжить;
			Иначе
				МассивРецептуры.Добавить(СтрокаТовары.Рецептура);
			КонецЕсли;
			Если СтрокаТовары.Номенклатура.питВидНоменклатуры=Перечисления.питВидыНоменклатуры.Блюдо 
				ИЛИ ЭтоБизнесЛанч Тогда
				// Выведем калькуляцию
				питОтчеты.ВывестиКалькуляцию(ТабличныйДокумент,СтрокаТовары.Рецептура,ДокументСсылка,СтрокаТовары,СтруктураПараметров);
				Если СтрокаТовары.НомерСтроки < ДокументСсылка.Товары.Количество()-1 Тогда
					ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();	
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
		// В табличном документе зададим имя области, в которую был 
		// выведен объект. Нужно для возможности печати покомплектно.
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент,НомерСтрокиНачало, ОбъектыПечати, ДокументСсылка.Ссылка);
		
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
	
КонецФункции // ПечатьОП1()

// Формирует печатную форму "ОП-1" по переданной строке
//
// Параметры:
//  СтрокаДокумента - возможность формирования ОП1 для строки Выпуска продукции
//
// Возвращаемое значение:
//  Табличный документ - печатная форма накладной
//
Функция ПечатьОП1_ТБ(МассивОбъектов, ОбъектыПечати, ПараметрыПечати=Неопределено, ВводПараметров=Ложь) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если ВводПараметров=Истина И ПараметрыПечати.Свойство("СтруктураПараметровОП1") Тогда
		СтруктураПараметров = ПараметрыПечати.СтруктураПараметровОП1;
	Иначе
		СтруктураПараметров = Новый Структура();
		СтруктураПараметров.Вставить("РецептурнаяЕдиница", Истина);
	КонецЕсли;
	
	СтрокаДокумента = ПараметрыПечати.ТекущаяСтрокаДляПечати;
	ЭтотОбъект = МассивОбъектов[0];
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.АвтоМасштаб			= Истина;
	ТабличныйДокумент.ПолеСверху = 0;
	ТабличныйДокумент.ПолеСлева  = 0;
	ТабличныйДокумент.ПолеСнизу  = 0;
	ТабличныйДокумент.ПолеСправа = 0;
	ТабличныйДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
	ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_Рецептура_ОП1";
	
	Если СтрокаДокумента.Номенклатура.питВидНоменклатуры=Перечисления.питВидыНоменклатуры.Блюдо 
		ИЛИ СтрокаДокумента.Номенклатура.питВидНоменклатуры=Перечисления.питВидыНоменклатуры.БизнесЛанч Тогда
		// Выведем калькуляцию
		питОтчеты.ВывестиКалькуляцию(ТабличныйДокумент,СтрокаДокумента.Рецептура,ЭтотОбъект,СтрокаДокумента,СтруктураПараметров);
	КонецЕсли;
	
	Возврат ТабличныйДокумент;
	
КонецФункции // ПечатьОП1_ТБ()

// Формирует табличный документ технико-технологическая карта по норме или по факту
// 
// Возвращаемое значение:
//  Табличный документ - Технико-технологическая карта
//
Функция ПечатьТехТехнолКарта(МассивОбъектов, ОбъектыПечати,ПараметрыПечати)
	
	
	УстановитьПривилегированныйРежим(Истина);
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.АвтоМасштаб			= Истина;
	ТабличныйДокумент.ПолеСверху = 0;
	ТабличныйДокумент.ПолеСлева  = 0;
	ТабличныйДокумент.ПолеСнизу  = 0;
	ТабличныйДокумент.ПолеСправа = 0;
	ТабличныйДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
	ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ВыпускПродукции_ТехТехнолКарта";
	
	
	ПервыйДокумент = Истина;
	
	МассивРецептуры = Новый Массив; // для исключения дублирования блюд
	
	ПоГост = Ложь;
	ПараметрыПечати.Свойство("ПоГОСТ", ПоГост);
	
	ПоФакту = Ложь;
	ПараметрыПечати.Свойство("ПоФакту", ПоФакту);
	
	Для Каждого ДокументСсылка Из МассивОбъектов Цикл
		
		Если НЕ ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		
		ПервыйДокумент = Ложь;
		// Запомним номер строки, с которой начали выводить текущий документ.
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		Для Каждого СтрокаТовары Из ДокументСсылка.Товары Цикл
			Если СтрокаТовары.Рецептура.Пустая() Тогда
				Продолжить;
			КонецЕсли;
			Если СтрокаТовары.Номенклатура.питВидНоменклатуры=Перечисления.питВидыНоменклатуры.Блюдо 
				ИЛИ СтрокаТовары.Номенклатура.питВидНоменклатуры=Перечисления.питВидыНоменклатуры.БизнесЛанч Тогда
				// Выведем технико-технологическую карту. 
				
				//+АвтовыборНоменклатуры
				УточненияАвтовыбора = Неопределено;
				Если ТипЗнч(ДокументСсылка)=Тип("ДокументОбъект.питВыпускБлюд") Тогда
					УточненияАвтовыбора = ДокументСсылка.УточненияАвтовыбора.Выгрузить();
				ИначеЕсли ТипЗнч(ДокументСсылка)=Тип("ДокументСсылка.питВыпускБлюд") Тогда
					УточненияАвтовыбора = питУправлениеДаннымиОбИзделиях.ПолучитьТаблицуУточненийАвтовыбораПоДокументу(ДокументСсылка);
				КонецЕсли;
				//-АвтовыборНоменклатуры
				
				питДиетпитание.ВывестиТехникоТехнологическуюКарту(ТабличныйДокумент,СтрокаТовары.Рецептура,ДокументСсылка,СтрокаТовары.Количество,ПоФакту,СтрокаТовары, ПоГост, ДокументСсылка.Подразделение, УточненияАвтовыбора);
				Если СтрокаТовары.НомерСтроки < ДокументСсылка.Товары.Количество()-1 Тогда
					ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();	
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
		// В табличном документе зададим имя области, в которую был 
		// выведен объект. Нужно для возможности печати покомплектно.
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, 
			НомерСтрокиНачало, ОбъектыПечати, ДокументСсылка.Ссылка);
		
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
	
КонецФункции // ПечатьТехТехнолКарта

