//// СЛУЖЕБНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

// Перечень табличных частей, данные которых не используются 
// в контексте документа, скрыты от пользователя
Функция НеИспользуемыеТабличныеЧасти(ВидОперации) Экспорт
	
	ТабличныеЧасти = Новый Массив;
	
	ТабличныеЧасти.Добавить("Услуги");
	ТабличныеЧасти.Добавить("АгентскиеУслуги");
	ТабличныеЧасти.Добавить("ЗачетАвансов");
	ТабличныеЧасти.Добавить("ВозвратнаяТара");
	
	// Оплаты не доступны вне розничной реализаци
	Если НЕ ВидОперации = Перечисления.питХозяйственныеОперации.ВыпускПродукцииСРозничнойРеализацией Тогда
		ТабличныеЧасти.Добавить("Оплата");
	КонецЕсли;
	
	Возврат ТабличныеЧасти;
	
КонецФункции

Функция ПроверитьТоварыНаДубли(ДокументОбъект) Экспорт
	
	Если ТипЗнч(ДокументОбъект) = Тип("ДанныеФормыСтруктура") Тогда
		Документ = ДанныеФормыВЗначение(ДокументОбъект, Тип("ДокументОбъект.питВыпускБлюд")); // Преобразования данных формы в объект
		УстановитьСоответствиеОбъектаИРеквизитаФормы(Документ, "Объект"); // Установка соответствия
	Иначе
		Документ = ДокументОбъект;
	КонецЕсли;
	
	Результат = Истина;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питВыпускБлюдТовары.НомерСтроки,
	|	питВыпускБлюдТовары.Номенклатура,
	|	питВыпускБлюдТовары.Характеристика,
	|	питВыпускБлюдТовары.Серия
	|ПОМЕСТИТЬ втТовары
	|ИЗ
	|	&втТовары КАК питВыпускБлюдТовары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	питВыпускБлюдТовары.Номенклатура,
	|	питВыпускБлюдТовары.Характеристика,
	|	МИНИМУМ(питВыпускБлюдТовары.НомерСтроки) КАК НомерСтроки,
	|	СУММА(1) КАК Количество
	|ПОМЕСТИТЬ втРезультат
	|ИЗ
	|	втТовары КАК питВыпускБлюдТовары
	|
	|СГРУППИРОВАТЬ ПО
	|	питВыпускБлюдТовары.Номенклатура,
	|	питВыпускБлюдТовары.Характеристика
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втРезультат.Номенклатура,
	|	втРезультат.Характеристика,
	|	втРезультат.НомерСтроки,
	|	втРезультат.Количество
	|ИЗ
	|	втРезультат КАК втРезультат
	|ГДЕ
	|	втРезультат.Количество > 1";
	
	Запрос.УстановитьПараметр("втТовары", ДокументОбъект.Товары.Выгрузить());
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			Результат = Ложь;
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Дубли в строке <"+ВыборкаДетальныеЗаписи.НомерСтроки+"> по реквизитам Номенклатура, Характеристика!";
			Сообщение.УстановитьДанные(Документ);
			Сообщение.Поле = "Товары[" + (ВыборкаДетальныеЗаписи.НомерСтроки - 1) + "].Номенклатура";
			Сообщение.Сообщить();
			Возврат Результат;
		КонецЦикла;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Функция проверяет таблицу модификаторов объекта на предмет возможности добавления в производство.
//
// Параметры:
//  Модификаторы - ТабличнаяЧасть, ТаблицаЗначений - Таблица модификаторов.
//
Процедура ПроверитьМодификаторы(Модификаторы) Экспорт
	
	НеЗаполненоНоменклатурМодификаторов = 0;
	Для каждого ТекСрокаМодификатор Из Модификаторы Цикл
		Если НЕ ЗначениеЗаполнено(ТекСрокаМодификатор.Номенклатура) Тогда
			ЗаписьЖурналаРегистрации("питВыпускБлюд", УровеньЖурналаРегистрации.Предупреждение,,
				,"Не заполнена номенклатура модификатора <"+ТекСрокаМодификатор.Модификатор+"> ! Модификатор не будет добавлен в производство!");
			НеЗаполненоНоменклатурМодификаторов = НеЗаполненоНоменклатурМодификаторов + 1;
		КонецЕсли;
	КонецЦикла;
	Если НеЗаполненоНоменклатурМодификаторов Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнена номенклатура у " + НеЗаполненоНоменклатурМодификаторов + " модификаторов. Такие модификаторы не будут добавлены в производство. Подробности в журнале регистрации.");
	КонецЕсли;
	
КонецПроцедуры

// Функция сворачивает таблицу модификаторов объекта так, чтобы одинаковые модификаторы сернулись в одну строку.
//
// Параметры:
//  Модификаторы - ТабличнаяЧасть, ТаблицаЗначений - Таблица модификаторов.
//
Процедура СвернутьМодификаторы(Модификаторы) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	Модфикаторы.Модификатор КАК Модификатор,
	|	Модфикаторы.Количество КАК Количество,
	|	Модфикаторы.Номенклатура КАК Номенклатура,
	|	Модфикаторы.Характеристика КАК Характеристика,
	|	Модфикаторы.Серия КАК Серия,
	|	Модфикаторы.СтатусУказанияСерий КАК СтатусУказанияСерий,
	|	Модфикаторы.Цена КАК Цена,
	|	Модфикаторы.Сумма КАК Сумма,
	|	Модфикаторы.СуммаСкидки КАК СуммаСкидки,
	|	Модфикаторы.УпаковкаНоменклатуры КАК УпаковкаНоменклатуры,
	|	Модфикаторы.КоличествоНоменклатуры КАК КоличествоНоменклатуры,
	|	Модфикаторы.КоличествоУпаковокНоменклатуры КАК КоличествоУпаковокНоменклатуры,
	|	Модфикаторы.ИдентификаторСтроки КАК ИдентификаторСтроки,
	|	Модфикаторы.Рецептура КАК Рецептура
	|ПОМЕСТИТЬ втМодфикаторы
	|ИЗ
	|	&Модфикаторы КАК Модфикаторы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втМодфикаторы.Модификатор КАК Модификатор,
	|	СУММА(втМодфикаторы.Количество) КАК Количество,
	|	втМодфикаторы.Номенклатура КАК Номенклатура,
	|	втМодфикаторы.Характеристика КАК Характеристика,
	|	втМодфикаторы.Серия КАК Серия,
	|	втМодфикаторы.СтатусУказанияСерий КАК СтатусУказанияСерий,
	|	0 КАК Цена,
	|	СУММА(втМодфикаторы.Сумма) КАК Сумма,
	|	СУММА(втМодфикаторы.СуммаСкидки) КАК СуммаСкидки,
	|	втМодфикаторы.УпаковкаНоменклатуры КАК УпаковкаНоменклатуры,
	|	СУММА(втМодфикаторы.КоличествоНоменклатуры) КАК КоличествоНоменклатуры,
	|	СУММА(втМодфикаторы.КоличествоУпаковокНоменклатуры) КАК КоличествоУпаковокНоменклатуры,
	|	втМодфикаторы.ИдентификаторСтроки КАК ИдентификаторСтроки,
	|	втМодфикаторы.Рецептура КАК Рецептура
	|ИЗ
	|	втМодфикаторы КАК втМодфикаторы
	|
	|СГРУППИРОВАТЬ ПО
	|	втМодфикаторы.Серия,
	|	втМодфикаторы.Характеристика,
	|	втМодфикаторы.ИдентификаторСтроки,
	|	втМодфикаторы.СтатусУказанияСерий,
	|	втМодфикаторы.Рецептура,
	|	втМодфикаторы.Номенклатура,
	|	втМодфикаторы.УпаковкаНоменклатуры,
	|	втМодфикаторы.Модификатор"; 
	Запрос.УстановитьПараметр("Модфикаторы", Модификаторы);
	Выборка = Запрос.Выполнить().Выбрать();
	Модификаторы.Очистить();
	Пока Выборка.Следующий() Цикл
		НоваяСтрока = Модификаторы.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
		Если НоваяСтрока.Количество <> 0 Тогда
			НоваяСтрока.Цена = НоваяСтрока.Сумма / НоваяСтрока.Количество;
		Иначе
			НоваяСтрока.Цена = 0;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Функция проверяет, содержит ли документ серийную номенклатуру для списания.
//
// Параметры:
//  ДокументВыпуска	 - ДокументСсылка.питВыпускБлюд - Документ для проверки.
// 
// Возвращаемое значение:
//  Булево - Результат проверки.
//
Функция СодержитСерийнуюНоменклатуруДляСписания(ДокументВыпуска) Экспорт
	
	Если НЕ ТипЗнч(ДокументВыпуска) = Тип("ДокументСсылка.питВыпускБлюд") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питВыпускБлюдИнгредиенты.СтатусУказанияСерий КАК СтатусУказанияСерий
	|ИЗ
	|	Документ.питВыпускБлюд.Ингредиенты КАК питВыпускБлюдИнгредиенты
	|ГДЕ
	|	питВыпускБлюдИнгредиенты.СтатусУказанияСерий <> 0
	|	И питВыпускБлюдИнгредиенты.Ссылка = &ДокументВыпуска";
	Запрос.УстановитьПараметр("ДокументВыпуска", ДокументВыпуска);
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат НЕ РезультатЗапроса.Пустой();
	
КонецФункции

// Возвращает параметры выбора статей и аналитик.
// 
// Возвращаемое значение:
//  см. ДоходыИРасходыСервер.ПараметрыВыбораСтатьиИАналитики
//
Функция ПараметрыВыбораСтатейИАналитик(ХозяйственнаяОперация) Экспорт
	
	ПараметрыВыбора = ДоходыИРасходыСервер.ПараметрыВыбораСтатьиИАналитики();
	ПараметрыВыбора.ПутьКДанным = "Объект";
	ПараметрыВыбора.Статья = "СтатьяРасходов";
	ПараметрыВыбора.ТипСтатьи = "ТипСтатьи";
	
	ПараметрыВыбора.ВыборСтатьиРасходов = Истина;
	ПараметрыВыбора.АналитикаРасходов = "АналитикаРасходов";
	
	ПараметрыВыбора.ВыборСтатьиАктивовПассивов = Истина;
	ПараметрыВыбора.АналитикаАктивовПассивов = "АналитикаАктивовПассивов";
	
	ПараметрыВыбора.ЭлементыФормы.Статья.Добавить("питСтатьяРасходов");
	ПараметрыВыбора.ЭлементыФормы.АналитикаРасходов.Добавить("АналитикаРасходов");
	ПараметрыВыбора.ЭлементыФормы.АналитикаАктивовПассивов.Добавить("АналитикаАктивовПассивов");
	
	Возврат ПараметрыВыбора;
	
КонецФункции

