// Функция формирует табличный документ с печатной формой ОП-2 "План-меню"
//
// Возвращаемое значение:
//  Табличный документ - печатная форма
//
Функция ПечатьОП2(МассивОбъектов, ОбъектыПечати)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	питВыпускБлюд.Ссылка,
	|	питВыпускБлюд.ХозяйственнаяОперация КАК ВидОперации,
	|	питВыпускБлюд.Номер КАК НомерДокумента,
	|	питВыпускБлюд.Дата КАК ДатаДокумента,
	|	питВыпускБлюд.Организация,
	|	питВыпускБлюд.Организация.НаименованиеПолное КАК ПредставлениеОрганизации,
	|	питВыпускБлюд.Подразделение КАК ПодразделениеОрганизации,
	|	питВыпускБлюд.Подразделение.Наименование КАК ПодразделениеПредставление,
	|	питВыпускБлюд.Склад,
	|	питВыпускБлюд.Склад.Представление КАК ПредставлениеСклад,
	|	питВыпускБлюд.Склад.ТипСклада КАК ТипСклада,
	|	NULL КАК РозничныйВидЦены,
	|	питВыпускБлюд.ТипЦен КАК ТипЦен,
	|	Истина КАК ТипЦенЦенаВключаетНДС
	|ИЗ
	|	Документ.питВыпускБлюд КАК питВыпускБлюд
	|ГДЕ
	|	питВыпускБлюд.Ссылка В(&МассивОбъектов)
	|
	|УПОРЯДОЧИТЬ ПО
	|	питВыпускБлюд.Дата,
	|	питВыпускБлюд.Ссылка";
	
	ЗапросПоТоварам = Новый Запрос;
	ЗапросПоТоварам.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	ЗапросПоТоварам.УстановитьПараметр("ДополнительнаяКолонкаПечатныхФормДокументов", Константы.ДополнительнаяКолонкаПечатныхФормДокументов.Получить());
	ЗапросПоТоварам.Текст =
	"ВЫБРАТЬ
	|	питВыпускБлюд.Номенклатура,
	|	питВыпускБлюд.Характеристика,
	|	питВыпускБлюд.Номенклатура.НаименованиеПолное + ВЫБОР КОГДА питВыпускБлюд.Характеристика = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка) ТОГДА """" ИНАЧЕ "" / "" + питВыпускБлюд.Характеристика.НаименованиеПолное КОНЕЦ  КАК ТоварНаименование,
	|	питВыпускБлюд.Рецептура.НомерРецептуры КАК НомерРецептуры,
	|	питВыпускБлюд.Рецептура.Выход КАК ВыходПродукта,
	|	ВЫБОР
	|		КОГДА &ДополнительнаяКолонкаПечатныхФормДокументов = ЗНАЧЕНИЕ(Перечисление.ДополнительнаяКолонкаПечатныхФормДокументов.Артикул)
	|			ТОГДА питВыпускБлюд.Номенклатура.Артикул
	|		ИНАЧЕ питВыпускБлюд.Номенклатура.Код
	|	КОНЕЦ КАК ТоварКод,
	|	питВыпускБлюд.Количество,
	|	ВЫБОР
	|		КОГДА питВыпускБлюд.Ссылка.СуммаВключаетНДС
	|			ТОГДА питВыпускБлюд.Цена
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Цена,
	|	ВЫБОР
	|		КОГДА питВыпускБлюд.Ссылка.СуммаВключаетНДС
	|			ТОГДА питВыпускБлюд.Сумма
	|		ИНАЧЕ питВыпускБлюд.Сумма + питВыпускБлюд.СуммаНДС
	|	КОНЕЦ КАК Сумма,
	|	питВыпускБлюд.СтавкаНДС,
	|	питВыпускБлюд.НомерСтроки,
	|	питВыпускБлюд.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.питВыпускБлюд.Товары КАК питВыпускБлюд
	|ГДЕ
	|	питВыпускБлюд.Ссылка В(&МассивОбъектов)
	|
	|УПОРЯДОЧИТЬ ПО
	|	питВыпускБлюд.НомерСтроки
	|ИТОГИ ПО
	|	Ссылка";
	
	Шапка = Запрос.Выполнить().Выбрать();
	
	ВыборкаПоТоварам = ЗапросПоТоварам.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Макет = УправлениеПечатью.МакетПечатнойФормы("ОбщийМакет.ПФ_MXL_питОП2");
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.АвтоМасштаб			= Истина;
	ТабличныйДокумент.ПолеСверху			= 0;
	ТабличныйДокумент.ПолеСлева				= 0;
	ТабличныйДокумент.ПолеСнизу				= 0;
	ТабличныйДокумент.ПолеСправа			= 0;
	ТабличныйДокумент.ОриентацияСтраницы	= ОриентацияСтраницы.Ландшафт;
	ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ВыпускПродукции_ОП2";
	
	СисИнфо = Новый СистемнаяИнформация;
	Если ПустаяСтрока(СисИнфо.ИнформацияПрограммыПросмотра) Тогда 
		ТабличныйДокумент.ПолеСлева          = 0;
	Иначе
		ТабличныйДокумент.ПолеСлева          = 10;
	КонецЕсли;
	
	ПервыйДокумент = Истина;
	Пока Шапка.Следующий() Цикл
		ВыборкаПоТоварам.Сбросить();
		ВыборкаПоТоварам.НайтиСледующий(Шапка.Ссылка, "Ссылка");
		
		ВыборкаСтрокТовары = ВыборкаПоТоварам.Выбрать();
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		
		ПервыйДокумент = Ложь;
		// Запомним номер строки, с которой начали выводить текущий документ.
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		// Выводим шапку накладной
		СведенияОбОрганизации = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Шапка.Организация, Шапка.ДатаДокумента);
		
		ОбластьМакета = Макет.ПолучитьОбласть("Шапка");
		ОбластьМакета.Параметры.Заполнить(Шапка);
		ОбластьМакета.Параметры.ПредставлениеОрганизации = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОбОрганизации, "НаименованиеДляПечатныхФорм,");
		ОбластьМакета.Параметры.КодПоОКПО		= СведенияОбОрганизации.КодПоОКПО;
		ОбластьМакета.Параметры.ДатаПланМеню = "на " + Формат(Шапка.ДатаДокумента, "ДФ = ""дд ММММ гггг""");
		
		// Чтение значения для директора
		ПодразделениеОтветственныхЛиц = Шапка.ПодразделениеОрганизации;
		Руководители = ОтветственныеЛицаСервер.ПолучитьОтветственныеЛицаОрганизации(Шапка.Организация, Шапка.ДатаДокумента);
		ОбластьМакета.Параметры.Руководитель = Руководители.РуководительНаименование;
		ОбластьМакета.Параметры.ДолжностьРуководителя = Руководители.РуководительДолжность;
		
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		// Выводим заголовок таблицы
		ЗаголовокТаблицы = Макет.ПолучитьОбласть("ЗаголовокТаблицы");
		ТабличныйДокумент.Вывести(ЗаголовокТаблицы);
		
		Ном = 0;
		
		// Выводим многострочную часть документа
		ОбластьМакетаПодвал = Макет.ПолучитьОбласть("Подвал");
		ОбластьМакета = Макет.ПолучитьОбласть("Строка");
		ИтогоСумма = 0;
		
		РозничныйТипЦен = Неопределено;
		//РозничныйВидЦены
		//Если Шапка.ТипСклада = Перечисления.ТипыСкладов.РозничныйМагазин Тогда
		//	мУчетВПродажныхЦенах = УчетнаяПолитика.СпособОценкиТоваровВРознице(Шапка.Организация, Шапка.ДатаДокумента) =
		//		Перечисления.СпособыОценкиТоваровВРознице.ПоПродажнойСтоимости;
		//	Если мУчетВПродажныхЦенах Тогда
		//		РозничныйТипЦен = Шапка.РозничныйВидЦены;
		//	КонецЕсли;
		//КонецЕсли;
		Если НЕ ЗначениеЗаполнено(РозничныйТипЦен) Тогда
			РозничныйТипЦен = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("ОсновнойТипЦенПродажи");
		КонецЕсли;
		
		Пока ВыборкаСтрокТовары.Следующий() Цикл
			
			Ном = Ном + 1;
			
			ОбластьМакета.Параметры.Заполнить(ВыборкаСтрокТовары);
			ОбластьМакета.Параметры.НомерСтроки = Ном;
			
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
		КонецЦикла;
		
		// Вывести подвал
		ОбластьМакетаПодвал.Параметры.Сумма = ИтогоСумма;
		Если Руководители.Свойство("питЗаведующийПроизводством") Тогда
			ОбластьМакетаПодвал.Параметры.ЗаведующийПроизводством = Руководители.питЗаведующийПроизводством;
		КонецЕсли;
		ТабличныйДокумент.Вывести(ОбластьМакетаПодвал);
		
		// В табличном документе зададим имя области, в которую был 
		// выведен объект. Нужно для возможности печати покомплектно.
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, 
			НомерСтрокиНачало, ОбъектыПечати, Шапка.Ссылка);
		
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
	
КонецФункции // ПечатьОП2()

// Функция формирует табличный документ с печатной формой "ВедомостьНедовложений"
//
// Возвращаемое значение:
//  Табличный документ - печатная форма
//
Функция ПечатьВедомостьНедовложений(МассивОбъектов, ОбъектыПечати)
	
	////////////////////////////////////////////////////////////
	// 1. Печать формы в привелегированном режиме.
	УстановитьПривилегированныйРежим(Истина);
	
	////////////////////////////////////////////////////////////
	// 2. Инициализация табличного документа
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.АвтоМасштаб			= Истина;
	ТабличныйДокумент.ПолеСверху = 0;
	ТабличныйДокумент.ПолеСлева  = 0;
	ТабличныйДокумент.ПолеСнизу  = 0;
	ТабличныйДокумент.ПолеСправа = 0;
	ТабличныйДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
	ТабличныйДокумент.КлючПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ВыпускПродукции_ВедомостьНедовложений";
	
	// Макет печатной формы
	Макет = УправлениеПечатью.МакетПечатнойФормы("ОбщийМакет.ПФ_MXL_питВедомостьНедовложений");
	
	// Признак того, что документ первый(для последующих документов
	// вставляем горизонтальный разделитель страниц.
	ПервыйДокумент = Истина;
	
	////////////////////////////////////////////////////////////
	// 3. Обход массива документов.
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питВыпускБлюд.Ссылка КАК Ссылка,
	|	питВыпускБлюд.Склад КАК Склад,
	|	питВыпускБлюд.Номер КАК Номер,
	|	питВыпускБлюд.Дата КАК Дата,
	|	питВыпускБлюд.Организация КАК Организация,
	|	питВыпускБлюд.Склад.Представление КАК СкладПредставление,
	|	питВыпускБлюд.Валюта КАК Валюта
	|ИЗ
	|	Документ.питВыпускБлюд КАК питВыпускБлюд
	|ГДЕ
	|	питВыпускБлюд.Ссылка В(&МассивОбъектов)";
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаСсылка = РезультатЗапроса.Выбрать();
	Пока ВыборкаСсылка.Следующий() Цикл
		
		////////////////////////////////////////////////////////////
		// Подготовка табличного документа и макета
		// Для не первого документа вставка разделителя страниц.
		Если НЕ ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент = Ложь;
		// Запомним номер строки, с которой начали выводить текущий документ.
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		// Определение таблиц недовложений.
		СкладДляАнализа				= ВыборкаСсылка.Склад;
		СтруктураТаблицПроизводства = питПроизводство.АнализНедовложений(ВыборкаСсылка.Ссылка, СкладДляАнализа, , Истина);
		СтруктураТаблицНедовложений = питПроизводство.АнализТаблицПроизводстваНаНедовложения(ВыборкаСсылка.Ссылка, СтруктураТаблицПроизводства);
		ТаблицаНедовложений			= СтруктураТаблицНедовложений.ТаблицаНедовложений;
		ТаблицаЗаменНедовложений	= СтруктураТаблицНедовложений.ТаблицаЗаменНедовложений;
		СтруктураТаблицПроизводства = Неопределено;
		
		// Вывод шапки печатной формы
		ОбластьМакета = Макет.ПолучитьОбласть("Шапка");
		ОбластьМакета.Параметры.Заголовок		= "Ведомость недовложений ингредиентов по складу " + ВыборкаСсылка.СкладПредставление;
		ОбластьМакета.Параметры.НомерДок		= ВыборкаСсылка.Номер;
		ОбластьМакета.Параметры.ДатаДок			= Формат(ВыборкаСсылка.Дата,"ДФ = дд.ММ.гггг");
		ОбластьМакета.Параметры.МестоХранения	= СкладДляАнализа;
		СведенияОбОрганизации					= ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ВыборкаСсылка.Организация, ВыборкаСсылка.Дата);
		СтрокаПредставления						= ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОбОрганизации, "НаименованиеДляПечатныхФорм,");
		ОбластьМакета.Параметры.Организация		= СтрокаПредставления;
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		// Область ингредиентов, по которым есть недовложения.
		ОбластьТовар = Макет.ПолучитьОбласть("Товар");
		
		// Печатать артикул или код.
		ПечататьАртикул = (Константы.ДополнительнаяКолонкаПечатныхФормДокументов.Получить() = Перечисления.ДополнительнаяКолонкаПечатныхФормДокументов.Артикул);
		
		// Получение цен ингредиентов для вывода в печатную форму.
		ОписаниеТиповЧисло		= Новый ОписаниеТипов("Число",Новый КвалификаторыЧисла(15,2));
		ОписаниеТиповЧисло100	= Новый ОписаниеТипов("Число",Новый КвалификаторыЧисла(10,0));
		ТаблицаНедовложений.Колонки.Добавить("Цена", ОписаниеТиповЧисло);
		ТаблицаНедовложений.Колонки.Добавить("Сумма", ОписаниеТиповЧисло);
		ТаблицаНедовложений.Колонки.Добавить("НомерСтроки", ОписаниеТиповЧисло100);
		Для Сч = 0 По ТаблицаНедовложений.Количество() - 1 Цикл
			ТаблицаНедовложений[Сч].НомерСтроки = Сч + 1;
		КонецЦикла;
		СтруктураДействий = Новый Структура;
		СтруктураДействий.Вставить("ПересчитатьСумму", "КоличествоУпаковокНоменклатурыНедовложение");
		ПараметрыЗаполнения = Новый Структура;
		ПараметрыЗаполнения.Вставить("Дата", ВыборкаСсылка.Дата);
		ПараметрыЗаполнения.Вставить("Валюта", ВыборкаСсылка.Валюта);
		ПараметрыЗаполнения.Вставить("ВидЦены", питОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВыборкаСсылка.Склад,"УчетныйВидЦены"));
		ПараметрыЗаполнения.Вставить("ИмяКолонкиУпаковка", "УпаковкаНоменклатуры");
		ЦеныПредприятияЗаполнениеСервер.ЗаполнитьЦены(
			ТаблицаНедовложений,
			, // Выделенные строки (заполнять во всех строках)
			ПараметрыЗаполнения,
			СтруктураДействий);
		
		// Получение представлений данных для вывода в печатную форму.
		Запрос = Новый Запрос;
		Запрос.Текст = "
		|	ВЫБРАТЬ * ПОМЕСТИТЬ втТаблицаНедовложений ИЗ &ТаблицаНедовложений КАК ТаблицаНедовложений;
		|	ВЫБРАТЬ * ПОМЕСТИТЬ втТаблицаЗаменНедовложений ИЗ &ТаблицаЗаменНедовложений КАК ТаблицаЗаменНедовложений;
		|ВЫБРАТЬ 
		|	*,
		|	ТаблицаНедовложений.Номенклатура.НаименованиеПолное КАК НоменклатураПредставление,
		|	ТаблицаНедовложений.Номенклатура.Код КАК НоменклатураКод,
		|	ТаблицаНедовложений.Номенклатура.Артикул КАК НоменклатураАртикул,
		|	ТаблицаНедовложений.Характеристика.НаименованиеПолное КАК ХарактеристикаПредставление,
		|	ТаблицаНедовложений.Номенклатура.ЕдиницаИзмерения КАК БазоваяЕдиницаНоменклатура,
		|	ТаблицаНедовложений.Номенклатура.ЕдиницаИзмерения.Код КАК КодБазоваяЕдиницаНоменклатура,
		|	ТаблицаНедовложений.УпаковкаНоменклатуры.Код КАК КодУпаковкаНоменклатуры
		|ИЗ
		|	втТаблицаНедовложений КАК ТаблицаНедовложений
		|;
		|ВЫБРАТЬ
		|	*,
		|	ТаблицаЗаменНедовложений.ИнгредиентИсходный.ЕдиницаИзмерения КАК БазоваяЕдиницаИнгредиентИсходный,
		|	ТаблицаЗаменНедовложений.ИнгредиентИсходный.ЕдиницаИзмерения.Код КАК КодБазоваяЕдиницаИнгредиентИсходный,
		|	ТаблицаЗаменНедовложений.ИнгредиентИсходный.НаименованиеПолное КАК ИнгредиентИсходныйПредставление,
		|	ТаблицаЗаменНедовложений.ИнгредиентИсходный.Код КАК ИнгредиентИсходныйКод,
		|	ТаблицаЗаменНедовложений.ИнгредиентИсходный.Артикул КАК ИнгредиентИсходныйАртикул,
		|	ТаблицаЗаменНедовложений.ХарактеристикаИнгредиентаИсходного.НаименованиеПолное КАК ХарактеристикаИнгредиентаИсходногоПредставление,
		|	ТаблицаЗаменНедовложений.ИнгредиентЗамена.ЕдиницаИзмерения КАК БазоваяЕдиницаИнгредиентЗамена,
		|	ТаблицаЗаменНедовложений.ИнгредиентЗамена.ЕдиницаИзмерения.Код КАК КодБазоваяЕдиницаИнгредиентЗамена,
		|	ТаблицаЗаменНедовложений.ИнгредиентЗамена.НаименованиеПолное КАК ИнгредиентЗаменаПредставление,
		|	ТаблицаЗаменНедовложений.ИнгредиентЗамена.Код КАК ИнгредиентЗаменаКод,
		|	ТаблицаЗаменНедовложений.ИнгредиентЗамена.Артикул КАК ИнгредиентЗаменаАртикул,
		|	ТаблицаЗаменНедовложений.ХарактеристикаИнгредиентаЗамена.НаименованиеПолное КАК ХарактеристикаИнгредиентаЗаменаПредставление,
		|	ТаблицаЗаменНедовложений.УпаковкаИнгредиентаИсходный.Код КАК УпаковкаИнгредиентаИсходныйКод,
		|	ТаблицаЗаменНедовложений.УпаковкаИнгредиентаЗамена.Код КАК УпаковкаИнгредиентаЗаменаКод
		|ИЗ
		|	втТаблицаЗаменНедовложений КАК ТаблицаЗаменНедовложений
		|УПОРЯДОЧИТЬ ПО
		|	ТаблицаЗаменНедовложений.ИнгредиентИсходный.НаименованиеПолное
		|";
		Запрос.УстановитьПараметр("ТаблицаНедовложений", ТаблицаНедовложений);
		Запрос.УстановитьПараметр("ТаблицаЗаменНедовложений", ТаблицаЗаменНедовложений);
		РезультатЗапроса = Запрос.ВыполнитьПакет();
		ВыборкаТаблицаНедовложений = РезультатЗапроса[2].Выбрать();
		
		// Обход таблицы недовложений.
		ТекущийНомерТовара = 1;
		Пока ВыборкаТаблицаНедовложений.Следующий() Цикл
			ОбластьТовар.Параметры.Заполнить(ВыборкаТаблицаНедовложений);
			ОбластьТовар.Параметры.Номенклатура = ВыборкаТаблицаНедовложений.НоменклатураПредставление 
				+ ?(ЗначениеЗаполнено(ВыборкаТаблицаНедовложений.Характеристика)
				," / " + СокрЛП(ВыборкаТаблицаНедовложений.ХарактеристикаПредставление),"");
			ОбластьТовар.Параметры.НоменклатураСсылка = ВыборкаТаблицаНедовложений.Номенклатура;
			Если НЕ ЗначениеЗаполнено(ВыборкаТаблицаНедовложений.УпаковкаНоменклатуры) Тогда
				ОбластьТовар.Параметры.УпаковкаНоменклатуры = ВыборкаТаблицаНедовложений.БазоваяЕдиницаНоменклатура;
				ОбластьТовар.Параметры.КодЕдиницыИзмерения = ВыборкаТаблицаНедовложений.КодБазоваяЕдиницаНоменклатура;
			Иначе
				ОбластьТовар.Параметры.КодЕдиницыИзмерения = ВыборкаТаблицаНедовложений.КодУпаковкаНоменклатуры;
			КонецЕсли;
			ОбластьТовар.Параметры.Номер = ТекущийНомерТовара;
			ОбластьТовар.Параметры.КодНоменклатуры = ?(ПечататьАртикул, ВыборкаТаблицаНедовложений.НоменклатураАртикул, ВыборкаТаблицаНедовложений.НоменклатураКод);
			ОбластьТовар.Параметры.ЦенаНоменклатурыНормативная = ВыборкаТаблицаНедовложений.Цена;
			ОбластьТовар.Параметры.СуммаНоменклатуры = ВыборкаТаблицаНедовложений.Сумма;
			ТабличныйДокумент.Вывести(ОбластьТовар);
			ТекущийНомерТовара = ТекущийНомерТовара + 1;
		КонецЦикла;	
		Если ТаблицаНедовложений.Количество()=0 Тогда
			ТабличныйДокумент.Вывести(Макет.ПолучитьОбласть("ПродуктовХватает"));
		КонецЕсли;
		
		// Блок замен недовложений
		Если ТаблицаЗаменНедовложений.Количество() Тогда
			
			ОбластьИнгредиентИсходный = Макет.ПолучитьОбласть("ИнгредиентИсходный");
			ОбластьЗамены = Макет.ПолучитьОбласть("Замены");
			ОбластьИнгредиентЗамена = Макет.ПолучитьОбласть("ИнгредиентЗамена");
			ТабличныйДокумент.Вывести(Макет.ПолучитьОбласть("ШапкаЗамен"));
			
			// Запоминаем предыдущие элементы для того, чтобы перейти от одного заменяемого элемента к другому
			// (таблица отсортирована).
			ИнгредиентИсходныйПред = Справочники.Номенклатура.ПустаяСсылка();
			ХарактеристикаИнгредиентаИсходногоПред = Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка();
			
			// Обходим таблицу Замен и выводим ее на просмотр
			ВыборкаТаблицаЗаменНедовложений = РезультатЗапроса[3].Выбрать();
			Пока ВыборкаТаблицаЗаменНедовложений.Следующий() Цикл
				
				ИнгредиентИсходный					= ВыборкаТаблицаЗаменНедовложений.ИнгредиентИсходный;
				ХарактеристикаИнгредиентаИсходного	= ВыборкаТаблицаЗаменНедовложений.ХарактеристикаИнгредиентаИсходного;
				ИнгредиентЗамена					= ВыборкаТаблицаЗаменНедовложений.ИнгредиентЗамена;
				ХарактеристикаИнгредиентаЗамена		= ВыборкаТаблицаЗаменНедовложений.ХарактеристикаИнгредиентаЗамена;
				Если НЕ (ИнгредиентИсходныйПред = ИнгредиентИсходный 
					И ХарактеристикаИнгредиентаИсходногоПред = ХарактеристикаИнгредиентаИсходного) Тогда
					
					ОбластьИнгредиентИсходный.Параметры.Заполнить(ВыборкаТаблицаЗаменНедовложений);
					Если НЕ ЗначениеЗаполнено(ВыборкаТаблицаЗаменНедовложений.УпаковкаИнгредиентаИсходный) Тогда
						ОбластьИнгредиентИсходный.Параметры.УпаковкаИнгредиентаИсходный = ВыборкаТаблицаЗаменНедовложений.БазоваяЕдиницаИнгредиентИсходный;
						ОбластьИнгредиентИсходный.Параметры.УпаковкаИнгредиентаИсходныйКод = ВыборкаТаблицаЗаменНедовложений.КодБазоваяЕдиницаИнгредиентИсходный;
					Иначе
						ОбластьИнгредиентИсходный.Параметры.УпаковкаИнгредиентаИсходныйКод = ВыборкаТаблицаЗаменНедовложений.УпаковкаИнгредиентаИсходныйКод;
					КонецЕсли;
					ОбластьИнгредиентИсходный.Параметры.ИнгредиентИсходный = ВыборкаТаблицаЗаменНедовложений.ИнгредиентИсходныйПредставление 
					+ ?(ЗначениеЗаполнено(ВыборкаТаблицаЗаменНедовложений.ХарактеристикаИнгредиентаИсходного)
					," / " + СокрЛП(ВыборкаТаблицаЗаменНедовложений.ХарактеристикаИнгредиентаИсходногоПредставление),"");
					ОбластьИнгредиентИсходный.Параметры.ИнгредиентИсходныйСсылка = ВыборкаТаблицаЗаменНедовложений.ИнгредиентИсходный;
					ОбластьИнгредиентИсходный.Параметры.ИнгредиентИсходныйКод = ?(ПечататьАртикул, ИнгредиентИсходный.Артикул, ИнгредиентИсходный.Код);
					ТабличныйДокумент.Вывести(ОбластьИнгредиентИсходный);
					ТабличныйДокумент.Вывести(ОбластьЗамены);
					
				КонецЕсли;
				
				ОбластьИнгредиентЗамена.Параметры.Заполнить(ВыборкаТаблицаЗаменНедовложений);
				Если НЕ ЗначениеЗаполнено(ВыборкаТаблицаЗаменНедовложений.УпаковкаИнгредиентаЗамена) Тогда
					ОбластьИнгредиентЗамена.Параметры.УпаковкаИнгредиентаЗамена = ВыборкаТаблицаЗаменНедовложений.БазоваяЕдиницаИнгредиентЗамена;
					ОбластьИнгредиентЗамена.Параметры.УпаковкаИнгредиентаЗаменаКод = ВыборкаТаблицаЗаменНедовложений.КодБазоваяЕдиницаИнгредиентЗамена;
				Иначе
					ОбластьИнгредиентЗамена.Параметры.УпаковкаИнгредиентаЗаменаКод = ВыборкаТаблицаЗаменНедовложений.УпаковкаИнгредиентаЗаменаКод;
				КонецЕсли;
				ОбластьИнгредиентЗамена.Параметры.ИнгредиентЗамена = ВыборкаТаблицаЗаменНедовложений.ИнгредиентЗаменаПредставление
				+ ?(ЗначениеЗаполнено(ВыборкаТаблицаЗаменНедовложений.ХарактеристикаИнгредиентаЗамена)
				," / " + СокрЛП(ВыборкаТаблицаЗаменНедовложений.ХарактеристикаИнгредиентаЗаменаПредставление),"");
				ОбластьИнгредиентЗамена.Параметры.ИнгредиентЗаменаСсылка = ВыборкаТаблицаЗаменНедовложений.ИнгредиентЗамена;
				ОбластьИнгредиентЗамена.Параметры.ИнгредиентЗаменаКод = ?(ПечататьАртикул, ИнгредиентЗамена.Артикул, ИнгредиентЗамена.Код);
				
				ТабличныйДокумент.Вывести(ОбластьИнгредиентЗамена);
				
				ИнгредиентИсходныйПред=ИнгредиентИсходный;
			КонецЦикла;
			
		КонецЕсли;
		
		// В табличном документе зададим имя области, в которую был 
		// выведен объект. Нужно для возможности печати покомплектно.
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, 
			НомерСтрокиНачало, ОбъектыПечати, ВыборкаСсылка.Ссылка);
		
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецФункции

// Функция формирует табличный документ с печатной формой ОП-10 "Акт о реализации"
//
// Возвращаемое значение:
//  Табличный документ - печатная форма
//
Функция ПечатьОП10(МассивОбъектов, ОбъектыПечати,ПараметрыПечати) Экспорт
	
	ТабДокумент = Новый ТабличныйДокумент;
	Если МассивОбъектов.Количество() = 0 Тогда
		Возврат ТабДокумент;
	иначе
		// Выпуски печатают все по оодному даже из формы списка.
		ЭтотОбъект = МассивОбъектов[0];
	КонецЕсли;
	
	ИмяРеквизитаКода = "Артикул";
	ФорматВыводаСуммы		= "ЧДЦ=2; ЧН=0,00";
	ФорматВыводаКоличества	= "ЧДЦ=3; ЧН=0,000";
	
	СтруктураПредставления = Новый Структура(
		"Наименование,ИНН,АдресЮридический,ТелефонРабочий,БанковскийСчет,Банк,БИК,КоррСчет",
		"","ИНН ","","тел.: ","р/с ","в банке ","БИК ","к/с ");
		
	// Зададим параметры макета
	ТабДокумент.ПолеСверху 				= 0;
	ТабДокумент.ПолеСлева  				= 0;
	ТабДокумент.ПолеСнизу  				= 0;
	ТабДокумент.ПолеСправа 				= 0;
	ТабДокумент.Автомасштаб				= Истина;
	ТабДокумент.ЭкземпляровНаСтранице	= 1;
	ТабДокумент.ОриентацияСтраницы		= ОриентацияСтраницы.Ландшафт;	
	
	Макет							= ПолучитьОбщийМакет("ПФ_MXL_питОП10");
	ОбластьМакета					= Макет.ПолучитьОбласть("Заголовок");
	ОбластьМакета.Параметры.Заполнить(ЭтотОбъект);
	ОбластьМакета.Параметры.Номер	= ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(ЭтотОбъект.Номер);
	
	ОбластьМакета.Параметры.ПредставлениеСклада = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЭтотОбъект.Склад, "Наименование");
	
	СведенияОбОрганизации = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ЭтотОбъект.Организация, ЭтотОбъект.Дата);
	СтрокаПредставления = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОбОрганизации, "НаименованиеДляПечатныхФорм,");
	ОбластьМакета.Параметры.ОрганизацияПредставление = СтрокаПредставления;
	
	ОбластьМакета.Параметры.КодПоОКПО = ЭтотОбъект.Организация.КодПоОКПО;
	
	//Чтение значения для директора
	Руководитель = ОтветственныеЛицаСервер.ПолучитьДанныеОтветственногоЛица(ЭтотОбъект.Организация,ЭтотОбъект.Дата,Перечисления.ОтветственныеЛицаОрганизаций.Руководитель);
	ОбластьМакета.Параметры.Заполнить(Руководитель);
	
	ТабДокумент.Вывести(ОбластьМакета);
	
	НомерСтраницы					= 2;
	НомерСтраницыПред				= НомерСтраницы;
	КоличествоСтрокНаТекущейСтранице= 0;	
	
	ОбластьЗаголовокТаблицы	= Макет.ПолучитьОбласть("Шапка");
	ОбластьСтрока			= Макет.ПолучитьОбласть("Строка");
	ОбластьИтоги			= Макет.ПолучитьОбласть("ИтогоПоСтранице");
	ОбластьПодвал			= Макет.ПолучитьОбласть("Подвал");
	ОбластьИтогоПодвал		= Макет.ПолучитьОбласть("ИтогоПодвал");
	
	ОбластьЗаголовокТаблицы.Параметры.НомерСтраницы	= "Страница: 1";
	ТабДокумент.Вывести(ОбластьЗаголовокТаблицы);
	
	СтруктураИтоговПоСтранице = Новый Структура("ИтогКоличествоПоСтранице,ИтогСуммаУчетПоСтранице,ИтогСуммаВсегоПоСтранице",0,0,0,0);
		
	ВыборкаСтрок = ПолучитьТаблицуТоваровДляПечатиОП(ЭтотОбъект);
	ПриписатьЕдИзм = ВыводитьЕденицыИзмерения(ЭтотОбъект);
	
	ИтогСуммаУчет	= 0; ИтогСуммаВсего	= 0;
	ИтогКоличество	= 0;
	ВыборкаСтрокКоличество	= ВыборкаСтрок.Количество();
	НомерСтроки				= 1;
	
	Для каждого СтрокаТоваров Из ВыборкаСтрок Цикл
		ОбластьСтрока.Параметры.Ном				= НомерСтроки;	
		ОбластьСтрока.Параметры.Номенклатура	= Строка(СтрокаТоваров.Номенклатура.НаименованиеПолное) + ?(ЗначениеЗаполнено(СтрокаТоваров.Характеристика)," / " + СокрЛП(СтрокаТоваров.Характеристика.НаименованиеПолное),"") + ?(ПриписатьЕдИзм , ", "+ Строка(СтрокаТоваров.ЕдиницаИзмерения) ,"" );
		ОбластьСтрока.Параметры.Код				= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаТоваров.Номенклатура, ИмяРеквизитаКода);
		ОбластьСтрока.Параметры.Цена			= Формат(СтрокаТоваров.ЦенаФакт,ФорматВыводаСуммы);
		ОбластьСтрока.Параметры.Количество		= Формат(СтрокаТоваров.Колво,ФорматВыводаКоличества);
		ОбластьСтрока.Параметры.СуммаВсего		= Формат(СтрокаТоваров.СуммаФакт,ФорматВыводаСуммы);
		ОбластьСтрока.Параметры.ЦенаУчет		= Формат(?(СтрокаТоваров.Колво=0,0,СтрокаТоваров.СуммаУч/СтрокаТоваров.Колво),ФорматВыводаСуммы);
		ОбластьСтрока.Параметры.СуммаУчет		= Формат(СтрокаТоваров.СуммаУч,ФорматВыводаСуммы);
		
		//доп. области
		мсвДопОбластиПодвала	= Неопределено;
		Если НомерСтроки = ВыборкаСтрокКоличество Тогда
			мсвДопОбластиПодвала	= Новый Массив();
			мсвДопОбластиПодвала.Добавить(ОбластьИтогоПодвал);
		КонецЕсли;		
		
		//выводим строку, делая проверку попадания на лист		
		НомерСтраницы = питДокументы.ВывестиГоризонтальнуюОбласть(ТабДокумент, ОбластьСтрока, ОбластьЗаголовокТаблицы, ОбластьИтоги, НомерСтраницы, СтруктураИтоговПоСтранице, мсвДопОбластиПодвала);
		
		// увеличим итоги по странице
		СтруктураСтрокиИтогов = Новый Структура("ИтогКоличествоПоСтранице,ИтогСуммаУчетПоСтранице,ИтогСуммаВсегоПоСтранице");
		СтруктураСтрокиИтогов.ИтогКоличествоПоСтранице		= СтрокаТоваров.КолВо;
		СтруктураСтрокиИтогов.ИтогСуммаУчетПоСтранице		= СтрокаТоваров.СуммаУч;
		СтруктураСтрокиИтогов.ИтогСуммаВсегоПоСтранице      = СтрокаТоваров.СуммаФакт;
		
		//инициализация итогов по странице
		Если НомерСтраницы <> НомерСтраницыПред Тогда
			СтруктураИтоговПоСтранице		= Новый Структура("ИтогКоличествоПоСтранице,ИтогСуммаУчетПоСтранице,ИтогСуммаВсегоПоСтранице",0,0,0,0);
			НомерСтраницыПред				= НомерСтраницы;
			КоличествоСтрокНаТекущейСтранице= 0; 
		Иначе
			КоличествоСтрокНаТекущейСтранице= КоличествоСтрокНаТекущейСтранице+1;
		КонецЕсли;
		//добавляем итоги
		питДокументы.ДобавитьИтогиПоСтранице(СтруктураСтрокиИтогов,СтруктураИтоговПоСтранице);
		
		ИтогСуммаУчет	= ИтогСуммаУчет  + СтрокаТоваров.СуммаУч;
		ИтогСуммаВсего	= ИтогСуммаВсего + СтрокаТоваров.СуммаФакт;
		ИтогКоличество	= ИтогКоличество + СтрокаТоваров.Колво;
		НомерСтроки = НомерСтроки + 1;
	КонецЦикла;
	
	//довыводим последний подвал, если страниц больше единицы
	Если (НомерСтраницы > 2) Тогда
		питДокументы.ВывестиИтогиПоСтранице(ТабДокумент,ОбластьИтоги,СтруктураИтоговПоСтранице,ЭтотОбъект);
	КонецЕсли;	
	
	ОбластьИтогоПодвал.Параметры.ИтогСуммаВсего	= ИтогСуммаВсего;
	ОбластьИтогоПодвал.Параметры.ИтогКоличество	= ИтогКоличество;
	ОбластьИтогоПодвал.Параметры.ИтогСуммаУчет	= ИтогСуммаУчет;
	
	НомерСтраницы = питДокументы.ВывестиГоризонтальнуюОбласть(ТабДокумент, ОбластьИтогоПодвал, , , НомерСтраницы,,);
	
	Руководители = ОтветственныеЛицаСервер.ПолучитьОтветственныеЛицаОрганизации(ЭтотОбъект.Организация, ЭтотОбъект.Дата);
	Если Руководители.Свойство("питЗаведующийПроизводством") Тогда
		ОбластьПодвал.Параметры.ЗаведующийПроизводствомПредставление = Руководители.питЗаведующийПроизводствомНаименование;
		ОбластьПодвал.Параметры.ЗаведующийПроизводством = Руководители.питЗаведующийПроизводством;
	КонецЕсли;
	Если Руководители.Свойство("Кассир") Тогда
		ОбластьПодвал.Параметры.КассирПредставление = Руководители.КассирНаименование;
	КонецЕсли;
	Если Руководители.Свойство("ГлавныйБухгалтер") Тогда
		ОбластьПодвал.Параметры.ГлавныйБухгалтерПредставление = Руководители.ГлавныйБухгалтерНаименование;
		ОбластьПодвал.Параметры.ГлавныйБухгалтер = Руководители.ГлавныйБухгалтер;
	КонецЕсли;
		
	ФорматСтрока  = "Л=ru_RU; ДП=Ложь";
	ПарамПредмета = "рубль, рубля, рублей, м, копейка, копейки, копеек, ж";
	ОбластьПодвал.Параметры.ИтогВсегоПропись	= ЧислоПрописью(ИтогСуммаВсего,ФорматСтрока,ПарамПредмета);
	ОбластьПодвал.Параметры.ИтогВыручкаПропись	= ЧислоПрописью(ИтогСуммаВсего,ФорматСтрока,ПарамПредмета);
	
	НомерСтраницы = питДокументы.ВывестиГоризонтальнуюОбласть(ТабДокумент, ОбластьПодвал, , ,НомерСтраницы);
	
	Возврат ТабДокумент;
	
КонецФункции

Функция ПечатьОП12(МассивОбъектов, ОбъектыПечати,ПараметрыПечати) Экспорт
	
	ТабДокумент = Новый ТабличныйДокумент;
	Если МассивОбъектов.Количество() = 0 Тогда
		Возврат ТабДокумент;
	иначе
		// Выпуски печатают все по оодному даже из формы списка.
		ЭтотОбъект = МассивОбъектов[0];
	КонецЕсли;
	
	ИмяРеквизитаКода = "Артикул";
	
	ТабДокумент.ПолеСверху = 0;
	ТабДокумент.ПолеСлева  = 0;
	ТабДокумент.ПолеСнизу  = 0;
	ТабДокумент.ПолеСправа = 0;
	ТабДокумент.Автомасштаб			= Истина;
	ТабДокумент.ОриентацияСтраницы	= ОриентацияСтраницы.Портрет;
	
	Макет = ПолучитьОбщийМакет("ПФ_MXL_питОП12");
	СтруктураПредставления = Новый Структура(
		"Наименование,ИНН,АдресЮридический,ТелефонРабочий,БанковскийСчет,Банк,БИК,КоррСчет",
		"","ИНН ","","тел.: ","р/с ","в банке ","БИК ","к/с ");
		
	ОбластьМакета = Макет.ПолучитьОбласть("Заголовок");
	ОбластьМакета.Параметры.Заполнить(ЭтотОбъект);
	ОбластьМакета.Параметры.Заполнить(ЭтотОбъект.Организация);
	ОбластьМакета.Параметры.Номер = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(ЭтотОбъект.Номер);
	
	//СтрокаПредставления = УправлениеПечатьюПлатформа.ПолучитьПредставлениеСправочника(ЭтотОбъект.Организация,СтруктураПредставления);
	СведенияОбОрганизации = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ЭтотОбъект.Организация, ЭтотОбъект.Дата);
	СтрокаПредставления = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОбОрганизации, "НаименованиеДляПечатныхФорм,");
	ОбластьМакета.Параметры.ОрганизацияПредставление = СтрокаПредставления;
	
	ОбластьМакета.Параметры.ПодразделениеКомпанииПредставление	= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЭтотОбъект.Подразделение, "Наименование");
	
	//Чтение значения для директора
	//Руководитель = дкОтветственноеЛицо(ЭтотОбъект,Перечисления.ВидыОбъектовСведений.Руководитель,,УправленческийУчет);
	Руководитель = ОтветственныеЛицаСервер.ПолучитьДанныеОтветственногоЛица(ЭтотОбъект.Организация,ЭтотОбъект.Дата,Перечисления.ОтветственныеЛицаОрганизаций.Руководитель);
	ОбластьМакета.Параметры.Заполнить(Руководитель);
	
	ТабДокумент.Вывести(ОбластьМакета);
	
	ОбластьШапкаТаблицы = Макет.ПолучитьОбласть("Шапка");
	ТабДокумент.Вывести(ОбластьШапкаТаблицы);
	НомерСтраницы = 2;
	ОбластьШапкаТаблицы.Параметры.НомерСтраницы = "Страница: " + НомерСтраницы;
	НомерСтраницыПред = НомерСтраницы;
	
	// Получим область итогов по странице
	ОбластьМакетаИтогоПоСтранице = Макет.ПолучитьОбласть("ИтогоПоСтранице");
	СтруктураИтоговПоСтранице	= Новый Структура("Колво,СуммаФакт,СуммаУч",0,0,0);
	ФорматВыводаСуммы		= "ЧДЦ=2; ЧН=0,00";
	ФорматВыводаКоличества	= "ЧДЦ=3; ЧН=0,000";
	
	ОбластьМакета = Макет.ПолучитьОбласть("Строка");
	ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");
	
	ВыборкаСтрок = ПолучитьТаблицуТоваровДляПечатиОП(ЭтотОбъект);
	ПриписатьЕдИзм = ВыводитьЕденицыИзмерения(ЭтотОбъект);
	
	
	ИтогСуммаУчет	= 0;
	ИтогКоличество	= 0;
	НомерСтроки		= 1;
	Для каждого СтрокаТоваров Из ВыборкаСтрок Цикл
		ОбластьМакета.Параметры.Ном				= НомерСтроки;
		НомерСтроки								= НомерСтроки + 1;
		ОбластьМакета.Параметры.НомКК			= СтрокаТоваров.НомКК;
		ОбластьМакета.Параметры.Наименование	= Строка(СтрокаТоваров.Номенклатура.НаименованиеПолное) + ?(ЗначениеЗаполнено(СтрокаТоваров.Характеристика)," / " + СокрЛП(СтрокаТоваров.Характеристика.НаименованиеПолное),"") + ?(ПриписатьЕдИзм , ", "+ Строка(СтрокаТоваров.ЕдиницаИзмерения) ,"" );
		ОбластьМакета.Параметры.Код				= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаТоваров.Номенклатура, ИмяРеквизитаКода);
		ОбластьМакета.Параметры.Колво			= Формат(СтрокаТоваров.Колво,ФорматВыводаКоличества);
		ОбластьМакета.Параметры.ЦенаФакт		= Формат(СтрокаТоваров.ЦенаФакт,ФорматВыводаСуммы);
		ОбластьМакета.Параметры.СуммаФакт		= Формат(СтрокаТоваров.СуммаФакт,ФорматВыводаСуммы);
		ОбластьМакета.Параметры.ЦенаУч			= Формат(?(СтрокаТоваров.Колво=0,0,СтрокаТоваров.СуммаУч/СтрокаТоваров.Колво),ФорматВыводаСуммы);
		ОбластьМакета.Параметры.СуммаУч			= Формат(СтрокаТоваров.СуммаУч,ФорматВыводаСуммы);
		
		ИтогСуммаУчет	= ИтогСуммаУчет + СтрокаТоваров.СуммаУч;
		ИтогКоличество	= ИтогКоличество + СтрокаТоваров.Колво;
		
		//доп. области
		мсвДопОбластиПодвала = Неопределено;
		Если ВыборкаСтрок.Индекс(СтрокаТоваров) = ВыборкаСтрок.Количество()-1 Тогда
			мсвДопОбластиПодвала = Новый Массив;
			мсвДопОбластиПодвала.Добавить(ОбластьПодвал);
		КонецЕсли;
				
		//выводим строку, делая проверку попадания на лист
		НомерСтраницы = питДокументы.ВывестиГоризонтальнуюОбласть(ТабДокумент, ОбластьМакета, ОбластьШапкаТаблицы, ОбластьМакетаИтогоПоСтранице, НомерСтраницы, СтруктураИтоговПоСтранице, мсвДопОбластиПодвала);
		
		//инициализация итогов по странице
		Если НомерСтраницы <> НомерСтраницыПред Тогда
			СтруктураИтоговПоСтранице	= Новый Структура("Колво,СуммаФакт,СуммаУч",0,0,0);
			НомерСтраницыПред = НомерСтраницы;
			ОбластьШапкаТаблицы.Параметры.НомерСтраницы = "Страница: " + НомерСтраницы; 
		КонецЕсли;
		СтруктураИтоговПоСтранице.Колво = СтруктураИтоговПоСтранице.Колво + СтрокаТоваров.Колво;
		СтруктураИтоговПоСтранице.СуммаФакт = СтруктураИтоговПоСтранице.СуммаФакт + СтрокаТоваров.СуммаФакт;
		СтруктураИтоговПоСтранице.СуммаУч = СтруктураИтоговПоСтранице.СуммаУч + СтрокаТоваров.СуммаУч;
	КонецЦикла;
	
	//довыводим последний подвал, если страниц больше единицы
	Если НомерСтраницы > 2 Тогда
		Для Каждого ЭлементИтога Из СтруктураИтоговПоСтранице Цикл
			ОбластьМакетаИтогоПоСтранице.Параметры[ЭлементИтога.Ключ] = Формат(ЭлементИтога.Значение,ФорматВыводаСуммы);
		КонецЦикла;
		НомерСтраницы = питДокументы.ВывестиГоризонтальнуюОбласть(ТабДокумент,ОбластьМакетаИтогоПоСтранице, , ,НомерСтраницы,,);
	КонецЕсли;
	
	ОбластьПодвал.Параметры.ИтогКолво=Формат(ИтогКоличество,ФорматВыводаКоличества);
	ОбластьПодвал.Параметры.ИтогСуммаФакт=Формат(ЭтотОбъект.Товары.Итог("Сумма"),ФорматВыводаСуммы);
	ОбластьПодвал.Параметры.ИтогСуммаУч=Формат(ИтогСуммаУчет,ФорматВыводаСуммы);
	ТабДокумент.Вывести(ОбластьПодвал);
	
	НомерСтраницыПред = НомерСтраницыПред + 1;
	НомерСтраницы = НомерСтраницы + 1;
	ОбластьШапкаТаблицы.Параметры.НомерСтраницы = ""; 		
	
	ОбластьМакета = Макет.ПолучитьОбласть("ОборотНаимен");
	ТабДокумент.Вывести(ОбластьМакета);
	
	// выводим оборотную часть
	ОбластьМакета = Макет.ПолучитьОбласть("Оборот");
	ФорматСтрока  = "Л=ru_RU; ДП=Ложь";
	ПарамПредмета = "рубль, рубля, рублей, м, копейка, копейки, копеек, ж";
	ОбластьМакета.Параметры.ВыручкаКассы	= ЧислоПрописью(ЭтотОбъект.Товары.Итог("Сумма"),ФорматСтрока,ПарамПредмета);
	
	Руководители = ОтветственныеЛицаСервер.ПолучитьОтветственныеЛицаОрганизации(ЭтотОбъект.Организация, ЭтотОбъект.Дата);
	Если Руководители.Свойство("питЗаведующийПроизводством") Тогда
		ОбластьМакета.Параметры.ЗаведующийПроизводствомПредставление = Руководители.питЗаведующийПроизводствомНаименование;
		ОбластьМакета.Параметры.ЗаведующийПроизводством = Руководители.питЗаведующийПроизводством;
	КонецЕсли;
	Если Руководители.Свойство("Кассир") Тогда
		ОбластьМакета.Параметры.КассирПредставление = Руководители.КассирНаименование;
	КонецЕсли;
	Если Руководители.Свойство("ГлавныйБухгалтер") Тогда
		ОбластьМакета.Параметры.ГлавныйБухгалтерПредставление = Руководители.ГлавныйБухгалтерНаименование;
		ОбластьМакета.Параметры.ГлавныйБухгалтер = Руководители.ГлавныйБухгалтер;
	КонецЕсли;
	
	//??
	////ЧленКомиссии1 = дкОтветственноеЛицо(ЭтотОбъект,"ЧленКомиссии1");
	//ЧленКомиссии1 = УправлениеПечатьюПлатформа.ДанныеОтветственногоЛица(ЭтотОбъект,"ЧленКомиссии1");
	//ОбластьМакета.Параметры.Заполнить(ЧленКомиссии1);
	////ЧленКомиссии2 = дкОтветственноеЛицо(ЭтотОбъект,"ЧленКомиссии2");
	//ЧленКомиссии2 = УправлениеПечатьюПлатформа.ДанныеОтветственногоЛица(ЭтотОбъект,"ЧленКомиссии2");
	//ОбластьМакета.Параметры.Заполнить(ЧленКомиссии2);
	
	ТабДокумент.Вывести(ОбластьМакета);
	
	Возврат ТабДокумент;

КонецФункции

Функция ПечатьОП21(МассивОбъектов, ОбъектыПечати,ПараметрыПечати) Экспорт
	
	ТабДокумент = Новый ТабличныйДокумент;
