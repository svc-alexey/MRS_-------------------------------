// Возвращает текст запроса для расчета статусов указания серий.
//	Параметры:
//		ПараметрыУказанияСерий - Структура - состав полей задается в функции НоменклатураКлиентСервер.ПараметрыУказанияСерий.
//	Возвращаемое значение:
//		Строка - текст запроса.
//
Функция ТекстЗапросаЗаполненияСтатусовУказанияСерий(ПараметрыУказанияСерий) Экспорт
	
	ТекстЗапроса = "";
	
	Если ПараметрыУказанияСерий.ИмяТЧТовары = "Товары" 
		ИЛИ ПараметрыУказанияСерий.ИмяТЧТовары = "Блюда"
		ИЛИ ПараметрыУказанияСерий.ИмяТЧТовары = "Модификаторы" Тогда
		ТекстЗапроса = ТекстЗапросаЗаполненияСтатусовУказанияСерийТоварыБлюда();
	ИначеЕсли ПараметрыУказанияСерий.ИмяТЧТовары = "ПобочныеИзделия" Тогда
		ТекстЗапроса = ТекстЗапросаЗаполненияСтатусовУказанияСерийВыходныеИзделия();
	ИначеЕсли ПараметрыУказанияСерий.ИмяТЧТовары = "Ингредиенты" Тогда
		ТекстЗапроса = ТекстЗапросаЗаполненияСтатусовУказанияСерийИнгредиенты();
	ИначеЕсли ПараметрыУказанияСерий.ИмяТЧТовары = "Замены" Тогда
		ТекстЗапроса = ТекстЗапросаЗаполненияСтатусовУказанияСерийЗамены();
	КонецЕсли;
	
	Возврат ТекстЗапроса;
	
КонецФункции

