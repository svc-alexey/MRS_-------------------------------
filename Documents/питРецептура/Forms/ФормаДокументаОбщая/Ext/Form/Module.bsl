&НаКлиенте
Процедура ИнгредиентыПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	Если НоваяСтрока Тогда
		Элемент.ТекущиеДанные.ИдентификаторСтроки	= Новый УникальныйИдентификатор;
		Элемент.ТекущиеДанные.СтатьяКалькуляции		= Объект.СтатьяКалькуляции;
		
		//+ПараметризацияРецептур
		ПриВводеНовойСтрокиМатериалов(ЭтаФорма, Элемент.ТекущиеДанные, Копирование);
		//-ПараметризацияРецептур
		
	КонецЕсли;
	
	Если Элементы.ТоварыВводСтрокиДиалогом.Пометка И Объект.ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.питХозяйственныеОперации.РецептураПриготовление")
		ИЛИ (ПрименятьМеханизмВидовОбработки И (Элемент.ТекущийЭлемент = Элементы.ИнгредиентыВидыОбработки
		ИЛИ Элемент.ТекущийЭлемент = Элементы.ТоварыПроцентПотерьПриГорячейОбработке
		ИЛИ Элемент.ТекущийЭлемент = Элементы.ТоварыПроцентПотерьПриХолоднойОбработке)) Тогда
		Отказ = Истина;
		РедактироватьСтрокуВДиалоге(Элементы.Ингредиенты.ТекущиеДанные, Неопределено);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьСтрокуИнгредиентыВидыОбработки(ТекущиеДанные = Неопределено)
	
	Если ТекущиеДанные = Неопределено Тогда
		ТекущиеДанные = Элементы.Ингредиенты.ТекущиеДанные;
	КонецЕсли;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Виды обработки
	СтруктураПоиска = Новый Структура("ИдентификаторСтроки", ТекущиеДанные.ИдентификаторСтроки);
	
	ОбщаяСтрока = "";
	
	НайденныеВиды = Объект.ВидыОбработки.НайтиСтроки(СтруктураПоиска);
	Разделитель = "";
	Для Каждого СтрокаВида Из НайденныеВиды Цикл
		ОбщаяСтрока = ОбщаяСтрока + Разделитель + СокрЛП(СтрокаВида.ВидОбработкиСырья) + " " + СокрЛП(СтрокаВида.ПроцентПотерь);
		Разделитель = ";";
	КонецЦикла;
	ТекущиеДанные.ВидыОбработки = ОбщаяСтрока;
	
КонецПроцедуры

&НаКлиенте
Процедура ИнгредиентыПередУдалением(Элемент, Отказ)
	ТекСтрока = Элементы.Ингредиенты.ТекущиеДанные;
	Если НЕ ТекСтрока = Неопределено Тогда
		УдалитьДанныеПоВидамОбработкиПоИдентификатору(ТекСтрока.ИдентификаторСтроки);
		//+ПараметризацияРецептур
		Если ЭтоУправлениеПредприятием Тогда
			УправлениеДаннымиОбИзделияхКлиент.ОчиститьНастройкиОтбораПоСвойствам(
				Элементы.Ингредиенты,
				Элементы.Ингредиенты.ВыделенныеСтроки,
				Объект.ОтборПоСвойствам);
		КонецЕсли;
		//-ПараметризацияРецептур
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура УдалитьДанныеПоВидамОбработкиПоИдентификатору(ИдентификаторСтроки)
	СтруктураПоиска = Новый Структура("ИдентификаторСтроки", ИдентификаторСтроки);
	МассивВидовОбработки = Объект.ВидыОбработки.НайтиСтроки(СтруктураПоиска);
	Для Каждого СтрокаВида Из МассивВидовОбработки Цикл
		Объект.ВидыОбработки.Удалить(СтрокаВида);
	КонецЦикла;
	МассивХЭХ = Объект.ПотериХЭХПриОбработке.НайтиСтроки(СтруктураПоиска);
	Для каждого ТекХЭХ Из МассивХЭХ Цикл
		Объект.ПотериХЭХПриОбработке.Удалить(ТекХЭХ);
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ИнгредиентыВидыОбработкиОткрытие(Элемент, СтандартнаяОбработка)
	Если Объект.ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.питХозяйственныеОперации.РецептураПриготовление") Тогда
		СтандартнаяОбработка = Ложь;
		РедактироватьСтрокуВДиалоге(Элементы.Ингредиенты.ТекущиеДанные, Неопределено);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ТоварыЗаменаПриИзменении(Элемент)
	ТаблицаНоменклатураПриИзменении("Ингредиенты");
КонецПроцедуры

#КонецОбласти


#Область РазрешенныеПодразделения

&НаСервере
Процедура ЗагрузитьДанныеПоПодразделениям()
	
	Подразделения.Очистить();
	Цеха.Очистить();
	
	Если Объект.Ссылка.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	питРецептураРазрешенныеПодразделения.Подразделение КАК Подразделение,
		|	питРецептураРазрешенныеПодразделения.ЦеховаяКладовая,
		|	питРецептураРазрешенныеПодразделения.ВключаяПодчиненные КАК ВключаяПодчиненные
		|ИЗ
		|	Документ.питРецептура.РазрешенныеПодразделения КАК питРецептураРазрешенныеПодразделения
		|ГДЕ
		|	питРецептураРазрешенныеПодразделения.Ссылка = &Ссылка
		|ИТОГИ
		|	МАКСИМУМ(ВключаяПодчиненные)
		|ПО
		|	Подразделение";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если НЕ РезультатЗапроса.Пустой() Тогда
		
		ВыборкаПодразделение = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Пока ВыборкаПодразделение.Следующий() Цикл
			
			НовПодразделение = Подразделения.Добавить();
			НовПодразделение.Подразделение = ВыборкаПодразделение.Подразделение;
			НовПодразделение.ВключаяПодчиненные = ВыборкаПодразделение.ВключаяПодчиненные;
			НовПодразделение.ИдентификаторСтроки = Новый УникальныйИдентификатор;
			
			ВыборкаДетальныеЗаписи = ВыборкаПодразделение.Выбрать();
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				
				//Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ЦеховаяКладовая) Тогда
					
					НовЦех = Цеха.Добавить();
					НовЦех.ИдентификаторПодразделения = НовПодразделение.ИдентификаторСтроки;
					НовЦех.ЦеховаяКладовая = ВыборкаДетальныеЗаписи.ЦеховаяКладовая;
					
				//КонецЕсли;
				
			КонецЦикла;
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ВыгрузитьДанныеПоПодразделениям(ТекущийОбъект)
	
	// Добавляем в разрешенные подразделение из шапки
	НайденныеПодразделения = Подразделения.НайтиСтроки(Новый Структура("Подразделение",ТекущийОбъект.Подразделение));
	ПодразделениеДобавлено = Ложь;
	Если НЕ НайденныеПодразделения.Количество() Тогда
		ТекПодр = Подразделения.Добавить();
		ТекПодр.ИдентификаторСтроки	= Новый УникальныйИдентификатор;
		ТекПодр.Подразделение		= ТекущийОбъект.Подразделение;
		ТекПодр.ВключаяПодчиненные	= ?(ЗначениеЗаполнено(Объект.ЦеховаяКладовая), Ложь, Истина);
		ПодразделениеДобавлено = Истина;
	Иначе
		ТекПодр = НайденныеПодразделения[0];
	КонецЕсли;
	
	Если НЕ ТекПодр.ВключаяПодчиненные Тогда
		
		// Добавляем в разрешенные цех из шапки
		ВсеНайденныеЦеха = Цеха.НайтиСтроки(Новый Структура("ИдентификаторПодразделения", ТекПодр.ИдентификаторСтроки));
		ПустыеЦеха = Цеха.НайтиСтроки(Новый Структура("ЦеховаяКладовая, ИдентификаторПодразделения", Справочники.Склады.ПустаяСсылка(), ТекПодр.ИдентификаторСтроки));
		НайденныеЦеха = Цеха.НайтиСтроки(Новый Структура("ЦеховаяКладовая, ИдентификаторПодразделения", ТекущийОбъект.ЦеховаяКладовая, ТекПодр.ИдентификаторСтроки));
		ЦеховБезПустых = ВсеНайденныеЦеха.Количество() - ПустыеЦеха.Количество();
		Если (НЕ НайденныеЦеха.Количество() И ЗначениеЗаполнено(ТекущийОбъект.ЦеховаяКладовая) И НЕ ПустыеЦеха.Количество()) 
			ИЛИ (НЕ ЗначениеЗаполнено(ТекущийОбъект.ЦеховаяКладовая) И ЦеховБезПустых > 0) Тогда
			НовЦех = Цеха.Добавить();
			НовЦех.ЦеховаяКладовая				= ТекущийОбъект.ЦеховаяКладовая;
			НовЦех.ИдентификаторПодразделения	= ТекПодр.ИдентификаторСтроки;
		КонецЕсли;
		
	КонецЕсли;
	
	ТекущийОбъект.РазрешенныеПодразделения.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	втПодразделения.ИдентификаторСтроки,
	|	втПодразделения.Подразделение,
	|	втПодразделения.ВключаяПодчиненные
	|ПОМЕСТИТЬ втПодразделения
	|ИЗ
	|	&втПодразделения КАК втПодразделения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втЦеха.ИдентификаторПодразделения,
	|	втЦеха.ЦеховаяКладовая
	|ПОМЕСТИТЬ втЦеха
	|ИЗ
	|	&втЦеха КАК втЦеха
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втПодразделения.Подразделение,
	|	втПодразделения.ВключаяПодчиненные,
	|	ЕСТЬNULL(втЦеха.ЦеховаяКладовая, ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)) КАК ЦеховаяКладовая
	|ИЗ
	|	втПодразделения КАК втПодразделения
	|		ЛЕВОЕ СОЕДИНЕНИЕ втЦеха КАК втЦеха
	|		ПО втПодразделения.ИдентификаторСтроки = втЦеха.ИдентификаторПодразделения";
	
	Запрос.УстановитьПараметр("втПодразделения"	, Подразделения.Выгрузить());
	Запрос.УстановитьПараметр("втЦеха"			, Цеха.Выгрузить());
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		НовПодр = ТекущийОбъект.РазрешенныеПодразделения.Добавить();
		ЗаполнитьЗначенияСвойств(НовПодр, ВыборкаДетальныеЗаписи);
	КонецЦикла;
	
КонецПроцедуры

