&НаКлиенте
Процедура ФормулаРасчетаКалорийностиОткрытие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	// Поищем, откуда брать формулу
	ТекФормула	= ВернутьКонстанту("питФормулаРасчетаКалорийности");
	Источник	= "из константы";
	Если ПустаяСтрока(ТекФормула) Тогда
		ТекФормула = "4 * [Белки] + 9 * [Жиры] + 4 * [Углеводы] + 7 * [Алкоголь]";
		Источник = "по умолчанию";
	КонецЕсли;
	Если ПустаяСтрока(Объект.ФормулаРасчетаКалорийности) Тогда
		// Если формулы не было - сразу подставим
		Объект.ФормулаРасчетаКалорийности = ТекФормула;
		Модифицированность = Истина;
		ФормулаРасчетаКалорийностиПриИзменении(Неопределено);
	Иначе
		// Если формула была - спросим, хотят ли новую
		ТекстВопроса = "Формула расчета калорийности не пустая! Заменить ее" + Символы.ПС + "на формулу " + Источник + " (" + ТекФормула + ")?";
		ПоказатьВопрос(Новый ОписаниеОповещения("ФормулаРасчетаКалорийностиОткрытиеЗавершение", ЭтотОбъект, Новый Структура("ТекФормула", ТекФормула)), ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ФормулаРасчетаКалорийностиОткрытиеЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	ТекФормула = ДополнительныеПараметры.ТекФормула;
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		Объект.ФормулаРасчетаКалорийности = ТекФормула;
		Модифицированность = Истина;
		ФормулаРасчетаКалорийностиПриИзменении(Неопределено);
	КонецЕсли;
	
КонецПроцедуры

