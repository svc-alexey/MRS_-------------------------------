&НаКлиенте
Процедура ПодразделениеЦеховаяПриИзменении()
	
	Если ЗначениеЗаполнено(Объект.Подразделение) Тогда
		
		ТекСтрокаПодразделения = Неопределено;
		НайденныеПодразделения = Подразделения.НайтиСтроки(Новый Структура("Подразделение", Объект.Подразделение));
		Если НайденныеПодразделения.Количество() Тогда
			ТекСтрокаПодразделения = НайденныеПодразделения[0];
		Иначе
			ТекСтрокаПодразделения = Подразделения.Добавить();
			ТекСтрокаПодразделения.Подразделение = Объект.Подразделение;
			ТекСтрокаПодразделения.ВключаяПодчиненные = Истина;
			ТекСтрокаПодразделения.ИдентификаторСтроки = Новый УникальныйИдентификатор;
		КонецЕсли;
		
		ПустыеЦеха = Цеха.НайтиСтроки(Новый Структура("ЦеховаяКладовая, ИдентификаторПодразделения" ,
			ПредопределенноеЗначение("Справочник.Склады.ПустаяСсылка"), ТекСтрокаПодразделения.ИдентификаторСтроки));
		Для каждого ПустойЦех Из ПустыеЦеха Цикл
			Цеха.Удалить(ПустойЦех);
		КонецЦикла;
		
		НайденныеЦеха = Цеха.НайтиСтроки(Новый Структура("ИдентификаторПодразделения", ТекСтрокаПодразделения.ИдентификаторСтроки));
		Если НЕ НайденныеЦеха.Количество() Тогда
			ТекСтрокаЦеха = Цеха.Добавить();
			ТекСтрокаЦеха.ЦеховаяКладовая = Объект.ЦеховаяКладовая;
			ТекСтрокаЦеха.ИдентификаторПодразделения = ТекСтрокаПодразделения.ИдентификаторСтроки;
			Если ЗначениеЗаполнено(Объект.ЦеховаяКладовая) Тогда
				ТекСтрокаПодразделения.ВключаяПодчиненные = Ложь;
			КонецЕсли;
		КонецЕсли;
		
		ОбновитьОтборСтрокТаблицыЦехов();
		
	КонецЕсли;

КонецПроцедуры

