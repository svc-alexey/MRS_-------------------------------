// Рассчитывает количество выхода в граммах
Процедура ОпределитьКоличествоВыходВЕдиницеИзмеренияВыходаВРецептурах(КоличествоРезультат, ТаблицаИнгредиентов, ЕдиницаИзмеренияВыходаВРецептурах)
	
	КоличествоРезультат = 0;
	
	Если НЕ ЗначениеЗаполнено(ЕдиницаИзмеренияВыходаВРецептурах) Тогда
		Возврат;
	КонецЕсли;
	ДанныеЕИВыходаВРецептурах = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ЕдиницаИзмеренияВыходаВРецептурах, "Числитель, Знаменатель");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ * ПОМЕСТИТЬ втИнгредиенты ИЗ &ТаблицаИнгредиентов КАК Ингредиенты;
	|ВЫБРАТЬ
	|	втИнгредиенты.Номенклатура,
	|	втИнгредиенты.КоличествоВыход,
	|	НоменклатураСпр.ВесЧислитель КАК ВесЧислитель,
	|	НоменклатураСпр.ВесЗнаменатель КАК ВесЗнаменатель,
	|	НоменклатураСпр.ВесЕдиницаИзмерения КАК ВесЕдиницаИзмерения,
	|	НоменклатураСпр.ВесЕдиницаИзмерения.Числитель КАК ВесЕдиницаИзмеренияЧислитель,
	|	НоменклатураСпр.ВесЕдиницаИзмерения.Знаменатель КАК ВесЕдиницаИзмеренияЗнаменатель
	|ИЗ
	|	втИнгредиенты КАК втИнгредиенты
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСпр
	|			ПО втИнгредиенты.Номенклатура = НоменклатураСпр.Ссылка
	|ГДЕ
	|	НоменклатураСпр.ВесИспользовать
	|";
	Запрос.УстановитьПараметр("ТаблицаИнгредиентов", ТаблицаИнгредиентов);
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			Если НЕ ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.Номенклатура) Тогда
				Продолжить;
			КонецЕсли;
			Если ВыборкаДетальныеЗаписи.ВесЕдиницаИзмерения = ЕдиницаИзмеренияВыходаВРецептурах Тогда
				КоэффициентПересчетаВОсновнуюЕИМассы = Неопределено;
				Если ВыборкаДетальныеЗаписи.ВесЗнаменатель <> 0 Тогда
					КоэффициентПересчетаВЕИВыходаВРецептурах = (ВыборкаДетальныеЗаписи.ВесЧислитель/ВыборкаДетальныеЗаписи.ВесЗнаменатель);
				Иначе
					КоэффициентПересчетаВЕИВыходаВРецептурах = 1;
				КонецЕсли;
			Иначе
				Если ВыборкаДетальныеЗаписи.ВесЗнаменатель <> 0 И ВыборкаДетальныеЗаписи.ВесЕдиницаИзмеренияЗнаменатель <> 0 Тогда
					КоэффициентПересчетаВОсновнуюЕИМассы = (ВыборкаДетальныеЗаписи.ВесЧислитель/ВыборкаДетальныеЗаписи.ВесЗнаменатель) * (ВыборкаДетальныеЗаписи.ВесЕдиницаИзмеренияЧислитель/ВыборкаДетальныеЗаписи.ВесЕдиницаИзмеренияЗнаменатель);
				Иначе
					КоэффициентПересчетаВЕИВыходаВРецептурах = 1;
				КонецЕсли;
				Если ДанныеЕИВыходаВРецептурах.Числитель <> 0 Тогда
					КоэффициентПересчетаВЕИВыходаВРецептурах = КоэффициентПересчетаВОсновнуюЕИМассы * (ДанныеЕИВыходаВРецептурах.Знаменатель / ДанныеЕИВыходаВРецептурах.Числитель);
				Иначе
					КоэффициентПересчетаВЕИВыходаВРецептурах = 1;
				КонецЕсли;
			КонецЕсли;
			КоличествоРезультат = КоличествоРезультат + ВыборкаДетальныеЗаписи.КоличествоВыход * КоэффициентПересчетаВЕИВыходаВРецептурах;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыходВесНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ВыходВесНачалоВыбораСервер();
	Модифицированность = Истина;
КонецПроцедуры

&НаСервере
Процедура ВыходВесНачалоВыбораСервер()
	ОпределитьКоличествоВыходВЕдиницеИзмеренияВыходаВРецептурах(Объект.ВыходВес, Объект.Ингредиенты.Выгрузить(,"Номенклатура,КоличествоВыход"), ЕдиницаИзмеренияВыходаВРецептурах);
КонецПроцедуры

&НаКлиенте
Процедура ВыходПриИзменении(Элемент)
	Если Не ЗначениеЗаполнено(Объект.ВыходВес) Тогда
		Попытка
			Объект.ВыходВес = Число(Объект.Выход);
		Исключение
		КонецПопытки;
	КонецЕсли;
КонецПроцедуры


#Область КопированиеВставкаСтрок

&НаКлиенте
Процедура СкопироватьСтроки(Команда)
	
	ИмяТаблицы = ПолучитьИмяТекущейТабличнойЧасти();
	Если ПустаяСтрока(ИмяТаблицы) Тогда
		Возврат;
	КонецЕсли;
	
	Для каждого ТекВыделеннаяСтрока Из Элементы[ИмяТаблицы].ВыделенныеСтроки Цикл
		ДанныеСтроки = Объект[ИмяТаблицы].НайтиПоИдентификатору(ТекВыделеннаяСтрока);
		ДанныеСтроки.Количество			= ДанныеСтроки.КоличествоВыход;
		ДанныеСтроки.КоличествоУпаковок	= ДанныеСтроки.КоличествоУпаковокВыход;
	КонецЦикла;
	
	КоличествоСтрок = Элементы[ИмяТаблицы].ВыделенныеСтроки.Количество();
	Если КоличествоСтрок = 0 Тогда
		Возврат;
	КонецЕсли;
	СкопироватьСтрокиНаСервере(ИмяТаблицы);
	РаботаСТабличнымиЧастямиКлиент.ОповеститьПользователяОКопированииСтрок(КоличествоСтрок);
	
КонецПроцедуры

&НаСервере
Процедура СкопироватьСтрокиНаСервере(ИмяТаблицы)
	
	РаботаСТабличнымиЧастями.СкопироватьСтрокиВБуферОбмена(Объект[ИмяТаблицы], Элементы[ИмяТаблицы].ВыделенныеСтроки);
	
КонецПроцедуры

&НаКлиенте
Процедура ВставитьСтроки(Команда)
	
	ИмяТаблицы = ПолучитьИмяТекущейТабличнойЧасти();
	Если ПустаяСтрока(ИмяТаблицы) Тогда
		Возврат;
	КонецЕсли;
	КоличествоТоваровДоВставки = Объект.Ингредиенты.Количество();
	ПолучитьСтрокиИзБуфераОбмена(ИмяТаблицы);
	
	ПосчитатьКоличестваВединицахХранения();
	
	КоличествоСтрок = Объект.Ингредиенты.Количество()-КоличествоТоваровДоВставки;
	РаботаСТабличнымиЧастямиКлиент.ОповеститьПользователяОВставкеСтрок(КоличествоСтрок);
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьСтрокиИзБуфераОбмена(ИмяТаблицы)
	
	ТаблицаТоваров = РаботаСТабличнымиЧастями.СтрокиИзБуфераОбмена();
	Если Не ЗначениеЗаполнено(ТаблицаТоваров) Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураДействий = Новый Структура;
	ДобавитьВСтруктуруДействияПриИзмененииКоличестваУпаковок(ИмяТаблицы, СтруктураДействий);
	КэшированныеЗначения = ОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
	
	Для Каждого СтрокаТовара Из ТаблицаТоваров Цикл
		
		// Произведем проверку, чтобы блюдо не включало в себя это же блюдо
		Если СтрокаТовара.Номенклатура = Объект.Номенклатура Тогда
			ТекстСообщения = "Рецептура блюда не может включать в себя это же блюдо. Номенклатура """+СтрокаТовара.Номенклатура+""" не добавлена.";
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, Объект.Ссылка, "Ингредиенты", "Объект", );
			// Пропускаем эту строку.
			Продолжить;
		КонецЕсли;
		
		РеквизитыНоменклатуры = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СтрокаТовара.Номенклатура, 
				"питВидНоменклатуры, питПроцентПотерьПриХолоднойОбработке, питПроцентПотерьПриГорячейОбработке");
		
		Если РеквизитыНоменклатуры.питВидНоменклатуры = Перечисления.питВидыНоменклатуры.БизнесЛанч Тогда
			ТекстСообщения = "Рецептура блюда не может включать в себя бизнес-ланч. Номенклатура """+СтрокаТовара.Номенклатура+""" не добавлена.";
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, Объект.Ссылка, "Ингредиенты", "Объект", );
			// Пропускаем эту строку.
			Продолжить;
		КонецЕсли;
		
		
		ТекущаяСтрока = Объект.Ингредиенты.Добавить();
		ТекущаяСтрока.ИдентификаторСтроки	= Новый УникальныйИдентификатор;
		ТекущаяСтрока.КлючСвязи				= Новый УникальныйИдентификатор;
		ЗаполнитьЗначенияСвойств(ТекущаяСтрока, СтрокаТовара);
		Если НЕ ТаблицаТоваров.Колонки.Найти("КоличествоУпаковок") = Неопределено 
			И НЕ ЗначениеЗаполнено(ТекущаяСтрока.КоличествоУпаковокБрутто) Тогда
			ТекущаяСтрока.КоличествоУпаковокБрутто	= СтрокаТовара.КоличествоУпаковок;
		КонецЕсли;
		Если НЕ ТаблицаТоваров.Колонки.Найти("Количество") = Неопределено 
			И НЕ ЗначениеЗаполнено(ТекущаяСтрока.КоличествоБрутто) Тогда
			ТекущаяСтрока.КоличествоБрутто			= СтрокаТовара.Количество;
		КонецЕсли;
		
		
		Если ТекущаяСтрока.КоличествоУпаковокНетто = 0 Тогда
			ОпределитьКоличество(ТекущаяСтрока.КоличествоУпаковокНетто, ТекущаяСтрока.КоличествоУпаковокВыход, ТекущаяСтрока.ПроцентПотерьПриГорячейОбработке, Истина, Истина, ТекущаяСтрока.Специя, ТекущаяСтрока.НомерСтроки-1);
		Иначе
			ТекущаяСтрока.ПроцентПотерьПриГорячейОбработке = РассчитатьПроцентПотерьОбработки(ТекущаяСтрока.КоличествоУпаковокНетто, ТекущаяСтрока.КоличествоУпаковокВыход);
		КонецЕсли;
		Если ТекущаяСтрока.КоличествоУпаковокБрутто = 0 Тогда
			ОпределитьКоличество(ТекущаяСтрока.КоличествоУпаковокБрутто, ТекущаяСтрока.КоличествоУпаковокНетто, ТекущаяСтрока.ПроцентПотерьПриХолоднойОбработке, Истина, Ложь, ТекущаяСтрока.Специя, ТекущаяСтрока.НомерСтроки-1);
		Иначе
			ТекущаяСтрока.ПроцентПотерьПриХолоднойОбработке = РассчитатьПроцентПотерьОбработки(ТекущаяСтрока.КоличествоУпаковокБрутто, ТекущаяСтрока.КоличествоУпаковокНетто);
		КонецЕсли;
		
		//ОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, КэшированныеЗначения);
		
		// Дозаполним еще реквизиты, такие как "Рецептура", "ЭтоБлюдо", "ЭтоТовар" и т.д.
		СписокСвойствСтрокой = "Номенклатура, Характеристика, Упаковка, ЭтоУслуга, ЭтоТовар, ЭтоБлюдо, Иконка, Рецептура, Специя, ПроцентПотерьПриХолоднойОбработке, ПроцентПотерьПриГорячейОбработке, КоличествоУпаковокНетто, КоличествоУпаковокБрутто, КоличествоУпаковокВыход, НомерСтроки";
		ДанныеСтрокаТаблицы = Новый Структура(СписокСвойствСтрокой);
		ЗаполнитьЗначенияСвойств(ДанныеСтрокаТаблицы, ТекущаяСтрока);
		
		СвойстваПараметрыОбъектаСтрокой = "ХозяйственнаяОперация, Организация, Дата, Ссылка, ЕдиницаИзмеренияВыходаВРецептурах";
		ПараметрыОбъекта = Новый Структура();
		ПараметрыОбъекта = Новый Структура(СвойстваПараметрыОбъектаСтрокой);
		ПараметрыОбъекта.Вставить("СпособРасчетаРецептурыПоАктуальной", СпособРасчетаРецептурыПоАктуальной);
		
		ЗаполнитьЗначенияСвойств(ПараметрыОбъекта, ЭтаФорма);
		ЗаполнитьЗначенияСвойств(ПараметрыОбъекта, Объект);
		
		Если ЗначениеЗаполнено(ТекущаяСтрока.ПроцентПотерьПриХолоднойОбработке) 
			ИЛИ ЗначениеЗаполнено(ТекущаяСтрока.ПроцентПотерьПриГорячейОбработке) Тогда
			ПараметрыОбъекта.Вставить("ВсеРавноСчитатьПотери", Ложь);
		Иначе
			ПараметрыОбъекта.Вставить("ВсеРавноСчитатьПотери", Истина);
		КонецЕсли;
		
		ТоварыНоменклатураПриИзмененииНаСервере(ДанныеСтрокаТаблицы, ПараметрыОбъекта);
		
		ЗаполнитьЗначенияСвойств(ТекущаяСтрока, ДанныеСтрокаТаблицы);
		
		//+ПараметризацияРецептур
		ПриВводеНовойСтрокиМатериалов(ЭтаФорма, ТекущаяСтрока);
		
	КонецЦикла;
	ЗаполнитьСлужебныеРеквизитыПоНоменклатуре();
	
КонецПроцедуры

&НаКлиенте
Функция ПолучитьИмяТекущейТабличнойЧасти()
	
	ИмяТекущейСтраницы = Элементы.ГруппаСтраницы.ТекущаяСтраница.Имя;
	ИмяТаблицы = "";
	Если ИмяТекущейСтраницы = "ГруппаТовары" Тогда
		
		ИмяТаблицы = "Ингредиенты";
		
	КонецЕсли;
	
	Возврат ИмяТаблицы;
	
КонецФункции

#КонецОбласти

//+АвтовыборНоменклатуры
#Область АвтовыборНоменклатуры

// %ИзЕРП%
// Справочник.РесурсныеСпецификации.ФормаЭлемента.ВыходныеИзделия_НастроитьПодборНоменклатуры
//
&НаКлиенте
Процедура Товары_НастроитьПодборНоменклатуры(Команда)
	
	//++ НЕ УТКА
	
	ТекущиеДанные = Элементы.Ингредиенты.ТекущиеДанные;
	
	ОчиститьСообщения();
	
	Если ТекущиеДанные = Неопределено Тогда
		ТекстСообщения = НСтр("ru = 'Не выбрана строка таблицы ""Товары"".';
								|en = 'Line of the ""Products"" table is not selected.'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,, "Объект.Ингредиенты", "Объект");
		
		Возврат;
	КонецЕсли;
	
	Если НЕ ПроверитьЗаполнениеОсновногоИзделия() Тогда
		Возврат;
	КонецЕсли;
	
	Номенклатура = ПроверитьПолучитьОсновноеИзделиеСпецификации();
	Если Номенклатура.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	СоответствиеСвойств = УправлениеДаннымиОбИзделияхКлиент.РеквизитыНастроекПоСтрокеВМассивСтруктур(
		ТекущиеДанные,
		Объект.СоответствиеСвойств,
		УправлениеДаннымиОбИзделияхКлиентСервер.РеквизитыНастройкаСоответствияСвойств());
	
	УправлениеДаннымиОбИзделияхКлиент.НастроитьАвтовыборНоменклатуры(
							ЭтаФорма,
							"Ингредиенты",
							СоответствиеСвойств, 
							Номенклатура,
							НСтр("ru = 'Указывается в спецификации';
								|en = 'Specified in specification'"),
	//+пит
							Ложь);
	//-пит
	//-- НЕ УТКА
	
	Возврат; // пустой обработчик
	
КонецПроцедуры

// %ИзЕРП%
// Справочник.РесурсныеСпецификации.ФормаЭлемента.ПроверитьПолучитьОсновноеИзделиеСпецификации
//
&НаКлиенте
Функция ПроверитьПолучитьОсновноеИзделиеСпецификации()
	//+пит
	Возврат Объект.Номенклатура;
	//-пит
КонецФункции

// %ИзЕРП%
// Справочник.РесурсныеСпецификации.ФормаЭлемента.ПроверитьЗаполнениеОсновногоИзделия
//
&НаСервере
Функция ПроверитьЗаполнениеОсновногоИзделия()
	
	ЕстьОшибки = Ложь;
	
	//+пит
	Если НЕ ЗначениеЗаполнено(Объект.Номенклатура) ИЛИ НЕ ЗначениеЗаполнено(Объект.Количество) Тогда
		ЕстьОшибки = Истина;
	КонецЕсли;
	//-пит
	
	Возврат Не ЕстьОшибки;
	
КонецФункции

// %ИзЕРП%
// Справочник.РесурсныеСпецификации.ФормаЭлемента.ОбработкаВыбораНастройкаАвтовыбораНоменклатуры
//
&НаКлиенте
Процедура ОбработкаВыбораНастройкаАвтовыбораНоменклатуры(ИмяТЧ, ВыбранноеЗначение)
	
	//+пит
	КэшированныеЗначения = ОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
	//-пит
	
	ТекущиеДанные = Элементы[ИмяТЧ].ТекущиеДанные;
	
	СпособАвтовыбораНоменклатуры = ТекущиеДанные.СпособАвтовыбораНоменклатуры;
	
	Если УправлениеДаннымиОбИзделияхКлиент.НастроитьАвтовыборНоменклатурыЗавершение(
			ВыбранноеЗначение,
			ТекущиеДанные,
			Объект.СоответствиеСвойств) Тогда
			
		СтруктураДействий = Новый Структура;
		
		Если СпособАвтовыбораНоменклатуры <> ТекущиеДанные.СпособАвтовыбораНоменклатуры Тогда
			
			СтруктураДействий.Вставить("ЗаполнитьПризнакАртикул", Новый Структура("Номенклатура", "Артикул"));
			//+пит
