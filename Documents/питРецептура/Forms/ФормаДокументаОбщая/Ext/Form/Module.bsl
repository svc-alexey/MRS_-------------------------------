// СтандартныеПодсистемы.ДополнительныеОтчетыИОбработки

&НаСервере
Процедура ДополнительныеОтчетыИОбработкиВыполнитьНазначаемуюКомандуНаСервере(ИмяЭлемента, РезультатВыполнения)
	
	ДополнительныеОтчетыИОбработки.ВыполнитьНазначаемуюКомандуНаСервере(ЭтаФорма, ИмяЭлемента, РезультатВыполнения);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ВыполнитьНазначаемуюКоманду(Команда)
	
	Если НЕ ДополнительныеОтчетыИОбработкиКлиент.ВыполнитьНазначаемуюКомандуНаКлиенте(ЭтаФорма, Команда.Имя) Тогда
		РезультатВыполнения = Неопределено;
		ДополнительныеОтчетыИОбработкиВыполнитьНазначаемуюКомандуНаСервере(Команда.Имя, РезультатВыполнения);
		ДополнительныеОтчетыИОбработкиКлиент.ПоказатьРезультатВыполненияКоманды(ЭтаФорма, РезультатВыполнения);
	КонецЕсли;
	
КонецПроцедуры

// Конец СтандартныеПодсистемы.ДополнительныеОтчетыИОбработки

#Область Печать

&НаКлиенте
Процедура ВыполнитьКомандуПечатиЗавершение(Результат, Команда) Экспорт
	
	Если Результат = Неопределено ИЛИ ТипЗнч(Результат) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	ИдентификаторКоманды = Неопределено;
	Если ТипЗнч(Команда) = Тип("КомандаФормы") Тогда
		ОписаниеКоманды = ПодключаемыеКомандыКлиентПовтИсп.ОписаниеКоманды(Команда.Имя, Этаформа.ПараметрыПодключаемыхКоманд.АдресТаблицыКоманд);
		ИдентификаторКоманды = ОписаниеКоманды.Идентификатор;
	КонецЕсли;
	
	Если ИдентификаторКоманды ="питОП1_СПараметрами" Тогда
		ОписаниеКоманды.ДополнительныеПараметры.ДополнительныеПараметры.Вставить("СтруктураПараметровОП1", Результат);
	ИначеЕсли ИдентификаторКоманды ="ТехКартаРассчитываемая" Тогда
		ОписаниеКоманды.ДополнительныеПараметры.ДополнительныеПараметры.Вставить("СтруктураПараметровТехКарта", Результат);
	ИначеЕсли ИдентификаторКоманды ="СоставХЭХ" Тогда
		ОписаниеКоманды.ДополнительныеПараметры.ДополнительныеПараметры.Вставить("СтруктураПараметровХЭХ", Результат);
	ИначеЕсли ИдентификаторКоманды ="ТехТехнолКартаПарам" Тогда
		ОписаниеКоманды.ДополнительныеПараметры.ДополнительныеПараметры.Вставить("СтруктураПараметровТТК", Результат);
	
		//<< Каюмов А.А., ВиП, 25.09.2023, I-143. Печать этикеток из рецептур	
	ИначеЕсли ИдентификаторКоманды = "ВИП_ПФ_MXL_Этикетка" 
		ИЛИ ИдентификаторКоманды = "ВИП_ЭтикеткаПредпросмтор" Тогда
		ОписаниеКоманды.ДополнительныеПараметры.ДополнительныеПараметры.Вставить("СтруктураПараметровЭтикетка", Результат);
		
		//Быкодаров В.Е Печатная форма Калькуляционна карта ОП-1 (С параметрами)(С деревом) Вывод формы. Перенос кода Адагамова АР., НЭП 
	ИначеЕсли ИдентификаторКоманды = "НЭП_питОП1_СПараметрами" Тогда 
		ОписаниеКоманды.ДополнительныеПараметры.ДополнительныеПараметры.Вставить("НЭП_СтруктураПараметровОП1", Результат);
		//Быкодаров В.Е
		
	Иначе
		Возврат;
	КонецЕсли;
	//>>
	
	ПодключаемыеКомандыКлиент.ВыполнитьКоманду(ЭтотОбъект, Команда, Объект);
	
КонецПроцедуры

// СтандартныеПодсистемы.ПодключаемыеКоманды
&НаКлиенте
Процедура Подключаемый_ВыполнитьКоманду(Команда)
	
	ИдентификаторКоманды = Неопределено;
	Если ТипЗнч(Команда) = Тип("КомандаФормы") Тогда
		ОписаниеКоманды = ПодключаемыеКомандыКлиентПовтИсп.ОписаниеКоманды(Команда.Имя, Этаформа.ПараметрыПодключаемыхКоманд.АдресТаблицыКоманд);
		ИдентификаторКоманды = ОписаниеКоманды.Идентификатор;
	КонецЕсли;
	
	ИмяФормыПараметровПечати = "";
	
	Если ИдентификаторКоманды ="питОП1_СПараметрами" Тогда
		ИмяФормыПараметровПечати = "Документ.питРецептура.Форма.ФормаПараметрыПечатиОП1";
		
	ИначеЕсли ИдентификаторКоманды ="ТехКартаРассчитываемая" Тогда
		ИмяФормыПараметровПечати = "Документ.питРецептура.Форма.ФормаВводаРасчетногоКоличества";
		
	ИначеЕсли ИдентификаторКоманды ="СоставХЭХ" Тогда
		ИмяФормыПараметровПечати = "Документ.питРецептура.Форма.ФормаПечатиСоставаХЭХ";
		
	ИначеЕсли ИдентификаторКоманды ="ТехТехнолКартаПарам" Тогда
		ИмяФормыПараметровПечати = "Документ.питРецептура.Форма.ФормаПараметрыПечатиТТК";
		//<< Каюмов А.А., ВиП, 25.09.2023, I-143. Печать этикеток из рецептур   
	ИначеЕсли ИдентификаторКоманды ="ВИП_ПФ_MXL_Этикетка"  
		ИЛИ  ИдентификаторКоманды ="ВИП_ЭтикеткаПредпросмтор" Тогда  
		
		ИмяФормыПараметровПечати = "Документ.питРецептура.Форма.ВИП_ФормаПараметрыПечатиЭтикеток";
		//>>
		
		//Быкодаров В.Е Печатная форма Калькуляционна карта ОП-1 (С параметрами)(С деревом) Вывод формы. Перенос кода Адагамова АР., НЭП 
	ИначеЕсли ИдентификаторКоманды = "НЭП_питОП1_СПараметрами" Тогда 
		ИмяФормыПараметровПечати = "Документ.питРецептура.Форма.НЭП_ФормаПараметрыПечатиОП2"; 
		//Быкодаров В.Е
		
		
	КонецЕсли;
	
	Если ИмяФормыПараметровПечати <> "" Тогда
		ОбъектыПечати = питОтчетыКлиент.ОбъектыПечати(Объект);
		ПараметрыФормы = Новый Структура("МассивОбъектов", ОбъектыПечати);  //Команда.ОбъектыПечати);
		//<< Каюмов А.А., ВиП, 25.09.2023, I-143. Печать этикеток из рецептур
		//Было 
		//ПараметрыФормы = Новый Структура("МассивОбъектов", ОбъектыПечати);  //Команда.ОбъектыПечати);
		
		//Стало
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("МассивОбъектов", ОбъектыПечати);

		Если ИдентификаторКоманды ="ВИП_ПФ_MXL_Этикетка" Тогда  
			ПараметрыФормы.Вставить("СразуНаПечать", Истина); 
		Иначе 
			ПараметрыФормы.Вставить("СразуНаПечать", Ложь); 
		КонецЕсли;
		//>> 
		Оповещение = Новый ОписаниеОповещения("ВыполнитьКомандуПечатиЗавершение", ЭтотОбъект, Команда);
		ОткрытьФорму(ИмяФормыПараметровПечати, ПараметрыФормы,,,ВариантОткрытияОкна.ОтдельноеОкно,,Оповещение);
		
	Иначе
		ПодключаемыеКомандыКлиент.ВыполнитьКоманду(ЭтотОбъект, Команда, Объект);
	КонецЕсли;
	
КонецПроцедуры

