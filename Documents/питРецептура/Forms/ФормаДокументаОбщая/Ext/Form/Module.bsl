	//	
	//	УстановитьДоступностьКомандыВставки(ЭтотОбъект, Истина);
	//	
	//Иначе
	//	ОбщегоНазначенияБПКлиент.ОбработкаОповещенияФормыДокумента(ЭтаФорма, Объект.Ссылка, ИмяСобытия, Параметр, Источник);
	//КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьРецептуры(Команда)
	// Необходима оптимизация проверки, возможно, сделать запросом.
	
	МассивОшибок = Новый Массив;
	ДатаРецептуры = ?(ЗначениеЗаполнено(Объект.Ссылка), Объект.Дата, КонецДня(Объект.Дата));
	Если НЕ ЗначениеЗаполнено(Объект.ХозяйственнаяОперация) Тогда
		Объект.ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.питХозяйственныеОперации.РецептураПриготовление");
	КонецЕсли;
	
	Для Каждого СтрокаТабличнойЧасти Из Объект.Ингредиенты Цикл
		Если НЕ СтрокаТабличнойЧасти.ЭтоБлюдо Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяРецептура = ВернутьОсновнуюРецептуруСервер(ДатаРецептуры, СтрокаТабличнойЧасти.Номенклатура, СтрокаТабличнойЧасти.Характеристика);
		
		Если ЗначениеЗаполнено(НоваяРецептура) И НоваяРецептура <> СтрокаТабличнойЧасти.Рецептура Тогда
			ТекстСообщения ="Для блюда """+СтрокаТабличнойЧасти.Номенклатура+""" "+
				?(ЗначениеЗаполнено(СтрокаТабличнойЧасти.Рецептура), ?(СпособРасчетаРецептурыПоАктуальной, "указана не актуальная", "указана не основная"), "не указана")+" рецептура.";
			ПолеТаблицы = "Ингредиенты[" + Формат(СтрокаТабличнойЧасти.НомерСтроки - 1, "ЧН=0; ЧГ=") + "].Номенклатура";
			//ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, Объект.Ссылка, ПолеТаблицы, "Объект", );
			МассивОшибок.Добавить(Новый Структура("СтрокаТЧ,НоваяРецептура", СтрокаТабличнойЧасти, НоваяРецептура));
		КонецЕсли;
	КонецЦикла;
	
	Если МассивОшибок.Количество()>0 Тогда
		Если СпособРасчетаРецептурыПоАктуальной Тогда
			ТекстСообщения = "Внимание! Обнаружены вложенные рецептуры, не являющиеся актуальными.
						|Выполнить автоматическую подстановку актуальных рецептур, для используемых полуфабрикатов?";
		Иначе
			ТекстСообщения = "Внимание! Обнаружены вложенные рецептуры, не являющиеся основными для соотвествующих блюд.
						|Выполнить автоматическую подстановку основных рецептур, для используемых полуфабрикатов?";
			КонецЕсли;
					
			
		ПоказатьВопрос(Новый ОписаниеОповещения("ПроверитьРецептуры_Завершение", ЭтотОбъект, Новый Структура("МассивОшибок", МассивОшибок)), ТекстСообщения, РежимДиалогаВопрос.ДаНет,, КодВозвратаДиалога.Да);
	Иначе
		ПоказатьПредупреждение(,"Не найдено ошибок в заполнении рецептур.");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ВернутьОсновнуюРецептуруСервер(ДатаРецептуры, Номенклатура, Характеристика)
	
	ТекПодразделения = питПроизводство.НайтиПодразделенияПоРазрешенным(Подразделения.Выгрузить());
	НоваяРецептура = питПроизводство.ВернутьОсновнуюРецептуру(Номенклатура, Характеристика, Объект.ХозяйственнаяОперация,
	ДатаРецептуры, СпособРасчетаРецептурыПоАктуальной, , Объект.Организация,,,ТекПодразделения);
	Возврат НоваяРецептура;
	
КонецФункции

&НаКлиенте
Процедура ПроверитьРецептуры_Завершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	МассивОшибок = ДополнительныеПараметры.МассивОшибок;
	
	Если РезультатВопроса=КодВозвратаДиалога.Да Тогда
		Для Каждого СтруктураОшибки Из МассивОшибок Цикл
			СтруктураОшибки.СтрокаТЧ.Рецептура = СтруктураОшибки.НоваяРецептура;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВводСтрокиДиалогом(Команда)
	Элементы.ТоварыВводСтрокиДиалогом.Пометка = НЕ Элементы.ТоварыВводСтрокиДиалогом.Пометка;
КонецПроцедуры

&НаКлиенте
// Процедура открывает модально дополнительную форму строки, с необходимым заполнением.
// После закрытия формы строки заполняет данные в таблице товаров в документе.
//
// Параметры:
//  Отказ - булево, Истина - отмена стандартного редактирования строки, и открытие формы строки.
//  ТекущиеДанные - строка таблицы, данные из текущий строки.
//  Копирование - Неопределено - редактирование текущей строки, Ложь - добавление новой строки, Истина - добавление копированием.
// 
Процедура РедактироватьСтрокуВДиалоге(ТекущиеДанные, Копирование, НоваяСтрока = Ложь)
	
	ПараметрыСтроки = Новый Структура("Номенклатура,СпособАвтовыбораНоменклатуры, Характеристика, СтатьяКалькуляции, Упаковка, КоличествоУпаковокБрутто, КоличествоУпаковокНетто, КоличествоУпаковокВыход,
	|КоличествоБрутто, КоличествоНетто, КоличествоВыход, Рецептура, Специя,
	|ЗапретитьЗамены, Замена, ХарактеристикаЗамены,КоэффициентЗамены, ПроцентПотерьПриГорячейОбработке, ПроцентПотерьПриХолоднойОбработке,
	|ЭтоБлюдо, ЭтоТовар, Иконка, СпособРасчетаРецептурыПоАктуальной, ИскатьПоВсемОрганизациям,
	//+АвтовыборНоменклатуры
	|НоменклатураСтрокой, ХарактеристикаСтрокой,
	//-АвтовыборНоменклатуры
	|ДокументХозяйственнаяОперация, ДокументДата, ДокументНоменклатура, ДокументХарактеристика, ДокументОрганизация, ДокументСсылка, АдресВидыОбработки, АдресПотериХЭХ, ИдентификаторСтроки, КлючСвязи, Копирование, НоваяСтрока, ПрименятьМеханизмВидовОбработки, ПроцентСебестоимости, РасчетПоФормуле, СуффиксКолонкиКоличествДляФормул");
	Если НЕ Копирование = Ложь Тогда
		ЗаполнитьЗначенияСвойств(ПараметрыСтроки, ТекущиеДанные);
	КонецЕсли;
	
	ПараметрыСтроки.ДокументХозяйственнаяОперация  = Объект.ХозяйственнаяОперация;
	ПараметрыСтроки.ДокументДата         = Объект.Дата;
	ПараметрыСтроки.ДокументНоменклатура = Объект.Номенклатура;
	ПараметрыСтроки.ДокументХарактеристика = Объект.Характеристика;
	ПараметрыСтроки.ДокументОрганизация  = Объект.Организация;
	ПараметрыСтроки.ДокументСсылка       = Объект.Ссылка;
	ПараметрыСтроки.СпособРасчетаРецептурыПоАктуальной = СпособРасчетаРецептурыПоАктуальной;
	ПараметрыСтроки.ИскатьПоВсемОрганизациям           = ИскатьПоВсемОрганизациям;
	
	// Виды обработки
	ПараметрыСтроки.АдресВидыОбработки 				= ПолучитьАдресВидовОбработки();
	ПараметрыСтроки.АдресПотериХЭХ					= ПолучитьАдресПотериХЭХ();
	ПараметрыСтроки.Вставить("АдресТекПодразделения");
	ПараметрыСтроки.АдресТекПодразделения		= ПолучитьАдресРазрешенныеПодразделения();
	ПараметрыСтроки.Копирование						= ?(Копирование = Истина, Копирование, Ложь);
	ПараметрыСтроки.НоваяСтрока						= НоваяСтрока;
	ПараметрыСтроки.ПрименятьМеханизмВидовОбработки	= ПрименятьМеханизмВидовОбработки;
	
	//+ПараметризацияРецептур
	ПараметрыСтроки.СуффиксКолонкиКоличествДляФормул = СуффиксКолонкиКоличествДляФормул;
	//-ПараметризацияРецептур
	
	НовыеПараметрыСтроки = Неопределено;
	
	ОткрытьФорму("Документ.питРецептура.Форма.ФормаСтроки", ПараметрыСтроки, ЭтаФорма,,,, Новый ОписаниеОповещения("РедактироватьСтрокуВДиалоге_Завершение", ЭтотОбъект, Новый Структура("Копирование, ТекущиеДанные", Копирование, ТекущиеДанные)), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте
Процедура РедактироватьСтрокуВДиалоге_Завершение(Результат, ДополнительныеПараметры) Экспорт
	
	Копирование = ДополнительныеПараметры.Копирование;
	ТекущиеДанные = ДополнительныеПараметры.ТекущиеДанные;
	
	
	НовыеПараметрыСтроки = Результат;
	
	Если ЗначениеЗаполнено(НовыеПараметрыСтроки) И ТипЗнч(НовыеПараметрыСтроки) = Тип("Структура") Тогда
		
		Если Копирование = Неопределено Тогда
			ЗаполнитьЗначенияСвойств(ТекущиеДанные, НовыеПараметрыСтроки);
		Иначе
			
			НоваяСтрока = Объект.Ингредиенты.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, НовыеПараметрыСтроки);
			Элементы.Ингредиенты.ТекущаяСтрока = НоваяСтрока.ПолучитьИдентификатор();
		КонецЕсли;
		
		Если ПрименятьМеханизмВидовОбработки Тогда
			Если НовыеПараметрыСтроки.Свойство("АдресВидыОбработки") Тогда
				ЗагрузитьВидыОбработкиПоАдресу(НовыеПараметрыСтроки.АдресВидыОбработки);
				Модифицированность = Истина;
			КонецЕсли;
			Если НовыеПараметрыСтроки.Свойство("АдресПотериХЭХ") Тогда
				ЗагрузитьПотериХЭХПоАдресу(НовыеПараметрыСтроки.АдресПотериХЭХ);
				Модифицированность = Истина;
			КонецЕсли;
			УстановитьСтрокуИнгредиентыВидыОбработки();
		КонецЕсли;
		
		ИсключитьДействия = Новый Массив;
		ИсключитьДействия.Добавить("ПроверитьЗаполнитьУпаковкуПоВладельцу");
		ТаблицаНоменклатураПриИзменении("Ингредиенты", ИсключитьДействия);
		
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Функция ВернутьКонстанту(Константа)
	УстановитьПривилегированныйРежим(Истина);
	Возврат Константы[Константа].Получить();
	УстановитьПривилегированныйРежим(Ложь);
КонецФункции


