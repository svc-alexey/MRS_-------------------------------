&НаКлиенте
Процедура ПодразделенияПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	Если Не Копирование И НоваяСтрока Тогда
		ТекДанные = Элемент.ТекущиеДанные;
		Если НЕ ТекДанные = Неопределено Тогда
			Элемент.ТекущиеДанные.ИдентификаторСтроки = Новый УникальныйИдентификатор;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПодразделенияВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ТекДанные = Элемент.ТекущиеДанные;
	Если НЕ ТекДанные = Неопределено 
		И НЕ Элемент.ТекущийЭлемент = Неопределено
		И Элемент.ТекущийЭлемент = Элементы.ПодразделенияПодразделение Тогда
		
		СтандартнаяОбработка = Ложь;
		Попытка
			ПоказатьЗначение(, ТекДанные.Подразделение);
		Исключение
		КонецПопытки;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПодразделенияОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если ТипЗнч(ВыбранноеЗначение) = Тип("СправочникСсылка.СтруктураПредприятия")
		И ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		
		ТекСтрокаПодразделения = Неопределено;
		НайденныеПодразделения = Подразделения.НайтиСтроки(Новый Структура("Подразделение", ВыбранноеЗначение));
		Если НайденныеПодразделения.Количество() Тогда
			ТекСтрокаПодразделения = НайденныеПодразделения[0];
		Иначе
			ТекСтрокаПодразделения = Подразделения.Добавить();
			ТекСтрокаПодразделения.Подразделение = ВыбранноеЗначение;
			ТекСтрокаПодразделения.ВключаяПодчиненные = Истина;
			ТекСтрокаПодразделения.ИдентификаторСтроки = Новый УникальныйИдентификатор;
			ТекСтрокаЦеха = Цеха.Добавить();
			ТекСтрокаЦеха.ЦеховаяКладовая = ПредопределенноеЗначение("Справочник.Склады.ПустаяСсылка");
			ТекСтрокаЦеха.ИдентификаторПодразделения = ТекСтрокаПодразделения.ИдентификаторСтроки;
		КонецЕсли;
		
		ОбновитьОтборСтрокТаблицыЦехов();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПодразделенияПередУдалением(Элемент, Отказ)
	ТекДанные = Элемент.ТекущиеДанные;
	Если НЕ ТекДанные = Неопределено Тогда
		НайденныеЦеха = Цеха.НайтиСтроки(Новый Структура("ИдентификаторПодразделения", ТекДанные.ИдентификаторСтроки));
		Для каждого НайденныйЦех Из НайденныеЦеха Цикл
			Цеха.Удалить(НайденныйЦех);
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьОтборСтрокТаблицыЦехов()
	
	ТекДанные = Элементы.Подразделения.ТекущиеДанные;
	Если ТекДанные <> Неопределено Тогда
		Элементы.Цеха.ОтборСтрок = Новый ФиксированнаяСтруктура("ИдентификаторПодразделения", ТекДанные.ИдентификаторСтроки);
	Иначе
		Элементы.Цеха.ОтборСтрок = Новый ФиксированнаяСтруктура("ИдентификаторПодразделения", "xxx");/// Скроем
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПодразделенияВключаяПодчиненныеПриИзменении(Элемент)
	
	ТекДанные = Элементы.Подразделения.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ТекДанные.ВключаяПодчиненные Тогда
		Возврат;
	КонецЕсли;
	
	ЦехаПоДодразделению = Цеха.НайтиСтроки(Новый Структура("ИдентификаторПодразделения", ТекДанные.ИдентификаторСтроки));
	Если ЦехаПоДодразделению.Количество() Тогда
		
		Оповещение = Новый ОписаниеОповещения("ВключаяПодчиненныеЗавершение", ЭтотОбъект,Новый Структура("ЦехаПоДодразделению, ИдентификаторПодразделения", ЦехаПоДодразделению, ТекДанные.ИдентификаторСтроки));
		ПоказатьВопрос(Оповещение, "Список разрешенных цеховых кладовых для подразделения будет очищен, продолжить?", РежимДиалогаВопрос.ОКОтмена);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВключаяПодчиненныеЗавершение(Результат, Параметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.ОК Тогда
		Для каждого ТекЦех Из Параметры.ЦехаПоДодразделению Цикл
			Цеха.Удалить(ТекЦех);
		КонецЦикла;
	КонецЕсли;
	
	// Добавляем пустой цех, что означает "Все цеха"
	ПустойЦех = Цеха.Добавить();
	ПустойЦех.ИдентификаторПодразделения = Параметры.ИдентификаторПодразделения;
	ПустойЦех.ЦеховаяКладовая = ПредопределенноеЗначение("Справочник.Склады.ПустаяСсылка");
	
КонецПроцедуры

