&НаКлиенте
Процедура УточнитьХарактеристики(Команда)
	
	СтруктураПараметров = Новый Структура();
	СтруктураПараметров.Вставить("АдресУточненияАвтовыбора"	, УпаковатьУточненияАвтовыбора());
	СтруктураПараметров.Вставить("Ссылка"					, ПредопределенноеЗначение("Документ.питВыпускБлюд.ПустаяСсылка"));
	СтруктураПараметров.Вставить("Организация"				, Объект.Организация);
	СтруктураПараметров.Вставить("Подразделение"			, ?(ЗначениеЗаполнено(ПодразделениеОтборПоСвойствам), ПодразделениеОтборПоСвойствам, Объект.Подразделение));
	СтруктураПараметров.Вставить("Дата"						, Объект.Дата);
	СтруктураПараметров.Вставить("Склад"					, Объект.ЦеховаяКладовая);
	СтруктураПараметров.Вставить("ЗаголовокКнопки"			, "Перенести в документ");
	
	ОткрытьФорму("ОбщаяФорма.питФормаПодбораХарактеристик", СтруктураПараметров, ЭтаФорма,,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаВыбораПодборХарактеристикНаСервере(ВыбранноеЗначение)
	
	Объект.УточненияАвтовыбора.Загрузить(РаспаковатьУточненияАвтовыбора(ВыбранноеЗначение));
	ПолучитьСписокХимикоэнергетическихПоказателей();
	
КонецПроцедуры

&НаСервере
Процедура ИнициализироватьУточненияАвтовыбора()
	
	Если Объект.Ссылка.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	Если ХарактеристикиИспользуются И НЕ ЗначениеЗаполнено(Объект.Характеристика) Тогда
		НайденныеУточнения = Объект.УточненияАвтовыбора.НайтиСтроки(Новый Структура("Номенклатура, Рецептура, КлючРодителя", Объект.Номенклатура, Объект.Ссылка, ""));
		Если (НайденныеУточнения.Количество() И НайденныеУточнения[0].Характеристика <> Объект.Характеристика) 
			ИЛИ НЕ НайденныеУточнения.Количество() Тогда
			Объект.УточненияАвтовыбора.Очистить();
			
			НовУточнение = Объект.УточненияАвтовыбора.Добавить();
			НовУточнение.Ключ = Новый УникальныйИдентификатор;
			НовУточнение.Номенклатура = Объект.Номенклатура;
			НовУточнение.Характеристика = Объект.Характеристика;
			НовУточнение.Рецептура = Объект.Ссылка;
			НовУточнение.ОшибкаАвтовыбора = Истина;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти


