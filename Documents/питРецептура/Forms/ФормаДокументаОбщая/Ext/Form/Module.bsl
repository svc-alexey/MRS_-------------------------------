&НаСервере
Процедура УстановитьУсловноеОформление()
	
	//УсловноеОформление.Элементы.Очистить();
	НоменклатураСервер.УстановитьУсловноеОформлениеЕдиницИзмерения(ЭтаФорма, "ТоварыНоменклатураЕдиницаИзмерения", "Объект.Ингредиенты.Упаковка");
	
	питОбщегоНазначенияКлиентСервер.ОтобразитьИнформациюОХарактеристике(Элементы.Характеристика, ХарактеристикиИспользуются);
	
	//+АвтовыборНоменклатуры
	Если ИспользоватьПараметризациюРесурсныхСпецификаций Тогда
		питУправлениеДаннымиОбИзделиях.УстановитьУсловноеОформлениеАвтовыбораНоменклатуры(ЭтаФорма, "Объект", "Ингредиенты");
	Иначе
	//-АвтовыборНоменклатуры
		НоменклатураСервер.УстановитьУсловноеОформлениеХарактеристикНоменклатуры(ЭтаФорма, 
			"ИнгредиентыХарактеристика",
			"Объект.Ингредиенты.ХарактеристикиИспользуются");
	КонецЕсли;
	
	НоменклатураСервер.УстановитьУсловноеОформлениеХарактеристикНоменклатуры(ЭтаФорма, 
		"ПобочныеИзделияХарактеристика",
		"Объект.ПобочныеИзделия.ХарактеристикиИспользуются");
		
	НоменклатураСервер.УстановитьУсловноеОформлениеХарактеристикНоменклатуры(ЭтаФорма, 
		"ИнгредиентыХарактеристикаЗамены",
		"Объект.Ингредиенты.ХарактеристикиЗаменыИспользуются");
	
	//+ПараметризацияРецептур
	питУправлениеДаннымиОбИзделиях.УстановитьУсловноеОформлениеОтбораПоСвойствамИРасчетаПоФормулам(
		ЭтаФорма,
		"Объект",
		"Ингредиенты",
		"Количество");
	питУправлениеДаннымиОбИзделиях.УстановитьУсловноеОформлениеОтбораПоСвойствамИРасчетаПоФормулам(
		ЭтаФорма,
		"Объект",
		"Ингредиенты",
		"КоличествоНетто");
	питУправлениеДаннымиОбИзделиях.УстановитьУсловноеОформлениеОтбораПоСвойствамИРасчетаПоФормулам(
		ЭтаФорма,
		"Объект",
		"Ингредиенты",
		"КоличествоВыход");
	//-ПараметризацияРецептур
	
	//Пустая строка в ТЧ "Цеховые кладовые"
	ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
	ПолеЭлемента = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ЦехаЦеховаяКладовая.Имя);
	ОтборЭлемента = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Цеха.ЦеховаяКладовая");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.НеЗаполнено;
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ТекстЗапрещеннойЯчейкиЦвет);
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = '<все цеховые кладовые>'"));
	
КонецПроцедуры

&НаСервере
Процедура ПодготовитьФормуНаСервере()
	
	СпособРасчетаРецептурыПоАктуальной = питДокументы.ОпределитьСпособРасчетаРецептурыПоАктуальной();
	ПредыдущееКоличество = Объект.КоличествоУпаковок;
	
	ИскатьПоВсемОрганизациям = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("ИскатьРецептурыПоВсемОрганизациям");
	Если НЕ СпособРасчетаРецептурыПоАктуальной И НЕ ИскатьПоВсемОрганизациям Тогда
		НоваяСвязьПараметровВыбора = Новый СвязьПараметраВыбора("Отбор.Организация", "Объект.Организация");
		питОбщегоНазначения.ЗаменитьСвязьПараметровВыбора(Элементы.ТоварыРецептура, "Отбор.Организация", НоваяСвязьПараметровВыбора)
	КонецЕсли;
	
	ЗаполнитьДобавленныеКолонкиТаблиц();
	
	УстановитьПараметрыВыбораНоменклатуры();
	
	////ОбщептЕРП!!!
	//Элементы.ТоварыВводСтрокиДиалогом.Пометка = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("РецептураВводСтрокиДиалогом");
	
	// Для всех
	УправлениеФормой(ЭтаФорма);
	
	// Проверка буфера обмена на наличие скопированных строк
	////ОбщептЕРП!!!
	//УстановитьДоступностьКомандыВставки(ЭтотОбъект, Не ОбщегоНазначения.ПустойБуферОбмена());
	
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	питИзменениеОтраслевыхФормСервер.ПриСозданииНаСервереВНачале(ЭтаФорма, Отказ, СтандартнаяОбработка);
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Объект", Объект);
	ДополнительныеПараметры.Вставить("ИмяЭлементаДляРазмещения", "ГруппаДополнительныеРеквизиты");
	УправлениеСвойствами.ПриСозданииНаСервере(ЭтотОбъект, ДополнительныеПараметры);
	
	ОбновлениеИнформационнойБазы.ПроверитьОбъектОбработан(Объект, ЭтотОбъект);
	
	//+ПараметризацияРецептур
	
	ИспользоватьПараметризациюРесурсныхСпецификаций = 
		ПолучитьФункциональнуюОпцию("ИспользоватьПараметризациюРесурсныхСпецификаций");
	ЭтоУправлениеПредприятием = питПроизводствоПовтИсп.ПолучитьИмяОсновнойКонфигурации() = "УправлениеПредприятием";
	
	ВидКоличествДляРасчета = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питКоличествоДляРасчетаПоФормулеВРецептурах");
	Если НЕ ЗначениеЗаполнено(ВидКоличествДляРасчета) Тогда
		ВидКоличествДляРасчета = Перечисления.питВидыКоличеств.КоличествоБрутто;
	КонецЕсли;
	СуффиксКолонкиКоличествДляФормул = питОбщегоНазначенияКлиентСервер.СуффиксКолонкиКоличествПоВидуКоличеств(ВидКоличествДляРасчета);
	//-ПараметризацияРецептур
	
	УстановитьХарактеристикиИспользуютсяВШапке();
	
	УстановитьУсловноеОформление();
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	// СтандартныеПодсистемы.ВерсионированиеОбъектов
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов
	
	Справочники.УпаковкиЕдиницыИзмерения.ОтобразитьИнформациюОЕдиницеХранения(Объект.Номенклатура, Элементы.Упаковка);
	
	// Виды обработки.
	ЭтоРазделка = Объект.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.РецептураРазделка;
	питИспользоватьВидыОбработкиСырья = Константы.питИспользоватьВидыОбработкиСырья.Получить();
	ПрименятьМеханизмВидовОбработки = питИспользоватьВидыОбработкиСырья И НЕ ЭтоРазделка;
	
	Если Параметры.Ключ.Пустая() Тогда
		Если НЕ ЗначениеЗаполнено(Объект.СтатьяКалькуляции) Тогда
			Объект.СтатьяКалькуляции = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("СтатьяКалькуляцииПоУмолчанию");
		КонецЕсли;
		
		ПодготовитьФормуНаСервере();
	КонецЕсли;
	
	Элементы.ТоварыВводСтрокиДиалогом.Пометка = Истина;
	
	ЗаполнитьСлужебныеРеквизитыПоНоменклатуре();
	
	//+ПараметризацияРецептур
	ОбновитьКолонкуУсловияОтбораПоСвойствам();
	//-ПараметризацияРецептур
	
	ЗагрузитьДанныеПоПодразделениям();
	
	Элементы.ЦеховаяКладовая.Видимость = Константы.питФормироватьДокументыПроизводства22.Получить();
	
	питПроизводство.УстановитьВидимостьНадписиРазныеЕдиницы(Объект, Элементы, "Ингредиенты");
	
	//+ПараметризацияРецептур
	ПодразделениеОтборПоСвойствам = Объект.Подразделение;
	//-ПараметризацияРецептур
	
	//+АвтовыборНоменклатуры
	ИнициализироватьУточненияАвтовыбора();
	//-АвтовыборНоменклатуры
	
	СпособРасчетаКалорийностиКонстанта = ВернутьКонстанту("питСпособРасчетаКалорийности");
	
	ЕдиницаИзмеренияВыходаВРецептурах = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питЕдиницаИзмеренияВыходаВРецептурах");
	Элементы.ВыходВес.Заголовок = "Выход, " + ?(ЗначениеЗаполнено(ЕдиницаИзмеренияВыходаВРецептурах)
		,ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЕдиницаИзмеренияВыходаВРецептурах, "Представление"), "г");
	
	ОбновитьЗаголовокФормы();
	
	//<< Ситдикова А.К., ВиП, 19.19.2023. I-143. Печать этикеток из рецептур
	ВИП_ДоработатьФорму();
	//>>

КонецПроцедуры

&НаСервере
Процедура УстановитьХарактеристикиИспользуютсяВШапке()
	
	Если ЗначениеЗаполнено(Объект.Номенклатура) Тогда
		ХарактеристикиИспользуются = питОбщегоНазначения.ХарактеристикиИспользуются(Объект.Номенклатура);
	Иначе
		ХарактеристикиИспользуются = Ложь;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	УправлениеСвойствами.ПриЧтенииНаСервере(ЭтаФорма, ТекущийОбъект);
	
	// Обработчик механизма "ДатыЗапретаИзменения"
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтаФорма, ТекущийОбъект);
	
	// СтандартныеПодсистемы.УправлениеДоступом
	Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.УправлениеДоступом") Тогда
		МодульУправлениеДоступом = ОбщегоНазначения.ОбщийМодуль("УправлениеДоступом");
		МодульУправлениеДоступом.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	КонецЕсли;
	// Конец СтандартныеПодсистемы.УправлениеДоступом
	
	// Виды обработки.
	ЭтоРазделка = Объект.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.РецептураРазделка;
	питИспользоватьВидыОбработкиСырья = Константы.питИспользоватьВидыОбработкиСырья.Получить();
	ПрименятьМеханизмВидовОбработки = питИспользоватьВидыОбработкиСырья И НЕ ЭтоРазделка;
	
	ИспользоватьПараметризациюРесурсныхСпецификаций = 
		ПолучитьФункциональнуюОпцию("ИспользоватьПараметризациюРесурсныхСпецификаций");
	ЭтоУправлениеПредприятием = питПроизводствоПовтИсп.ПолучитьИмяОсновнойКонфигурации() = "УправлениеПредприятием";
	
	ПодготовитьФормуНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	//Если питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("РецептураВводСтрокиДиалогом") <> Элементы.ТоварыВводСтрокиДиалогом.Пометка Тогда
	//	ОбщегоНазначенияБПВызовСервера.УстановитьЗначениеПоУмолчанию("РецептураВводСтрокиДиалогом", Элементы.ТоварыВводСтрокиДиалогом.Пометка);
	//КонецЕсли;
	
	ЗаполнитьДобавленныеКолонкиТаблиц();
	
	ЗаполнитьСлужебныеРеквизитыПоНоменклатуре();
	
	//+ПараметризацияРецептур
	ОбновитьКолонкуУсловияОтбораПоСвойствам();
	//-ПараметризацияРецептур
	
	//+АвтовыборНоменклатуры
	ИнициализироватьУточненияАвтовыбора();
	//-АвтовыборНоменклатуры
	
	ОбновитьЗаголовокФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
		Возврат;
	КонецЕсли;
	
	// Проверить и очистить значения в не нужных колоках
	Для Каждого СтрокаТаблицы Из Объект.Ингредиенты Цикл
		Если НЕ СтрокаТаблицы.Специя Тогда 
			Если СтрокаТаблицы.КоличествоУпаковокБрутто <> Окр(СтрокаТаблицы.КоличествоУпаковокБрутто, 3) Тогда
				СтрокаТаблицы.КоличествоУпаковокБрутто = Окр(СтрокаТаблицы.КоличествоУпаковокБрутто, 3);
			КонецЕсли;
			Если СтрокаТаблицы.КоличествоУпаковокНетто <> Окр(СтрокаТаблицы.КоличествоУпаковокНетто, 3) Тогда
				СтрокаТаблицы.КоличествоУпаковокНетто = Окр(СтрокаТаблицы.КоличествоУпаковокНетто, 3);
			КонецЕсли;
			Если СтрокаТаблицы.КоличествоУпаковокВыход <> Окр(СтрокаТаблицы.КоличествоУпаковокВыход, 3) Тогда
				СтрокаТаблицы.КоличествоУпаковокВыход = Окр(СтрокаТаблицы.КоличествоУпаковокВыход, 3);
			КонецЕсли;
		КонецЕсли;
		Если НЕ СтрокаТаблицы.ЭтоБлюдо Тогда
			Если ЗначениеЗаполнено(СтрокаТаблицы.Рецептура) Тогда
				СтрокаТаблицы.Рецептура = Неопределено;
			КонецЕсли;
		КонецЕсли;
		Если СтрокаТаблицы.ЗапретитьЗамены ИЛИ НЕ СтрокаТаблицы.ЭтоТовар ИЛИ СтрокаТаблицы.Специя Тогда
			Если ЗначениеЗаполнено(СтрокаТаблицы.Замена) ИЛИ СтрокаТаблицы.КоэффициентЗамены<>0 Тогда
				СтрокаТаблицы.Замена = Неопределено;
				СтрокаТаблицы.ХарактеристикаЗамены = Неопределено;
				СтрокаТаблицы.КоэффициентЗамены = 0;
			КонецЕсли;
		ИначеЕсли НЕ ЗначениеЗаполнено(СтрокаТаблицы.Замена) И СтрокаТаблицы.КоэффициентЗамены<>0 Тогда
			СтрокаТаблицы.КоэффициентЗамены = 0;
		КонецЕсли;
		Если СтрокаТаблицы.ЗапретитьЗамены И НЕ СтрокаТаблицы.ЭтоТовар Тогда
			СтрокаТаблицы.ЗапретитьЗамены = Ложь;
		КонецЕсли;
	КонецЦикла;
	
	// Если способ расчета калорийности не был заполнен пользователем, то он будет определен тут.
	ОпределитьСпособРасчетаКалорийности(Ложь);

	//>>Швецов. ERP-4852. 05.05.2025. Запрет изменения используемых рецептур
	Если НЕ MRS_Сервер.РольДоступнаВызовСервера("АдминистраторСистемы") и ЗначениеЗаполнено(Объект.Ссылка) Тогда
		
		MRS_ИзменениеРарешено = MRS_ПроверитьВозможностьРедактирования(Отказ);	
		
		Если НЕ MRS_ИзменениеРарешено Тогда					
			Если НЕ ЗначениеЗаполнено(Объект.ДатаКонца) Тогда		
				Режим = РежимДиалогаВопрос.ДаНетОтмена;
				Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопросаПроверкиРецептуры", ЭтаФорма);
				ПоказатьВопрос(Оповещение,
				               "Данная рецептура используется в документах Выпуска блюд за последние 3 месяца.
							   |Текущая рецептура будет скопирована и станет не актуальной с текущей даты.
							   |Продолжить?",
				               Режим,
				               0);
			Иначе
				ОбщегоНазначенияКлиент.СообщитьПользователю("Изменять текущий документ запрещено!
															|Установлена конечная дата актуальности!
															|Обратитесь к администратору!",,,,Истина);
			КонецЕсли;
		КонецЕсли;		
	КонецЕсли;
	//<<Швецов. ERP-4852. 05.05.2025. Запрет изменения используемых рецептур
КонецПроцедуры                                                          

//>>Швецов. ERP-4852. 05.05.2025. Запрет изменения используемых рецептур
&НаСервере
Функция MRS_ПроверитьВозможностьРедактирования(Отказ)
	
	РецепутраОбъект = Объект.Ссылка.ПолучитьОбъект();
	ТЧИнгридиентыОбъект = РецепутраОбъект.Ингредиенты.Выгрузить();
	ТЧИнгридиентыФорма = РеквизитФормыВЗначение("Объект.Ингредиенты").Выгрузить();
	
	MRS_ИзменениеРарешено = MRS_Сервер.MRS_ПроверитьДействиеРецептуры(РецепутраОбъект, ТЧИнгридиентыОбъект, ТЧИнгридиентыФорма);
	
	Если MRS_ИзменениеРарешено Тогда
		Возврат Истина;			
	Иначе
		Отказ = Истина;
		Возврат Ложь;
	КонецЕсли;

КонецФункции

&НаКлиенте
Процедура ПослеЗакрытияВопросаПроверкиРецептуры(Результат, ПараметрыФормы) Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда
		// Устанавливаем дату конца для текущего документа на сервере
		ОписаниеОшибки = "";
		Если НЕ УстановитьДатуКонцаНаСервере(Объект.Ссылка, КонецДня(ТекущаяДата()), ОписаниеОшибки) Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю("Ошибка при установке даты конца: " + ОписаниеОшибки);
			Возврат;
		КонецЕсли;
		
		// Вызов серверной процедуры для создания нового документа
		РезультатКопирования = MRS_СкопироватьРецептуруНаСервере();
		
		Если РезультатКопирования.Успех Тогда
			// Открытие формы нового документа
			ПараметрыФормы = Новый Структура("Ключ", РезультатКопирования.НоваяРецептура);
			
			// Сброс модифицированности, чтобы избежать вопроса о сохранении
			ЭтаФорма.Модифицированность = Ложь;
	
			// Закрытие текущего документа
			ЭтаФорма.Закрыть();
			
			ОткрытьФорму("Документ.питРецептура.Форма.ФормаДокументаОбщая", ПараметрыФормы,,,,,,);
		Иначе
			ОбщегоНазначенияКлиент.СообщитьПользователю("Ошибка при копировании рецептуры: " + 
			                                           РезультатКопирования.ОписаниеОшибки);
		КонецЕсли;
		
	ИначеЕсли Результат = КодВозвратаДиалога.Нет Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;;
КонецПроцедуры

// Устанавливает дату конца для указанного документа.
//
// Параметры:
//   Ссылка - ДокументСсылка.питРецептура - Ссылка на документ.
//   ДатаКонца - Дата - Новая дата конца.
//   ОписаниеОшибки - Строка - Описание ошибки, если операция не удалась.
//
// Возвращаемое значение:
//   Булево - Истина, если операция успешна, Ложь в противном случае.
//
&НаСервере
Функция УстановитьДатуКонцаНаСервере(Ссылка, ДатаКонца, ОписаниеОшибки)
	
	Попытка
		// Получаем объект документа
		ДокументОбъект = Ссылка.ПолучитьОбъект();
		Если ДокументОбъект = Неопределено Тогда
			ОписаниеОшибки = "Документ не найден.";
			Возврат Ложь;
		КонецЕсли;
		
		// Устанавливаем только дату конца
		ДокументОбъект.ДатаКонца = ДатаКонца;
		
		// Записываем документ
		ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
		
		Возврат Истина;
		
	Исключение
		ОписаниеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат Ложь;
	КонецПопытки;
	
КонецФункции

// Копирует данные документа из структуры формы в новый документ и изменяет дату актуальности.
//
// Параметры:
//   Объект - ДанныеФормыСтруктура - Данные формы текущего документа.
//
// Возвращаемое значение:
//   Структура - Результат копирования:
//     * Успех - Булево - Признак успешного выполнения.
//     * НоваяРецептура - ДокументСсылка.питРецептура - Ссылка на новый документ.
//     * ОписаниеОшибки - Строка - Описание ошибки, если копирование не удалось.
//
&НаСервере
Функция MRS_СкопироватьРецептуруНаСервере()
	
	Результат = Новый Структура("Успех, НоваяРецептура, ОписаниеОшибки", Ложь, Неопределено, "");
	
	НачатьТранзакцию();
	Попытка
		// Создаем новый документ
		НовыйДокумент = Документы.питРецептура.СоздатьДокумент();
		
		// Копируем основные реквизиты из структуры формы
		ЗаполнитьЗначенияСвойств(НовыйДокумент, Объект,, "Ссылка, Проведен, ПометкаУдаления, Номер, Ответственный");
		
		// Устанавливаем новую дату документа
		НовыйДокумент.Дата = КонецДня(ТекущаяДатаСеанса()) + 1;
		НовыйДокумент.ДатаНачала = КонецДня(ТекущаяДатаСеанса()) + 1;
		
		НовыйДокумент.ДокументОснование = Объект.Ссылка;
		НовыйДокумент.Ответственный = Пользователи.ТекущийПользователь();
		// Копируем табличные части
		Для Каждого ТабличнаяЧасть Из Объект.Ссылка.Метаданные().ТабличныеЧасти Цикл
			ИмяТЧ = ТабличнаяЧасть.Имя;
			Если Объект.Свойство(ИмяТЧ) Тогда
				НовыйДокумент[ИмяТЧ].Очистить();
				Для Каждого СтрокаТЧ Из Объект[ИмяТЧ] Цикл
					НоваяСтрока = НовыйДокумент[ИмяТЧ].Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
		
		// Записываем новый документ
		НовыйДокумент.Записать(РежимЗаписиДокумента.Запись);
		
		// Формируем результат
		Результат.Успех = Истина;
		Результат.НоваяРецептура = НовыйДокумент.Ссылка;
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		Результат.ОписаниеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;
	
	Возврат Результат;	
КонецФункции
//<<Швецов. ERP-4852. 05.05.2025. Запрет изменения используемых рецептур

// Устанавливает способ расчета калорийности и определяет формулу расчета при условии, что этого не было сделано заранее.
//
// Параметры:
//  УстанавливатьМодифицированность	 - Булево - Определяет необходимость установки флага модифицированности формы при смене формулы расчета.
//
&НаКлиенте
Процедура ОпределитьСпособРасчетаКалорийности(УстанавливатьМодифицированность = Истина)
	
	Если Объект.СпособРасчетаКалорийности.Пустая() Тогда
		Объект.СпособРасчетаКалорийности = СпособРасчетаКалорийностиКонстанта;
		СпособРасчетаКалорийностиПриИзменении(Неопределено, Ложь, УстанавливатьМодифицированность);
		//Модифицированность = УстанавливатьМодифицированность;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ХозяйственнаяОперацияПриИзменении(Элемент)
	
	ЭтоРазделка = Объект.ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.питХозяйственныеОперации.РецептураРазделка");
	
	УстановитьПараметрыВыбораНоменклатуры();
	УправлениеФормой(ЭтаФорма);
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	
	Если СпособРасчетаРецептурыПоАктуальной И Объект.Дата <> НачалоДня(Объект.ДатаНачала) И ЗначениеЗаполнено(Объект.ДатаНачала) Тогда
		ТекстСообщения = "Установить дату начала действия рецептуры как дату документа: " + Формат(Объект.Дата,"ДФ=dd.MM.yyyy") + "?";
		
		ПоказатьВопрос(Новый ОписаниеОповещения("ДатаПриИзменении_Завершение", ЭтотОбъект ), ТекстСообщения, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Да);
		Возврат;
		
	КонецЕсли;
	 
	
	ДатаПриИзмененииФрагмент(Ложь);
КонецПроцедуры

&НаКлиенте
Процедура ДатаПриИзменении_Завершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Перем ДатаИзменена;
	
	ДатаИзменена = Ложь;
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		Объект.ДатаНачала = НачалоДня(Объект.Дата);
		ДатаИзменена = Истина;
	КонецЕсли;
	
	ДатаПриИзмененииФрагмент(ДатаИзменена);
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаПриИзмененииФрагмент(ДатаИзменена)
	
	Перем ПараметрыОбъекта;
	
	Если СпособРасчетаРецептурыПоАктуальной Тогда
		Если Объект.Дата <> НачалоДня(Объект.ДатаНачала) Тогда
			Если НЕ ЗначениеЗаполнено(Объект.ДатаНачала) Тогда
				Объект.ДатаНачала = НачалоДня(Объект.Дата);
				ДатаИзменена = Истина;
			КонецЕсли;
			
			Если ДатаИзменена Тогда
				// Проверка на случай, если установленная дата начала уже занята.
				ПараметрыОбъекта = Новый Структура("ХозяйственнаяОперация, Организация, Дата, Ссылка, Номенклатура, Характеристика");
				ЗаполнитьЗначенияСвойств(ПараметрыОбъекта, Объект);
				ПроверитьДатуНаСервере(ПараметрыОбъекта, Объект.ДатаНачала);
			КонецЕсли;
		КонецЕсли;
	Иначе
		Если НЕ ЗначениеЗаполнено(Объект.ДатаНачала) Тогда
			Объект.ДатаНачала = НачалоДня(Объект.Дата);
			ДатаИзменена = Истина;
		КонецЕсли;
	КонецЕсли;
	Если ДатаИзменена И ЗначениеЗаполнено(Объект.ДатаКонца) И Объект.ДатаНачала > Объект.ДатаКонца Тогда
		Объект.ДатаКонца = КонецДня(Объект.ДатаНачала);
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Процедура ПроверитьДатуНаСервере(ПараметрыОбъекта, ОбъектДатаНачала);
	НоваяДатаНачала = Документы.питРецептура.ПолучитьДругуюАктуальнуюРецептуру(ПараметрыОбъекта, ОбъектДатаНачала);
	Если ЗначениеЗаполнено(НоваяДатаНачала) Тогда
		ОбъектДатаНачала = НоваяДатаНачала;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)
	
	// Проверим, есть ли в табличной части блюда, для которых нужно исправить рецептуру.
	Если НЕ СпособРасчетаРецептурыПоАктуальной
		И (НЕ ЗначениеЗаполнено(Объект.ХозяйственнаяОперация)
		ИЛИ Объект.ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.питХозяйственныеОперации.РецептураПриготовление")) Тогда
		
		Проверять = Ложь;
		Для Каждого СтрокаТабличнойЧасти Из Объект.Ингредиенты Цикл
			Если СтрокаТабличнойЧасти.ЭтоБлюдо Тогда
				Проверять = Истина;
			КонецЕсли;
		КонецЦикла;
		Если Проверять Тогда
			ТекстСообщения = "Возможно изменение "+?(СпособРасчетаРецептурыПоАктуальной, "актуальных", "основных")+" рецептур в табличной части. Необходимо проверить рецептуры.";
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, Объект.Ссылка, "Ингредиенты", "Объект", );
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаНачалаПриИзменении(Элемент)
	Если НЕ СпособРасчетаРецептурыПоАктуальной Тогда
		Возврат;
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.ДатаКонца) И Объект.ДатаНачала > Объект.ДатаКонца  Тогда
		ТекстСообщения = "Конечная дата периода действия меньше начальной даты, необходимо исправить.";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, Объект.Ссылка, "ДатаКонца", "Объект", );
	КонецЕсли;
	
	//ЗаполнитьНаименованиеРецептуры();
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаКонцаПриИзменении(Элемент)
	Если НЕ СпособРасчетаРецептурыПоАктуальной Тогда
		Возврат;
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.ДатаКонца) И Формат(Объект.ДатаКонца,"ДФ=ЧЧммсс; ДП=000000") = "000000" Тогда
		Объект.ДатаКонца = КонецДня(Объект.ДатаКонца);
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.ДатаНачала) И ЗначениеЗаполнено(Объект.ДатаКонца) И Объект.ДатаНачала > Объект.ДатаКонца Тогда
		ТекстСообщения = "Начальная дата периода действия больше конечной даты, необходимо исправить.";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, Объект.Ссылка, "ДатаНачала", "Объект", );
	КонецЕсли;
	
	//ЗаполнитьНаименованиеРецептуры();
	
КонецПроцедуры

&НаКлиенте
Процедура НоменклатураПриИзменении(Элемент)
	
	ПараметрыОбъекта = Новый Структура("ХозяйственнаяОперация, Организация, Дата, Ссылка, ДатаНачала, ДатаКонца, Основная,
		|Номенклатура, Характеристика, Количество, Упаковка, Коэффициент, ЭтоБлюдо");
	ЗаполнитьЗначенияСвойств(ПараметрыОбъекта, Объект);
	ПараметрыОбъекта.Вставить("СпособРасчетаРецептурыПоАктуальной", СпособРасчетаРецептурыПоАктуальной);
	НоменклатураПриИзмененииНаСервере(ПараметрыОбъекта);
	
	ЗаполнитьЗначенияСвойств(Объект, ПараметрыОбъекта);
	ЭтоБлюдо = ?(ПараметрыОбъекта.Свойство("ЭтоБлюдо"), ПараметрыОбъекта.ЭтоБлюдо, Ложь); 
	ПредыдущееКоличество = Объект.КоличествоУпаковок;
	
	ПересчитатьКоличествоВШапке();
	
КонецПроцедуры

&НаКлиенте
Процедура ХарактеристикаПриИзменении(Элемент)
	//ЗаполнитьНаименованиеРецептуры();
	//+АвтовыборНоменклатуры
