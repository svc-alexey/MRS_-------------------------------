// Связано с отказом от модальных вызовов
&НаКлиенте
Процедура СпособРасчетаКалорийностиПриИзменении(Элемент, СпрашиватьОПересчете = Истина, УстанавливатьМодифицированность = Истина)
	СпособыРасчетаКалорийностиПоФормуле = ПредопределенноеЗначение("Перечисление.питСпособыРасчетаКалорийности.ПоФормуле");
	Элементы.ФормулаРасчетаКалорийности.Доступность = (Объект.СпособРасчетаКалорийности = СпособыРасчетаКалорийностиПоФормуле ИЛИ СпособРасчетаКалорийностиКонстанта = СпособыРасчетаКалорийностиПоФормуле);
	ИзмениласьФормула = Ложь;
	Если Объект.СпособРасчетаКалорийности = СпособыРасчетаКалорийностиПоФормуле 
		ИЛИ СпособРасчетаКалорийностиКонстанта = СпособыРасчетаКалорийностиПоФормуле Тогда
		Если ПустаяСтрока(Объект.ФормулаРасчетаКалорийности) Тогда
			// Поищем, откуда брать формулу
			// Из блюда
			Если ЗначениеЗаполнено(Объект.Номенклатура) Тогда
				ТекФормула = ОбщегоНазначенияУТВызовСервера.ЗначениеРеквизитаОбъекта(Объект.Номенклатура, "питФормулаРасчетаКалорийности");
			КонецЕсли;
			// из константы
			Если ПустаяСтрока(ТекФормула) Тогда
				ТекФормула = ВернутьКонстанту("питФормулаРасчетаКалорийности");
			КонецЕсли;
			// По умолчанию
			Если ПустаяСтрока(ТекФормула) Тогда
				ТекФормула = "4 * [Белки] + 9 * [Жиры] + 4 * [Углеводы] + 7 * [Алкоголь]";
			КонецЕсли;
			Объект.ФормулаРасчетаКалорийности = ТекФормула;
			Модифицированность = Истина;
			Если Не КорректнаФормулаКалорийности(Объект.ФормулаРасчетаКалорийности) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Формула расчета калорийности неверна!");
				Возврат;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Если СпрашиватьОПересчете Тогда
		Ответ = Неопределено;
		ПоказатьВопрос(Новый ОписаниеОповещения("СпособРасчетаКалорийностиПриИзмененииЗавершение", ЭтотОбъект), "Количество химико-энергетических характеристик могло измениться!" + Символы.ПС + "Пересчитать?", РежимДиалогаВопрос.ДаНет);
	КонецЕсли;
	 
КонецПроцедуры

&НаКлиенте
Процедура ПодразделениеОтборПоСвойствамПриИзменении(Элемент)
	Ответ = Неопределено;
	ПоказатьВопрос(Новый ОписаниеОповещения("СпособРасчетаКалорийностиПриИзмененииЗавершение", ЭтотОбъект), "Количество химико-энергетических характеристик могло измениться!" + Символы.ПС + "Пересчитать?", РежимДиалогаВопрос.ДаНет);
КонецПроцедуры

&НаКлиенте
Процедура СпособРасчетаКалорийностиПриИзмененииЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		ПолучитьСписокХимикоэнергетическихПоказателей();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КоличествоПриИзменении(Элемент)
	
	Если Объект.КоличествоУпаковок=0 Тогда
		ПоказатьПредупреждение(,"Количество не может быть нулевым");
		Объект.КоличествоУпаковок = ПредыдущееКоличество;
		
		// Если количество изменили, то предложим пересчитать табличную часть
	ИначеЕсли Объект.КоличествоУпаковок<>ПредыдущееКоличество И ПредыдущееКоличество<>0 Тогда
		
		ПересчитатьКоличествоВШапке();
		
		Если Объект.Ингредиенты.Количество() > 0 Тогда
			ПоказатьВопрос(Новый ОписаниеОповещения("КоличествоПриИзменении_Завершение", ЭтотОбъект), "Пересчитать количества в табличной части ?",РежимДиалогаВопрос.ДаНет,,КодВозвратаДиалога.Да);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьКоличествоВШапке()
	
	Перем ТекКоэффициент;
	
	ТекКоэффициент = ПолучитьКоэффициентУпаковки(Объект.Номенклатура,Объект.Упаковка);
	Объект.Количество = Объект.КоличествоУпаковок * ТекКоэффициент;

КонецПроцедуры

&НаКлиенте
Процедура КоличествоПриИзменении_Завершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса=КодВозвратаДиалога.Нет Тогда
		ПредыдущееКоличество = Объект.КоличествоУпаковок;
		Возврат;
	КонецЕсли;
	
	КоэффициентПересчета = Объект.КоличествоУпаковок / ПредыдущееКоличество;
	Для Каждого СтрокаТаблицы Из Объект.Ингредиенты Цикл
		СтрокаТаблицы.КоличествоУпаковокБрутто      = СтрокаТаблицы.КоличествоУпаковокБрутто * КоэффициентПересчета;
		СтрокаТаблицы.КоличествоУпаковокНетто = СтрокаТаблицы.КоличествоУпаковокНетто * КоэффициентПересчета;
		СтрокаТаблицы.КоличествоУпаковокВыход = СтрокаТаблицы.КоличествоУпаковокВыход * КоэффициентПересчета;
	КонецЦикла;
	ПосчитатьВсеКоличестваВединицахХраненияНаСервере();
	ПредыдущееКоличество = Объект.КоличествоУпаковок;
КонецПроцедуры


