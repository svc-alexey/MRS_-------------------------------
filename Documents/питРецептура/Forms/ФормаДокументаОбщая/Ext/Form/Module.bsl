&НаСервере
Процедура ВИП_ДоработатьФорму() 
	
    //<< Ситдикова А.К., ВиП, 19.09.2023, I-143. Печать этикеток из рецептур
	НоваяСтраница = Элементы.Добавить("ПечатьЭтикеток", Тип("ГруппаФормы"), Элементы.ГруппаСтраницы);
    НоваяСтраница.Вид = ВидГруппыФормы.Страница;
    НоваяСтраница.Заголовок = "Печать этикеток";
        
	НовыйЭлементНаименование = Элементы.Добавить("ЭтикеткаНаименование", Тип("ПолеФормы"), Элементы.ПечатьЭтикеток);
	НовыйЭлементНаименование.Вид = ВидПоляФормы.ПолеВвода;
	НовыйЭлементНаименование.ПутьКДанным = "Объект.ВИП_ЭтикеткаНаименование";
	
	НовыйЭлементГОСТ = Элементы.Добавить("ЭтикеткаГОСТ", Тип("ПолеФормы"), Элементы.ПечатьЭтикеток);
	НовыйЭлементГОСТ.Вид = ВидПоляФормы.ПолеВвода;
	НовыйЭлементГОСТ.ПутьКДанным = "Объект.ВИП_ЭтикеткаГОСТ";
	
	НовыйЭлементСостав = Элементы.Добавить("ЭтикеткаСостав", Тип("ПолеФормы"), Элементы.ПечатьЭтикеток);
	НовыйЭлементСостав.Вид = ВидПоляФормы.ПолеВвода;
	НовыйЭлементСостав.ПутьКДанным = "Объект.ВИП_ЭтикеткаСостав";
	
	ГруппаТемпература = Элементы.Добавить("ГруппаТемпература",Тип("ГруппаФормы"), Элементы.ПечатьЭтикеток); 
	ГруппаТемпература.Вид = ВидГруппыФормы.ОбычнаяГруппа;
   	ГруппаТемпература.Группировка = ГруппировкаПодчиненныхэлементовФормы.Вертикальная;
	
	НовыйЭлементТемператураХранения = Элементы.Добавить("ЭтикеткаТемператураХранения", Тип("ПолеФормы"), ГруппаТемпература);
	НовыйЭлементТемператураХранения.Вид = ВидПоляФормы.ПолеВвода;
	НовыйЭлементТемператураХранения.ПутьКДанным = "Объект.ВИП_ЭтикеткаТемператураХранения";
	НовыйЭлементТемператураХранения.Ширина = 5;  
	НовыйЭлементТемператураХранения.МаксимальнаяШирина = 5;
	
	НовыйЭлементСрокХранения = Элементы.Добавить("ЭтикеткаСрокХранения", Тип("ПолеФормы"), ГруппаТемпература);
	НовыйЭлементСрокХранения.Вид = ВидПоляФормы.ПолеВвода;
	НовыйЭлементСрокХранения.ПутьКДанным = "Объект.ВИП_ЭтикеткаСрокХранения";
	НовыйЭлементСрокХранения.Ширина = 5;
	НовыйЭлементСрокХранения.МаксимальнаяШирина = 5;
	
	ГруппаЖиры = Элементы.Добавить("ГруппаЖиры",Тип("ГруппаФормы"), Элементы.ПечатьЭтикеток); 
	ГруппаЖиры.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаЖиры.Группировка = ГруппировкаПодчиненныхэлементовФормы.ГоризонтальнаяВсегда;
	
	НовыйЭлементЖиры = Элементы.Добавить("ЭтикеткаЖиры", Тип("ПолеФормы"), ГруппаЖиры);
	НовыйЭлементЖиры.Вид = ВидПоляФормы.ПолеВвода;
	НовыйЭлементЖиры.ПутьКДанным = "Объект.ВИП_ЭтикеткаЖиры";
		
	НовыйЭлементБелки = Элементы.Добавить("ЭтикеткаБелки", Тип("ПолеФормы"), ГруппаЖиры);
	НовыйЭлементБелки.Вид = ВидПоляФормы.ПолеВвода;
	НовыйЭлементБелки.ПутьКДанным = "Объект.ВИП_ЭтикеткаБелки";  
	
	ГруппаУглеводы = Элементы.Добавить("ГруппаУглеводы",Тип("ГруппаФормы"), Элементы.ПечатьЭтикеток); 
	ГруппаУглеводы.Вид = ВидГруппыФормы.ОбычнаяГруппа;
    ГруппаУглеводы.Группировка = ГруппировкаПодчиненныхэлементовФормы.ГоризонтальнаяВсегда;
		
	НовыйЭлементУглеводы = Элементы.Добавить("ЭтикеткаУглеводы", Тип("ПолеФормы"), ГруппаУглеводы);
	НовыйЭлементУглеводы.Вид = ВидПоляФормы.ПолеВвода;
	НовыйЭлементУглеводы.ПутьКДанным = "Объект.ВИП_ЭтикеткаУглеводы";
		
	НовыйЭлементКалорийность = Элементы.Добавить("ЭтикеткаКалорийность", Тип("ПолеФормы"), ГруппаУглеводы);
	НовыйЭлементКалорийность.Вид = ВидПоляФормы.ПолеВвода;
	НовыйЭлементКалорийность.ПутьКДанным = "Объект.ВИП_ЭтикеткаКалорийность";  
	
	ВИП_ЗаполнитьРеквизитыЭтиектки();
	//>>
КонецПроцедуры

&НаСервере
Процедура ВИП_ЗаполнитьРеквизитыЭтиектки()

	//<< Каюмов А.А., ВиП, 25.09.2023, I-143. Печать этикеток из рецептур 
	Если НЕ ЗначениеЗаполнено(Объект.ВИП_ЭтикеткаНаименование) Тогда   
		Объект.ВИП_ЭтикеткаНаименование	= Объект.Наименование;
	КонецЕсли;  
	
	Если НЕ ЗначениеЗаполнено(Объект.ВИП_ЭтикеткаЖиры) 
		ИЛИ НЕ ЗначениеЗаполнено(Объект.ВИП_ЭтикеткаБелки) 
		ИЛИ НЕ ЗначениеЗаполнено(Объект.ВИП_ЭтикеткаУглеводы)
		ИЛИ НЕ ЗначениеЗаполнено(Объект.ВИП_ЭтикеткаКалорийность) Тогда 
		
		УточненияАвтовыбора = Объект.УточненияАвтовыбора.Выгрузить();
		ТекущийСпособРасчетаКалорийности = ?(ЗначениеЗаполнено(Объект.СпособРасчетаКалорийности), Объект.СпособРасчетаКалорийности, СпособРасчетаКалорийностиКонстанта);
		СписокХЭХ = питДиетпитание.ПолучитьСоставХЭХ(Объект.Номенклатура, Объект.Характеристика, Объект, Объект.Количество,Объект.КоличествоУпаковок, , Перечисления.питСпособыРасчетаКоличестваХЭХ.ПоКоличествуНетто, , ТекущийСпособРасчетаКалорийности,,?(ЗначениеЗаполнено(ПодразделениеОтборПоСвойствам), ПодразделениеОтборПоСвойствам, Объект.Подразделение), УточненияАвтовыбора);
		
		Если НЕ ЗначениеЗаполнено(Объект.ВИП_ЭтикеткаБелки) Тогда   
			Объект.ВИП_ЭтикеткаБелки = ВИП_ПолучитьХЭХ(СписокХЭХ, Справочники.питХимикоэнергетическиеХарактеристики.Белки);
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(Объект.ВИП_ЭтикеткаЖиры) Тогда   
			Объект.ВИП_ЭтикеткаЖиры	= ВИП_ПолучитьХЭХ(СписокХЭХ, Справочники.питХимикоэнергетическиеХарактеристики.Жиры);
		КонецЕсли; 
		
		Если НЕ ЗначениеЗаполнено(Объект.ВИП_ЭтикеткаУглеводы) Тогда   
			Объект.ВИП_ЭтикеткаУглеводы	= ВИП_ПолучитьХЭХ(СписокХЭХ, Справочники.питХимикоэнергетическиеХарактеристики.Углеводы);
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(Объект.ВИП_ЭтикеткаКалорийность) Тогда   
			Объект.ВИП_ЭтикеткаКалорийность	= ВИП_ПолучитьХЭХ(СписокХЭХ, Справочники.питХимикоэнергетическиеХарактеристики.Калорийность);
		КонецЕсли;

	КонецЕсли;
	//>>  
	
КонецПроцедуры	

&НаСервере
Функция ВИП_ПолучитьХЭХ(СписокХЭХ, ХЭХ)   
	//<< Каюмов А.А., ВиП, 25.09.2023, I-143. Печать этикеток из рецептур
	// << Кайдаров.С.В., ВиП, 04.10.2023, ERP-4410
	Если СписокХЭХ = Неопределено Тогда 
		Возврат 0;
	КонецЕсли;
	// >>
	НайденныеСтроки = СписокХЭХ.НайтиСтроки(Новый Структура("ХимикоэнергетическаяХарактеристика", ХЭХ));
	
	Если НайденныеСтроки.Количество() = 0 Тогда 
		Возврат 0;
	Иначе
		Возврат Формат(НайденныеСтроки[0].КоличествоХарактеристики,"ЧДЦ=2");
	КонецЕсли;
	//>>
КонецФункции

