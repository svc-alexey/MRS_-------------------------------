&НаСервере
Процедура ОбновитьЗаголовокФормы()
	
	Если НЕ ЗначениеЗаполнено(Объект.Наименование) Тогда
		ТекущийЗаголовок = Документы.питРецептура.СформироватьНаименованиеРецептуры(Объект.Номенклатура, Объект.Характеристика, Объект.ДатаНачала, Объект.ДатаКонца);
	Иначе
		ТекущийЗаголовок = Объект.Наименование;
	КонецЕсли;
	
	ТекущийЗаголовок = ТекущийЗаголовок + ?(Объект.Ссылка.Пустая(), " (создание)", "");
	
	ЭтаФорма.Заголовок = ТекущийЗаголовок;
	
КонецПроцедуры

