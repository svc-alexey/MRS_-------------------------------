Процедура ИнгредиентыУсловиеОткрытие(Элемент, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	МатериалыИУслуги_НастройкаОтбораПоСвойствамИРасчетаПоФормулам(Неопределено);
КонецПроцедуры

&НаСервере
Процедура ОбновитьКолонкуУсловияОтбораПоСвойствам(КлючСвязи = "", питНаименованиеУсловия = "")
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ * ПОМЕСТИТЬ втОтборПоСвойствам ИЗ &втОтборПоСвойствам КАК втОтборПоСвойствам;
	|ВЫБРАТЬ
	|	питРецептураОтборПоСвойствам.КлючСвязи КАК КлючСвязи,
	|	питРецептураОтборПоСвойствам.Свойство.Представление КАК СвойствоПредставление,
	|	питРецептураОтборПоСвойствам.Условие КАК УсловиеПредставление,
	|	питРецептураОтборПоСвойствам.Значение.Представление КАК ЗначениеПредставление,
	|	питРецептураОтборПоСвойствам.НаименованиеУсловия КАК НаименованиеУсловия
	|ИЗ
	|	втОтборПоСвойствам КАК питРецептураОтборПоСвойствам";
	Запрос.УстановитьПараметр("втОтборПоСвойствам", Объект.ОтборПоСвойствам.Выгрузить());
	УстановитьПривилегированныйРежим(Истина);
	РезультатОтборПоСвойствам = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	Для каждого ТекИнгредиент Из Объект.Ингредиенты Цикл
		Если НЕ ПустаяСтрока(КлючСвязи) И НЕ ПустаяСтрока(питНаименованиеУсловия) И КлючСвязи = ТекИнгредиент.КлючСвязи Тогда
			ТекИнгредиент.Условие = питНаименованиеУсловия;
		Иначе
			ТекИнгредиент.Условие = "";
			СтрокиУсловия = РезультатОтборПоСвойствам.НайтиСтроки(Новый Структура("КлючСвязи", ТекИнгредиент.КлючСвязи));
			Для каждого СтрокаУсловия Из СтрокиУсловия Цикл
				Если ЗначениеЗаполнено(СтрокаУсловия.НаименованиеУсловия) Тогда
					ТекИнгредиент.Условие = СтрокаУсловия.НаименованиеУсловия;
				Иначе
					ТекИнгредиент.Условие = ТекИнгредиент.Условие + ?(ПустаяСтрока(ТекИнгредиент.Условие),"",";") + " <" + СтрокаУсловия.СвойствоПредставление + "> " + СтрокаУсловия.УсловиеПредставление + " <" + СтрокаУсловия.ЗначениеПредставление + ">";
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла
	
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьКоличествоФормульныхСтрок(КлючСвязи = "", питНаименованиеУсловия = "")
	
	ТекущиеДанные = Элементы.Ингредиенты.ТекущиеДанные;
	Если НЕ ТекущиеДанные = Неопределено Тогда
		ТекущийИлентификаторСтроки = ТекущиеДанные.ПолучитьИдентификатор();
	Иначе
		ТекущийИлентификаторСтроки = Неопределено;
	КонецЕсли;
	
	НовыйИдентификаторСтроки = РассчитатьКоличествоФормульныхСтрокНаСервере(ТекущийИлентификаторСтроки, КлючСвязи, питНаименованиеУсловия);
	Если НЕ НовыйИдентификаторСтроки = Неопределено Тогда
		Элементы.Ингредиенты.ТекущаяСтрока = НовыйИдентификаторСтроки;
	КонецЕсли;
	
	Для каждого ТекИнгредиент Из Объект.Ингредиенты Цикл
		Если ЗначениеЗаполнено(ТекИнгредиент.АлгоритмРасчетаКоличества) Тогда
			ТоварыКоличествоПриИзменении(,ТекИнгредиент, СуффиксКолонкиКоличествДляФормул);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция РассчитатьКоличествоФормульныхСтрокНаСервере(ТекущийИлентификаторСтроки = Неопределено, КлючСвязи = "", питНаименованиеУсловия = "")
	СтрокаИнгредиентов = Неопределено;
	Если НЕ ТекущийИлентификаторСтроки = Неопределено Тогда
		СтрокаИнгредиентов = Объект.Ингредиенты.НайтиПоИдентификатору(ТекущийИлентификаторСтроки);
	КонецЕсли;
	Если НЕ СтрокаИнгредиентов = Неопределено Тогда
		СП = Новый Структура("КлючСвязи", СтрокаИнгредиентов.КлючСвязи);
	КонецЕсли;
	
	Документы.питРецептура.РассчитатьКоличествоФормульныхСтрок(Объект, Истина);
	ОбновитьКолонкуУсловияОтбораПоСвойствам(КлючСвязи, питНаименованиеУсловия);
	
	Результат = Неопределено;
	Если НЕ СтрокаИнгредиентов = Неопределено Тогда
		НайденныеСтроки = Объект.Ингредиенты.НайтиСтроки(СП);
		Если НайденныеСтроки.Количество() Тогда
			Результат = НайденныеСтроки[0].ПолучитьИдентификатор();
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ПересчитатьФормульныеСтроки(Команда)
	РассчитатьКоличествоФормульныхСтрок();
КонецПроцедуры

