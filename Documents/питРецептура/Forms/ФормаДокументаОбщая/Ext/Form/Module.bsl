&НаСервере
// Заполнение колонок "Ингредиенты.ЭтоБлюдо", "Ингредиенты.ЭтоТовар", "Ингредиенты.Иконка"
//
Процедура ЗаполнитьДобавленныеКолонкиТаблиц()
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТаблицаТовары.Номенклатура
	|ПОМЕСТИТЬ ТаблицаТовары
	|ИЗ
	|	&ТаблицаТовары КАК ТаблицаТовары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаТовары.Номенклатура,
	|	СправочникНоменклатура.питВидНоменклатуры КАК питВидНоменклатуры,
	|	ВЫБОР
	|		КОГДА СправочникНоменклатура.питВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.питВидыНоменклатуры.Блюдо)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЭтоБлюдо,
	|	ВЫБОР
	|		КОГДА СправочникНоменклатура.питВидНоменклатуры = ЗНАЧЕНИЕ(Перечисление.питВидыНоменклатуры.Товар)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЭтоТовар
	|ИЗ
	|	ТаблицаТовары КАК ТаблицаТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправочникНоменклатура
	|		ПО ТаблицаТовары.Номенклатура = СправочникНоменклатура.Ссылка";
	
	ТаблицаТовары = Объект.Ингредиенты.Выгрузить(, "Номенклатура");
	Запрос.УстановитьПараметр("ТаблицаТовары", ТаблицаТовары);
	
	Результат = Запрос.ВыполнитьПакет();
	ТаблицаТоваров = Результат[1].Выгрузить();
	ТаблицаТоваров.Индексы.Добавить("Номенклатура");
	
	Для Каждого СтрокаТабличнойЧасти Из Объект.Ингредиенты Цикл
		// Заполняем колонки "ЭтоБлюдо" и "ЭтоТовар"
		СтрокаТоваров = ТаблицаТоваров.Найти(СтрокаТабличнойЧасти.Номенклатура, "Номенклатура");
		СтрокаТабличнойЧасти.ЭтоБлюдо = СтрокаТоваров.ЭтоБлюдо;
		СтрокаТабличнойЧасти.ЭтоТовар = СтрокаТоваров.ЭтоТовар;
		СтрокаТабличнойЧасти.Иконка = питДокументы.ОпределитьНомерИконкиНоменклатуры(СтрокаТоваров.питВидНоменклатуры, СтрокаТабличнойЧасти.Специя);
	КонецЦикла;
	
	// Также заполним для Номенклатуры в шапке документа
	
	РеквизитыНоменклатуры = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.Номенклатура, "питВидНоменклатуры");
	ЭтаФорма.ЭтоБлюдо = (РеквизитыНоменклатуры.питВидНоменклатуры = Перечисления.питВидыНоменклатуры.Блюдо);
	
КонецПроцедуры

&НаКлиенте
Функция ПолучитьПараметрыПодбора(ИмяТаблицы = "Товары")
	
	ПараметрыФормы = Новый Структура;
	
	Если ИмяТаблицы = "Товары" Тогда
		
		ПараметрЗаголовок = НСтр("ru = 'Подбор товаров в %Документ%'");
		Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
			ПараметрЗаголовок = СтрЗаменить(ПараметрЗаголовок, "%Документ%", Объект.Ссылка);
		Иначе
			ПараметрЗаголовок = СтрЗаменить(ПараметрЗаголовок, "%Документ%", НСтр("ru = 'рецептуру'"));
		КонецЕсли;
		
		ОтборТипЦен = питОбщегоНазначения.ПолучитьЗначениеПоУмолчанию("НормативныйТипЦенОбщепит");
		ОтборЦенаВключаетНДС = питОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОтборТипЦен,"ЦенаВключаетНДС");
		
		ПараметрыФормы.Вставить("Заголовок",										ПараметрЗаголовок);
		ПараметрыФормы.Вставить("Дата",												Объект.Дата);
		ПараметрыФормы.Вставить("Организация",										Объект.Организация);
		ПараметрыФормы.Вставить("РежимПодбораИспользоватьСкладыВТабличнойЧасти",	Ложь);
		ПараметрыФормы.Вставить("Документ",											Объект.Ссылка);
		ПараметрыФормы.Вставить("ОстаткиПоВсемСкладам",								Истина);
		ПараметрыФормы.Вставить("Валюта",											питПроизводствоПовтИсп.ПолучитьВалютуРегламентированногоУчета());
		ПараметрыФормы.Вставить("ВидЦены",											ОтборТипЦен);
		ПараметрыФормы.Вставить("ЦенаВключаетНДС",									ОтборЦенаВключаетНДС);
		ПараметрыФормы.Вставить("РежимПодбораБезСоглашенийСКлиентами",				Истина);
		
	КонецЕсли;
	
	Возврат ПараметрыФормы;
	
КонецФункции

&НаСервере
Функция НайтиСтрокуТабличнойЧасти(ИмяТабличнойЧасти, СтруктураОтбора)
	
	СтрокаТабличнойЧасти = Неопределено;
	
	МассивНайденныхСтрок = Объект[ИмяТабличнойЧасти].НайтиСтроки(СтруктураОтбора);
	Если МассивНайденныхСтрок.Количество() > 0 Тогда
		// Нашли. Вернем первую найденную строку.
		СтрокаТабличнойЧасти = МассивНайденныхСтрок[0];
	КонецЕсли;
	
	Возврат СтрокаТабличнойЧасти;
	
КонецФункции


