Процедура ПредыдущаяРецептура(Команда)
	
	СледРецептура = ПредСледРецептураНаСервере(Ложь);
	Если СледРецептура = Неопределено Тогда
		ПоказатьПредупреждение(,"Предыдущей рецептуры не существует" , 60);
	иначе
		Парам = Новый Структура("Ключ", СледРецептура);
		ОткрытьФорму("Документ.питРецептура.ФормаОбъекта",Парам);
		Закрыть();
	КонецЕсли;
	
