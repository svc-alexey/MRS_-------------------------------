&НаСервере
// Возвращает предыдущую или следующую рецептуру
//  След - булево ложь: нужна предыдущая, Истина: нужна следующая.
Функция ПредСледРецептураНаСервере(След, Номенклатура = Неопределено, Характеристика = Неопределено)
	ХозяйственнаяОперацияРецептуры = ?(ЗначениеЗаполнено(Объект.ХозяйственнаяОперация), Объект.ХозяйственнаяОперация, Перечисления.питХозяйственныеОперации.РецептураПриготовление);
	Если След Тогда
		НаДату = Объект.ДатаНачала;
	иначе
		НаДату = Объект.ДатаНачала - 1;
	КонецЕсли;
	
	ТекПодразделения = питПроизводство.НайтиПодразделенияПоРазрешенным(Подразделения.Выгрузить());
	ПредРецептура = питПроизводство.ВернутьОсновнуюРецептуру(Объект.Номенклатура, Объект.Характеристика,  ХозяйственнаяОперацияРецептуры,НаДату, Перечисления.питСпособРасчетаРецептур.ПоАктуальнойРецептуре, , Объект.Организация, Ложь, След,ТекПодразделения);
	Если НЕ ЗначениеЗаполнено(ПредРецептура) Тогда
		ПредРецептура = Неопределено;
	КонецЕсли;
	
	Возврат ПредРецептура;
КонецФункции

