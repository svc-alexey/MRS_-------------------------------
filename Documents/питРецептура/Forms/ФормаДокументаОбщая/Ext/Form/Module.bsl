// Получает список химикоэнергетических характеристик для всех товаров, входящих в рецептуру (в т.ч. в автопеределы).
//
// Параметры:
//  НЕТ
//
//
Процедура ПолучитьСписокХимикоэнергетическихПоказателей()
	
	ХимикоэнергетическиеХарактеристики.Очистить();
	
	//+АвтовыборНоменклатуры
	УточненияАвтовыбора = Объект.УточненияАвтовыбора.Выгрузить();
	//-АвтовыборНоменклатуры
	
	ТекущийСпособРасчетаКалорийности = ?(ЗначениеЗаполнено(Объект.СпособРасчетаКалорийности), Объект.СпособРасчетаКалорийности, СпособРасчетаКалорийностиКонстанта);
	
	СписокХЭХ = питДиетпитание.ПолучитьСоставХЭХ(Объект.Номенклатура, Объект.Характеристика, Объект, Объект.Количество,Объект.КоличествоУпаковок, , Перечисления.питСпособыРасчетаКоличестваХЭХ.ПоКоличествуБрутто, , ТекущийСпособРасчетаКалорийности, ,?(ЗначениеЗаполнено(ПодразделениеОтборПоСвойствам), ПодразделениеОтборПоСвойствам, Объект.Подразделение), УточненияАвтовыбора);
	
	Если СписокХЭХ <> Неопределено Тогда
		Для Каждого СтрокаСписка Из СписокХЭХ Цикл
			НоваяСтрока										= ХимикоэнергетическиеХарактеристики.Добавить();
			НоваяСтрока.ХимикоэнергетическаяХарактеристика	= СтрокаСписка.ХимикоэнергетическаяХарактеристика;
			НоваяСтрока.ЕдиницаИзмерения                  	= СтрокаСписка.ЕдиницаИзмерения;
			НоваяСтрока.Количество                        	= СтрокаСписка.КоличествоХарактеристики;
			НоваяСтрока.КоличествоНетто                   	= 0;
			НоваяСтрока.КоличествоВыход                   	= 0;
			НоваяСтрока.СУчетомПотерь                     	= 0;
		КонецЦикла;
	КонецЕсли;
	
	СписокХЭХ = питДиетпитание.ПолучитьСоставХЭХ(Объект.Номенклатура, Объект.Характеристика, Объект, Объект.Количество,Объект.КоличествоУпаковок, , Перечисления.питСпособыРасчетаКоличестваХЭХ.ПоКоличествуНетто, , ТекущийСпособРасчетаКалорийности,,?(ЗначениеЗаполнено(ПодразделениеОтборПоСвойствам), ПодразделениеОтборПоСвойствам, Объект.Подразделение), УточненияАвтовыбора);
	
	Если СписокХЭХ <> Неопределено Тогда
		Для Каждого СтрокаСписка Из СписокХЭХ Цикл
			НоваяСтрока										= ХимикоэнергетическиеХарактеристики.Добавить();
			НоваяСтрока.ХимикоэнергетическаяХарактеристика	= СтрокаСписка.ХимикоэнергетическаяХарактеристика;
			НоваяСтрока.ЕдиницаИзмерения                  	= СтрокаСписка.ЕдиницаИзмерения;
			НоваяСтрока.Количество                        	= 0;
			НоваяСтрока.КоличествоНетто                   	= СтрокаСписка.КоличествоХарактеристики;
			НоваяСтрока.КоличествоВыход                   	= 0;
			НоваяСтрока.СУчетомПотерь                     	= 0;
		КонецЦикла;
	КонецЕсли;
	
	СписокХЭХ = питДиетпитание.ПолучитьСоставХЭХ(Объект.Номенклатура, Объект.Характеристика, Объект, Объект.Количество,Объект.КоличествоУпаковок ,, Перечисления.питСпособыРасчетаКоличестваХЭХ.ПоКоличествуВыход, , ТекущийСпособРасчетаКалорийности,,?(ЗначениеЗаполнено(ПодразделениеОтборПоСвойствам), ПодразделениеОтборПоСвойствам, Объект.Подразделение), УточненияАвтовыбора);
	
	Если СписокХЭХ <> Неопределено Тогда
		Для Каждого СтрокаСписка Из СписокХЭХ Цикл
			НоваяСтрока										= ХимикоэнергетическиеХарактеристики.Добавить();
			НоваяСтрока.ХимикоэнергетическаяХарактеристика	= СтрокаСписка.ХимикоэнергетическаяХарактеристика;
			НоваяСтрока.ЕдиницаИзмерения                  	= СтрокаСписка.ЕдиницаИзмерения;
			НоваяСтрока.Количество                        	= 0;
			НоваяСтрока.КоличествоНетто                   	= 0;
			НоваяСтрока.КоличествоВыход                   	= СтрокаСписка.КоличествоХарактеристики;
			НоваяСтрока.СУчетомПотерь                     	= 0;
		КонецЦикла;
	КонецЕсли;
	
	СписокХЭХ = питДиетпитание.ПолучитьСоставХЭХ(Объект.Номенклатура, Объект.Характеристика, Объект, Объект.Количество,Объект.КоличествоУпаковок ,, Перечисления.питСпособыРасчетаКоличестваХЭХ.СУчетомПотерьХЭХ, , ТекущийСпособРасчетаКалорийности,,?(ЗначениеЗаполнено(ПодразделениеОтборПоСвойствам), ПодразделениеОтборПоСвойствам, Объект.Подразделение), УточненияАвтовыбора);
	
	Если СписокХЭХ <> Неопределено Тогда
		Для Каждого СтрокаСписка Из СписокХЭХ Цикл
			НоваяСтрока										= ХимикоэнергетическиеХарактеристики.Добавить();
			НоваяСтрока.ХимикоэнергетическаяХарактеристика	= СтрокаСписка.ХимикоэнергетическаяХарактеристика;
			НоваяСтрока.ЕдиницаИзмерения                  	= СтрокаСписка.ЕдиницаИзмерения;
			НоваяСтрока.Количество                        	= 0;
			НоваяСтрока.КоличествоНетто                   	= 0;
			НоваяСтрока.КоличествоВыход                   	= 0;
			НоваяСтрока.СУчетомПотерь                     	= СтрокаСписка.КоличествоХарактеристики;
		КонецЦикла;
	КонецЕсли;
	
	ТаблицаХимикоэнергетическиеХарактеристики = РеквизитФормыВЗначение("ХимикоэнергетическиеХарактеристики");
	ТаблицаХимикоэнергетическиеХарактеристики.Свернуть("ХимикоэнергетическаяХарактеристика,ЕдиницаИзмерения", "Количество,КоличествоНетто,КоличествоВыход,СУчетомПотерь");
	ЗначениеВРеквизитФормы(ТаблицаХимикоэнергетическиеХарактеристики,"ХимикоэнергетическиеХарактеристики");
КонецПроцедуры // ПолучитьСписокХимикоэнергетическихПоказателей()

