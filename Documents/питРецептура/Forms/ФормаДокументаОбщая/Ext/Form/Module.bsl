	СтандартнаяОбработка = Ложь;
	
	ТекДанныеПодразделения = Элементы.Подразделения.ТекущиеДанные;
	Если ТекДанныеПодразделения = Неопределено Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не установлено подразделение в списке подразделений!");
		Возврат;
	КонецЕсли;
	
	Если ТекДанныеПодразделения.ВключаяПодчиненные Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("У подразделения установлен флаг ""Включая подчиненные"". Для данного режима разрешены все цеховые кладовые!");
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(ВыбранноеЗначение) = Тип("СправочникСсылка.Склады") Тогда
		
		ПустыеЦеха = Цеха.НайтиСтроки(Новый Структура("ЦеховаяКладовая,ИдентификаторПодразделения", ПредопределенноеЗначение("Справочник.Склады.ПустаяСсылка"), ТекДанныеПодразделения.ИдентификаторСтроки));
		Для каждого ПустойЦех Из ПустыеЦеха Цикл
			Цеха.Удалить(ПустойЦех);
		КонецЦикла;
		
		ТекСтрокаЦех = Неопределено;
		НайденныеЦеха = Цеха.НайтиСтроки(Новый Структура("ЦеховаяКладовая,ИдентификаторПодразделения", ВыбранноеЗначение, ТекДанныеПодразделения.ИдентификаторСтроки));
		Если НайденныеЦеха.Количество() Тогда
			ТекСтрокаЦех = НайденныеЦеха[0];
		Иначе
			ТекСтрокаЦех = Цеха.Добавить();
			ТекСтрокаЦех.ЦеховаяКладовая = ВыбранноеЗначение;
			ТекСтрокаЦех.ИдентификаторПодразделения = ТекДанныеПодразделения.ИдентификаторСтроки;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

