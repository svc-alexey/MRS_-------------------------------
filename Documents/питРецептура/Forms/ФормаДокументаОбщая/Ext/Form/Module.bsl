// ПРОЦЕДУРЫ И ФУНКЦИИ ОБЩЕГО НАЗНАЧЕНИЯ
//

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	УправлениеСвойствами.ОбработкаПроверкиЗаполнения(ЭтаФорма, Отказ, ПроверяемыеРеквизиты);
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
// Процедура округляет количество до 3 или до 6 десятичных знаков, в зависимости от признака Специя.
//
Процедура ОкруглитьКоличество(пКоличество, пСпеция)
	// При пересчетах оставляем только видимые знаки.
	Если пСпеция=Истина  Тогда
		пКоличество = Окр(пКоличество,6);
	Иначе
		пКоличество = Окр(пКоличество,3);
	КонецЕсли;
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
// Расчитывает новое количество по проценту потерь, и с округлением по признаку Специя.
//
Процедура ОпределитьКоличество(КоличествоРезультат, КоличествоИсходное, ПроцентПотерь, ОбратныйРассчет=Ложь, ГорячаяОбработка=Неопределено, пСпеция, НомерСтроки)
	
	Если ПроцентПотерь > 100 Тогда
		Если ГорячаяОбработка=Ложь Тогда
			ТекстСообщения = "Процент потерь при холодной обработке не может превышать 100%.";
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, , "Ингредиенты["+НомерСтроки+"].ПроцентПотерьПриХолоднойОбработке", "Объект", );
		ИначеЕсли ГорячаяОбработка=Истина Тогда
			ТекстСообщения = "Процент потерь при горячей обработке не может превышать 100%.";
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, , "Ингредиенты["+НомерСтроки+"].ПроцентПотерьПриГорячейОбработке", "Объект", );
		Иначе
			// без предупреждений
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	Если ПроцентПотерь=100 И ОбратныйРассчет=Истина И КоличествоИсходное<>0 Тогда
		Если ГорячаяОбработка=Ложь Тогда
			ТекстСообщения = "Не правильный процент потерь при холодной обработке.";
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, , "Ингредиенты["+НомерСтроки+"].ПроцентПотерьПриХолоднойОбработке", "Объект", );
		ИначеЕсли ГорячаяОбработка=Истина Тогда
			ТекстСообщения = "Не правильный процент потерь при горячей обработке.";
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, , "Ингредиенты["+НомерСтроки+"].ПроцентПотерьПриГорячейОбработке", "Объект", );
		Иначе
			// без предупреждений
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	Если ОбратныйРассчет=Истина Тогда
		Если ПроцентПотерь <> 100 Тогда
			КоличествоРезультат = КоличествоИсходное * 100 / (100 - ПроцентПотерь);
			ОкруглитьКоличество(КоличествоРезультат, пСпеция);
		КонецЕсли;
	Иначе
		КоличествоРезультат = КоличествоИсходное * (100 - ПроцентПотерь) / 100;
		ОкруглитьКоличество(КоличествоРезультат, пСпеция);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
// Определяет процент потерь холодной или горячей обработки по количествам.
//
// Параметры:
//  КоличествоИсх - исходное количество продукта до обработки.
//  КоличествоОбработанное - количество продукта после холодной или горячей обработки.
//
Функция РассчитатьПроцентПотерьОбработки(КоличествоИсх, КоличествоОбработанное)
	Если КоличествоИсх = 0 Тогда
		Возврат 0;
	Иначе
		Возврат Окр((КоличествоИсх - КоличествоОбработанное) * 100 / КоличествоИсх, 2);
	КонецЕсли;
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура УправлениеФормой(Форма)
	
	Элементы = Форма.Элементы;
	Объект   = Форма.Объект;
	
	РежимПриготовление = (Объект.ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.питХозяйственныеОперации.РецептураПриготовление") ИЛИ НЕ ЗначениеЗаполнено(Объект.ХозяйственнаяОперация));
	РежимРазделка      = (Объект.ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.питХозяйственныеОперации.РецептураРазделка"));
	
	Форма.ПрименятьМеханизмВидовОбработки = Форма.питИспользоватьВидыОбработкиСырья И НЕ РежимРазделка;
	
	Элементы.ТоварыВводСтрокиДиалогом.Доступность = РежимПриготовление;
	Элементы.ТоварыВводСтрокиДиалогом.Видимость   = РежимПриготовление;
	Если НЕ Элементы.ТоварыВводСтрокиДиалогом.Доступность Тогда
		Элементы.ТоварыВводСтрокиДиалогом.Пометка = Ложь;
	КонецЕсли;
	
	Элементы.ТоварыПроверитьРецептуры.Доступность = РежимПриготовление;
	Элементы.ТоварыПроверитьРецептуры.Видимость   = РежимПриготовление;
	
	// Покажем/скроем закладку приготовления
	Элементы.ГруппаТехнологияПриготовления.Видимость            = РежимПриготовление;
	Элементы.ГруппаХимикоэнергетическиеХарактеристики.Видимость = РежимПриготовление;
	Элементы.ГруппаОрганолептическиеПоказатели.Видимость        = РежимПриготовление;
	
	Элементы.Количество.Доступность = Не РежимРазделка;
	Элементы.Упаковка.Доступность = Истина;
	
	Элементы.НомерРецептуры.Доступность = Истина;
	Элементы.Выход.Видимость = Не РежимРазделка;
	
	Если РежимРазделка Тогда
		// Переименуем колонку Количество
		Элементы.ИнгредиентыКоличество.Заголовок = "Доля выхода";
		Элементы.ИнгредиентыКоличество.Подсказка = "Доля выхода номенклатуры";
		Элементы.ИнгредиентыКоличество.Формат = "ЧЦ=5; ЧДЦ=2";
		Элементы.ИнгредиентыКоличество.ФорматРедактирования = "ЧЦ=5; ЧДЦ=2";
	Иначе
		Элементы.ИнгредиентыКоличество.Заголовок = "Брутто";
		Элементы.ИнгредиентыКоличество.Подсказка = "Количество номенклатуры";
		Элементы.ИнгредиентыКоличество.Формат = "ЧЦ=15; ЧДЦ=3";
		Элементы.ИнгредиентыКоличество.ФорматРедактирования = "ЧЦ=15; ЧДЦ=3";
	КонецЕсли;
	
	// Виды обработки.
	Если Форма.ПрименятьМеханизмВидовОбработки Тогда
		Элементы.ТоварыПроцентПотерьПриХолоднойОбработке.ТолькоПросмотр	= Истина;
		Элементы.ТоварыПроцентПотерьПриГорячейОбработке.ТолькоПросмотр	= Истина;
		Элементы.ИнгредиентыКоличествоВыход.ТолькоПросмотр					= Истина;
		Элементы.ИнгредиентыКоличествоНетто.ТолькоПросмотр					= Истина;
		
		Элементы.ТоварыПроцентПотерьПриХолоднойОбработке.Видимость		= Истина;
		Элементы.ТоварыПроцентПотерьПриГорячейОбработке.Видимость		= Истина;
		Элементы.ИнгредиентыКоличествоВыход.Видимость						= Истина;
		Элементы.ИнгредиентыКоличествоНетто.Видимость						= Истина;
		
		Элементы.ТоварыПроцентСебестоимости.Видимость					= Ложь;
		Элементы.ИнгредиентыВидыОбработки.Видимость						= Истина;
		
		Элементы.ТоварыПроцентПотерьПриХолоднойОбработке.ТолькоПросмотр	= Истина;
		Элементы.ТоварыПроцентПотерьПриГорячейОбработке.ТолькоПросмотр	= Истина;
		
	ИначеЕсли РежимРазделка Тогда
		Элементы.ТоварыПроцентПотерьПриХолоднойОбработке.Видимость		= Ложь;
		Элементы.ТоварыПроцентПотерьПриГорячейОбработке.Видимость		= Ложь;
		Элементы.ИнгредиентыКоличествоВыход.Видимость						= Ложь;
		Элементы.ИнгредиентыКоличествоНетто.Видимость						= Ложь;
		Элементы.ТоварыПроцентСебестоимости.Видимость					= Истина;
		Элементы.ИнгредиентыВидыОбработки.Видимость						= Ложь;
	Иначе
		Элементы.ТоварыПроцентПотерьПриХолоднойОбработке.ТолькоПросмотр	= Ложь;
		Элементы.ТоварыПроцентПотерьПриГорячейОбработке.ТолькоПросмотр	= Ложь;
		Элементы.ИнгредиентыКоличествоВыход.ТолькоПросмотр					= Ложь;
		Элементы.ИнгредиентыКоличествоНетто.ТолькоПросмотр					= Ложь;
		
		Элементы.ТоварыПроцентПотерьПриХолоднойОбработке.Видимость		= Истина;
		Элементы.ТоварыПроцентПотерьПриГорячейОбработке.Видимость		= Истина;
		Элементы.ИнгредиентыКоличествоВыход.Видимость						= Истина;
		Элементы.ИнгредиентыКоличествоНетто.Видимость						= Истина;
		
		Элементы.ТоварыПроцентСебестоимости.Видимость					= Ложь;
		Элементы.ИнгредиентыВидыОбработки.Видимость						= Истина;
		
		Элементы.ТоварыПроцентПотерьПриХолоднойОбработке.ТолькоПросмотр	= Ложь;
		Элементы.ТоварыПроцентПотерьПриГорячейОбработке.ТолькоПросмотр	= Ложь;
		
	КонецЕсли;
	
	//+ПараметризацияРецептур
	ОтображатьЭлементыПараметризации = Форма.ЭтоУправлениеПредприятием И Форма.ИспользоватьПараметризациюРесурсныхСпецификаций И НЕ Форма.ЭтоРазделка;
	Элементы.ИнгредиентыНастройкаОтбораПоСвойствамИРасчетаПоФормулам.Видимость	= ОтображатьЭлементыПараметризации;
	Элементы.ИнгредиентыПересчитатьФормульныеСтроки.Видимость					= ОтображатьЭлементыПараметризации;
	Элементы.ИнгредиентыУсловие.Видимость										= ОтображатьЭлементыПараметризации;
	//-ПараметризацияРецептур
	
	//+АвтовыборНоменклатуры
	Элементы.ИнгредиентыТовары_НастроитьПодборНоменклатуры.Видимость = Форма.ЭтоУправлениеПредприятием;
	//-АвтовыборНоменклатуры
	
КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрыВыбораНоменклатуры()
	
	// Для номенклатуры в шапке
	Если Объект.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.РецептураРазделка Тогда
		МассивВидовНоменклатуры = Новый Массив;
		МассивВидовНоменклатуры.Добавить(Перечисления.питВидыНоменклатуры.Блюдо);
		МассивВидовНоменклатуры.Добавить(Перечисления.питВидыНоменклатуры.Товар);
		ВидНоменклатуры = Новый ФиксированныйМассив(МассивВидовНоменклатуры);
	Иначе
		ВидНоменклатуры = Перечисления.питВидыНоменклатуры.Блюдо;
	КонецЕсли;
	
	НовыйМассивПараметров = Новый Массив();
	НовыйМассивПараметров.Добавить(Новый ПараметрВыбора("Отбор.питВидНоменклатуры", ВидНоменклатуры));
	
	НовыеПараметрыВыбора = Новый ФиксированныйМассив(НовыйМассивПараметров);
	Элементы.Номенклатура.ПараметрыВыбора = НовыеПараметрыВыбора;
	
	// Для номенклатуры в таблице
	Если Объект.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.РецептураРазделка Тогда
		МассивВидовНоменклатуры = Новый Массив;
		МассивВидовНоменклатуры.Добавить(Перечисления.питВидыНоменклатуры.Блюдо);
		МассивВидовНоменклатуры.Добавить(Перечисления.питВидыНоменклатуры.Товар);
		МассивВидовНоменклатуры.Добавить(Перечисления.питВидыНоменклатуры.ТехнологическийИнгредиент); // Технический ингредиент
		ВидНоменклатуры = Новый ФиксированныйМассив(МассивВидовНоменклатуры);
	Иначе
		МассивВидовНоменклатуры = Новый Массив;
		МассивВидовНоменклатуры.Добавить(Перечисления.питВидыНоменклатуры.Товар);
		МассивВидовНоменклатуры.Добавить(Перечисления.питВидыНоменклатуры.Блюдо);
		МассивВидовНоменклатуры.Добавить(Перечисления.питВидыНоменклатуры.ТехнологическийИнгредиент); // Технический ингредиент
		ВидНоменклатуры = Новый ФиксированныйМассив(МассивВидовНоменклатуры);
	КонецЕсли;
	
	НовыйМассивПараметров = Новый Массив();
	НовыйМассивПараметров.Добавить(Новый ПараметрВыбора("Отбор.питВидНоменклатуры", ВидНоменклатуры));
	
	НовыеПараметрыВыбора = Новый ФиксированныйМассив(НовыйМассивПараметров);
	Элементы.ИнгредиентыНоменклатура.ПараметрыВыбора = НовыеПараметрыВыбора;
	
	// Для рецептуры в таблице: всегда только Приготовление.
	
КонецПроцедуры

&НаСервере
Процедура НоменклатураПриИзмененииНаСервере(ПараметрыОбъекта)
	
	РеквизитыНоменклатуры = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПараметрыОбъекта.Номенклатура, 
		"питВидНоменклатуры, питРецептурнаяУпаковка,ЕдиницаИзмерения");
		
	ПараметрыОбъекта.ЭтоБлюдо = (РеквизитыНоменклатуры.питВидНоменклатуры = Перечисления.питВидыНоменклатуры.Блюдо);
	
	Если ПараметрыОбъекта.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.РецептураПриготовление
		ИЛИ ПараметрыОбъекта.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.РецептураРазукомплектацияБлюд Тогда
		ПараметрыОбъекта.Упаковка = РеквизитыНоменклатуры.питРецептурнаяУпаковка;
	Иначе
		ПараметрыОбъекта.Упаковка = Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка();
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(ПараметрыОбъекта.Упаковка) ИЛИ ПараметрыОбъекта.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.РецептураРазделка Тогда
		ПараметрыОбъекта.Упаковка = РеквизитыНоменклатуры.ЕдиницаИзмерения;
	КонецЕсли;
	
	// Устанавливаем дату начала действия на ближайшую незанятую секунду вперед (для способа расчета - по актуальной).
	Если ПараметрыОбъекта.СпособРасчетаРецептурыПоАктуальной Тогда
		Если НЕ ЗначениеЗаполнено(ПараметрыОбъекта.ДатаНачала) Тогда
			ПараметрыОбъекта.ДатаНачала = НачалоДня(ПараметрыОбъекта.Дата);
		КонецЕсли;
		НоваяДатаНачала = Документы.питРецептура.ПолучитьДругуюАктуальнуюРецептуру(ПараметрыОбъекта, ПараметрыОбъекта.ДатаНачала);
		Если ЗначениеЗаполнено(НоваяДатаНачала) Тогда
			ПараметрыОбъекта.ДатаНачала = НоваяДатаНачала;
		КонецЕсли;
		Если ЗначениеЗаполнено(ПараметрыОбъекта.ДатаКонца) И ПараметрыОбъекта.ДатаНачала > ПараметрыОбъекта.ДатаКонца Тогда
			ПараметрыОбъекта.ДатаКонца = КонецДня(ПараметрыОбъекта.ДатаНачала);
		КонецЕсли;
	КонецЕсли;
	
	Справочники.УпаковкиЕдиницыИзмерения.ОтобразитьИнформациюОЕдиницеХранения(Объект.Номенклатура, Элементы.Упаковка);
	
	УстановитьХарактеристикиИспользуютсяВШапке();
	питОбщегоНазначенияКлиентСервер.ОтобразитьИнформациюОХарактеристике(Элементы.Характеристика, ХарактеристикиИспользуются);
	
	питПроизводство.УстановитьВидимостьНадписиРазныеЕдиницы(Объект, Элементы, "Ингредиенты");
	
КонецПроцедуры

// Пересчеты реквизитов в строках табличных частей
// 
&НаСервере
Процедура ТоварыНоменклатураПриИзмененииНаСервере(СтрокаТабличнойЧасти, Знач ПараметрыОбъекта)
	
	ПараметрыОбъекта.Вставить("РазрешенныеПодразделения", Подразделения.Выгрузить());
	ТоварыНоменклатураПриИзмененииНаСервереБезКонтекста(СтрокаТабличнойЧасти, ПараметрыОбъекта);
	
КонецПроцедуры

// Пересчеты реквизитов в строках табличных частей
// 
&НаСервереБезКонтекста
Процедура ТоварыНоменклатураПриИзмененииНаСервереБезКонтекста(СтрокаТабличнойЧасти, Знач ПараметрыОбъекта)
	
	РеквизитыНоменклатуры = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СтрокаТабличнойЧасти.Номенклатура, 
		"питВидНоменклатуры, питРецептурнаяУпаковка, ЕдиницаИзмерения, питПроцентПотерьПриХолоднойОбработке, питПроцентПотерьПриГорячейОбработке");
	
	СтрокаТабличнойЧасти.ЭтоБлюдо = (РеквизитыНоменклатуры.питВидНоменклатуры = Перечисления.питВидыНоменклатуры.Блюдо);
	СтрокаТабличнойЧасти.ЭтоТовар = (РеквизитыНоменклатуры.питВидНоменклатуры = Перечисления.питВидыНоменклатуры.Товар);
	СтрокаТабличнойЧасти.Иконка = питДокументы.ОпределитьНомерИконкиНоменклатуры(РеквизитыНоменклатуры.питВидНоменклатуры, СтрокаТабличнойЧасти.Специя);
	
	Если ПараметрыОбъекта.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.РецептураПриготовление
		ИЛИ ПараметрыОбъекта.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.РецептураРазукомплектацияБлюд Тогда
		СтрокаТабличнойЧасти.Упаковка = РеквизитыНоменклатуры.питРецептурнаяУпаковка;
	Иначе
		СтрокаТабличнойЧасти.Упаковка = Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка();
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(СтрокаТабличнойЧасти.Упаковка) ИЛИ ПараметрыОбъекта.ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.РецептураРазделка Тогда
		СтрокаТабличнойЧасти.Упаковка = РеквизитыНоменклатуры.ЕдиницаИзмерения;
	КонецЕсли;
	////////////СтрокаТабличнойЧасти.Коэффициент = питДокументы.ПолучитьКоэффициентЕдиницыИзмерения(СтрокаТабличнойЧасти.Номенклатура, СтрокаТабличнойЧасти.Упаковка);
	
	Если СтрокаТабличнойЧасти.ЭтоБлюдо Тогда
		ДатаРецептуры = ?(ЗначениеЗаполнено(ПараметрыОбъекта.Ссылка), ПараметрыОбъекта.Дата, КонецДня(ПараметрыОбъекта.Дата));
		ХозяйственнаяОперацияРецептуры = ?(ЗначениеЗаполнено(ПараметрыОбъекта.ХозяйственнаяОперация), ПараметрыОбъекта.ХозяйственнаяОперация, Перечисления.питХозяйственныеОперации.РецептураПриготовление);
		
		Подразделения = питПроизводство.НайтиПодразделенияПоРазрешенным(ПараметрыОбъекта.РазрешенныеПодразделения);
		СтрокаТабличнойЧасти.Рецептура = питПроизводство.ВернутьОсновнуюРецептуру(СтрокаТабличнойЧасти.Номенклатура, СтрокаТабличнойЧасти.Характеристика,  ХозяйственнаяОперацияРецептуры,
			ДатаРецептуры, ПараметрыОбъекта.СпособРасчетаРецептурыПоАктуальной, , ПараметрыОбъекта.Организация,,,Подразделения);
	Иначе
		СтрокаТабличнойЧасти.Рецептура = Неопределено;
	КонецЕсли;
	
	ЕстьПроцентыПотерь = ЗначениеЗаполнено(РеквизитыНоменклатуры.питПроцентПотерьПриХолоднойОбработке) ИЛИ ЗначениеЗаполнено(РеквизитыНоменклатуры.питПроцентПотерьПриГорячейОбработке);
	ВсеРавноСчитатьПотери = Ложь;
	Если ПараметрыОбъекта.Свойство("ВсеРавноСчитатьПотери") Тогда
		ВсеРавноСчитатьПотери = ПараметрыОбъекта.ВсеРавноСчитатьПотери;
	КонецЕсли;
	
	Если ЕстьПроцентыПотерь ИЛИ ВсеРавноСчитатьПотери Тогда
		СтрокаТабличнойЧасти.ПроцентПотерьПриХолоднойОбработке = РеквизитыНоменклатуры.питПроцентПотерьПриХолоднойОбработке;
		СтрокаТабличнойЧасти.ПроцентПотерьПриГорячейОбработке  = РеквизитыНоменклатуры.питПроцентПотерьПриГорячейОбработке;
		ОпределитьКоличество(СтрокаТабличнойЧасти.КоличествоУпаковокНетто, СтрокаТабличнойЧасти.КоличествоУпаковокБрутто, СтрокаТабличнойЧасти.ПроцентПотерьПриХолоднойОбработке, Ложь, Ложь, СтрокаТабличнойЧасти.Специя, СтрокаТабличнойЧасти.НомерСтроки-1);
		ОпределитьКоличество(СтрокаТабличнойЧасти.КоличествоУпаковокВыход, СтрокаТабличнойЧасти.КоличествоУпаковокНетто, СтрокаТабличнойЧасти.ПроцентПотерьПриГорячейОбработке, Ложь, Истина, СтрокаТабличнойЧасти.Специя, СтрокаТабличнойЧасти.НомерСтроки-1);
	КонецЕсли;
	
КонецПроцедуры

