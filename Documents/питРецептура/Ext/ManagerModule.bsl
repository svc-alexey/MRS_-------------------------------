Процедура РассчитатьКоличествоВСтроке(ПартияВыпуска, Строка, ЕстьУпаковки, ЕстьРасчетПоФормуле, ЕстьВероятность, ДанныеДляРасчета = Неопределено)
	
	//+пит
	ЭтоУправлениеПредприятием = питПроизводствоПовтИсп.ПолучитьИмяОсновнойКонфигурации() = "УправлениеПредприятием";
	
	ВидКоличествДляРасчета = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питКоличествоДляРасчетаПоФормулеВРецептурах");
	Если НЕ ЗначениеЗаполнено(ВидКоличествДляРасчета) Тогда
		ВидКоличествДляРасчета = Перечисления.питВидыКоличеств.КоличествоБрутто;
	КонецЕсли;
	СуффиксКолонкиКоличеств = питОбщегоНазначенияКлиентСервер.СуффиксКолонкиКоличествПоВидуКоличеств(ВидКоличествДляРасчета);
	
	Если ЭтоУправлениеПредприятием Тогда
		//++ НЕ УТКА
		Если ЕстьРасчетПоФормуле И НЕ ПустаяСтрока(Строка.АлгоритмРасчетаКоличества) Тогда
			
			УправлениеДаннымиОбИзделиях.РассчитатьКоличествоПоФормуле(Строка, ДанныеДляРасчета, "КоличествоУпаковок"+СуффиксКолонкиКоличеств);
			
			Если ЕстьУпаковки Тогда
				
				СтруктураДействий = Новый Структура;
				СтруктураДействий.Вставить("ПересчитатьКоличествоЕдиницСуффикс", Новый Структура("Суффикс, НужноОкруглять", СуффиксКолонкиКоличеств, Ложь));
				
				ОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(Строка, СтруктураДействий, Неопределено);
				
			КонецЕсли;
			
			Возврат;
			
		КонецЕсли;
		//-- НЕ УТКА
	КонецЕсли;
	//-пит
	
	//+пит
	Если ЕстьУпаковки Тогда
		//ИмяПоляБазаДляРасчета = "КоличествоУпаковокНаЕдиницуПартииВыпуска";
		ИмяПоляБазаДляРасчета = "КоличествоУпаковок"+СуффиксКолонкиКоличеств;
	Иначе
		//ИмяПоляБазаДляРасчета = "КоличествоНаЕдиницуПартииВыпуска";
		ИмяПоляБазаДляРасчета = "Количество"+СуффиксКолонкиКоличеств;
	КонецЕсли;
	//-пит
	
	РезультатРасчета = Строка[ИмяПоляБазаДляРасчета] * ПартияВыпуска.Числитель / ПартияВыпуска.Знаменатель;
	
	//+пит
	//Если ЕстьВероятность И Строка.КоэффициентВероятности <> 1 Тогда
	//	РезультатРасчета = Окр(РезультатРасчета * Строка.КоэффициентВероятности, ?(Строка.УпаковкаШтучная, 0, 3));
	//КонецЕсли;
	
	//Если ЕстьУпаковки Тогда
	//	Строка.КоличествоУпаковокБрутто = РезультатРасчета;
	//	Строка.КоличествоБрутто         = Строка.КоличествоУпаковокБрутто * Строка.КоэффициентУпаковки;
	//Иначе
	//	Строка.Количество = РезультатРасчета;
	//КонецЕсли;
	//-пит
	
КонецПроцедуры

Процедура РассчитатьКоличество(ПартияВыпуска, Коллекция, ЕстьУпаковки, ЕстьРасчетПоФормуле, ЕстьВероятность, ДанныеДляРасчета = Неопределено)
	
	Для каждого Строка Из Коллекция Цикл
		
		РассчитатьКоличествоВСтроке(
			ПартияВыпуска,
			Строка,
			ЕстьУпаковки,
			ЕстьРасчетПоФормуле,
			ЕстьВероятность,
			ДанныеДляРасчета);
		
	КонецЦикла;
	
КонецПроцедуры

Функция СтруктураИсточниковДляРасчетаПоФормулам() Экспорт
	
	ИсточникиДанных = Новый Структура;
	
	ИсточникиДанных.Вставить("ОсновноеИзделие");
	
	ИсточникиДанных.Вставить("Ингредиенты", УправлениеДаннымиОбИзделиях.СоздатьТаблицуИсточниковДанныхДляРасчетаПоФормулам());
	//+пит
	ИсточникиДанных.Ингредиенты.Колонки.Добавить("КоличествоБрутто", Новый ОписаниеТипов("Число"));
	ИсточникиДанных.Ингредиенты.Колонки.Добавить("КоличествоНетто", Новый ОписаниеТипов("Число"));
	ИсточникиДанных.Ингредиенты.Колонки.Добавить("КоличествоВыход", Новый ОписаниеТипов("Число"));
	//-пит
	
	ИсточникиДанных.Вставить("ДанныеПоНоменклатуре"); // данные по номенклатуре распоряжения
	
	Возврат ИсточникиДанных;
	
КонецФункции

Процедура ЗаполнитьПереченьДанныхСпецификации(ПереченьДанных)
	
	ПереченьДанных = Новый Массив;
	ПереченьДанных.Добавить("Ингредиенты");
	
КонецПроцедуры

Функция ПереченьДанныхСпецификации(СписокСвойств = "", ИсключаяСвойства = "")
	
	ПереченьДанных = Новый Массив;
	ЗаполнитьПереченьДанныхСпецификации(ПереченьДанных);
	
	ЕстьСписокСвойств = НЕ ПустаяСтрока(СписокСвойств);
	Если ЕстьСписокСвойств ИЛИ НЕ ПустаяСтрока(ИсключаяСвойства) Тогда
	
		Для Индекс = -ПереченьДанных.ВГраница() По 0 Цикл
			
			Свойство = ПереченьДанных[-Индекс];
			
			Если ЕстьСписокСвойств И СтрНайти(СписокСвойств, Свойство) = 0
				ИЛИ СтрНайти(ИсключаяСвойства, Свойство) > 0 
				Тогда
				ПереченьДанных.Удалить(-Индекс);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат ПереченьДанных;
	
КонецФункции

// Функция - конструктор структуры параметров расчета количества данных спецификаций.
//
// Параметры:
//  ДанныеПоНоменклатуре - Структура - см. ДанныеПоНоменклатуреРасширенный()
//  СтруктураДанных		 - Структура - данные спецификации (кеш данных спецификации)
//  СписокСвойств		 - Строка	 - список свойств структуры ДанныеСпецификации, которые необходимо рассчитать
//  ИсключаяСвойства	 - Строка	 - список свойств структуры ДанныеСпецификации, которые необходимо исключить из расчета
// 
// Возвращаемое значение:
//  Структура - параметры расчета количества
//
Функция ПараметрыРасчетаКоличества(ДанныеПоНоменклатуре, СтруктураДанных = Неопределено, СписокСвойств = "", ИсключаяСвойства = "") Экспорт
	
	Результат = Новый Структура;
	
	Результат.Вставить("ДанныеПоНоменклатуре", ДанныеПоНоменклатуре);
	
	Результат.Вставить("СтруктураДанных", СтруктураДанных);
	Результат.Вставить("ПереченьДанных", ПереченьДанныхСпецификации(СписокСвойств, ИсключаяСвойства));
	
	Результат.Вставить("ИспользоватьОдновременноПроизводимоеКоличество", Истина);
	
	Возврат Результат;
	
КонецФункции

// Функция - конструктор структуры для выборки данных ресурсной спецификации.
//
// Возвращаемое значение:
//  Структура - структура с параметрами выборки данных спецификации.
//
Функция ДанныеПоНоменклатуреРасширенный() Экспорт
	
	ДанныеПоНоменклатуре = Новый Структура;
	
	ДанныеПоНоменклатуре.Вставить("Номенклатура");
	ДанныеПоНоменклатуре.Вставить("Характеристика");
	ДанныеПоНоменклатуре.Вставить("Спецификация");
	ДанныеПоНоменклатуре.Вставить("Рецептура");
	ДанныеПоНоменклатуре.Вставить("Количество");
	ДанныеПоНоменклатуре.Вставить("КоличествоУпаковок");
	ДанныеПоНоменклатуре.Вставить("Идентификатор", 0);
	
	
	Возврат ДанныеПоНоменклатуре;
	
КонецФункции

Процедура ДобавитьСтрокиДляРасчетаПоФормулам(НаборДанных, ДанныеСпецификации, ПереченьДанных)
	
	Отбор = Новый Структура("АлгоритмРасчетаКоличества", "");
	
	//+пит
	СоставТЧ = 
		СтрРазделить("Ингредиенты",",");
	//-пит
	
	Для каждого ИмяТЧ Из СоставТЧ Цикл
		
		Если ПереченьДанных.Найти(ИмяТЧ) <> Неопределено Тогда
			
			Если ДанныеСпецификации.Свойство(ИмяТЧ)
				И ДанныеСпецификации[ИмяТЧ].НайтиСтроки(Отбор).Количество() <> ДанныеСпецификации[ИмяТЧ].Количество() Тогда
				
				Если ДанныеСпецификации[ИмяТЧ].Колонки.Найти("Формула") = Неопределено Тогда
					ДанныеСпецификации[ИмяТЧ].Колонки.Добавить("Формула", Новый ОписаниеТипов("Строка"));
				КонецЕсли;
				
				НаборДанных.Добавить(ДанныеСпецификации[ИмяТЧ]);
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ИсточникДанныхДляРасчетаПоФормулам(ПутьКДанным, ИсточникиДанных) Экспорт
	
	Источник = Неопределено;
	
	Если ПутьКДанным.Ключ = "ОсновноеИзделие" Тогда
		
		Источник = УправлениеДаннымиОбИзделиях.СоздатьСтруктуруДанныхИсточникаДляРасчетаПоФормулам();
		ЗаполнитьЗначенияСвойств(Источник, ИсточникиДанных.ОсновноеИзделие);
		
	ИначеЕсли ПутьКДанным.Ключ = "Ингредиенты" Тогда
		
		ДанныеСтроки = ИсточникиДанных[ПутьКДанным.Ключ].Найти(ПутьКДанным.НомерСтроки, "НомерСтроки");
		Если ДанныеСтроки <> Неопределено Тогда
			Источник = УправлениеДаннымиОбИзделиях.СоздатьСтруктуруДанныхИсточникаДляРасчетаПоФормулам();
			//+пит
			Источник.Вставить("КоличествоБрутто");
			Источник.Вставить("КоличествоНетто");
			Источник.Вставить("КоличествоВыход");
			//-пит
			ЗаполнитьЗначенияСвойств(Источник, ДанныеСтроки);
		КонецЕсли;
		
	ИначеЕсли ПутьКДанным.Ключ = "Ингредиент" Тогда
		
		Источник = УправлениеДаннымиОбИзделиях.СоздатьСтруктуруДанныхИсточникаДляРасчетаПоФормулам();
		//+пит
		Источник.Вставить("КоличествоБрутто");
		Источник.Вставить("КоличествоНетто");
		Источник.Вставить("КоличествоВыход");
		//-пит
		ЗаполнитьЗначенияСвойств(Источник, ПутьКДанным.ДанныеСтроки);
		
	КонецЕсли;
	
	Возврат Источник;
	
КонецФункции


