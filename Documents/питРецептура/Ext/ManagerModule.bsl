Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	// Проверяем, нужно ли для макета "..." формировать табличный документ.
	// А затем формируем табличный документ, и добавляем его в коллекцию печатных форм.
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "питОП1") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "питОП1", "ОП-1",
			ПечатьОП1(МассивОбъектов, ОбъектыПечати, ПараметрыПечати),,"ОбщийМакет.ПФ_MXL_питОП1");
	КонецЕсли;
		
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "питОП1_СПараметрами") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "питОП1_СПараметрами", "ОП-1",
			ПечатьОП1(МассивОбъектов, ОбъектыПечати, ПараметрыПечати),,"ОбщийМакет.ПФ_MXL_питОП1");
	КонецЕсли;
	
	//АдагамовАР., НЭП, 14.07.2024. ORIP-1425. ++
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "НЭП_питОП1_СПараметрами") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "НЭП_питОП1_СПараметрами", "ОП-1",
			ПечатьОП1(МассивОбъектов, ОбъектыПечати, ПараметрыПечати),,"ОбщийМакет.ПФ_MXL_питОП1");
	КонецЕсли;
	//АдагамовАР., НЭП, 14.07.2024. ORIP-1425. --
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ТехКарта") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ТехКарта", "Тех. карта",
			ПечатьТехКарта(МассивОбъектов, ОбъектыПечати,ПараметрыПечати),,"ОбщийМакет.ПФ_MXL_питТехнологическаяКарта");
	КонецЕсли;
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ТехКартаРассчитываемая") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ТехКартаРассчитываемая", "Технико-технологическая карта",
			ПечатьТехКарта(МассивОбъектов, ОбъектыПечати, ПараметрыПечати),,"ОбщийМакет.ПФ_MXL_питТехнологическаяКарта");
	КонецЕсли;
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ТехТехнолКарта") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ТехТехнолКарта", "Технико-технологическая карта",
			ПечатьТехТехнолКарта(МассивОбъектов, ОбъектыПечати, ПараметрыПечати),,"ОбщийМакет.ПФ_MXL_питТехникоТехнологическаяКарта");
	КонецЕсли;
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ТехТехнолКартаГОСТ") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ТехТехнолКартаГОСТ", "Технико-технологическая карта ГОСТ",
			ПечатьТехТехнолКарта(МассивОбъектов, ОбъектыПечати, ПараметрыПечати),,"ОбщийМакет.ПФ_MXL_питТехникоТехнологическаяКартаГОСТ");
	КонецЕсли;
		
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ТехТехнолКартаПарам") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ТехТехнолКартаПарам", "Технико-технологическая карта",
			ПечатьТехТехнолКарта(МассивОбъектов, ОбъектыПечати, ПараметрыПечати),,"ОбщийМакет.ПФ_MXL_питТехникоТехнологическаяКарта");
	КонецЕсли;

	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "СоставХЭХ") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "СоставХЭХ", "Состав химикоэнергетических характеристик",
			ПечатьСоставХЭХ(МассивОбъектов, ОбъектыПечати, ПараметрыПечати),,"Документ.питРецептура.ПФ_MXL_СоставХЭХ");
КонецЕсли;  
		
	//<< Каюмов А.А., ВиП, 25.09.2023, I-143. Печать этикеток из рецептур 
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ВИП_ПФ_MXL_Этикетка") Тогда 
		
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ВИП_ПФ_MXL_Этикетка", "Этикетка",
			ВИП_ПечатьЭтикетки(МассивОбъектов, ОбъектыПечати, ПараметрыПечати),,"Документ.питРецептура.ВИП_ПФ_MXL_Этикетка"); 
			
	КонецЕсли;
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ВИП_ЭтикеткаПредпросмтор") Тогда 
		
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ВИП_ЭтикеткаПредпросмтор", "Этикетка",
			ВИП_ПечатьЭтикетки(МассивОбъектов, ОбъектыПечати, ПараметрыПечати),,"Документ.питРецептура.ВИП_ПФ_MXL_Этикетка"); 
			
	КонецЕсли;
	//>>	
КонецПроцедуры

