// Печать

// Формирует печатную форму "ОП-1"
//
// Возвращаемое значение:
//  Табличный документ - печатная форма накладной
//
Функция ПечатьОП1(МассивОбъектов, ОбъектыПечати, ПараметрыПечати=Неопределено)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если ПараметрыПечати <> Неопределено И ПараметрыПечати.Свойство("СтруктураПараметровОП1") Тогда
		СтруктураПараметров = ПараметрыПечати.СтруктураПараметровОП1;
	//АдагамовАР., НЭП, 14.07.2024. ORIP-1425. ++	
	ИначеЕсли ПараметрыПечати <> Неопределено И ПараметрыПечати.Свойство("НЭП_СтруктураПараметровОП1") Тогда
		СтруктураПараметров = ПараметрыПечати.НЭП_СтруктураПараметровОП1;		
	//АдагамовАР., НЭП, 14.07.2024. ORIP-1425. --	
	Иначе
		СтруктураПараметров = Новый Структура();
		СтруктураПараметров.Вставить("РецептурнаяЕдиница", Истина);
	КонецЕсли;
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.АвтоМасштаб = Истина;
	ТабличныйДокумент.ПолеСверху = 0;
	ТабличныйДокумент.ПолеСлева  = 0;
	ТабличныйДокумент.ПолеСнизу  = 0;
	ТабличныйДокумент.ПолеСправа = 0;
	ТабличныйДокумент.ОриентацияСтраницы  = ОриентацияСтраницы.Ландшафт;
	ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_Рецептура_ОП1";
	
	МассивРецептуры = Новый Массив; // для исключения дублирования блюд
	
	ПервыйДокумент = Истина;
	
	Для Каждого ДокументСсылка Из МассивОбъектов Цикл
		
		Если НЕ ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		
		ПервыйДокумент = Ложь;
		// Запомним номер строки, с которой начали выводить текущий документ.
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		// Выведем калькуляцию
		////ОбщептЕРП!!!
		питОтчеты.ВывестиКалькуляцию(ТабличныйДокумент, ДокументСсылка, ДокументСсылка, , СтруктураПараметров);
		
		// В табличном документе зададим имя области, в которую был 
		// выведен объект. Нужно для возможности печати покомплектно.
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, 
			НомерСтрокиНачало, ОбъектыПечати, ДокументСсылка.Ссылка);
		
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
	
КонецФункции // ПечатьОП1()

// Формирует и возвращает текст запроса для выборки данных,
// необходимых для формирования печатной формы.
Функция ПолучитьТекстЗапросаДляФормированияПечатнойФормыТехКарта()
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	питРецептура.Ссылка КАК Ссылка,
	|	питРецептура.Номер КАК Номер,
	|	питРецептура.Дата КАК Дата,
	|	питРецептура.Организация,
	|	питРецептура.Ответственный,
	|	питРецептура.Номенклатура,
	|	питРецептура.Характеристика,
	|	питРецептура.КоличествоУпаковок КАК Количество,
	|	питРецептура.Упаковка,
	|	питРецептура.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаХранения,
	|	питРецептура.Выход,
	|	питРецептура.НомерРецептуры,
	|	питРецептура.ТехнологияПриготовления,
	|	ДокументОснованиеРецептуры.Ссылка КАК ДокументОснование,
	|	ДокументОснованиеРецептуры.Номер КАК ДокументОснованиеНомер,
	|	ДокументОснованиеРецептуры.Дата КАК ДокументОснованиеДата,
	|	1 КАК ID,
	|	питРецептура.Ингредиенты.(
	|		НомерСтроки КАК НомерСтроки,
	|		Номенклатура,
	|		Характеристика,
	|		Номенклатура.НаименованиеПолное КАК Товар,
	|		Упаковка.Представление КАК ЕдиницаИзмерения,
	|		Номенклатура.ЕдиницаИзмерения.Представление КАК ЕдиницаХранения,
	|		КоличествоУпаковокБрутто КАК КоличествоУпаковок,
	|		КоличествоУпаковокНетто КАК КоличествоУпаковокНетто,
	|		КоличествоУпаковокВыход КАК КоличествоУпаковокВыход,
	|		КлючСвязи КАК КлючСвязи,
	|		ПроцентПотерьПриХолоднойОбработке КАК ПроцентОтходовХолоднойОбработки,
	|		ПроцентПотерьПриГорячейОбработке КАК ПроцентОтходовТепловойОбработки,
	//<< Портал-Юг, Свинцов И.И., 2019.10.03 [9.07. Пересчет весовых показателей в печатных формах рецептур] 
	// Рассчитываем коэф пересчета (только для документов "Рецептура") и выводим единицу измерения веса
	// Если товар не весовой коэф = 0
	|		ВЫБОР
	|			КОГДА НЕ питРецептура.Ингредиенты.Номенклатура.ВесИспользовать
	|				ТОГДА 0
	//<<Портал-Юг, Каунов, 2019.11.26
	|			КОГДА питРецептура.Ингредиенты.КоличествоУпаковокВыход = 0
	|				ТОГДА 0
	//>>Портал-Юг, Каунов, 2019.11.26	
	|			ИНАЧЕ питРецептура.Ингредиенты.КоличествоВыход * питРецептура.Ингредиенты.Номенклатура.ВесЧислитель / ВЫБОР
	|					КОГДА питРецептура.Ингредиенты.Номенклатура.ВесЗнаменатель = 0
	|						ТОГДА 1
	|					ИНАЧЕ питРецептура.Ингредиенты.Номенклатура.ВесЗнаменатель
	|				КОНЕЦ / питРецептура.Ингредиенты.КоличествоУпаковокВыход
	|		КОНЕЦ КАК Коэф ,
	|	Номенклатура.ВесЕдиницаИзмерения.Представление КАК ВесЕдиницаИзмерения,
	//>> Портал-Юг, Свинцов И.И., 2019.10.03
	//+АвтовыборНоменклатуры
	|		Рецептура КАК Рецептура,
	|		СпособАвтовыбораНоменклатуры КАК СпособАвтовыбораНоменклатуры,
	|		СпособАвтовыбораХарактеристики КАК СпособАвтовыбораХарактеристики,
	|		СвойствоСодержащееНоменклатуру КАК СвойствоСодержащееНоменклатуру,
	|		АлгоритмАвтовыбораХарактеристики КАК АлгоритмАвтовыбораХарактеристики,
	|		Номенклатура.питВидНоменклатуры КАК НоменклатурапитВидНоменклатуры
	//-АвтовыборНоменклатуры
	|	) КАК Ингредиенты
	|ИЗ
	|	Документ.питРецептура КАК питРецептура
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.питАктПроработки КАК ДокументОснованиеРецептуры
	|		ПО (ДокументОснованиеРецептуры.Ссылка = питРецептура.ДокументОснование)
	|ГДЕ
	|	питРецептура.Ссылка В(&МассивОбъектов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	питАктПроработки.Ссылка,
	|	питАктПроработки.Номер,
	|	питАктПроработки.Дата,
	|	питАктПроработки.Организация,
	|	питАктПроработки.Ответственный,
	|	питАктПроработки.Номенклатура,
	|	питАктПроработки.Характеристика,
	|	питАктПроработки.КоличествоУпаковок КАК Количество,
	|	питАктПроработки.Упаковка,
	|	питАктПроработки.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаХранения,
	|	питАктПроработки.Выход,
	|	питАктПроработки.НомерРецептуры,
	|	питАктПроработки.ТехнологияПриготовления,
	|	NULL,
	|	NULL,
	|	NULL,
	|	2,
	|	питАктПроработки.Ингредиенты.(
	|		НомерСтроки,
	|		Номенклатура,
	|		Характеристика,
	|		Номенклатура.НаименованиеПолное,
	|		Упаковка.Представление,
	|		Номенклатура.ЕдиницаИзмерения.Представление КАК ЕдиницаИзмерения,
	|		ВЫРАЗИТЬ((КоличествоУпаковокБрутто + КоличествоУпаковокБрутто1 + КоличествоУпаковокБрутто2) / 3 КАК ЧИСЛО(15,3)),
	|		ВЫРАЗИТЬ((КоличествоУпаковокНетто + КоличествоУпаковокНетто1 + КоличествоУпаковокНетто2) / 3 КАК ЧИСЛО(15,3)),
	|		ВЫРАЗИТЬ((КоличествоУпаковокВыход + КоличествоУпаковокВыход1 + КоличествоУпаковокВыход2) / 3 КАК ЧИСЛО(15,3)),
	|		"""" КАК КлючСвязи,
	|		0,
	|		0,
	//<< Портал-Юг, Свинцов И.И., 2019.10.03 [9.07. Пересчет весовых показателей в печатных формах рецептур] 
	|		1,
	|		Номенклатура.ЕдиницаИзмерения.Представление,
	//>> Портал-Юг, Свинцов И.И., 2019.10.03
	//+АвтовыборНоменклатуры
	|		ЗНАЧЕНИЕ(Документ.питРецептура.ПустаяСсылка) КАК Рецептура,
	|		ЗНАЧЕНИЕ(Перечисление.СпособыАвтовыбораНоменклатуры.УказываетсяВНСИ) КАК СпособАвтовыбораНоменклатуры,
	|		ЗНАЧЕНИЕ(Перечисление.СпособыАвтовыбораХарактеристики.УказываетсяВНСИ) КАК СпособАвтовыбораХарактеристики,
	|		"""" КАК СвойствоСодержащееНоменклатуру,
	|		"""" КАК АлгоритмАвтовыбораХарактеристики,
	|		Номенклатура.питВидНоменклатуры КАК НоменклатурапитВидНоменклатуры
	//-АвтовыборНоменклатуры
	|	)
	|ИЗ
	|	Документ.питАктПроработки КАК питАктПроработки
	|ГДЕ
	|	питАктПроработки.Ссылка В(&МассивОбъектов)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата,
	|	Ссылка,
	|	ID,
	|	НомерСтроки";
	
	Возврат ТекстЗапроса;
	
КонецФункции

// Функция формирует табличный документ с печатной формой "Технологическая карта".
//
// Возвращаемое значение:
//  Табличный документ - печатная форма акта проработки.
//
Функция ПечатьТехКарта(МассивОбъектов, ОбъектыПечати, ПараметрыПечати = Неопределено)
	
	УстановитьПривилегированныйРежим(Истина);
	
	РассчитываемоеКоличество = Неопределено;
	КоэффициентПересчета = 1;
	НеИспользоватьСезонныеПроценты = питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("питНеИспользоватьСезонныеПроценты");
	ДатаФормирования = ТекущаяДата();
	
	//+ПараметризацияРецептур
	питПодразделениеПроизводства = Неопределено;
	//-ПараметризацияРецептур
	
	//+АвтовыборНоменклатуры
	УточненияАвтовыбора = Неопределено;
	//-АвтовыборНоменклатуры
	
	РазворачиватьДоИнгредиентов = Ложь;
	
	Если ПараметрыПечати <> Неопределено И ПараметрыПечати.Свойство("СтруктураПараметровТехКарта") Тогда
		СтруктураПараметров = ПараметрыПечати.СтруктураПараметровТехКарта;
		Если СтруктураПараметров.Свойство("РассчитываемоеКоличество") Тогда
			РассчитываемоеКоличество = СтруктураПараметров.РассчитываемоеКоличество;
		КонецЕсли;
		Если СтруктураПараметров.Свойство("НеИспользоватьСезонныеПроценты") Тогда
			НеИспользоватьСезонныеПроценты = СтруктураПараметров.НеИспользоватьСезонныеПроценты;
		КонецЕсли;
		Если СтруктураПараметров.Свойство("ДатаФормирования") Тогда
			ДатаФормирования = СтруктураПараметров.ДатаФормирования;
		КонецЕсли;
		Если СтруктураПараметров.Свойство("РазворачиватьДоИнгредиентов") Тогда
			РазворачиватьДоИнгредиентов = СтруктураПараметров.РазворачиватьДоИнгредиентов;
		КонецЕсли;
		//+ПараметризацияРецептур
		Если СтруктураПараметров.Свойство("питПодразделениеПроизводства") Тогда
			питПодразделениеПроизводства = СтруктураПараметров.питПодразделениеПроизводства;
		КонецЕсли;
		//-ПараметризацияРецептур
		//+АвтовыборНоменклатуры
		Если СтруктураПараметров.Свойство("УточненияАвтовыбора") Тогда
			УточненияАвтовыбора = ПолучитьИзВременногоХранилища(СтруктураПараметров.УточненияАвтовыбора);
		КонецЕсли;
		//-АвтовыборНоменклатуры
	КонецЕсли;
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.АвтоМасштаб = Истина;
	ТабличныйДокумент.ПолеСверху = 0;
	ТабличныйДокумент.ПолеСлева  = 0;
	ТабличныйДокумент.ПолеСнизу  = 0;
	ТабличныйДокумент.ПолеСправа = 0;
	ТабличныйДокумент.ОриентацияСтраницы  = ОриентацияСтраницы.Ландшафт;
	ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_Рецептура_ТехКарта";
	
	Макет = УправлениеПечатью.МакетПечатнойФормы("ОбщийМакет.ПФ_MXL_питТехнологическаяКарта");
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	Запрос.Текст = ПолучитьТекстЗапросаДляФормированияПечатнойФормыТехКарта();
	
	Шапка = Запрос.Выполнить().Выбрать();
	
	ПервыйДокумент = Истина;
	
	// Служебная структура, хранящая кэшированные значения, уменбшает общее число запросов 
	//  к базе во время заполнения дерева состава, вычисления сезонных процентов и т.д.
	КэшЗаполненияДерева = питПроизводство.ИнициализироватьСтруктуруКэшированныхЗначенийДляЗаполненияДереваСостава();
	
	Пока Шапка.Следующий() Цикл
		
		//+АвтовыборНоменклатуры
		Если УточненияАвтовыбора = Неопределено И ТипЗнч(Шапка.Ссылка) = Тип("ДокументСсылка.питРецептура") Тогда
			УточненияАвтовыбора = питУправлениеДаннымиОбИзделиях.ПолучитьТаблицуУточненийАвтовыбораПоДокументу(Шапка.Ссылка);
		КонецЕсли;
		//-АвтовыборНоменклатуры
		
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		
		ПервыйДокумент = Ложь;
		// Запомним номер строки, с которой начали выводить текущий документ.
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		Если РассчитываемоеКоличество<>Неопределено И Шапка.Количество<>0 Тогда
			КоэффициентПересчета = РассчитываемоеКоличество / Шапка.Количество;
		Иначе
			КоэффициентПересчета = 1;
		КонецЕсли;
		
		// Выводим шапку накладной
		
		ЕдиницаШапкиДляВывода = ?(ЗначениеЗаполнено(Шапка.Упаковка),Шапка.Упаковка, Шапка.ЕдиницаХранения);
		
		ОбластьЗаголовок = Макет.ПолучитьОбласть("Заголовок");
		ОбластьЗаголовок.Параметры.Заполнить(Шапка);
		ОбластьЗаголовок.Параметры.Номенклатура = СокрЛП(Шапка.Номенклатура.НаименованиеПолное)+ "" + ?(ЗначениеЗаполнено(Шапка.Характеристика)," / " + СокрЛП(Шапка.Характеристика.НаименованиеПолное),"") + ", "+Строка(Окр(Шапка.Количество*КоэффициентПересчета,3))+" " + ЕдиницаШапкиДляВывода;
		СведенияОбОрганизации    = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Шапка.Организация, ДатаФормирования);
		ПредставлениеОрганизации = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОбОрганизации, "НаименованиеДляПечатныхФорм,");
		ОбластьЗаголовок.Параметры.Организация = ПредставлениеОрганизации;
		ТабличныйДокумент.Вывести(ОбластьЗаголовок);
		
		// Шапка таблицы
		ОбластьШапка = Макет.ПолучитьОбласть("ШапкаТаблицы");
		ОбластьШапка.Параметры.КолвоПорций = " 1 " + ЕдиницаШапкиДляВывода;
		ТабличныйДокумент.Вывести(ОбластьШапка);
		
		// Вывести табличную часть
		ВыборкаСтрокТовары = Шапка.Ингредиенты.Выбрать();
		
		ОбластьСтрока = Макет.ПолучитьОбласть("Строка");
		
		ИтогоВыход = 0;
		
		ИспользуетсяДеревоСостава = Ложь;
		Если ТипЗнч(Шапка.Ссылка) = Тип("ДокументСсылка.питРецептура") 
			И РазворачиватьДоИнгредиентов Тогда
			
			ИспользуетсяДеревоСостава = Истина;
			
			МассивПодразделенийПФ = Неопределено;
			Если НЕ питПодразделениеПроизводства = Неопределено Тогда
				МассивПодразделенийПФ = Новый Массив(1);
				МассивПодразделенийПФ[0] = питПодразделениеПроизводства;
			КонецЕсли;
			
			СтруктураРассчитываемогоБлюдо = Неопределено;
			СтруктураРассчитываемогоБлюдо = Новый Структура("Блюдо,Характеристика,Упаковка",Шапка.Номенклатура,Шапка.Характеристика,Шапка.Упаковка);
			ДеревоСостава	= питПроизводство.РассчитатьДеревоСоставаРецептуры(Шапка.Ссылка,,Шапка.Количество,,,,,,,,,,СтруктураРассчитываемогоБлюдо,,,,,,,,,МассивПодразделенийПФ,питПодразделениеПроизводства,,УточненияАвтовыбора);
			ТаблицаТовары = питОбщегоНазначения.СоздатьТаблицуЗначенийПоРезультату(ДеревоСостава, Истина);
			Для каждого ТекСтрокаТовары Из ТаблицаТовары Цикл
				Если НЕ ЗначениеЗаполнено(ТекСтрокаТовары.ЕдиницаИзмерения) Тогда
					ТекСтрокаТовары.ЕдиницаИзмерения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекСтрокаТовары.Номенклатура, "ЕдиницаИзмерения");
				КонецЕсли;
			КонецЦикла;
			КолонкиГруппировокСтрокой = "";
			КолонкиСверткиСтрокой = "";
			Для каждого ТекКолонкаДерева Из ДеревоСостава.Колонки Цикл
				Если СтрНайти(ТекКолонкаДерева.Имя, "СтатьяКалькуляции") Тогда
					Продолжить;
				КонецЕсли;
				Если СтрНайти(ТекКолонкаДерева.Имя, "Количество") Тогда
					КолонкиСверткиСтрокой = КолонкиСверткиСтрокой + ?(ПустаяСтрока(КолонкиСверткиСтрокой), "", ",") + ТекКолонкаДерева.Имя;
				Иначе
					КолонкиГруппировокСтрокой = КолонкиГруппировокСтрокой + ?(ПустаяСтрока(КолонкиГруппировокСтрокой), "", ",") + ТекКолонкаДерева.Имя;
				КонецЕсли;
			КонецЦикла;
			ТаблицаТовары.Свернуть(КолонкиГруппировокСтрокой, КолонкиСверткиСтрокой);
			
			// Функция "РассчитатьДеревоСоставаРецептуры" не считает процент ХО и ГО.
			ТаблицаТовары.Колонки.Добавить("ПроцентОтходовХолоднойОбработки", ОбщегоНазначения.ОписаниеТипаЧисло(15,3));
			ТаблицаТовары.Колонки.Добавить("ПроцентОтходовТепловойОбработки", ОбщегоНазначения.ОписаниеТипаЧисло(15,3));
			Для каждого ТекСтрокаТовары Из ТаблицаТовары Цикл
				ТекСтрокаТовары.ПроцентОтходовХолоднойОбработки = (
					(ТекСтрокаТовары.КоличествоУпаковок - ТекСтрокаТовары.КоличествоУпаковокНетто)
					/ ТекСтрокаТовары.КоличествоУпаковок)*100;
				ТекСтрокаТовары.ПроцентОтходовТепловойОбработки = (
					(ТекСтрокаТовары.КоличествоУпаковокНетто - ТекСтрокаТовары.КоличествоУпаковокВыход)
					/ ТекСтрокаТовары.КоличествоУпаковокНетто)*100;
			КонецЦикла;
			
		Иначе
			
			ТаблицаТовары = Шапка.Ингредиенты.Выгрузить();
			
			//+ПараметризацияРецептур
			Если ТипЗнч(Шапка.Ссылка) = Тип("ДокументСсылка.питРецептура") 
				И ЗначениеЗаполнено(Шапка.Ссылка) Тогда
				Если питПодразделениеПроизводства = Неопределено Тогда
					питПодразделениеПроизводства = питОбщегоНазначения.ЗначениеРеквизитаОбъекта(Шапка.Ссылка, "Подразделение");
				КонецЕсли;
				ТаблицаОтборПоСвойствам = питУправлениеСвойствами.ПолучитьТаблицуОтборПоСвойствам(Шапка.Ссылка, питПодразделениеПроизводства);
				СПОтборПоСвойствам = Новый Структура("КлючСвязи");
			КонецЕсли;
			//-ПараметризацияРецептур
			
			//+АвтовыборНоменклатуры
			питУправлениеДаннымиОбИзделиях.ОбработатьНастройкиАвтовыбораНоменклатуры(ТаблицаТовары, Шапка.Ссылка, Шапка.Количество, Шапка, УточненияАвтовыбора);
			//-АвтовыборНоменклатуры
			
			СтрокиУдалить = Новый Массив;
			
			Для каждого ТекСтрокаТовары Из ТаблицаТовары Цикл
				
				//+ПараметризацияРецептур
				Если ТипЗнч(Шапка.Ссылка) = Тип("ДокументСсылка.питРецептура") 
					И ЗначениеЗаполнено(Шапка.Ссылка) Тогда
					СПОтборПоСвойствам.КлючСвязи = ТекСтрокаТовары.КлючСвязи;
					СтрокиОтборПоСвойствам = ТаблицаОтборПоСвойствам.НайтиСтроки(СПОтборПоСвойствам);
					ТекИспользуется = Истина;
					Для каждого ТекСтрокаОтборПоСвойствам Из СтрокиОтборПоСвойствам Цикл
						Если НЕ ТекСтрокаОтборПоСвойствам.Используется Тогда
							ТекИспользуется = Ложь;
						КонецЕсли;
					КонецЦикла;
					Если НЕ ТекИспользуется Тогда
						СтрокиУдалить.Добавить(ТекСтрокаТовары);
					КонецЕсли;
				КонецЕсли;
				//-ПараметризацияРецептур
				
			КонецЦикла;
			
			Для каждого ТекСтрокаУдалить Из СтрокиУдалить Цикл
				ТаблицаТовары.Удалить(ТекСтрокаУдалить);
			КонецЦикла;
			
		КонецЕсли;
		
		Для каждого ВыборкаСтрокТовары Из ТаблицаТовары Цикл
			
			ОбластьСтрока.Параметры.Заполнить(ВыборкаСтрокТовары);
			
			Если ЗначениеЗаполнено(ВыборкаСтрокТовары.Номенклатура) Тогда
				ОбластьСтрока.Параметры.Номенклатура = СокрЛП(ВыборкаСтрокТовары.Номенклатура.НаименованиеПолное)+ "" + ?(ЗначениеЗаполнено(ВыборкаСтрокТовары.Характеристика)," / " + СокрЛП(ВыборкаСтрокТовары.Характеристика.НаименованиеПолное),"");
			Иначе
				ОбластьСтрока.Параметры.Номенклатура = "<Уточняется при производстве>";
			КонецЕсли;
			
			Если ВыборкаСтрокТовары.КоличествоУпаковок > 0 Тогда
				ОбластьСтрока.Параметры.ПроцентОтходовТепловойОбработки	= ВыборкаСтрокТовары.ПроцентОтходовХолоднойОбработки;
			КонецЕсли;
			Если ВыборкаСтрокТовары.КоличествоУпаковокНетто > 0 Тогда
				ОбластьСтрока.Параметры.ПроцентОтходовТепловойОбработки	= ВыборкаСтрокТовары.ПроцентОтходовТепловойОбработки;
			КонецЕсли;
			
			ОбластьСтрока.Параметры.Количество      = ВыборкаСтрокТовары.КоличествоУпаковок;
			ОбластьСтрока.Параметры.КоличествоНетто = ВыборкаСтрокТовары.КоличествоУпаковокНетто;
			ОбластьСтрока.Параметры.КоличествоВыход = ВыборкаСтрокТовары.КоличествоУпаковокВыход;
			
			//<<=== Плотникова Н. 05.10.2021 
			пл_КоличествоУпаковокВыход = ВыборкаСтрокТовары.КоличествоУпаковокВыход;	
			//>>=== Плотникова Н.Ю. 05.10.2021 
			
			ОбластьСтрока.Параметры.КоличествоНеттоНаКоличествоПорций = ОбластьСтрока.Параметры.КоличествоНетто / Шапка.Количество;
			Если КоэффициентПересчета <> 1 Тогда
				ОбластьСтрока.Параметры.Количество      = ВыборкаСтрокТовары.КоличествоУпаковок * КоэффициентПересчета;
				ОбластьСтрока.Параметры.КоличествоНетто = ВыборкаСтрокТовары.КоличествоУпаковокНетто * КоэффициентПересчета;
				ОбластьСтрока.Параметры.КоличествоВыход = ВыборкаСтрокТовары.КоличествоУпаковокВыход * КоэффициентПересчета;
				
				//<<=== Плотникова Н. 05.10.2021 
				пл_КоличествоУпаковокВыход = ВыборкаСтрокТовары.КоличествоУпаковокВыход * КоэффициентПересчета;	
				//>>=== Плотникова Н.Ю. 05.10.2021
				
			КонецЕсли;
			
			// В случае, если производится нормативный расчет калькуляции, то следует учесть влияние сезонного коэффициента.
			Если НЕ НеИспользоватьСезонныеПроценты Тогда
				СезонныйПроцент = питЛицензированиеСервер.ПолучитьСезонныйПроцент(ВыборкаСтрокТовары.Номенклатура, ДатаФормирования, КэшЗаполненияДерева.КэшСезонныхПроцентов);
				СезонныйКоэффициент = 1+СезонныйПроцент/100;
				ОбластьСтрока.Параметры.Количество = ВыборкаСтрокТовары.КоличествоУпаковок * КоэффициентПересчета * СезонныйКоэффициент;
			КонецЕсли;
			Если НЕ ЗначениеЗаполнено(ОбластьСтрока.Параметры.ЕдиницаИзмерения) Тогда
				Если ИспользуетсяДеревоСостава Тогда
					ОбластьСтрока.Параметры.ЕдиницаИзмерения = ВыборкаСтрокТовары.Номенклатура.ЕдиницаИзмерения;
				Иначе
					ОбластьСтрока.Параметры.ЕдиницаИзмерения = ВыборкаСтрокТовары.ЕдиницаХранения;
				КонецЕсли;
			КонецЕсли;
			
			// << MRS  #HELP1C-9787 ДенисламовАД <Adel.Denislamov@mriyaresort.com> 06.11.2024 [Обновление релиза]
			//ТабличныйДокумент.Вывести(ОбластьСтрока);
			//
			//ИтогоВыход = ИтогоВыход + ВыборкаСтрокТовары.КоличествоУпаковокВыход;
			// >> MRS  #HELP1C-9787 ДенисламовАД <Adel.Denislamov@mriyaresort.com> 06.11.2024 [Обновление релиза]
			
			//<<===ПорталЮгКрым, Плотникова Н.Ю. 06.09.2021 [исправление ошибок обновления] 
			//ИтогоВыход = ИтогоВыход + ВыборкаСтрокТовары.КоличествоУпаковокВыход;
			
			мКоличествоВыход = ?(ТаблицаТовары.Колонки.Найти("КоличествоВыход")=Неопределено,0,ВыборкаСтрокТовары.КоличествоВыход);
			мНомерСтроки = ?(ТаблицаТовары.Колонки.Найти("КоличествоВыход")=Неопределено,ВыборкаСтрокТовары.НомерСтроки,0);
			пл_СтрукВозврат = ПЛ_ВернутьВесовойКоэффициент(Новый Структура("Номенклатура,КоличествоВыход,КоличествоУпаковокВыход,Ссылка,НомерСтроки,РассчитываемоеКоличество",ВыборкаСтрокТовары.Номенклатура,мКоличествоВыход,пл_КоличествоУпаковокВыход,Шапка.Ссылка,мНомерСтроки,КоэффициентПересчета));
			Коэф = пл_СтрукВозврат.Коэф;
			
			Прочерк = "----";
			ОбластьСтрока.Параметры.Количество      = ?(Коэф = 0, Прочерк, ОбластьСтрока.Параметры.Количество * Коэф);
			ОбластьСтрока.Параметры.КоличествоНетто = ?(Коэф = 0, Прочерк, ОбластьСтрока.Параметры.КоличествоНетто * Коэф);
			ОбластьСтрока.Параметры.КоличествоВыход = ?(Коэф = 0, Прочерк, ОбластьСтрока.Параметры.КоличествоВыход * Коэф);
			ОбластьСтрока.Параметры.КоличествоНеттоНаКоличествоПорций = ?(Коэф = 0, Прочерк, ОбластьСтрока.Параметры.КоличествоНеттоНаКоличествоПорций * Коэф);
			ОбластьСтрока.Параметры.ЕдиницаИзмерения = пл_СтрукВозврат.ВесЕдиницаИзмерения;
			
			ТабличныйДокумент.Вывести(ОбластьСтрока);
			
			Если Коэф = 0 Тогда
				ИтогоВыход = ИтогоВыход + ВыборкаСтрокТовары.КоличествоУпаковокВыход;
			иначе
				ИтогоВыход = ИтогоВыход + ВыборкаСтрокТовары.КоличествоУпаковокВыход*Коэф;
			КонецЕсли; 
			
		КонецЦикла;
		
		// Выводим подвал документа
		ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");
		
		Если ЗначениеЗаполнено(Шапка.ДокументОснование) И ТипЗнч(Шапка.ДокументОснование) = Тип("ДокументСсылка.питАктПроработки") Тогда
			ОбластьПодвал.Параметры.ТекстСоставлена = " составлена на основании акта проработки №"+Шапка.ДокументОснованиеНомер+" от "+Формат(Шапка.ДокументОснованиеДата,"ДФ=dd.MM.yy");
		ИначеЕсли ТипЗнч(Шапка.Ссылка) = Тип("ДокументСсылка.питАктПроработки") Тогда
			ОбластьПодвал.Параметры.ТекстСоставлена = " составлена на основании акта проработки №"+Шапка.Номер+" от "+Формат(Шапка.Дата,"ДФ=dd.MM.yy");
		Иначе
			ОбластьПодвал.Параметры.ТекстСоставлена = "";
		КонецЕсли;
		
		Руководители = ОтветственныеЛицаСервер.ПолучитьОтветственныеЛицаОрганизации(Шапка.Организация, Шапка.Дата);
		ОбластьПодвал.Параметры.Руководитель = Руководители.РуководительНаименование;
		
		//<< Швецов. 12.07.2022. SD75275. Убрать руководителя
		ОбластьПодвал.Параметры.Руководитель = Неопределено;
		//>> Швецов. 12.07.2022. SD75275. Убрать руководителя
		
		Если Руководители.Свойство("питКалькулятор") Тогда
			ОбластьПодвал.Параметры.Калькулятор = Руководители.питКалькулятор;
		Иначе
			ОбластьПодвал.Параметры.Калькулятор = Шапка.Ответственный;
		КонецЕсли;
		Если Руководители.Свойство("питЗаведующийПроизводством") Тогда
			ОбластьПодвал.Параметры.ЗаведующийПроизводством = Руководители.питЗаведующийПроизводством;
		КонецЕсли;
		
		ОбластьПодвал.Параметры.Выход = Шапка.Выход;  // Уточнить, какой здесь нужен выход, сумма колонок, или из реквизита?
		ОбластьПодвал.Параметры.ТехнологияПриготовления = Шапка.ТехнологияПриготовления;
		ТабличныйДокумент.Вывести(ОбластьПодвал);
		
		// В табличном документе зададим имя области, в которую был 
		// выведен объект. Нужно для возможности печати покомплектно.
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, 
			НомерСтрокиНачало, ОбъектыПечати, Шапка.Ссылка);
		
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
	
КонецФункции

// Формирует табличный документ технико-технологическая карта по норме
// 
// Возвращаемое значение:
//  Табличный документ - Технико-технологическая карта
//
Функция ПечатьТехТехнолКарта(МассивОбъектов, ОбъектыПечати, ПараметрыПечати)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если ПараметрыПечати <> Неопределено И ПараметрыПечати.Свойство("СтруктураПараметровТТК") Тогда
		СтруктураПараметров = ПараметрыПечати.СтруктураПараметровТТК;
	Иначе
		СтруктураПараметров = Новый Структура();
	КонецЕсли;
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.АвтоМасштаб = Истина;
	ТабличныйДокумент.ПолеСверху = 0;
	ТабличныйДокумент.ПолеСлева  = 0;
	ТабличныйДокумент.ПолеСнизу  = 0;
	ТабличныйДокумент.ПолеСправа = 0;
	ТабличныйДокумент.ОриентацияСтраницы  = ОриентацияСтраницы.Ландшафт;
	ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ВыпускПродукции_ТехТехнолКарта";
	
	МассивРецептуры = Новый Массив; // для исключения дублирования блюд
	
	ПервыйДокумент = Истина;
	
	ПоГост = Ложь;
	Если ПараметрыПечати.Свойство("ПоГОСТ") Тогда
		ПоГост = ПараметрыПечати.ПоГОСТ;
	ИначеЕсли СтруктураПараметров.Свойство("ПоГОСТ") Тогда
		ПоГост = СтруктураПараметров.ПоГОСТ;
	КонецЕсли;
	
	//+АвтовыборНоменклатуры
	УточненияАвтовыбора = Неопределено;
	Если СтруктураПараметров.Свойство("УточненияАвтовыбора") Тогда
		УточненияАвтовыбора = ПолучитьИзВременногоХранилища(СтруктураПараметров.УточненияАвтовыбора);
	КонецЕсли;
	//-АвтовыборНоменклатуры
	
	питПодразделениеПроизводства = Неопределено;
	Если СтруктураПараметров.Свойство("питПодразделениеПроизводства") Тогда
		питПодразделениеПроизводства = СтруктураПараметров.питПодразделениеПроизводства;
	КонецЕсли;
	
	Для Каждого ДокументСсылка Из МассивОбъектов Цикл
		
		//+АвтовыборНоменклатуры
		Если УточненияАвтовыбора = Неопределено Тогда
			Если ТипЗнч(ДокументСсылка)=Тип("ДокументОбъект.питРецептура") Тогда
				УточненияАвтовыбора = ДокументСсылка.УточненияАвтовыбора.Выгрузить();
			ИначеЕсли ТипЗнч(ДокументСсылка)=Тип("ДокументСсылка.питРецептура") Тогда
				УточненияАвтовыбора = питУправлениеДаннымиОбИзделиях.ПолучитьТаблицуУточненийАвтовыбораПоДокументу(ДокументСсылка);
			КонецЕсли;
		КонецЕсли;
		//-АвтовыборНоменклатуры
		
		Если НЕ ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		
		ПервыйДокумент = Ложь;
		// Запомним номер строки, с которой начали выводить текущий документ.
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		// Выведем технико-технологическую карту. 
		питДиетпитание.ВывестиТехникоТехнологическуюКарту(ТабличныйДокумент, ДокументСсылка, ДокументСсылка,,,,ПоГост,питПодразделениеПроизводства, УточненияАвтовыбора);
		
		// В табличном документе зададим имя области, в которую был 
		// выведен объект. Нужно для возможности печати покомплектно.
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, 
			НомерСтрокиНачало, ОбъектыПечати, ДокументСсылка.Ссылка);
		
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
	
КонецФункции // ПечатьТехТехнолКарта

// Функция формирует печатную форму "Состав химикоэнергетических характеристик"
//
// Возвращаемое значение:
//  Сформированный табличный документ:
//
Функция ПечатьСоставХЭХ(МассивОбъектов, ОбъектыПечати, ПараметрыПечати=Неопределено)
	
	УстановитьПривилегированныйРежим(Истина);
	
	СпособРасчетаКоличестваХЭХ = Константы.питСпособРасчетаКоличестваХЭХ.Получить();
	СтруктураРезультата = ПараметрыПечати.СтруктураПараметровХЭХ;
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.АвтоМасштаб = Истина;
	ТабличныйДокумент.ПолеСверху = 0;
	ТабличныйДокумент.ПолеСлева  = 0;
	ТабличныйДокумент.ПолеСнизу  = 0;
	ТабличныйДокумент.ПолеСправа = 0;
	ТабличныйДокумент.ОриентацияСтраницы  = ?(СтруктураРезультата.СпособВыводаРезультата = 0, ОриентацияСтраницы.Ландшафт, ОриентацияСтраницы.Портрет);
	ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_Рецептура_СоставХЭХ" + ?(СтруктураРезультата.СпособВыводаРезультата = 0, "Полная", "Краткая");
	
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.питРецептура.ПФ_MXL_СоставХЭХ");
	
	//+АвтовыборНоменклатуры
	УточненияАвтовыбора = Неопределено;
	Если СтруктураРезультата.Свойство("УточненияАвтовыбора") Тогда
		УточненияАвтовыбора = ПолучитьИзВременногоХранилища(СтруктураРезультата.УточненияАвтовыбора);
	КонецЕсли;
	//-АвтовыборНоменклатуры
	
	ПервыйДокумент = Истина;
	
	Для Каждого ДокументСсылка Из МассивОбъектов Цикл
		
		//+АвтовыборНоменклатуры
		Если УточненияАвтовыбора = Неопределено Тогда
			Если ТипЗнч(ДокументСсылка)=Тип("ДокументОбъект.питРецептура") Тогда
				УточненияАвтовыбора = ДокументСсылка.УточненияАвтовыбора.Выгрузить();
			ИначеЕсли ТипЗнч(ДокументСсылка)=Тип("ДокументСсылка.питРецептура") Тогда
				УточненияАвтовыбора = питУправлениеДаннымиОбИзделиях.ПолучитьТаблицуУточненийАвтовыбораПоДокументу(ДокументСсылка);
			КонецЕсли;
		КонецЕсли;
		//-АвтовыборНоменклатуры
		
		Если НЕ ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		
		ПервыйДокумент = Ложь;
		// Запомним номер строки, с которой начали выводить текущий документ.
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		ОбластьЗаголовок = Макет.ПолучитьОбласть("Заголовок|КолонкаНоменклатура");
		Если ЗначениеЗаполнено(ДокументСсылка.Номенклатура) Тогда
			ОбластьЗаголовок.Параметры.Блюдо = СокрЛП(ДокументСсылка.Номенклатура.НаименованиеПолное) + " " + ?(ЗначениеЗаполнено(ДокументСсылка.Характеристика)," / " + ДокументСсылка.Характеристика.НаименованиеПолное,"");
		Иначе
			ОбластьЗаголовок.Параметры.Блюдо = "<Уточняется при производстве>";
		КонецЕсли;
		ОбластьЗаголовок.Параметры.Рецептура = ДокументСсылка.Ссылка;
		ОбластьЗаголовок.Параметры.Количество = ?(СтруктураРезультата.СпособВыводаКоличества = 0, ДокументСсылка.КоличествоУпаковок, СтруктураРезультата.КоличествоУпаковок);
		ЕдиницаБлюда = ?(СтруктураРезультата.СпособВыводаКоличества = 0, ДокументСсылка.Упаковка, СтруктураРезультата.ЕдиницаИзмерения);
		ОбластьЗаголовок.Параметры.ЕдиницаБлюда =?(ЗначениеЗаполнено(ЕдиницаБлюда),ЕдиницаБлюда, ДокументСсылка.Номенклатура.ЕдиницаИзмерения); 
		
		ТабличныйДокумент.Вывести(ОбластьЗаголовок);
		
		РассчетноеКоличество =         ?(СтруктураРезультата.СпособВыводаКоличества = 0, ДокументСсылка.Количество, СтруктураРезультата.Количество);
		РассчетноеКоличествоУпаковок = ?(СтруктураРезультата.СпособВыводаКоличества = 0, ДокументСсылка.КоличествоУпаковок, СтруктураРезультата.КоличествоУпаковок);
		
		СпособРасчетаКоличестваХЭХ = Перечисления.питСпособыРасчетаКоличестваХЭХ[СтруктураРезультата.СпособРасчетаКоличестваХЭХ];
		
		ТаблицаСостава = Новый ТаблицаЗначений();
		
		СписокХЭХ = питДиетпитание.ПолучитьСоставХЭХ(ДокументСсылка.Номенклатура, ДокументСсылка.Характеристика, ДокументСсылка, РассчетноеКоличество,РассчетноеКоличествоУпаковок, , СпособРасчетаКоличестваХЭХ, , ДокументСсылка.СпособРасчетаКалорийности, ТаблицаСостава, ?(ЗначениеЗаполнено(СтруктураРезультата.питПодразделениеПроизводства), СтруктураРезультата.питПодразделениеПроизводства, ДокументСсылка.Подразделение), УточненияАвтовыбора);
		
		Если СписокХЭХ = Неопределено Тогда
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Для блюда """+ДокументСсылка.Номенклатура.НаименованиеПолное+""" химико-энергетические характеристики не заданы!";
			Сообщение.Сообщить();
			Продолжить;
		КонецЕсли;
		
		// Получение областей
		
		ОбластьХЭХ = Макет.ПолучитьОбласть("ХЭХ|КолонкаНоменклатура");
		ОбластьШапкаНоменклатура = Макет.ПолучитьОбласть("ШапкаНоменклатура|КолонкаНоменклатура");
		ОбластьСтрокаНоменклатура = Макет.ПолучитьОбласть("СтрокаНоменклатура|КолонкаНоменклатура");
		
		ИмяШапкаХЭХПоГоризонтали = "ШапкаХЭХ" + ?(СтруктураРезультата.СпособВыводаРезультата = 0, "Полная", "Краткая");
		ИмяШапкаХЭХПоВертикали = "КолонкаХЭХ"+ ?(СпособРасчетаКоличестваХЭХ = Перечисления.питСпособыРасчетаКоличестваХЭХ.СУчетомПотерьХЭХ, "СПотерями", "");
		
		ОбластьШапкаХЭХ = Макет.ПолучитьОбласть(ИмяШапкаХЭХПоГоризонтали + "|" + ИмяШапкаХЭХПоВертикали);
		ОбластьСтрокаХЭХ = Макет.ПолучитьОбласть("СтрокаХЭХ|" + ИмяШапкаХЭХПоВертикали);
		
		ИмяШапкаКалорийностьПоГоризонтали = "ШапкаКалорийность" + ?(СтруктураРезультата.СпособВыводаРезультата = 0, "Полная", "Краткая");
		ИмяШапкаКалорийностьПоВертикали = "КолонкаКалорийность" + ?(СпособРасчетаКоличестваХЭХ = Перечисления.питСпособыРасчетаКоличестваХЭХ.СУчетомПотерьХЭХ, "СПотерями", "");
		
		ОбластьШапкаКалорийность = Макет.ПолучитьОбласть(ИмяШапкаКалорийностьПоГоризонтали + "|" + ИмяШапкаКалорийностьПоВертикали);
		ОбластьСтрокаКалорийность = Макет.ПолучитьОбласть("СтрокаКалорийность|" + ИмяШапкаКалорийностьПоВертикали);
		
		СтруктураШапкиХЭХ = Новый Структура("ХЭХ,ЕдиницаХЭХ");
		СтруктураСтрокиХЭХ = Новый Структура("Количество,ПроцентПотерь,Итого,Формула,Источник");
		
		// Вычислим порядок обхода таблицы состава
		ПорядокОбходаТаблицыСостава = питДиетпитание.СоздатьПорядокОбходаТаблицыСоставаХЭХ(ТаблицаСостава);
		МассивВходов = питДиетпитание.СформироватьМассивВходовВПорядокОбходаДеревоСостава(ТаблицаСостава, ПорядокОбходаТаблицыСостава);
		ДеревоНоменклатуры = питДиетпитание.СоздатьТаблицуДереваНоменклатурыСоставаХЭХ(ТаблицаСостава, ПорядокОбходаТаблицыСостава, МассивВходов);
		
		// ПОЛУЧАЕМ ТАБЛИЦУ НЕОБХОДИМЫХ ХЭХ
		Если СтруктураРезультата.ВыводимыеХЭХ = 1 Тогда
			Запрос = Новый Запрос();
			Запрос.Текст = "ВЫБРАТЬ
			|	ХимикоэнергетическиеХарактеристики.Ссылка КАК ХЭХ,
			|	ХимикоэнергетическиеХарактеристики.ЕдиницаИзмерения КАК ЕдиницаИзмеренияХЭХ
			|ИЗ
			|	Справочник.питХимикоэнергетическиеХарактеристики КАК ХимикоэнергетическиеХарактеристики
			|ГДЕ
			|	ХимикоэнергетическиеХарактеристики.Предопределенный";
			ПереченьХЭХ = Запрос.Выполнить().Выгрузить();
		ИначеЕсли СтруктураРезультата.ВыводимыеХЭХ = 2 Тогда
			ПечатныеХЭХ = питДиетпитание.ПолучитьПереченьПечатныхХЭХ();
			ПереченьХЭХ = ПечатныеХЭХ.Скопировать(, "ХимикоэнергетическаяХарактеристика,ЕдиницаИзмерения");
			ПереченьХЭХ.Колонки.ХимикоэнергетическаяХарактеристика.Имя = "ХЭХ";
			ПереченьХЭХ.Колонки.ЕдиницаИзмерения.Имя = "ЕдиницаИзмеренияХЭХ";
			ПереченьХЭХ.Свернуть("ХЭХ,ЕдиницаИзмеренияХЭХ");
		ИначеЕсли СтруктураРезультата.ВыводимыеХЭХ = 3 Тогда
			ВыбраннаяГруппа = СтруктураРезультата.ГруппаХЭХ;
			Если ВыбраннаяГруппа.Пустая() Тогда
				Возврат Неопределено;
			КонецЕсли;
			Запрос = Новый Запрос();
			Запрос.Текст = "ВЫБРАТЬ
			|	ХимикоэнергетическиеХарактеристики.Ссылка КАК ХЭХ,
			|	ХимикоэнергетическиеХарактеристики.ЕдиницаИзмерения КАК ЕдиницаИзмеренияХЭХ
			|ИЗ
			|	Справочник.питХимикоэнергетическиеХарактеристики КАК ХимикоэнергетическиеХарактеристики
			|ГДЕ
			|	ХимикоэнергетическиеХарактеристики.ГруппаХЭХ = &ВыбраннаяГруппа";
			Запрос.УстановитьПараметр("ВыбраннаяГруппа", ВыбраннаяГруппа);
			ПереченьХЭХ = Запрос.Выполнить().Выгрузить();
			
		ИначеЕсли СтруктураРезультата.ВыводимыеХЭХ = 4 Тогда
			Запрос = Новый Запрос();
			Запрос.Текст = "ВЫБРАТЬ
			|	ХимикоэнергетическиеХарактеристики.Ссылка КАК ХЭХ,
			|	ХимикоэнергетическиеХарактеристики.ЕдиницаИзмерения КАК ЕдиницаИзмеренияХЭХ
			|ИЗ
			|	Справочник.питХимикоэнергетическиеХарактеристики КАК ХимикоэнергетическиеХарактеристики";
			ПереченьХЭХ = Запрос.Выполнить().Выгрузить();
		Иначе
			ПереченьХЭХ = ТаблицаСостава.Скопировать(, "ХЭХ,ЕдиницаИзмеренияХЭХ");
			ПереченьХЭХ.Свернуть("ХЭХ,ЕдиницаИзмеренияХЭХ");
		КонецЕсли;
		
		СоответствиеХЭХ = Новый Соответствие();
		Для Каждого ЭлементПеречня Из ПереченьХЭХ Цикл
			СоответствиеХЭХ.Вставить(ЭлементПеречня.ХЭХ, -1);
			Сч = 0;
			Для Сч = 0 По МассивВходов.Количество() - 1 Цикл
				Вход = МассивВходов[Сч];
				Если Вход.ХЭХ = ЭлементПеречня.ХЭХ Тогда
					СоответствиеХЭХ[Вход.ХЭХ] = Сч;
					Прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
		
		// Инициализируем входы
		Для Каждого Вход Из МассивВходов Цикл
			Вход.Индекс = Вход.Начало;
		КонецЦикла;
		
		Если СтруктураРезультата.СпособВыводаРезультата = 0 Тогда
			// Собираем шапку таблицы
			ТабличныйДокумент.Вывести(ОбластьШапкаНоменклатура);
			Для Каждого ЭлементПеречня Из ПереченьХЭХ Цикл
				Если ЭлементПеречня.ХЭХ.Пустая() Тогда
					Продолжить;
				КонецЕсли;
				Если ЭлементПеречня.ХЭХ = Справочники.питХимикоэнергетическиеХарактеристики.Калорийность Тогда
					ОбластьШапкаКалорийность.Параметры.Заполнить(ЭлементПеречня);
					ТабличныйДокумент.Присоединить(ОбластьШапкаКалорийность);
				Иначе
					ОбластьШапкаХЭХ.Параметры.Заполнить(ЭлементПеречня);
					ТабличныйДокумент.Присоединить(ОбластьШапкаХЭХ);
				КонецЕсли;
			КонецЦикла;
			
			// Выводим строки
			НомерСтроки = 1;
			Для Каждого СтрокаНоменклатуры Из ДеревоНоменклатуры Цикл
				// Данные о номенклатуре
				ОбластьСтрокаНоменклатура.Параметры.Заполнить(СтрокаНоменклатуры);
				ОбластьСтрокаНоменклатура.Параметры.НомерСтроки = НомерСтроки;
				//ОбластьСтрокаНоменклатура.Параметры.НоменклатураНаименование = ОбластьСтрокаНоменклатура.Параметры.НоменклатураНаименование + "" + ?(ЗначениеЗаполнено(СтрокаТаблицы.Характеристика)," / " + СокрЛП(СтрокаТаблицы.Характеристика),"")
				
				// Если единица измерения равна базовой, то она в ЕРП не пишется, поэтому берем напрямую из номенклатуры (отобразить то в ПФ нам ее надо все-равно).
				Если НЕ ЗначениеЗаполнено(СтрокаНоменклатуры.ЕдиницаИзмерения) Тогда
					ОбластьСтрокаНоменклатура.Параметры.ЕдиницаИзмерения = СтрокаНоменклатуры.Номенклатура.ЕдиницаИзмерения;
				КонецЕсли;
				
				Если СтрокаНоменклатуры.Рецептура.Пустая() Тогда
					ОбластьСтрокаНоменклатура.Параметры.РецептураПредставление = "";
				Иначе
					ОбластьСтрокаНоменклатура.Параметры.РецептураПредставление = "№" + СокрЛП(СтрокаНоменклатуры.Рецептура.Номер) + " от " + СокрЛП(Формат(СтрокаНоменклатуры.Рецептура.Дата, "ДФ=dd.MM.yyyy; ДЛФ=D"));
				КонецЕсли;
				ТабличныйДокумент.Вывести(ОбластьСтрокаНоменклатура);
				
				// Выводим ХЭХ
				Для Каждого ЭлементПеречня Из ПереченьХЭХ Цикл
					Если ЭлементПеречня.ХЭХ.Пустая() Тогда
						Продолжить;
					КонецЕсли;
					
					НомерВхода = СоответствиеХЭХ[ЭлементПеречня.ХЭХ];
					ОбнулитьВывод = Истина;
					Если НомерВхода >= 0 Тогда
						Вход = МассивВходов[НомерВхода];
						
						Если Вход.Индекс < Вход.Начало + Вход.Число Тогда
							ТекСтрокаСостава = ТаблицаСостава[ПорядокОбходаТаблицыСостава[Вход.Индекс]];
							
							СовпадаютСтроки =	(СтрокаНоменклатуры.Номенклатура = ТекСтрокаСостава.Номенклатура) И
												(СтрокаНоменклатуры.Количество = ТекСтрокаСостава.КоличествоНоменклатуры) И
												(СтрокаНоменклатуры.ЕдиницаИзмерения = ТекСтрокаСостава.ЕдиницаИзмеренияНоменклатуры) И
												(СтрокаНоменклатуры.Рецептура = ТекСтрокаСостава.Рецептура) И
												(СтрокаНоменклатуры.Уровень = ТекСтрокаСостава.Уровень) И
												(СтрокаНоменклатуры.НомерВетки = ТекСтрокаСостава.НомерВетки);
							
							Если СовпадаютСтроки Тогда
								ОбнулитьВывод = Ложь;
								
								СтруктураСтрокиХЭХ.Количество = ТекСтрокаСостава.КоличествоИсходное;
								СтруктураСтрокиХЭХ.ПроцентПотерь = ТекСтрокаСостава.ПроцентПотерь;
								СтруктураСтрокиХЭХ.Итого = ТекСтрокаСостава.КоличествоИтого;
								СтруктураСтрокиХЭХ.Формула = ТекСтрокаСостава.Формула;
								СтруктураСтрокиХЭХ.Источник = ТекСтрокаСостава.Источник;
								
								Если ЭлементПеречня.ХЭХ = Справочники.питХимикоэнергетическиеХарактеристики.Калорийность Тогда
									ОбластьСтрокаКалорийность.Параметры.Заполнить(СтруктураСтрокиХЭХ);
									ТабличныйДокумент.Присоединить(ОбластьСтрокаКалорийность);
								Иначе
									ОбластьСтрокаХЭХ.Параметры.Заполнить(СтруктураСтрокиХЭХ);
									ТабличныйДокумент.Присоединить(ОбластьСтрокаХЭХ);
								КонецЕсли;
								
								Вход.Индекс = Вход.Индекс + 1;
							КонецЕсли;
							
						КонецЕсли;
						
					КонецЕсли;
					
					Если ОбнулитьВывод Тогда
						СтруктураСтрокиХЭХ.Количество = 0;
						СтруктураСтрокиХЭХ.ПроцентПотерь = 0;
						СтруктураСтрокиХЭХ.Итого = 0;
						СтруктураСтрокиХЭХ.Формула = "";
						СтруктураСтрокиХЭХ.Источник = "";
						
						Если ЭлементПеречня.ХЭХ = Справочники.питХимикоэнергетическиеХарактеристики.Калорийность Тогда
							ОбластьСтрокаКалорийность.Параметры.Заполнить(СтруктураСтрокиХЭХ);
							ТабличныйДокумент.Присоединить(ОбластьСтрокаКалорийность);
						Иначе
							ОбластьСтрокаХЭХ.Параметры.Заполнить(СтруктураСтрокиХЭХ);
							ТабличныйДокумент.Присоединить(ОбластьСтрокаХЭХ);
						КонецЕсли;
					КонецЕсли;
					
				КонецЦикла;
				
				
				НомерСтроки = НомерСтроки + 1;
			КонецЦикла;
			
		Иначе
			
			Для Каждого ЭлементПеречня Из ПереченьХЭХ Цикл
				Если ЭлементПеречня.ХЭХ.Пустая() Тогда
					Продолжить;
				КонецЕсли;
				
				НомерСтроки = 1;
				НомерВхода = СоответствиеХЭХ[ЭлементПеречня.ХЭХ];
				
				ОбластьХЭХ.Параметры.Заполнить(ЭлементПеречня);
				ТабличныйДокумент.Вывести(ОбластьХЭХ);
				
				// Выводим шапку
				ТабличныйДокумент.Вывести(ОбластьШапкаНоменклатура);
				Если ЭлементПеречня.ХЭХ = Справочники.питХимикоэнергетическиеХарактеристики.Калорийность Тогда
					ОбластьШапкаКалорийность.Параметры.Заполнить(ЭлементПеречня);
					ТабличныйДокумент.Присоединить(ОбластьШапкаКалорийность);
				Иначе
					ОбластьШапкаХЭХ.Параметры.Заполнить(ЭлементПеречня);
					ТабличныйДокумент.Присоединить(ОбластьШапкаХЭХ);
				КонецЕсли;
				
				Для Каждого СтрокаНоменклатуры Из ДеревоНоменклатуры Цикл
					// Данные о номенклатуре
					ОбластьСтрокаНоменклатура.Параметры.Заполнить(СтрокаНоменклатуры);
					ОбластьСтрокаНоменклатура.Параметры.НомерСтроки = НомерСтроки;
					//ОбластьСтрокаНоменклатура.Параметры.НоменклатураНаименование = ОбластьСтрокаНоменклатура.Параметры.НоменклатураНаименование + "" + ?(ЗначениеЗаполнено(СтрокаТаблицы.Характеристика)," / " + СокрЛП(СтрокаТаблицы.Характеристика),"")
					// Если единица измерения равна базовой, то она в ЕРП не пишется, поэтому берем напрямую из номенклатуры (отобразить то в ПФ нам ее надо все-равно).
					Если НЕ ЗначениеЗаполнено(СтрокаНоменклатуры.ЕдиницаИзмерения) Тогда
						ОбластьСтрокаНоменклатура.Параметры.ЕдиницаИзмерения = СтрокаНоменклатуры.Номенклатура.ЕдиницаИзмерения;
					КонецЕсли;
					
					Если СтрокаНоменклатуры.Рецептура.Пустая() Тогда
						ОбластьСтрокаНоменклатура.Параметры.РецептураПредставление = "";
					Иначе
						ОбластьСтрокаНоменклатура.Параметры.РецептураПредставление = "№" + СокрЛП(СтрокаНоменклатуры.Рецептура.Номер) + " от " + СокрЛП(Формат(СтрокаНоменклатуры.Рецептура.Дата, "ДФ=dd.MM.yyyy; ДЛФ=D"));
					КонецЕсли;
					ТабличныйДокумент.Вывести(ОбластьСтрокаНоменклатура);
					
					ОбнулитьВывод = Истина;
					Если НомерВхода >= 0 Тогда
						Вход = МассивВходов[НомерВхода];
						
						Если Вход.Индекс < Вход.Начало + Вход.Число Тогда
							ТекСтрокаСостава = ТаблицаСостава[ПорядокОбходаТаблицыСостава[Вход.Индекс]];
							
							СовпадаютСтроки =	(СтрокаНоменклатуры.Номенклатура = ТекСтрокаСостава.Номенклатура) И
												(СтрокаНоменклатуры.Количество = ТекСтрокаСостава.КоличествоНоменклатуры) И
												(СтрокаНоменклатуры.ЕдиницаИзмерения = ТекСтрокаСостава.ЕдиницаИзмеренияНоменклатуры) И
												(СтрокаНоменклатуры.Рецептура = ТекСтрокаСостава.Рецептура) И
												(СтрокаНоменклатуры.Уровень = ТекСтрокаСостава.Уровень) И
												(СтрокаНоменклатуры.НомерВетки = ТекСтрокаСостава.НомерВетки);
							
							Если СовпадаютСтроки Тогда
								ОбнулитьВывод = Ложь;
								
								СтруктураСтрокиХЭХ.Количество = ТекСтрокаСостава.КоличествоИсходное;
								СтруктураСтрокиХЭХ.ПроцентПотерь = ТекСтрокаСостава.ПроцентПотерь;
								СтруктураСтрокиХЭХ.Итого = ТекСтрокаСостава.КоличествоИтого;
								СтруктураСтрокиХЭХ.Формула = ТекСтрокаСостава.Формула;
								СтруктураСтрокиХЭХ.Источник = ТекСтрокаСостава.Источник;
								
								Если ЭлементПеречня.ХЭХ = Справочники.питХимикоэнергетическиеХарактеристики.Калорийность Тогда
									ОбластьСтрокаКалорийность.Параметры.Заполнить(СтруктураСтрокиХЭХ);
									ТабличныйДокумент.Присоединить(ОбластьСтрокаКалорийность);
								Иначе
									ОбластьСтрокаХЭХ.Параметры.Заполнить(СтруктураСтрокиХЭХ);
									ТабличныйДокумент.Присоединить(ОбластьСтрокаХЭХ);
								КонецЕсли;
								
								Вход.Индекс = Вход.Индекс + 1;
							КонецЕсли;
							
						КонецЕсли;
						
					КонецЕсли;
					
					Если ОбнулитьВывод Тогда
						СтруктураСтрокиХЭХ.Количество = 0;
						СтруктураСтрокиХЭХ.ПроцентПотерь = 0;
						СтруктураСтрокиХЭХ.Итого = 0;
						СтруктураСтрокиХЭХ.Формула = "";
						СтруктураСтрокиХЭХ.Источник = "";
						
						Если ЭлементПеречня.ХЭХ = Справочники.питХимикоэнергетическиеХарактеристики.Калорийность Тогда
							ОбластьСтрокаКалорийность.Параметры.Заполнить(СтруктураСтрокиХЭХ);
							ТабличныйДокумент.Присоединить(ОбластьСтрокаКалорийность);
						Иначе
							ОбластьСтрокаХЭХ.Параметры.Заполнить(СтруктураСтрокиХЭХ);
							ТабличныйДокумент.Присоединить(ОбластьСтрокаХЭХ);
						КонецЕсли;
					КонецЕсли;
					
					НомерСтроки = НомерСтроки + 1;
				КонецЦикла;
				
			КонецЦикла;
			
		КонецЕсли;
		
		// В табличном документе зададим имя области, в которую был 
		// выведен объект. Нужно для возможности печати покомплектно.
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, 
			НомерСтрокиНачало, ОбъектыПечати, ДокументСсылка.Ссылка);
		
		КонецЦикла;
		
	Возврат ТабличныйДокумент;
	
КонецФункции

