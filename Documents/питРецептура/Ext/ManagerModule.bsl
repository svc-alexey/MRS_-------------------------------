// Получает значение основного реквизита по данным основного изделия спецификации
//
// Параметры:
//  Объект  - СправочникОбъект.РесурсныеСпецификации, Структура - спецификация.
//  ОсновноеИзделие - Структура - см. ДанныеОсновногоИзделияСпецификации
// 
// Возвращаемое значение:
//  Структура - данные основного реквизита
//
Функция ОсновнойРеквизитОсновногоИзделияСпецификации(Объект, ОсновноеИзделие = Неопределено) Экспорт
	
	Результат = Новый Структура;
	
	Если ОсновноеИзделие = Неопределено Тогда
		ОсновноеИзделие = ДанныеОсновногоИзделияСпецификации(Объект);
	КонецЕсли;
	
	Если Объект.ВариантНазначения = ПредопределенноеЗначение("Перечисление.ВариантыНазначенияСпецификации.ВидНоменклатуры") Тогда
		Результат.Вставить("Имя", "ВидНоменклатуры");
	Иначе
		Результат.Вставить("Имя", "Номенклатура");
	КонецЕсли;
	
	Результат.Вставить("Значение", ОсновноеИзделие[Результат.Имя]);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

// Функция формирует печатную форму "Этикетка"
//
// Возвращаемое значение:
//  Сформированный табличный документ:
//
Функция ВИП_ПечатьЭтикетки(МассивОбъектов, ОбъектыПечати, ПараметрыПечати = Неопределено)  
	
	//<< Каюмов А.А., ВиП, 25.09.2023, I-143. Печать этикеток из рецептур 	  
	
	УстановитьПривилегированныйРежим(Истина);
	ДатаЭтикетки = ПараметрыПечати.СтруктураПараметровЭтикетка.ДатаЭтикетки;
	КоличествоЭтикеток = ПараметрыПечати.СтруктураПараметровЭтикетка.КоличествоЭтикеток;
	 
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.ОриентацияСтраницы  = ОриентацияСтраницы.Ландшафт;
	ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_Этикетка"; 
	ТабличныйДокумент.АвтоМасштаб = Истина;
	ТабличныйДокумент.ВысотаСтраницы = 40;
	ТабличныйДокумент.ШиринаСтраницы = 60;
	ТабличныйДокумент.ИмяПринтера = "Zebra"; 
	
	Если КоличествоЭтикеток > 0 Тогда   
		ТабличныйДокумент.КоличествоЭкземпляров = КоличествоЭтикеток;
		
	КонецЕсли;
	
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.питРецептура.ВИП_ПФ_MXL_Этикетка");
	ТЗ_Шапка = ВИП_ПолучитьДанныеПечати(МассивОбъектов); 
	
	ПервыйДокумент = Истина;
	
	Для Каждого ДокументСсылка Из МассивОбъектов Цикл
			
		Если НЕ ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		
		ПервыйДокумент = Ложь;
		// Запомним номер строки, с которой начали выводить текущий документ.
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		ОбластьШапка = Макет.ПолучитьОбласть("Шапка");
		НайденныеРеквизитыШапки = ТЗ_Шапка.НайтиСтроки(Новый Структура("Ссылка",ДокументСсылка.Ссылка)); 
		Если НайденныеРеквизитыШапки.Количество() > 0 Тогда
			ОбластьШапка.Параметры.Заполнить(НайденныеРеквизитыШапки[0]);
		Иначе
			Продолжить;
		КонецЕсли; 
		
		ОбластьШапка.Параметры.ДатаВремя = ДатаЭтикетки;
		ТабличныйДокумент.Вывести(ОбластьШапка);

		// В табличном документе зададим имя области, в которую был 
		// выведен объект. Нужно для возможности печати покомплектно.
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, 
		НомерСтрокиНачало, ОбъектыПечати, ДокументСсылка.Ссылка);
		
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
	//>>  
	
КонецФункции	

Функция ВИП_ПолучитьДанныеПечати(МассивОбъектов) 
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	питРецептура.Ссылка КАК Ссылка,
	               |	питРецептура.ВИП_ЭтикеткаНаименование КАК ВИП_ЭтикеткаНаименование,
	               |	питРецептура.ВИП_ЭтикеткаГОСТ КАК ВИП_ЭтикеткаГОСТ,
	               |	питРецептура.ВИП_ЭтикеткаТемператураХранения КАК ВИП_ЭтикеткаТемператураХранения,
	               |	питРецептура.ВИП_ЭтикеткаСрокХранения КАК ВИП_ЭтикеткаСрокХранения,
	               |	питРецептура.ВИП_ЭтикеткаЖиры КАК ВИП_ЭтикеткаЖиры,
	               |	питРецептура.ВИП_ЭтикеткаБелки КАК ВИП_ЭтикеткаБелки,
	               |	питРецептура.ВИП_ЭтикеткаУглеводы КАК ВИП_ЭтикеткаУглеводы,
	               |	питРецептура.ВИП_ЭтикеткаКалорийность КАК ВИП_ЭтикеткаКалорийность,
	               |	питРецептура.ВИП_ЭтикеткаСостав КАК ВИП_ЭтикеткаСостав
	               |ИЗ
	               |	Документ.питРецептура КАК питРецептура
	               |ГДЕ
	               |	питРецептура.Ссылка В(&МассивОбъектов)"; 
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции 
