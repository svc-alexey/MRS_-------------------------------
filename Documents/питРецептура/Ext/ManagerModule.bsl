// %ИзЕРП%
// Справочник.РесурсныеСпецификации.ВыгрузитьДанныеДляКонструктораФормул
//
Функция ВыгрузитьДанныеДляКонструктораФормул(ОбъектИлиСсылка, ИмяТЧ, ДанныеСтроки = Неопределено) Экспорт
	
	//+пит
	ОписаниеИсточников = Документы.питРецептура.ОписаниеИсточниковДанныхОперандов();
	
	ОсновноеИзделие = ДанныеОсновногоИзделияСпецификации(ОбъектИлиСсылка);
	//-пит
	
	ОписаниеИсточников["ОсновноеИзделие"].ИсточникСвойствНоменклатуры = ОсновноеИзделие.Номенклатура;
	
	//+пит
	РазрешенныеКлючи = Новый Массив;
	РазрешенныеКлючи.Добавить("Ингредиент");
	РазрешенныеКлючи.Добавить("Ингредиенты");
	РазрешенныеКлючи.Добавить("ОсновноеИзделие");
	КлючиУдалить = Новый Массив;
	Для каждого ТекОписаниеИсточника Из ОписаниеИсточников Цикл
		Если РазрешенныеКлючи.Найти(ТекОписаниеИсточника.Ключ) = Неопределено Тогда
			КлючиУдалить.Добавить(ТекОписаниеИсточника.Ключ);
		КонецЕсли;
	КонецЦикла;
	Для каждого ТекКлючУдалить Из КлючиУдалить Цикл
		ОписаниеИсточников.Удалить(ТекКлючУдалить);
	КонецЦикла;
	//-пит
	
	УправлениеДаннымиОбИзделиях.ДополнитьОписаниеИсточниковСоставомОперандов(
		ОписаниеИсточников, ОбъектИлиСсылка, ИмяТЧ, ДанныеСтроки);
	
	Возврат ОписаниеИсточников;
	
КонецФункции

// %ИзЕРП%
// Справочник.РесурсныеСпецификации.ОписаниеИсточниковДанныхОперандов
//
Функция ОписаниеИсточниковДанныхОперандов(Объект = Неопределено) Экспорт
	
	Результат = Справочники.РесурсныеСпецификации.ОписаниеИсточниковДанныхОперандов();
	
	ОписаниеТипаЧисло = Новый ОписаниеТипов("Число");
	
	// [Ингредиенты]
	ПредставлениеИсточника = НСтр("ru = 'Ингредиенты';
										|en = 'Ingredients'");
	Описание = УправлениеДаннымиОбИзделиях.СоздатьОписанияИсточникаДанныхОперандов("Ингредиенты", ПредставлениеИсточника);
	
	//+пит
	ПредставлениеИсточника = НСтр("ru = 'КоличествоБрутто';
										|en = 'Quantity'");
	НовыйРеквизит = УправлениеДаннымиОбИзделиях.СоздатьОписанияРеквизитаИсточникаДанныхОперандов("КоличествоБрутто", ОписаниеТипаЧисло, ПредставлениеИсточника);
	Описание.Реквизиты.Добавить(НовыйРеквизит);
	
	ПредставлениеИсточника = НСтр("ru = 'КоличествоНетто';
										|en = 'Quantity'");
	НовыйРеквизит = УправлениеДаннымиОбИзделиях.СоздатьОписанияРеквизитаИсточникаДанныхОперандов("КоличествоНетто", ОписаниеТипаЧисло, ПредставлениеИсточника);
	Описание.Реквизиты.Добавить(НовыйРеквизит);
	
	ПредставлениеИсточника = НСтр("ru = 'КоличествоВыход';
										|en = 'Quantity'");
	НовыйРеквизит = УправлениеДаннымиОбИзделиях.СоздатьОписанияРеквизитаИсточникаДанныхОперандов("КоличествоВыход", ОписаниеТипаЧисло, ПредставлениеИсточника);
	Описание.Реквизиты.Добавить(НовыйРеквизит);
	//-пит
	
	Описание.СодержитСвойстваНоменклатуры = Истина;
	Описание.Коллекция                    = Истина;
	
	Результат.Вставить("Ингредиенты", Описание);
	
	// [Ингредиент]
	Описание = УправлениеДаннымиОбИзделиях.СоздатьОписанияИсточникаДанныхОперандов(НСтр("ru = 'Ингредиент';
																						|en = 'Ingredient'"), НСтр("ru = 'Ингредиент (текущая строка)';
																												|en = 'Ingredient (current line)'"));
	
	Описание.СодержитСвойстваНоменклатуры = Истина;
	Описание.ИмяТЧ = "Ингредиенты";
	
	Результат.Вставить("Ингредиент", Описание);
	
	Возврат Результат;
	
КонецФункции

