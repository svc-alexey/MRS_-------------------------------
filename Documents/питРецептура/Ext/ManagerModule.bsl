// СЛУЖЕБНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

Функция ОпределитьВидОперацииПоДокументуОснованию(Основание) Экспорт
	
	Результат = Перечисления.питХозяйственныеОперации.РецептураПриготовление;
	
	Если ЗначениеЗаполнено(Основание)
		И ТипЗнч(Основание) = Тип("ДокументСсылка.питАктПроработки") Тогда
		
		Результат = Перечисления.питХозяйственныеОперации.РецептураПриготовление;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПолучитьСоответствиеВидовОперацийФормам() Экспорт
	
	ФормыДокумента = Новый Соответствие;
	ФормыДокумента.Вставить(Перечисления.питХозяйственныеОперации.РецептураПриготовление,        "ФормаДокументаОбщая");
	ФормыДокумента.Вставить(Перечисления.питХозяйственныеОперации.РецептураРазделка,             "ФормаДокументаОбщая");
	ФормыДокумента.Вставить(Перечисления.питХозяйственныеОперации.РецептураРазукомплектацияБлюд, "ФормаДокументаОбщая");
	//ФормыДокумента.Вставить(Перечисления.питХозяйственныеОперации.РецептураРазделка,             "ФормаДокументаРазделка");
	//ФормыДокумента.Вставить(Перечисления.питХозяйственныеОперации.РецептураРазукомплектацияБлюд, "ФормаДокументаРазукомплектация");
	
	Возврат ФормыДокумента;
	
КонецФункции

// Функция формирует строку с наименованием номенклатуры по переданным парметрам.
//
// Параметры:
//  Номенклатура	 - СправочникСсылка.Номенклатура - Ссылка на номенклатуру.
//  Характеристика	 - СправочникСсылка.ХарактеристикиНоменклатуры - Ссылка на характеристику номенклатуры.
//  ДатаДействияС	 - Дата - Дата начала действия рецептуры.
//  ДатаДействияПо	 - Дата - Дата окончания действия рецептуры.
// 
// Возвращаемое значение:
//   - 
//
Функция СформироватьНаименованиеРецептуры(Номенклатура, Характеристика = Неопределено, ДатаДействияС = Неопределено, ДатаДействияПо = Неопределено) Экспорт
	
	Если Характеристика = Неопределено Тогда
		Характеристика = Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка();
	КонецЕсли;
	
	Если ДатаДействияС = Неопределено Тогда
		ДатаДействияС = Дата("00010101");
	КонецЕсли;
	
	Если ДатаДействияПо = Неопределено Тогда
		ДатаДействияПо = Дата("00010101");
	КонецЕсли;
	
	
	Возврат Строка(Номенклатура) 
		+ ?(ЗначениеЗаполнено(Характеристика), ";", "") + Строка(Характеристика) 
		+ ?(ЗначениеЗаполнено(ДатаДействияС), " (с " + Формат(ДатаДействияС, "ДФ='dd.MM.yyyy HH:mm'") + ?(ЗначениеЗаполнено(ДатаДействияПо), " по " + Формат(ДатаДействияПо, "ДФ='dd.MM.yyyy HH:mm'"), "") + ")", "");
	
КонецФункции

// Функция проверяет на дубли табличные части документа.
//
// Параметры:
//  ДокументОбъект	 - ДокументОбъект.питРецептура, ДанныеФормыСтруктура - Объект документа.
// 
// Возвращаемое значение:
//  Булево - Результат работы функции.
//
&НаСервере
Функция ПроверитьНаДубли(ДокументОбъект) Экспорт
	
	//+ПараметризацияРецептур
	Возврат Истина;
	//-ПараметризацияРецептур
	
	Если ТипЗнч(ДокументОбъект) = Тип("ДанныеФормыСтруктура") Тогда
		Документ = ДанныеФормыВЗначение(ДокументОбъект, Тип("ДокументОбъект.питРецептура")); // Преобразования данных формы в объект
		УстановитьСоответствиеОбъектаИРеквизитаФормы(Документ, "Объект"); // Установка соответствия
	Иначе
		Документ = ДокументОбъект;
	КонецЕсли;
	
	Результат = Истина;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питРецептураИнгредиенты.НомерСтроки,
	|	питРецептураИнгредиенты.Номенклатура,
	|	питРецептураИнгредиенты.Характеристика,
	|	питРецептураИнгредиенты.Упаковка
	|ПОМЕСТИТЬ втИнгредиенты
	|ИЗ
	|	&втИнгредиенты КАК питРецептураИнгредиенты
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	питРецептураИнгредиенты.Номенклатура,
	|	питРецептураИнгредиенты.Характеристика,
	|	питРецептураИнгредиенты.Упаковка,
	|	МИНИМУМ(питРецептураИнгредиенты.НомерСтроки) КАК НомерСтроки,
	|	СУММА(1) КАК Количество
	|ПОМЕСТИТЬ втРезультат
	|ИЗ
	|	втИнгредиенты КАК питРецептураИнгредиенты
	|
	|СГРУППИРОВАТЬ ПО
	|	питРецептураИнгредиенты.Номенклатура,
	|	питРецептураИнгредиенты.Характеристика,
	|	питРецептураИнгредиенты.Упаковка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втРезультат.Номенклатура,
	|	втРезультат.Характеристика,
	|	втРезультат.Упаковка,
	|	втРезультат.НомерСтроки,
	|	втРезультат.Количество
	|ИЗ
	|	втРезультат КАК втРезультат
	|ГДЕ
	|	втРезультат.Количество > 1";
	
	Запрос.УстановитьПараметр("втИнгредиенты", ДокументОбъект.Ингредиенты.Выгрузить());
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			Результат = Ложь;
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Дубли в строке <"+ВыборкаДетальныеЗаписи.НомерСтроки+"> по реквизитам Номенклатура, Характеристика, Единица измерения!";
			Сообщение.УстановитьДанные(Документ);
			Сообщение.Поле = "Ингредиенты[" + (ВыборкаДетальныеЗаписи.НомерСтроки - 1) + "].Номенклатура";
			Сообщение.Сообщить();
			Возврат Результат;
		КонецЦикла;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

