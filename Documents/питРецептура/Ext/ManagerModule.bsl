Процедура РассчитатьКоличествоФормульныхСтрок(ОбъектРецептура, ОбновлятьОбъектРецептура) Экспорт
	
	ЭтоУправлениеПредприятием = питПроизводствоПовтИсп.ПолучитьИмяОсновнойКонфигурации() = "УправлениеПредприятием";
	
	ПереченьДанных = Новый Массив();
	ПереченьДанных.Добавить("Ингредиенты");
	
	ДанныеСпецификации					= Новый Структура("ОсновноеИзделие, Ингредиенты");
	ДанныеСпецификации.ОсновноеИзделие	= ДанныеОсновногоИзделияСпецификации(ОбъектРецептура);
	ДанныеСпецификации.Ингредиенты		= ОбъектРецептура.Ингредиенты.Выгрузить();
	
	ДанныеПоНоменклатуре = ДанныеПоНоменклатуреРасширенный();
	ЗаполнитьЗначенияСвойств(ДанныеПоНоменклатуре, ОбъектРецептура);
	ДанныеПоНоменклатуре.Рецептура = ОбъектРецептура.Ссылка;
	ДанныеПоНоменклатуре.Спецификация = ОбъектРецептура.Ссылка;
	
	ПартияВыпуска = Новый Структура("Значение,Числитель,Знаменатель",1,1,1);
	
	ПараметрыРасчета = ПараметрыРасчетаКоличества(
			ДанныеПоНоменклатуре,
			ДанныеСпецификации);
	ПараметрыРасчета.ИспользоватьОдновременноПроизводимоеКоличество = Ложь;
	
	НаборДанных = Новый Массив;
	ДанныеДляРасчета = Неопределено;
	Если ЭтоУправлениеПредприятием Тогда
		ДобавитьСтрокиДляРасчетаПоФормулам(НаборДанных, ДанныеСпецификации, ПереченьДанных);
		ДанныеДляРасчета = ДанныеДляРасчетаПоФормулам(НаборДанных, ПартияВыпуска, ПараметрыРасчета);
	КонецЕсли;
	
	
	Если ДанныеСпецификации.Свойство("Ингредиенты")
		И ПереченьДанных.Найти("Ингредиенты") <> Неопределено Тогда
		РассчитатьКоличество(
			ПартияВыпуска,
			ДанныеСпецификации.Ингредиенты,
			Истина,
			Истина,
			Истина,
			ДанныеДляРасчета);
	КонецЕсли;
	
	Если ОбновлятьОбъектРецептура Тогда
		ОбъектРецептура.Ингредиенты.Загрузить(ДанныеСпецификации.Ингредиенты);
	КонецЕсли;
	
КонецПроцедуры

