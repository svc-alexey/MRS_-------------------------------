// Расчет количества в формульных строках

Функция ДанныеДляРасчетаПоФормулам(НаборДанных, ПартияВыпуска, ПараметрыРасчета)
	
	Перем ДанныеДляРасчета;
	
	Если Не ЗначениеЗаполнено(НаборДанных) Тогда
		Возврат ДанныеДляРасчета;
	КонецЕсли;
	
	#Область ОписаниеИсточников
	
	ОписаниеИсточников = ОписаниеИсточниковДанныхОперандов();
	ИсточникиЗначенийПараметров       = УправлениеДаннымиОбИзделиях.СоздатьТаблицуИсточниковЗначенийПараметровДляРасчетаПоФормулам();
	
	#КонецОбласти
	
	#Область ДанныеСпецификаций
	
	СтруктураДанных = Новый Структура("ОсновноеИзделие,Ингредиенты");
	
	ДанныеПоНоменклатуре = ДанныеПоНоменклатуреРасширенный();
	ЗаполнитьЗначенияСвойств(ДанныеПоНоменклатуре, ПараметрыРасчета.ДанныеПоНоменклатуре);
	
	//+пит
	//Если (НЕ ЗначениеЗаполнено(ПараметрыРасчета.СтруктураДанных)
	//		ИЛИ ПараметрыДляРасчета.Найти("ОсновноеИзделие",  "Ключ")  <> Неопределено И НЕ ПараметрыРасчета.СтруктураДанных.Свойство("ОсновноеИзделие")
	//		ИЛИ ПараметрыДляРасчета.Найти("ВыходныеИзделия",  "Ключ")  <> Неопределено И НЕ ПараметрыРасчета.СтруктураДанных.Свойство("ВыходныеИзделия")
	//		ИЛИ ПараметрыДляРасчета.Найти("ВозвратныеОтходы", "Ключ")  <> Неопределено И НЕ ПараметрыРасчета.СтруктураДанных.Свойство("ВозвратныеОтходы")
	//		ИЛИ ПараметрыДляРасчета.Найти("МатериалыИУслуги", "Ключ")  <> Неопределено И НЕ ПараметрыРасчета.СтруктураДанных.Свойство("МатериалыИУслуги")
	//	) Тогда
	//	ПараметрыВыборки = ПараметрыВыборкиДанных("ВыходныеИзделия, ВозвратныеОтходы, МатериалыИУслуги");
	//	ЗаполнитьЗначенияСвойств(СтруктураДанных, ДанныеСпецификации(ДанныеПоНоменклатуре, ПараметрыВыборки));
	//Иначе
		ЗаполнитьЗначенияСвойств(СтруктураДанных, ПараметрыРасчета.СтруктураДанных);
	//КонецЕсли;
	//-пит
	
	#КонецОбласти
	
	#Область ИсточникиДанных
	
	ИсточникиДанных = СтруктураИсточниковДляРасчетаПоФормулам();
	
	// данные распоряжения по номенклатуре
	ИсточникиДанных.ДанныеПоНоменклатуре = ДанныеПоНоменклатуре;
	
	// основное изделие спецификации
	ОсновноеИзделие = ОбщегоНазначенияКлиентСервер.СкопироватьСтруктуру(СтруктураДанных.ОсновноеИзделие);
	//+пит
	//РассчитатьКоличествоВСтроке(
	//	ПартияВыпуска,
	//	ОсновноеИзделие,
	//	Истина,
	//	Ложь,
	//	Ложь);
	//-пит
	ИсточникиДанных.ОсновноеИзделие = ОсновноеИзделие;
	
	// табличная часть Ингредиенты
	Если СтруктураДанных.Ингредиенты <> Неопределено Тогда
		
		Для каждого Строка Из СтруктураДанных.Ингредиенты Цикл
			
			//+пит
			//РассчитатьКоличествоВСтроке(ПартияВыпуска, Строка, Истина, Ложь, Ложь);
			//-пит
			НовСтрокаИнгр = ИсточникиДанных.Ингредиенты.Добавить();
			ЗаполнитьЗначенияСвойств(НовСтрокаИнгр, Строка);
			НовСтрокаИнгр.КоличествоБрутто = Строка.КоличествоУпаковокБрутто;
			НовСтрокаИнгр.КоличествоНетто = Строка.КоличествоУпаковокНетто;
			НовСтрокаИнгр.КоличествоВыход = Строка.КоличествоУпаковокВыход;
			
		КонецЦикла;
		
	КонецЕсли;
	
	#КонецОбласти
	
	#Область ПараметрыДляРасчета
	
