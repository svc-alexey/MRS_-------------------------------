// СтандартныеПодсистемы.ВерсионированиеОбъектов

// Определяет настройки объекта для подсистемы ВерсионированиеОбъектов.
//
// Параметры:
//  Настройки - Структура - настройки подсистемы.
Процедура ПриОпределенииНастроекВерсионированияОбъектов(Настройки) Экспорт

КонецПроцедуры

// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов

// Получение актуальной рецептуры, отличной от данной, но с той же датой начала действия.
// Процедура используется в обработке загрузки рецептур, и при записи редактируемой процедуры.
//
// Параметры:
//	НаДату - Дата, дата начала действия рецептуры
//	ШагДат - Число, шаг смещения новой даты.
//	МаксимальнаяЗаДень - Булево, необходимость раместить новую дату последней за день,
//						необходимо при загрузке основных рецептур из Рецептурника.
//
// Возвращаемое значение:
//	Неопределено или Дата, новая свободная дата для актуальной рецептуры
//
Функция ПолучитьДругуюАктуальнуюРецептуру(Знач Объект, Знач НаДату, Знач ШагДат=+1, Знач МаксимальнаяЗаДень=Ложь) Экспорт
	
	Результат = Неопределено;
	// Если не указан ХозяйственнаяОперация, значит ничего не ищем
	Если НЕ ЗначениеЗаполнено(Объект.ХозяйственнаяОперация) Тогда
		Возврат Результат;
	КонецЕсли;
	// Если НаДату не указана, то нечего искать
	Если НЕ ЗначениеЗаполнено(НаДату) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Запрос=Новый Запрос();
	
	// Сформируем текст запроса.
	// Первый запрос определяет, есть ли другая рецептура с той же датой.
	// Вложенный запрос собирает все рецептуры за этот день, чтобы потом определить максимальную дату.
	Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РецептурыЗаДень.Ссылка,
	|	РецептурыЗаДень.ДатаНачала КАК ДатаНачала
	|ИЗ
	|	Документ.питРецептура КАК Рецептура
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			Рецептура.Ссылка КАК Ссылка,
	|			Рецептура.ДатаНачала КАК ДатаНачала
	|		ИЗ
	|			Документ.питРецептура КАК Рецептура
	|		ГДЕ
	|			Рецептура.Ссылка <> &Ссылка
	|			И Рецептура.Номенклатура = &Номенклатура
	|			И Рецептура.Характеристика = &Характеристика
	|			И НАЧАЛОПЕРИОДА(Рецептура.ДатаНачала, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ДатаОбъекта, ДЕНЬ)
	|			И Рецептура.ХозяйственнаяОперация = &ХозяйственнаяОперация
	|			И (НЕ Рецептура.ПометкаУдаления)) КАК РецептурыЗаДень
	|		ПО (ИСТИНА)
	|ГДЕ
	|	Рецептура.Ссылка <> &Ссылка
	|	И Рецептура.Номенклатура = &Номенклатура
	|	И Рецептура.Характеристика = &Характеристика
	|	И Рецептура.ДатаНачала = &ДатаОбъекта
	|	И Рецептура.ХозяйственнаяОперация = &ХозяйственнаяОперация
	|	И (НЕ Рецептура.ПометкаУдаления)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаНачала УБЫВ";
	
	Запрос.Текст = Текст;
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запрос.УстановитьПараметр("Номенклатура",Объект.Номенклатура);
	Запрос.УстановитьПараметр("Характеристика",Объект.Характеристика);
	Запрос.УстановитьПараметр("ХозяйственнаяОперация",Объект.ХозяйственнаяОперация);
	Если НаДату <> Неопределено Тогда
		Запрос.УстановитьПараметр("ДатаОбъекта", НаДату);
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если НЕ РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		Результат = Выборка.Ссылка;
		// Определим доступную дату начала.
		НоваяДатаНачала = НаДату;
		МассивДат = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("ДатаНачала");
		Если ТипЗнч(ШагДат) <> Тип("Число") ИЛИ ШагДат=0 ИЛИ ШагДат>4000 ИЛИ ШагДат<-4000 Тогда
			ШагДат = +1;
		ИначеЕсли ШагДат<-4000 Тогда
			ШагДат = -2;
		КонецЕсли;
		Если МаксимальнаяЗаДень = Истина Тогда
			НоваяДатаНачала = МассивДат[0]+?(ШагДат>0,ШагДат,-ШагДат);
		Иначе
			Для СчетчикВыхода = 1 По 1000 Цикл
				НоваяДатаНачала = НоваяДатаНачала + ШагДат;
				Если МассивДат.Найти(НоваяДатаНачала) = Неопределено Тогда
					// Дата свободна, выходим
					Прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
		Возврат НоваяДатаНачала;
		
	Иначе
		Возврат Результат;
	КонецЕсли;
	
КонецФункции


////////////////////////////////////////////////////////////////////////////////
// ОБРАБОТЧИКИ СОБЫТИЙ

Процедура ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)
	
	Если ВидФормы <> "ФормаДокумента"
		И ВидФормы <> "ФормаОбъекта" Тогда
		Возврат;
	КонецЕсли;
	
	ХозяйственнаяОперация = Неопределено; 
	
	Если Параметры.Свойство("Ключ") И ЗначениеЗаполнено(Параметры.Ключ) Тогда
		ХозяйственнаяОперация = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Параметры.Ключ, "ХозяйственнаяОперация");
	КонецЕсли;
	
	// Если документ копируется, то вид формы получаем из копируемого документа.
	Если НЕ ЗначениеЗаполнено(ХозяйственнаяОперация) Тогда
		Если Параметры.Свойство("ЗначениеКопирования")
			И ЗначениеЗаполнено(Параметры.ЗначениеКопирования) Тогда
			ХозяйственнаяОперация = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
				Параметры.ЗначениеКопирования, "ХозяйственнаяОперация");
		КонецЕсли;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ХозяйственнаяОперация) Тогда
		Если Параметры.Свойство("ЗначенияЗаполнения") 
			И ТипЗнч(Параметры.ЗначенияЗаполнения) = Тип("Структура") Тогда
			Если Параметры.ЗначенияЗаполнения.Свойство("ХозяйственнаяОперация") Тогда
				ХозяйственнаяОперация = Параметры.ЗначенияЗаполнения.ХозяйственнаяОперация;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ХозяйственнаяОперация) Тогда
		Если Параметры.Свойство("Основание")
			И ЗначениеЗаполнено(Параметры.Основание) Тогда
			ХозяйственнаяОперация = ОпределитьВидОперацииПоДокументуОснованию(Параметры.Основание);
		КонецЕсли;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	ФормыПоступлениеТоваровУслуг = ПолучитьСоответствиеВидовОперацийФормам();
	ВыбраннаяФорма = ФормыПоступлениеТоваровУслуг[ХозяйственнаяОперация];
	Если ВыбраннаяФорма = Неопределено Тогда
		ВыбраннаяФорма = "ФормаДокумента";
	КонецЕсли;
	
КонецПроцедуры


