Функция пл_ВернутьВесовойКоэффициент(Пар)

	СтруктураВозврат = Новый Структура;
	СтруктураВозврат.Вставить("Коэф",0);
	СтруктураВозврат.Вставить("ВесЕдиницаИзмерения",Пар.Номенклатура.ВесЕдиницаИзмерения);
	
	мКоличествоВыход = Пар.КоличествоВыход;
	
	Если мКоличествоВыход = 0 Тогда
	
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	питРецептураИнгредиенты.КоличествоВыход КАК КоличествоВыход,
			|	питРецептураИнгредиенты.НомерСтроки КАК НомерСтроки,
			|	питРецептураИнгредиенты.Номенклатура КАК Номенклатура
			|ИЗ
			|	Документ.питРецептура.Ингредиенты КАК питРецептураИнгредиенты
			|ГДЕ
			|	питРецептураИнгредиенты.НомерСтроки = &НомерСтроки
			|	И питРецептураИнгредиенты.Ссылка = &Ссылка
			|	И питРецептураИнгредиенты.Номенклатура = &Номенклатура";
		
		Запрос.УстановитьПараметр("Номенклатура", Пар.Номенклатура);
		Запрос.УстановитьПараметр("НомерСтроки", Пар.НомерСтроки);
		Запрос.УстановитьПараметр("Ссылка", Пар.Ссылка);
		
		РезультатЗапроса = Запрос.Выполнить();
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			мКоличествоВыход = ВыборкаДетальныеЗаписи.КоличествоВыход;
		КонецЦикла;
	
	КонецЕсли; 
	

	    Запрос = Новый Запрос;
		Запрос.Текст ="	
			|ВЫБРАТЬ
			|	ВЫБОР
			|		КОГДА НЕ Номенклатура.ВесИспользовать
			|			ТОГДА 0
			|		иначе	
			|			Выбор когда Номенклатура.ВесЕдиницаИзмерения = Номенклатура.ЕдиницаИзмерения 
			|				Тогда 1
			|			КОГДА &КоличествоУпаковокВыход = 0
			|				ТОГДА 0
			//<<===ПорталЮгКрым, Плотникова Н.Ю. 22.11.2021 [исправление количества нетто/брутто при пересчете из одной единицы в другую]   
			//|			ИНАЧЕ &КоличествоВыход * Номенклатура.ВесЧислитель / ВЫБОР
			//|					КОГДА Номенклатура.ВесЗнаменатель = 0
			//|						ТОГДА 1
			//|					ИНАЧЕ Номенклатура.ВесЗнаменатель
			|			ИНАЧЕ &РассчитываемоеКоличество * &КоличествоВыход * Номенклатура.ВесЧислитель / ВЫБОР
			|					КОГДА Номенклатура.ВесЗнаменатель = 0
			|						ТОГДА 1
			|					ИНАЧЕ Номенклатура.ВесЗнаменатель
			|			КОНЕЦ / &КоличествоУпаковокВыход
			|		КОНЕЦ		
			|	КОНЕЦ КАК Коэф,
			|	Номенклатура.ВесЕдиницаИзмерения.Представление КАК ВесЕдиницаИзмерения
			|ИЗ
			|	Справочник.Номенклатура КАК Номенклатура
			|ГДЕ
			|	Номенклатура.Ссылка = &Номенклатура";
		
		Запрос.УстановитьПараметр("Номенклатура",Пар.Номенклатура);
		Запрос.УстановитьПараметр("КоличествоУпаковокВыход",Пар.КоличествоУпаковокВыход);
		Запрос.УстановитьПараметр("КоличествоВыход",мКоличествоВыход);
		//<<===ПорталЮгКрым, Плотникова Н.Ю. 22.11.2021 [исправление количества нетто/брутто при пересчете из одной единицы в другую]   
		Запрос.УстановитьПараметр("РассчитываемоеКоличество",Пар.РассчитываемоеКоличество);
		//>>===ПорталЮгКрым === Плотникова Н.Ю. 22.11.2021  
		
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
		    ЗаполнитьЗначенияСвойств(СтруктураВозврат,Выборка);
		КонецЕсли; 
	возврат СтруктураВозврат;

