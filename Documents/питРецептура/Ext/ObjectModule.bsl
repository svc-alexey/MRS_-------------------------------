Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	ТипДанныхЗаполнения = ТипЗнч(ДанныеЗаполнения);
	Если ДанныеЗаполнения <> Неопределено И ТипДанныхЗаполнения <> Тип("Структура")
		И Метаданные().ВводитсяНаОсновании.Содержит(ДанныеЗаполнения.Метаданные()) Тогда
		ЗаполнитьПоДокументуОснованию(ДанныеЗаполнения);
	КонецЕсли;
	
	Если ОбщегоНазначения.ПодсистемаСуществует("РегламентированныйУчетПодсистемы") Тогда
		МодульЗаполнениеДокументов = ОбщегоНазначения.ОбщийМодуль("ЗаполнениеДокументов");
		МодульЗаполнениеДокументов.Заполнить(ЭтотОбъект, ДанныеЗаполнения);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Номенклатура) И НЕ ЗначениеЗаполнено(ХозяйственнаяОперация) Тогда
		
		ДоступныеВидыРецептур = питОбщегоНазначенияКлиентСервер.ПолучитьДоступныеВидыРецептур(Номенклатура);
		Если ДоступныеВидыРецептур.Количество() Тогда
			// Берем 1е доступное значение(это будет значение по умолчанию).
			ХозяйственнаяОперация = ДоступныеВидыРецептур[0];
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	
	Дата = НачалоДня(ОбщегоНазначения.ТекущаяДатаПользователя());
	Ответственный = Пользователи.ТекущийПользователь();
	
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка 
		ИЛИ (ДополнительныеСвойства.Свойство("Загрузка") 
		И ДополнительныеСвойства.Загрузка) Тогда
		Возврат;
	КонецЕсли;
	
	//+АвтовыборНоменклатуры
	ПредставленияНоменклатуры = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(Ингредиенты.ВыгрузитьКолонку("Номенклатура"), "Представление");
	ПредставленияХарактеристик = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(Ингредиенты.ВыгрузитьКолонку("Характеристика"), "Представление");
	Для каждого ТекИнгредиент Из Ингредиенты Цикл
		ТекИнгредиент.НоменклатураПредставление = ?(ПустаяСтрока(ТекИнгредиент.НоменклатураСтрокой), ПредставленияНоменклатуры.Получить(ТекИнгредиент.Номенклатура), ТекИнгредиент.НоменклатураСтрокой);
		ТекИнгредиент.ХарактеристикаПредставление = ?(ПустаяСтрока(ТекИнгредиент.ХарактеристикаСтрокой), ПредставленияНоменклатуры.Получить(ТекИнгредиент.Характеристика), ТекИнгредиент.ХарактеристикаСтрокой);
	КонецЦикла;
	//-АвтовыборНоменклатуры
	
	Отказ = НЕ Документы.питРецептура.ПроверитьНаДубли(ЭтотОбъект);
	
	Заголовок = "Сохранение документа: " + СокрЛП(ЭтотОбъект)+"";
	
	//+ПараметрищацияРецептур
	Если ХозяйственнаяОперация = Перечисления.питХозяйственныеОперации.РецептураРазделка Тогда
		Для каждого ТекИнгредиент Из Ингредиенты Цикл
			ТекИнгредиент.АлгоритмРасчетаКоличества = "";
		КонецЦикла;
		ОтборПоСвойствам.Очистить();
	КонецЕсли;
	//-ПараметризацияРецептур
	
	// Режим - актуальные рецептуры
	//Если Константы.питСпособРасчетаРецептур.Получить() = Перечисления.питСпособРасчетаРецептур.ПоАктуальнойРецептуре Тогда
	Если питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("СпособРасчетаРецептур") = Перечисления.питСпособРасчетаРецептур.ПоАктуальнойРецептуре Тогда
		Если НЕ ЗначениеЗаполнено(ДатаНачала) Тогда
			ДатаНачала = Дата;
		КонецЕсли;
		// Проверим, а не программно ли записывается документ: в этом случае с него могла быть снята пометка удаления.
		// Тогда при совпадении дат начала действия переведем дату.
		//ФормаДокумента = ПолучитьФорму("ФормаДокумента");
		//ЗаписьПрограммно = НЕ ФормаДокумента.Открыта();
		//Если ЗаписьПрограммно Тогда
		//	НоваяДатаНачала = ПолучитьДругуюАктуальнуюРецептуру(ДатаНачала);
		//	Если ЗначениеЗаполнено(НоваяДатаНачала) Тогда
		//		// Эта дата занята, изменим дату начала действия
		//		ДатаНачала = НоваяДатаНачала;
		//	КонецЕсли;
		//КонецЕсли;
		
		// Проверка корректности заполнения периода действия
		Если ЗначениеЗаполнено(ДатаКонца) И ДатаНачала > ДатаКонца Тогда
			ТекстСообщения = "Дата начала периода действия рецептуры <" + Формат(ДатаНачала, "ДЛФ=DT") + "> превышает дату окончания <" + Формат(ДатаКонца, "ДЛФ=DT")+">";
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, "ДатаКонца", "Объект", Отказ);
		КонецЕсли;
	КонецЕсли;
	
	// Нужно очистить невидимые разряды в количествах,
	// только для специй допустимо указывать более трех разрядов в количествах.
	Для Каждого СтрокаТовара Из Ингредиенты Цикл
		//<< Портал-Юг, Гребенюк, 2023.05.12 [Обновление 2.5. Код без комментариев]
		Если СтрокаТовара.Специя Тогда
			Продолжить;
		КонецЕсли;		
		//>> Портал-Юг, Гребенюк, 2023.05.12
		Если НЕ СтрокаТовара.КоличествоУпаковокБрутто = Окр(СтрокаТовара.КоличествоУпаковокБрутто,3) Тогда
			СтрокаТовара.КоличествоУпаковокБрутто = Окр(СтрокаТовара.КоличествоУпаковокБрутто,3);
		КонецЕсли;
		Если НЕ СтрокаТовара.КоличествоУпаковокНетто = Окр(СтрокаТовара.КоличествоУпаковокНетто,3) Тогда
			СтрокаТовара.КоличествоУпаковокНетто = Окр(СтрокаТовара.КоличествоУпаковокНетто,3);
		КонецЕсли;
		Если НЕ СтрокаТовара.КоличествоУпаковокВыход = Окр(СтрокаТовара.КоличествоУпаковокВыход,3) Тогда
			СтрокаТовара.КоличествоУпаковокВыход = Окр(СтрокаТовара.КоличествоУпаковокВыход,3);
		КонецЕсли;
	КонецЦикла;
	
	//+РазрешенныеПодразделения
	НайденныеПодразделения = ЭтотОбъект.РазрешенныеПодразделения.НайтиСтроки(Новый Структура("Подразделение", ЭтотОбъект.Подразделение));
	КоличествоНайденных = НайденныеПодразделения.Количество();
	Если КоличествоНайденных И НЕ ЗначениеЗаполнено(ЭтотОбъект.ЦеховаяКладовая) Тогда
		// Нашли в ТЧ строки, соответствующие подразделению из шапки и при этом в шапке не указан цех.
		
		// Ищем среди найденных строк строку с пустым цехом.
		ПустыхСтрокНайдено = 0;
		СтрокиУдалить = Новый Массив;
		Для каждого НайденноеПодразделение Из НайденныеПодразделения Цикл
			Если НЕ ЗначениеЗаполнено(НайденноеПодразделение.ЦеховаяКладовая) Тогда
				СтрокиУдалить.Добавить(НайденноеПодразделение);
				ПустыхСтрокНайдено = ПустыхСтрокНайдено + 1;
			КонецЕсли;
		КонецЦикла;
		// Если строки кроме пустых строк еще что-то есть, то удаляем пустые строки.
		Если КоличествоНайденных - ПустыхСтрокНайдено Тогда
			Для каждого ТекСтрокаУдалить Из СтрокиУдалить Цикл
				РазрешенныеПодразделения.Удалить(ТекСтрокаУдалить);
				КоличествоНайденных = КоличествоНайденных - 1;
			КонецЦикла;
		КонецЕсли;
		
		ПодразделениеЦехНайдено = Истина;
		
	Иначе
		ПодразделениеЦехНайдено = Ложь;
		Для каждого ТекНайденноеПодразделение Из НайденныеПодразделения Цикл
			Если ТекНайденноеПодразделение.ЦеховаяКладовая = Справочники.Склады.ПустаяСсылка() 
				ИЛИ ТекНайденноеПодразделение.ЦеховаяКладовая = ЭтотОбъект.ЦеховаяКладовая Тогда
				ПодразделениеЦехНайдено = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	Если НЕ ПодразделениеЦехНайдено Тогда
		НовПодразделение = ЭтотОбъект.РазрешенныеПодразделения.Добавить();
		НовПодразделение.Подразделение		= ЭтотОбъект.Подразделение;
		НовПодразделение.ЦеховаяКладовая	= ЭтотОбъект.ЦеховаяКладовая;
		НовПодразделение.ВключаяПодчиненные	= Истина;
	КонецЕсли;
	//-РазрешенныеПодразделения
	
	ДополнительныеСвойства.Вставить("ЭтоПометкаУдаления", ПометкаУдаления = Истина);
	
	// Заполнение наименования рецептуры.
	Если НЕ ЗначениеЗаполнено(Наименование) Тогда
		Наименование = Документы.питРецептура.СформироватьНаименованиеРецептуры(Номенклатура, Характеристика, ДатаНачала, ДатаКонца);
	КонецЕсли;
	
КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	ТекстСообщения = "";
	
	// Удалим существующие записи по рецептуре.
	Отказ = НЕ РегистрыСведений.питАктуальныеРецептуры.УдалитьЗаписиПоРецептуре(Ссылка, ТекстСообщения);
	
	Если НЕ Отказ И НЕ ДополнительныеСвойства.ЭтоПометкаУдаления Тогда
		
		ТекПодразделения = питПроизводство.НайтиПодразделенияПоРазрешенным(РазрешенныеПодразделения.Выгрузить());
		
		Для каждого ТекПодразделение Из ТекПодразделения Цикл
			
			МенеджерДобавить = РегистрыСведений.питАктуальныеРецептуры.СоздатьМенеджерЗаписи();
			МенеджерДобавить.Период					= ДатаНачала;
			МенеджерДобавить.Номенклатура			= Номенклатура;
			МенеджерДобавить.Характеристика			= Характеристика;
			МенеджерДобавить.Организация			= Организация;
			МенеджерДобавить.Подразделение			= ТекПодразделение;
			МенеджерДобавить.Рецептура				= Ссылка;
			МенеджерДобавить.ДатаОкончания			= ДатаКонца;
			
			Попытка
				МенеджерДобавить.Записать(Ложь);
			Исключение
				Отказ = Истина;
				ТекстСообщения = ТекстСообщения + "
				|Не удалось записать рецептуру с параметрами:
				| - Дата начала:	<"+ДатаНачала+">
				| - Номенклатура:	<"+Номенклатура+">
				| - Характеристика:	<"+Характеристика+">
				| - Организация:	<"+Организация+"> 
				| - Подразделение:	<"+ТекПодразделение+">!
				|"+ОписаниеОшибки();
				Прервать;
			КонецПопытки;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Если Отказ Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,,,, Отказ);
	КонецЕсли;
	
КонецПроцедуры

#КонецЕсли

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	МассивНепроверяемыхРеквизитов = Новый Массив;
	
	//+debug
	МассивНепроверяемыхРеквизитов.Добавить("Ингредиенты.КоличествоУпаковокБрутто");
	//-debug
	
	#Область ПроверкаХарактеристик
	
	// Проверка заполнения характеристик в шапке.
	Если НЕ питОбщегоНазначения.ХарактеристикиИспользуются(Номенклатура) Тогда
		МассивНепроверяемыхРеквизитов.Добавить("Характеристика");
	КонецЕсли;
	
	ПараметрыПроверкиХарактеристик = НоменклатураСервер.ПараметрыПроверкиЗаполненияХарактеристик();
	
	//ПараметрыПроверкиХарактеристик.ИмяТЧ = "Ингредиенты";
	//НоменклатураСервер.ПроверитьЗаполнениеХарактеристик(ЭтотОбъект, МассивНепроверяемыхРеквизитов, Отказ, ПараметрыПроверкиХарактеристик);
	//ПараметрыПроверкиХарактеристик.СуффиксДопРеквизита = "Замены";
	//НоменклатураСервер.ПроверитьЗаполнениеХарактеристик(ЭтотОбъект, МассивНепроверяемыхРеквизитов, Отказ, ПараметрыПроверкиХарактеристик);
	//ПараметрыПроверкиХарактеристик.СуффиксДопРеквизита = "";
	
	МассивНепроверяемыхРеквизитов.Добавить("Ингредиенты.Характеристика");
	МассивНепроверяемыхРеквизитов.Добавить("Ингредиенты.ХарактеристикаЗамены");
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"
		|ВЫБРАТЬ 
		|	ТЧИнгредиенты.НомерСтроки,
		|	ТЧИнгредиенты.Номенклатура, 
		|	ТЧИнгредиенты.Характеристика, 
		|	ТЧИнгредиенты.Замена,
		|	ТЧИнгредиенты.ХарактеристикаЗамены,
		|	ТЧИнгредиенты.СпособАвтовыбораХарактеристики
		|ПОМЕСТИТЬ ВТИнгредиенты 
		|ИЗ &ТЧИнгредиенты КАК ТЧИнгредиенты;
		|
		|ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА НЕ НоменклатураСпр.ИспользованиеХарактеристик = ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать)
		|				И питРецептураИнгредиенты.Характеристика = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)
		|				И питРецептураИнгредиенты.СпособАвтовыбораХарактеристики = ЗНАЧЕНИЕ(Перечисление.СпособыАвтовыбораХарактеристики.УказываетсяВНСИ)
		|			ТОГДА ЛОЖЬ
		|		ИНАЧЕ ИСТИНА
		|	КОНЕЦ КАК ХарактеристикаЗаполнена,
		|	питРецептураИнгредиенты.НомерСтроки,
		|	ВЫБОР
		|		КОГДА НЕ Замены.ИспользованиеХарактеристик = ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать)
		|				И питРецептураИнгредиенты.ХарактеристикаЗамены = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)
		|			ТОГДА ЛОЖЬ
		|		ИНАЧЕ ИСТИНА
		|	КОНЕЦ КАК ХарактеристикаЗаменыЗаполнена
		|ИЗ
		|	ВТИнгредиенты КАК питРецептураИнгредиенты
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСпр
		|		ПО питРецептураИнгредиенты.Номенклатура = НоменклатураСпр.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Замены
		|		ПО питРецептураИнгредиенты.Замена = Замены.Ссылка";
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("ТЧИнгредиенты", ЭтотОбъект.Ингредиенты.Выгрузить());
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	КлючДанных = ОбщегоНазначенияУТ.КлючДанныхДляСообщенияПользователю(ЭтотОбъект);
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если НЕ ВыборкаДетальныеЗаписи.ХарактеристикаЗаполнена Тогда
			Отказ = Истина;
			Поле = ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти("Ингредиенты", ВыборкаДетальныеЗаписи.НомерСтроки, "Характеристика");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнена характеристика ингредиента в строке "+ВыборкаДетальныеЗаписи.НомерСтроки+" таблицы ""Ингредиенты""!",,,,Отказ);
		КонецЕсли;
		Если НЕ ВыборкаДетальныеЗаписи.ХарактеристикаЗаменыЗаполнена Тогда
			Отказ = Истина;
			Поле = ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти("Ингредиенты", ВыборкаДетальныеЗаписи.НомерСтроки, "ХарактеристикаЗамены");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнена характеристика замены в строке "+ВыборкаДетальныеЗаписи.НомерСтроки+" таблицы ""Ингредиенты""!",,,,Отказ);
		КонецЕсли;
	КонецЦикла;
	
	ПараметрыПроверкиХарактеристик.ИмяТЧ = "ПобочныеИзделия";
	НоменклатураСервер.ПроверитьЗаполнениеХарактеристик(ЭтотОбъект, МассивНепроверяемыхРеквизитов, Отказ, ПараметрыПроверкиХарактеристик);
	
	#КонецОбласти
	
	//+АвтовыборНоменклатуры
	МассивНепроверяемыхРеквизитов.Добавить("Ингредиенты.Номенклатура");
	ПроверитьЗаполнениеНоменклатурыИнгредиентов(
		МассивНепроверяемыхРеквизитов,
		Отказ);
	//+АвтовыборНоменклатуры
	
	ОбщегоНазначения.УдалитьНепроверяемыеРеквизитыИзМассива(ПроверяемыеРеквизиты, МассивНепроверяемыхРеквизитов);
	
КонецПроцедуры

//+АвтовыборНоменклатуры
Процедура ПроверитьЗаполнениеНоменклатурыИнгредиентов(МассивНепроверяемыхРеквизитов, Отказ)
	
	ИмяТЧ           = "Ингредиенты";
	ПредставлениеТЧ = "Ингредиенты";
	
	ИспользуетсяПроизводство22 = ПроизводствоСервер.ИспользуетсяПроизводство22();
	ТипыНоменклатуры           = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(Ингредиенты.ВыгрузитьКолонку("Номенклатура"), "ТипНоменклатуры");
	
	Для каждого Строка Из Ингредиенты Цикл
		
		Если Строка.Номенклатура.Пустая()
			И (Строка.СпособАвтовыбораНоменклатуры = Перечисления.СпособыАвтовыбораНоменклатуры.УказываетсяВНСИ
			
			//ИЛИ Строка.СпособАвтовыбораНоменклатуры = Перечисления.СпособыАвтовыбораНоменклатуры.ЗадаетсяВСвойствеПродукции
			//	И Строка.ПроизводитсяВПроцессе
			//	И Строка.СпособПолученияМатериала = Перечисления.СпособыПолученияМатериаловВСпецификации.ПроизводитсяНаЭтапе
			//
			//ИЛИ Строка.СпособАвтовыбораНоменклатуры = Перечисления.СпособыАвтовыбораНоменклатуры.УточняетсяПриПроизводстве
			//	И Строка.ПроизводитсяВПроцессе
				
			ИЛИ НЕ ПолучитьФункциональнуюОпцию("ИспользоватьПараметризациюРесурсныхСпецификаций")
			) Тогда
			
			ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("Колонка", "Заполнение", НСтр("ru = 'Номенклатура';
																												|en = 'Products and services'"), Строка.НомерСтроки, ПредставлениеТЧ);
			Поле = ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти(ИмяТЧ, Строка.НомерСтроки, "Номенклатура");
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
				ТекстСообщения,
				ЭтотОбъект,
				Поле,,
				Отказ);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры
//-АвтовыборНоменклатуры


