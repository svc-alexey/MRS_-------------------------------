// ЭКСПОРТНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ ДОКУМЕНТА

// Получение актуальной рецептуры, отличной от данной, но с той же датой начала действия.
//
// Параметры:
//	НаДату - Дата, дата начала действия рецептуры
//
// Возвращаемое значение:
//	ДокументСсылка.питРецептура, найденная актуальная рецептура
//
Функция ПолучитьДругуюАктуальнуюРецептуру_2(Знач НаДату, Знач ШагДат=+1, Знач МаксимальнаяЗаДень=Ложь) Экспорт
	Результат = Новый Массив;
	// Если не указан ХозяйственнаяОперация, значит ничего не ищем
	Если НЕ ЗначениеЗаполнено(ХозяйственнаяОперация) Тогда
		Возврат Результат;
	КонецЕсли;
	// Если НаДату не указана, то нечего искать
	Если НЕ ЗначениеЗаполнено(НаДату) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Запрос=Новый Запрос();
	
	// Сформируем текст запроса.
	// Первый запрос определяет, есть ли другая рецептура с той же датой.
	// Вложенный запрос собирает все рецептуры за этот день, чтобы потом определить максимальную дату.
	Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РецептурыЗаДень.Ссылка,
	|	РецептурыЗаДень.ДатаНачала КАК ДатаНачала
	|ИЗ
	|	Документ.питРецептура КАК Рецептура
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			Рецептура.Ссылка КАК Ссылка,
	|			Рецептура.ДатаНачала КАК ДатаНачала
	|		ИЗ
	|			Документ.питРецептура КАК Рецептура
	|		ГДЕ
	|			Рецептура.Ссылка <> &Ссылка
	|			И Рецептура.Номенклатура = &Номенклатура
	|			И Рецептура.Характеристика = &Характеристика
	|			И НАЧАЛОПЕРИОДА(Рецептура.ДатаНачала, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ДатаОбъекта, ДЕНЬ)
	|			И Рецептура.ХозяйственнаяОперация = &ХозяйственнаяОперация
	|			И (НЕ Рецептура.ПометкаУдаления)) КАК РецептурыЗаДень
	|		ПО (ИСТИНА)
	|ГДЕ
	|	Рецептура.Ссылка <> &Ссылка
	|	И Рецептура.Номенклатура = &Номенклатура
	|	И Рецептура.Характеристика = &Характеристика
	|	И Рецептура.ДатаНачала = &ДатаОбъекта
	|	И Рецептура.ХозяйственнаяОперация = &ХозяйственнаяОперация
	|	И (НЕ Рецептура.ПометкаУдаления)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаНачала УБЫВ";
	
	Запрос.Текст = Текст;
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("Номенклатура",Номенклатура);		
	Запрос.УстановитьПараметр("Характеристика",Характеристика);
	Запрос.УстановитьПараметр("ХозяйственнаяОперация",ХозяйственнаяОперация);
	Если НаДату <> Неопределено Тогда
		Запрос.УстановитьПараметр("ДатаОбъекта", НаДату);
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если НЕ РезультатЗапроса.Пустой() Тогда
		Результат = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Ссылка");
		
		Возврат Результат;
		
	Иначе
		Возврат Результат;
	КонецЕсли;
	
КонецФункции

// Получение актуальной рецептуры, отличной от данной, но с той же датой начала действия.
//
// Параметры:
//	НаДату - Дата, дата начала действия рецептуры
//
// Возвращаемое значение:
//	ДокументСсылка.питРецептура, найденная актуальная рецептура
//
Функция ПолучитьДругуюАктуальнуюРецептуру(Знач НаДату, Знач ШагДат=+1, Знач МаксимальнаяЗаДень=Ложь) Экспорт
