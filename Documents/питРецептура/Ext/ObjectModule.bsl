Процедура ЗаполнитьПоДокументуОснованию(Основание)
	
	Если ТипЗнч(Основание)=Тип("ДокументСсылка.питАктПроработки") Тогда
		
		Наименование				= Основание.Наименование;
		ХозяйственнаяОперация		= Перечисления.питХозяйственныеОперации.РецептураПриготовление;
		Организация					= Основание.Организация;
		Ответственный				= Основание.Ответственный;
		Комментарий					= Основание.Комментарий;
		Подразделение				= Основание.Подразделение;
		Номенклатура				= Основание.Номенклатура;
		Характеристика				= Основание.Характеристика;
		Количество					= Основание.Количество;
		КоличествоУпаковок			= Основание.КоличествоУпаковок;
		Упаковка					= Основание.Упаковка;
		НомерРецептуры				= Основание.НомерРецептуры;
		Выход						= Основание.Выход;
		ТехнологияПриготовления		= Основание.ТехнологияПриготовления;
		ДатаНачала					= Основание.ДатаНачала;
		ДатаКонца					= Основание.ДатаКонца;
		ДокументОснование			= Основание;
		СтатьяКалькуляци			= питОбщегоНазначенияСервер.ПолучитьЗначениеПоУмолчанию("СтатьяКалькуляцииПоУмолчанию");
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Ссылка", Основание);
		Запрос.Текст = "
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	АктПроработкиТовары.Номенклатура,
		|	АктПроработкиТовары.Характеристика,
		|	АктПроработкиТовары.Упаковка,
		|	ВЫРАЗИТЬ((АктПроработкиТовары.КоличествоУпаковокБрутто + АктПроработкиТовары.КоличествоУпаковокБрутто1 + АктПроработкиТовары.КоличествоУпаковокБрутто2)/3 КАК ЧИСЛО(15,3))КАК КоличествоУпаковокБрутто,
		|	ВЫРАЗИТЬ((АктПроработкиТовары.КоличествоУпаковокНетто + АктПроработкиТовары.КоличествоУпаковокНетто1 + АктПроработкиТовары.КоличествоУпаковокНетто2)/3 КАК ЧИСЛО(15,3)) КАК КоличествоУпаковокНетто,
		|	ВЫРАЗИТЬ((АктПроработкиТовары.КоличествоУпаковокВыход + АктПроработкиТовары.КоличествоУпаковокВыход1 + АктПроработкиТовары.КоличествоУпаковокВыход2)/3 КАК ЧИСЛО(15,3)) КАК КоличествоУпаковокВыход
		|ИЗ
		|	Документ.питАктПроработки.Ингредиенты КАК АктПроработкиТовары
		|ГДЕ
		|	АктПроработкиТовары.Ссылка = &Ссылка";
		
		Ингредиенты.Загрузить(Запрос.Выполнить().Выгрузить());
		
		КэшированныеЗначенияУпаковок = ОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
	
		// Заполним проценты потерь
		Для Каждого СтрокаТовары Из Ингредиенты Цикл
			Если НЕ СтрокаТовары.КоличествоУпаковокБрутто = СтрокаТовары.КоличествоУпаковокНетто Тогда
				СтрокаТовары.ПроцентПотерьПриХолоднойОбработке = РассчитатьПроцентПотерьОбработки(СтрокаТовары.КоличествоУпаковокБрутто, СтрокаТовары.КоличествоУпаковокНетто);
			КонецЕсли;
			Если НЕ СтрокаТовары.КоличествоУпаковокНетто = СтрокаТовары.КоличествоУпаковокВыход Тогда
				СтрокаТовары.ПроцентПотерьПриГорячейОбработке = РассчитатьПроцентПотерьОбработки(СтрокаТовары.КоличествоУпаковокНетто, СтрокаТовары.КоличествоУпаковокВыход);
			КонецЕсли;
			
			ТекКоэффициент = питОбщегоНазначения.ПолучитьКоэффициентУпаковки(СтрокаТовары.Номенклатура, СтрокаТовары.Упаковка);
			СтрокаТовары.КоличествоБрутто	= СтрокаТовары.КоличествоУпаковокБрутто * ТекКоэффициент;
			СтрокаТовары.КоличествоНетто	= СтрокаТовары.КоличествоУпаковокНетто * ТекКоэффициент;
			СтрокаТовары.КоличествоВыход	= СтрокаТовары.КоличествоУпаковокВыход * ТекКоэффициент;
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

// Определяет процент потерь холодной или горячей обработки по количествам.
//
// Параметры:
//  КоличествоИсх - исходное количество продукта до обработки.
//  КоличествоОбработанное - количество продукта после холодной или горячей обработки.
//
Функция РассчитатьПроцентПотерьОбработки(КоличествоИсх, КоличествоОбработанное)
	Если КоличествоИсх = 0 Тогда
		Возврат 0;
	Иначе
		Возврат Окр((КоличествоИсх - КоличествоОбработанное) * 100 / КоличествоИсх, 2);
	КонецЕсли;
КонецФункции

