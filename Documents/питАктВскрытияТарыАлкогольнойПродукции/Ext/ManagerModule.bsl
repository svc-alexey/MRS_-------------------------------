// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
// Параметры:
//  ДокументСсылкаРегистрацияЗамен - ДокументСсылка.РегистрацияЗамен - ДокументСсылкаРегистрацияЗамен
//  СтруктураДополнительныеСвойства - Структура - СтруктураДополнительныеСвойства
//
Процедура ИнициализироватьДанныеДокумента(ДокументСсылка, СтруктураДополнительныеСвойства) Экспорт
	
	РеквизитыШапки = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументСсылка, "Дата, Организация, Склад");
	
	Склад = РеквизитыШапки.Склад;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Запрос.УстановитьПараметр("Дата", РеквизитыШапки.Дата);
	Запрос.УстановитьПараметр("Организация", РеквизитыШапки.Организация);
	Запрос.УстановитьПараметр("ОсобенностиУчета", 
		РегистрыНакопления.питОстаткиМарокИС.ОсобенностиУчетаДоступныеДляОтраженияОстатковИС());
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	Товары.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	Товары.Количество КАК Количество,
	|	АкцизныеМарки.АкцизнаяМарка КАК Штрихкод,
	|	Товары.АлкогольнаяПродукция КАК АлкогольнаяПродукция,
	|	&Дата КАК Период,
	|	&Организация КАК Организация,
	|	Товары.Ссылка КАК Регистратор,
	|	&Склад КАК МестоПечати,
	|	ЗНАЧЕНИЕ(Перечисление.питВидыДвиженийОстатковМарокИС.ВскрытиеАлкоголя) КАК ВидДвиженияМарок,
	|	Товары.ЕмкостьТары КАК ЕмкостьТары
	|ИЗ
	|	Документ.питАктВскрытияТарыАлкогольнойПродукции.Товары КАК Товары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.питАктВскрытияТарыАлкогольнойПродукции.АкцизныеМарки КАК АкцизныеМарки
	|		ПО Товары.Ссылка = АкцизныеМарки.Ссылка
	|			И Товары.ИдентификаторСтроки = АкцизныеМарки.ИдентификаторСтроки
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНоменклатура
	|		ПО Товары.Номенклатура = СпрНоменклатура.Ссылка
	|ГДЕ
	|	Товары.Ссылка = &Ссылка
	|	И АкцизныеМарки.Ссылка = &Ссылка
	|	И СпрНоменклатура.ОсобенностьУчета В(&ОсобенностиУчета)";
	
	РезультатЗапроса = Запрос.Выполнить();
	ТаблицаОстаткиМарокИС = питОбщегоНазначения.ПустаяТаблицаПоРезультатуЗапроса(РезультатЗапроса);
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Если НЕ ЗначениеЗаполнено(Выборка.Штрихкод) Тогда
			Продолжить;
		КонецЕсли;
		
		КоличествоМЛ = питОбщегоНазначения.ПеревестиОбъемВМиллилитры(Выборка.Номенклатура,
			Выборка.ЕдиницаИзмерения,
			Выборка.ЕмкостьТары, //Швецов. 29.05.2025. берем не общее кол-во а емкость по марке
			Выборка.АлкогольнаяПродукция);
		Если НЕ ЗначениеЗаполнено(КоличествоМЛ) Тогда
			Продолжить;
		КонецЕсли;
		НоваяСтрока = ТаблицаОстаткиМарокИС.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
		НоваяСтрока.Количество = КоличествоМЛ;
		
	КонецЦикла;
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("питОстаткиМарокИС", ТаблицаОстаткиМарокИС);
	
КонецПроцедуры

