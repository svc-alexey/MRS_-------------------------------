//<< Портал-Юг, Баринов, 2019.09.19 [6.2.22 Загрузка продаж из Sanatorium] + сумма скидки
Процедура РассчитатьСуммуНДСТабЧастиЧека(ДанныеСтроки, СуммаВключаетНДС) Экспорт
	
	СтруктураДанныеСтроки = Новый Структура("Сумма, СуммаСкидки, СтавкаНДС, СуммаНДС");
	ЗаполнитьЗначенияСвойств(СтруктураДанныеСтроки, ДанныеСтроки);
	ДанныеСтроки.СуммаСкидки = ДанныеСтроки.СуммаСкидки + ДанныеСтроки.СуммаСкидкиСтроки;
	питОбщегоНазначенияКлиентСервер.РассчитатьСуммуНДСТабЧасти(СтруктураДанныеСтроки, СуммаВключаетНДС);
	ДанныеСтроки.СуммаНДС = СтруктураДанныеСтроки.СуммаНДС;
	
КонецПроцедуры //>> Портал-Юг, Баринов, 2019.09.19

//<< Портал-Юг, Баринов, 2019.04.02 [6.2.23 Функционал установки ссылочных типов в местах где указан код]
Процедура ПроверитьЗаписьСоответствия(Поле, Выборка, НовыеЗаписиСоответствий, ФронтСистема = Неопределено)
	
	Если ЗначениеЗаполнено(Поле.Значение) Тогда
		Код = СокрЛП(Выборка[Поле.Ключ + "Код"]);
		Если ЗначениеЗаполнено(Код) И Выборка[Поле.Ключ + "НетСоответствия"] Тогда
			// Нет записи в регистре соответствий, создадим её
			Запись = НовыеЗаписиСоответствий.Добавить();
			Запись.Код = Код;
			Запись.ФронтСистема = ?(ЗначениеЗаполнено(ФронтСистема), ФронтСистема, Выборка.ФронтСистема);
			Запись.ТипОбъекта = Поле.Значение;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры //>> Портал-Юг, Баринов, 2019.04.02

//<< Портал-Юг, Баринов, 2019.09.14 [9.32 Автоформирование характеристики для открытой цены при обработке загруженных чеков]
Процедура ДозаполнитьХарактеристикиДляОткрытойЦены(ЧекОбъект, НоменклатураСХарактеристиками, СвойстваХарактеристикОткрытаяЦена)
	
	Если НоменклатураСХарактеристиками.Количество() = 0 Тогда 
		Возврат;
	КонецЕсли;	
	
	Если ЧекОбъект.ВидОперации <> Перечисления.питХозяйственныеОперации.ДанныеПродажФронтаПродажа Тогда
		// Для возвратов заполнение характеристики смысла не имеет и чек не считает её обязательной.
		Возврат;
	КонецЕсли;
	
	Если СвойстваХарактеристикОткрытаяЦена = Неопределено Тогда
		// Не найдены реквизиты, сообщение об ошибке выдано уже при поиске
		Возврат;
	КонецЕсли; 
	
	ДатаЧека = НачалоДня(ЧекОбъект.Дата);
	НомерЧека = ?(ЗначениеЗаполнено(ЧекОбъект.НомерЧека), ЧекОбъект.НомерЧека, ЧекОбъект.Номер); 
	
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("Товары", ЧекОбъект.Товары.Выгрузить(, "НомерСтроки, Номенклатура"));
	Запрос.УстановитьПараметр("ДатаЧека", ДатаЧека);
	Запрос.УстановитьПараметр("НомерЧека", НомерЧека);
	Для каждого ДопРеквизит Из СвойстваХарактеристикОткрытаяЦена Цикл
		Запрос.УстановитьПараметр(ДопРеквизит.Ключ, ДопРеквизит.Значение);
	КонецЦикла; 
		
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Товары.НомерСтроки КАК НомерСтроки,
	|	ВЫРАЗИТЬ(Товары.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура
	|ПОМЕСТИТЬ тчТовары
	|ИЗ
	|	&Товары КАК Товары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ХарактеристикаШапка.Ссылка КАК Характеристика,
	|	ХарактеристикаНомерСтроки.Значение КАК НомерСтроки,
	|	ХарактеристикаШапка.Владелец КАК Владелец
	|ПОМЕСТИТЬ спрХарактеристики
	|ИЗ
	|	Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикаШапка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ХарактеристикиНоменклатуры.ДополнительныеРеквизиты КАК ХарактеристикаНомерСтроки
	|		ПО ХарактеристикаШапка.Ссылка = ХарактеристикаНомерСтроки.Ссылка
	|			И (ХарактеристикаНомерСтроки.Свойство = &ПЛ_НомерСтроки_ОткрытаяЦена_Характеристика)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ХарактеристикиНоменклатуры.ДополнительныеРеквизиты КАК ХарактеристикаНомерЧека
	|		ПО ХарактеристикаШапка.Ссылка = ХарактеристикаНомерЧека.Ссылка
	|			И (ХарактеристикаНомерЧека.Свойство = &ПЛ_НомерЧека_ОткрытаяЦена_Характеристика)
	|			И (ХарактеристикаНомерЧека.Значение = &НомерЧека)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ХарактеристикиНоменклатуры.ДополнительныеРеквизиты КАК ХарактеристикаДатаЧека
	|		ПО ХарактеристикаШапка.Ссылка = ХарактеристикаДатаЧека.Ссылка
	|			И (ХарактеристикаДатаЧека.Свойство = &ПЛ_ДатаЧека_ОткрытаяЦена_Характеристика)
	|			И (ХарактеристикаДатаЧека.Значение = &ДатаЧека)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	тчТовары.НомерСтроки КАК НомерСтроки,
	|	тчТовары.Номенклатура КАК Номенклатура,
	|	спрХарактеристики.Характеристика КАК Характеристика
	|ИЗ
	|	тчТовары КАК тчТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ спрХарактеристики КАК спрХарактеристики
	|		ПО тчТовары.НомерСтроки = спрХарактеристики.НомерСтроки
	|			И тчТовары.Номенклатура = спрХарактеристики.Владелец
	|ГДЕ
	|	тчТовары.Номенклатура.питПродажаПоСвободнойЦене
	|	И тчТовары.Номенклатура.ИспользованиеХарактеристик = ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.ИндивидуальныеДляНоменклатуры)";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	СпрМенеджер = Справочники.ХарактеристикиНоменклатуры;
	
	Пока Выборка.Следующий() Цикл
		
		Характеристика = Выборка.Характеристика;
		
		Если НЕ ЗначениеЗаполнено(Характеристика) Тогда
			
			Новая = СпрМенеджер.СоздатьЭлемент();
			Новая.Владелец = Выборка.Номенклатура;
			Новая.Заполнить(Неопределено);
			
			ДопРеквизит = Новая.ДополнительныеРеквизиты.Добавить();
			ДопРеквизит.Свойство = СвойстваХарактеристикОткрытаяЦена.ПЛ_ДатаЧека_ОткрытаяЦена_Характеристика;
			ДопРеквизит.Значение = ДатаЧека;
			
			ДопРеквизит = Новая.ДополнительныеРеквизиты.Добавить();
			ДопРеквизит.Свойство = СвойстваХарактеристикОткрытаяЦена.ПЛ_НомерЧека_ОткрытаяЦена_Характеристика;
			ДопРеквизит.Значение = НомерЧека;
			
			ДопРеквизит = Новая.ДополнительныеРеквизиты.Добавить();
			ДопРеквизит.Свойство = СвойстваХарактеристикОткрытаяЦена.ПЛ_НомерСтроки_ОткрытаяЦена_Характеристика;
			ДопРеквизит.Значение = Выборка.НомерСтроки;
			
			Новая.Записать();
			Характеристика = Новая.Ссылка;
		КонецЕсли; 
		
		ТекСтрока = ЧекОбъект.Товары[Выборка.НомерСтроки - 1];
		ТекСтрока.Характеристика = Характеристика;
	КонецЦикла;
	
КонецПроцедуры //>> Портал-Юг, Баринов, 2019.09.14

//<< Портал-Юг, Баринов, 2019.04.04 [6.2.23 Функционал установки ссылочных типов в местах где указан код]
Процедура ОбработатьПолеШапкиЧека(Поле, ВыборкаШапка, ЧекОбъект, СопоставлениеЗавершено, НовыеЗаписиСоответствий)
	
	ЗначениеСоответствия = ВыборкаШапка[Поле.Ключ + "Соответствие"];
	Если НЕ ЗначениеЗаполнено(ВыборкаШапка[Поле.Ключ]) И ЗначениеЗаполнено(ЗначениеСоответствия) Тогда
		ЧекОбъект = ЧекОбъект(ВыборкаШапка.ЧекСсылка, ЧекОбъект);
		ЧекОбъект[Поле.Ключ] = ЗначениеСоответствия;		
	ИначеЕсли НЕ ЗначениеЗаполнено(ВыборкаШапка[Поле.Ключ]) И ЗначениеЗаполнено(Поле.Значение) Тогда 
		// Поле осталось незаполнено, но для этого поля есть код соответствия
		Если НЕ ПустаяСтрока(ВыборкаШапка[Поле.Ключ + "Код"]) И НЕ ВыборкаШапка[Поле.Ключ + "НеВлияетНаУчетТМЦ"] Тогда 
			// Есть код, и не установлен флаг "Не влияет на учет ТМЦ" в строке соответствия
			СопоставлениеЗавершено = Ложь;
		КонецЕсли;				
	КонецЕсли;
	
	ПроверитьЗаписьСоответствия(Поле, ВыборкаШапка, НовыеЗаписиСоответствий);
		
КонецПроцедуры //>> Портал-Юг, Баринов, 2019.04.04

//<< Портал-Юг, Баринов, 2019.04.02 [6.2.23 Функционал установки ссылочных типов в местах где указан код]
Процедура ДобавитьЗаписи(НовыеЗаписиСоответствий)
	
	НовыеЗаписиСоответствий.Свернуть("Код, ФронтСистема, ТипОбъекта");
	
	Для каждого НоваяЗапись Из НовыеЗаписиСоответствий Цикл
	
		МенеджерЗаписи = СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(МенеджерЗаписи, НоваяЗапись);
		МенеджерЗаписи.Записать();
		
	КонецЦикла;
	
КонецПроцедуры //>> Портал-Юг, Баринов, 2019.04.02

