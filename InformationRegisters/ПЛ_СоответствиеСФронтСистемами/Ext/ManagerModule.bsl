//<< Портал-Юг Баринов 2019.03.14 [6.2.22 Загрузка продаж из Micros\TNG]
// Добавляет запись в регистр, если записи ещё нет
//
// Параметры:
//  ТипОбъекта		 - ПланВидовХарактеристикСсылка.ПЛ_ТипыОбъектовФронтСистем - Тип объекта, для которого нужна запись о соответствии
//  ТипФронтСистемы	 - ПеречислениеСсылка.ПЛ_ТипыФронтСистем - Тип системы, для которой нужна запись о соответствии
//  Код				 - Строка - код объекта во фронт-системе
//  Наименование	 - Строка - наименование объекта во фронт-системе, может быть не указано
//
Процедура ДобавитьЗаписьДляСопоставления(ТипОбъекта, ТипФронтСистемы, Код, Наименование = "") Экспорт
	
	МенеджерЗаписи = СоздатьМенеджерЗаписи();
	МенеджерЗаписи.ТипОбъекта = ТипОбъекта;
	МенеджерЗаписи.ФронтСистема = ТипФронтСистемы;
	МенеджерЗаписи.Код = Код;
	
	МенеджерЗаписи.Прочитать();
	
	Если МенеджерЗаписи.Выбран() И НЕ (НЕ ПустаяСтрока(Наименование) И МенеджерЗаписи.НаименованиеКнопки <> Наименование) Тогда
		// Запись существует, наименование в ней такое же или оно не передано в процедуру
		Возврат;
	КонецЕсли;
	
	МенеджерЗаписи.ТипОбъекта = ТипОбъекта;
	МенеджерЗаписи.ФронтСистема = ТипФронтСистемы;
	МенеджерЗаписи.Код = Код;
	
	МенеджерЗаписи.НаименованиеКнопки = Наименование;
	
	МенеджерЗаписи.Записать();
	
КонецПроцедуры //>> Портал-Юг Баринов 2019.03.14

//<< Портал-Юг, Баринов, 2019.04.03 [6.2.23 Функционал установки ссылочных типов в местах где указан код]
// Запускает заполнение ссылок в фоне
//
// Параметры:
//  ФронтСистема		 - ПеречислениеСсылка.ПЛ_ТипыФронтСистем - Фронт-система, данные из которой нужно обработать
//  ИдентификаторФормы	 - УникальныйИдентификатор - уникальный идентификатор формы, из которой запущено выполнение.
// 
// Возвращаемое значение:
//  Структура            - параметры выполнения задания. см. ДлительныеОперации.ВыполнитьВФоне  
//
Функция ЗаполнитьСсылкиПоКодамПослеЗагрузкиВФоне(ФронтСистема = Неопределено, ИдентификаторФормы = Неопределено) Экспорт
	
	ИмяПроцедуры = "РегистрыСведений.ПЛ_СоответствиеСФронтСистемами.ЗаполнитьСсылкиПоКодамПослеЗагрузки";
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(ИдентификаторФормы);
	ПараметрыВыполнения.КлючФоновогоЗадания = "ЗаполнитьСсылкиПоКодамПослеЗагрузки";
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Заполнение загруженных данных фронт-систем по соответствию.'");
	ПараметрыВыполнения.ЗапуститьВФоне = Истина;
	
	ПараметрыПроцедуры = Новый Структура("ФронтСистема", ФронтСистема);
	
	Возврат ДлительныеОперации.ВыполнитьВФоне(ИмяПроцедуры, ПараметрыПроцедуры, ПараметрыВыполнения);

КонецФункции //>> Портал-Юг, Баринов, 2019.04.03

//<< Портал-Юг, Баринов, 2019.04.01 [6.2.23 Функционал установки ссылочных типов в местах где указан код]
// Обрабатывает загруженные данные, заполняет в них ссылки из соответствий по кодам.
//
// Параметры:
//  Параметры		 - Структура - может содержать свойство "ФронтСистема"
//  АдресРезультата	 - Строка - адрес временного хранилища, в которое может быть помещен результат работы процедуры.
//
Процедура ЗаполнитьСсылкиПоКодамПослеЗагрузки(Параметры, АдресРезультата) Экспорт
	
	ФронтСистема = Неопределено;
	
	Если ТипЗнч(Параметры) = Тип("Структура") Тогда 
		Параметры.Свойство("ФронтСистема", ФронтСистема);
	КонецЕсли;	
	
	ТекстСообщения = НСтр("ru = 'Начато заполнения ссылок после загрузки данных из фронт-систем по соответствиям'");
	ЗаписьЖурналаРегистрацииСопоставленияДанных(ТекстСообщения);

	ОбработатьЧеки(ФронтСистема);
	
	ТекстСообщения = НСтр("ru = 'Завершено заполнение ссылок после загрузки данных из фронт-систем по соответствиям'");
	ЗаписьЖурналаРегистрацииСопоставленияДанных(ТекстСообщения);
			
КонецПроцедуры //>> Портал-Юг, Баринов, 2019.04.01

#КонецОбласти

