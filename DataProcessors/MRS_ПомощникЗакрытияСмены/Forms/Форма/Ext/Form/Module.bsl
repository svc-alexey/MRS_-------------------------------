#Область ОбработчикиСобытийФормы

// Выполняется при открытии формы.
// Инициализирует страницу параметров: заполняет список складов.
//
&НаКлиенте
Процедура ПриОткрытии(Отказ)

	Элементы.ГруппаОсновная.ТекущаяСтраница = Элементы.СтраницаПараметров;

	ЗаполнитьСкладыВыборНаСервере();
	ОбновитьВидимостьКомандФормы();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

// Обработчик активизации страницы в группе шагов.
// Пересчитывает статус текущего шага и обновляет содержимое таблиц на странице.
//
&НаКлиенте
Процедура ГруппаШаговПриАктивизации(Элемент)

	ОбновитьВидимостьКомандФормы();
	ОбновитьСтатусТекущегоШага();

КонецПроцедуры

// Сбрасывает рассчитанный рекомендуемый день при изменении выбора точки продаж.
//
&НаКлиенте
Процедура СкладыВыборОтмеченПриИзменении(Элемент)

	РекомендуемыйДень = Дата(1, 1, 1);

КонецПроцедуры

// Пересчитывает данные шага при смене текущего склада.
//
&НаКлиенте
Процедура ТекущийСкладПриИзменении(Элемент)

	ОбновитьСтатусТекущегоШага();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

// Команда «Начать работу» — фиксирует выбранные точки продаж и переходит к шагам.
//
&НаКлиенте
Процедура НачатьРаботу(Команда)

	Если НЕ ЗначениеЗаполнено(ВыбранныйДень) Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Выберите день для работы.'"));
		Возврат;
	КонецЕсли;

	ТочкиПродаж = ПолучитьОтмеченныеТочкиПродаж();
	Если ТочкиПродаж.Количество() = 0 Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Отметьте хотя бы одну точку продаж.'"));
		Возврат;
	КонецЕсли;

	МассивСкладов = ПолучитьСкладыИзТочекПродаж(ТочкиПродаж);
	Если МассивСкладов.Количество() = 0 Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Для выбранных точек продаж не заполнен склад.'"));
		Возврат;
	КонецЕсли;

	СохранитьВыбранныеТочкиПродажНаСервере(ТочкиПродаж);

	ДлительнаяОперация = РассчитатьРекомендуемыйДеньНаСервере(МассивСкладов);

	Если ДлительнаяОперация = Неопределено Тогда
		ПерейтиКШагамРаботы();
		Возврат;
	КонецЕсли;

	ОжидатьДлительнуюОперацию(
		ДлительнаяОперация,
		НСтр("ru = 'Расчет рекомендуемого дня...'"),
		"ПослеНачалаРаботы");

КонецПроцедуры

// Команда «Далее» — проверяет статус текущего шага и переходит к следующему.
//
&НаКлиенте
Процедура Далее(Команда)

	ТекущаяСтраница = Элементы.ГруппаШагов.ТекущаяСтраница.Имя;
	Статус = ПолучитьСтатусШагаПоСтраницеНаСервере(ТекущаяСтраница);

	Если Статус <> "Пройден" Тогда
		ПоказатьПредупреждение(,
			НСтр("ru = 'Текущий шаг не завершен. Выполните необходимые действия перед переходом дальше.'"));
		Возврат;
	КонецЕсли;

	Если ТекущаяСтраница = "СтраницаСопоставления" Тогда
		Элементы.ГруппаШагов.ТекущаяСтраница = Элементы.СтраницаСверка;
	ИначеЕсли ТекущаяСтраница = "СтраницаСверка" Тогда
		Элементы.ГруппаШагов.ТекущаяСтраница = Элементы.СтраницаФормирование;
	ИначеЕсли ТекущаяСтраница = "СтраницаФормирование" Тогда
		Элементы.ГруппаШагов.ТекущаяСтраница = Элементы.СтраницаОстатки;
	ИначеЕсли ТекущаяСтраница = "СтраницаОстатки" Тогда
		ОбновитьИндикациюГотовностиНаСервере();
	КонецЕсли;

	ОбновитьВидимостьТекущегоСклада();
	ОбновитьВидимостьКомандФормы();
	ОбновитьСтатусТекущегоШага();

КонецПроцедуры

// Команда «Назад» — возвращает к предыдущему шагу без проверки статуса.
//
&НаКлиенте
Процедура Назад(Команда)

	ТекущаяСтраница = Элементы.ГруппаШагов.ТекущаяСтраница.Имя;

	Если ТекущаяСтраница = "СтраницаСверка" Тогда
		Элементы.ГруппаШагов.ТекущаяСтраница = Элементы.СтраницаСопоставления;
	ИначеЕсли ТекущаяСтраница = "СтраницаФормирование" Тогда
		Элементы.ГруппаШагов.ТекущаяСтраница = Элементы.СтраницаСверка;
	ИначеЕсли ТекущаяСтраница = "СтраницаОстатки" Тогда
		Элементы.ГруппаШагов.ТекущаяСтраница = Элементы.СтраницаФормирование;
	КонецЕсли;

	ОбновитьВидимостьТекущегоСклада();
	ОбновитьВидимостьКомандФормы();
	ОбновитьСтатусТекущегоШага();

КонецПроцедуры

// Команда «Сопоставить» — сопоставляет выбранные объекты фронта с объектами 1С.
//
&НаКлиенте
Процедура Сопоставить(Команда)

	ДлительныеОперации = СопоставитьНаСервере();

	Если ДлительныеОперации.Количество() = 0 Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Отметьте строки и укажите объект для сопоставления.'"));
		Возврат;
	КонецЕсли;

	ОжидатьДлительныеОперации(
		ДлительныеОперации,
		НСтр("ru = 'Обновление ссылок в загруженных чеках...'"),
		"ПослеСопоставления");

КонецПроцедуры

// Команда «(Пере)загрузить чеки за день» — запускает фоновую перезагрузку чеков.
//
&НаКлиенте
Процедура ПерезагрузитьЧекиЗаДень(Команда)

	ДлительнаяОперация = ПерезагрузитьЧекиЗаДеньНаСервере();

	ОжидатьДлительнуюОперацию(
		ДлительнаяОперация,
		НСтр("ru = 'Перезагрузка чеков за выбранный день...'"),
		"ПослеПерезагрузкиЧеков");

КонецПроцедуры

// Команда «Переформировать выпуска» — запускает фоновое формирование целевых документов.
//
&НаКлиенте
Процедура ПереформироватьВыпуска(Команда)

	ДлительнаяОперация = ПереформироватьВыпускаНаСервере();

	ОжидатьДлительнуюОперацию(
		ДлительнаяОперация,
		НСтр("ru = 'Формирование целевых документов...'"),
		"ПослеПереформированияВыпусков");

КонецПроцедуры

// Команда «Открыть документ выпуска» — открывает сформированный документ.
//
&НаКлиенте
Процедура ОткрытьДокументВыпуска(Команда)

	ДокументВыпуска = ПолучитьДокументВыпускаНаСервере();

	Если НЕ ЗначениеЗаполнено(ДокументВыпуска) Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Документ выпуска не найден. Сначала выполните переформирование.'"));
		Возврат;
	КонецЕсли;

	ПоказатьЗначение(, ДокументВыпуска);

КонецПроцедуры

// Команда «Выбрать другой день» — возвращает на страницу выбора параметров.
//
&НаКлиенте
Процедура ВыбратьДругойДень(Команда)

	Элементы.ГруппаОсновная.ТекущаяСтраница = Элементы.СтраницаПараметров;
	ОбновитьВидимостьКомандФормы();

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Заполняет таблицу выбора точек продаж на сервере.
//
&НаСервере
Процедура ЗаполнитьСкладыВыборНаСервере()

	СкладыВыбор.Очистить();

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	КассыККМ.питКассовыйУзел.СкладПриготовления КАК Склад,
	|	КассыККМ.Ссылка КАК КассаККМ,
	|	Соответствие.ФронтСистема КАК ФронтСистема,
	|	Соответствие.Код КАК КодТочкиПродаж,
	|	Соответствие.НаименованиеКнопки КАК НаименованиеТочкиПродаж
	|ИЗ
	|	Справочник.КассыККМ КАК КассыККМ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ПЛ_СоответствиеСФронтСистемами КАК Соответствие
	|		ПО КассыККМ.Ссылка = Соответствие.Объект
	|ГДЕ
	|	НЕ КассыККМ.ПометкаУдаления
	|	И Соответствие.ТипОбъекта = &ТипКасса
	|	И Соответствие.ФронтСистема В (&ФронтСистемы)
	|	И Соответствие.Код <> """"
	|	И КассыККМ.питКассовыйУзел.СкладПриготовления
	|		<> ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
	|УПОРЯДОЧИТЬ ПО
	|	Склад,
	|	ФронтСистема,
	|	КодТочкиПродаж";

	ФронтСистемы = Новый Массив;
	ФронтСистемы.Добавить(Перечисления.ПЛ_ТипыФронтСистем.TNG);
	ФронтСистемы.Добавить(Перечисления.ПЛ_ТипыФронтСистем.Micros);

	Запрос.УстановитьПараметр("ТипКасса", ПланыВидовХарактеристик.ПЛ_ТипыОбъектовФронтСистем.КассаККМ);
	Запрос.УстановитьПараметр("ФронтСистемы", ФронтСистемы);

	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();

	Пока Выборка.Следующий() Цикл
		НоваяСтрока = СкладыВыбор.Добавить();
		НоваяСтрока.Склад                  = Выборка.Склад;
		НоваяСтрока.КассаККМ               = Выборка.КассаККМ;
		НоваяСтрока.ФронтСистема           = Выборка.ФронтСистема;
		НоваяСтрока.КодТочкиПродаж         = Выборка.КодТочкиПродаж;
		НоваяСтрока.НаименованиеТочкиПродаж = Выборка.НаименованиеТочкиПродаж;
		НоваяСтрока.Отмечен                = Ложь;
	КонецЦикла;

КонецПроцедуры

// Возвращает массив отмеченных точек продаж из таблицы выбора.
//
&НаКлиенте
Функция ПолучитьОтмеченныеТочкиПродаж()

	Массив = Новый Массив;

	Для Каждого Строка Из СкладыВыбор Цикл
		Если Строка.Отмечен Тогда
			ТочкаПродаж = Новый Структура;
			ТочкаПродаж.Вставить("Склад", Строка.Склад);
			ТочкаПродаж.Вставить("КассаККМ", Строка.КассаККМ);
			ТочкаПродаж.Вставить("ФронтСистема", Строка.ФронтСистема);
			ТочкаПродаж.Вставить("КодТочкиПродаж", Строка.КодТочкиПродаж);
			ТочкаПродаж.Вставить("НаименованиеТочкиПродаж", Строка.НаименованиеТочкиПродаж);
			Массив.Добавить(ТочкаПродаж);
		КонецЕсли;
	КонецЦикла;

	Возврат Массив;

КонецФункции

// Возвращает уникальные склады по отмеченным точкам продаж.
//
&НаКлиенте
Функция ПолучитьСкладыИзТочекПродаж(ТочкиПродаж)

	МассивСкладов = Новый Массив;
	ИндексСкладов = Новый Соответствие;

	Для Каждого ТочкаПродаж Из ТочкиПродаж Цикл

		Склад = ТочкаПродаж.Склад;
		Если НЕ ЗначениеЗаполнено(Склад) Тогда
			Продолжить;
		КонецЕсли;

		Если ИндексСкладов.Получить(Склад) = Неопределено Тогда
			ИндексСкладов.Вставить(Склад, Истина);
			МассивСкладов.Добавить(Склад);
		КонецЕсли;

	КонецЦикла;

	Возврат МассивСкладов;

КонецФункции

// Сохраняет выбранные точки продаж сессии в реквизит формы.
//
&НаСервере
Процедура СохранитьВыбранныеТочкиПродажНаСервере(Знач ТочкиПродаж)

	МассивСкладовСессии.Очистить();

	Для Каждого ТочкаПродаж Из ТочкиПродаж Цикл
		НоваяСтрока = МассивСкладовСессии.Добавить();
		НоваяСтрока.Склад                  = ТочкаПродаж.Склад;
		НоваяСтрока.КассаККМ               = ТочкаПродаж.КассаККМ;
		НоваяСтрока.ФронтСистема           = ТочкаПродаж.ФронтСистема;
		НоваяСтрока.КодТочкиПродаж         = ТочкаПродаж.КодТочкиПродаж;
		НоваяСтрока.НаименованиеТочкиПродаж = ТочкаПродаж.НаименованиеТочкиПродаж;
	КонецЦикла;

	Если МассивСкладовСессии.Количество() > 0 Тогда
		ТекущийСклад = МассивСкладовСессии[0].Склад;
	Иначе
		ТекущийСклад = Неопределено;
	КонецЕсли;

КонецПроцедуры

// Инициализирует таблицу статусов шагов.
//
&НаСервере
Процедура ИнициализироватьСтатусыШаговНаСервере()

	СтатусыШагов.Очистить();

	НоваяСтрока = СтатусыШагов.Добавить();
	НоваяСтрока.Номер = 1;
	НоваяСтрока.Наименование = НСтр("ru = 'Сопоставление объектов фронта'");
	НоваяСтрока.Статус = "";

	НоваяСтрока = СтатусыШагов.Добавить();
	НоваяСтрока.Номер = 2;
	НоваяСтрока.Наименование = НСтр("ru = 'Сверка чеков'");
	НоваяСтрока.Статус = "";

	НоваяСтрока = СтатусыШагов.Добавить();
	НоваяСтрока.Номер = 3;
	НоваяСтрока.Наименование = НСтр("ru = 'Формирование целевых документов'");
	НоваяСтрока.Статус = "";

	НоваяСтрока = СтатусыШагов.Добавить();
	НоваяСтрока.Номер = 4;
	НоваяСтрока.Наименование = НСтр("ru = 'Анализ отрицательных остатков'");
	НоваяСтрока.Статус = "";

КонецПроцедуры

// Обновляет статус текущего шага и данные на активной странице.
//
&НаКлиенте
Процедура ОбновитьСтатусТекущегоШага()

	ТекущаяСтраница = Элементы.ГруппаШагов.ТекущаяСтраница.Имя;
	ДлительнаяОперация = ОбновитьСтатусТекущегоШагаВФонеНаСервере(ТекущаяСтраница);

	Если ДлительнаяОперация = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ОжидатьДлительнуюОперацию(
		ДлительнаяОперация,
		НСтр("ru = 'Обновление статуса шага...'"),
		"ПослеОбновленияСтатусаТекущегоШага");

КонецПроцедуры

// Запускает фоновое обновление статуса текущего шага.
//
&НаСервере
Функция ОбновитьСтатусТекущегоШагаВФонеНаСервере(ТекущаяСтраница)

	МассивСкладов = ПолучитьМассивСкладовСессии();
	УстановитьТекущийСкладПоУмолчанию(МассивСкладов);

	АдресРезультатаСтатуса = ПоместитьВоВременноеХранилище(Новый Структура, УникальныйИдентификатор);

	ПараметрыСтатуса = Новый Структура;
	ПараметрыСтатуса.Вставить("ТекущаяСтраница", ТекущаяСтраница);
	ПараметрыСтатуса.Вставить("ВыбранныйДень", ВыбранныйДень);
	ПараметрыСтатуса.Вставить("МассивСкладов", МассивСкладов);
	ПараметрыСтатуса.Вставить("ТекущийСклад", ТекущийСклад);
	ПараметрыСтатуса.Вставить("ПараметрыКасс", ПолучитьПараметрыКассСессии());

	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияПроцедуры();
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Обновление статуса шага...'");

	Возврат ДлительныеОперации.ВыполнитьПроцедуру(
		ПараметрыВыполнения,
		"MRS_ПомощникЗакрытияСменыСервер.СтатусШагаВФоне",
		ПараметрыСтатуса,
		АдресРезультатаСтатуса);

КонецФункции

// Запускает фоновый пересчет рекомендуемого дня.
//
&НаКлиенте
Процедура ОбновитьРекомендуемыйДеньНаКлиенте()

	ТочкиПродаж = ПолучитьОтмеченныеТочкиПродаж();
	МассивСкладов = ПолучитьСкладыИзТочекПродаж(ТочкиПродаж);

	Если МассивСкладов.Количество() = 0 Тогда
		РекомендуемыйДень = Дата(1, 1, 1);
		Возврат;
	КонецЕсли;

	ДлительнаяОперация = РассчитатьРекомендуемыйДеньНаСервере(МассивСкладов);

	ОжидатьДлительнуюОперацию(
		ДлительнаяОперация,
		НСтр("ru = 'Расчет рекомендуемого дня...'"),
		"ПослеРасчетаРекомендуемогоДня");

КонецПроцедуры

// Возвращает текущий статус шага по имени страницы.
//
&НаСервере
Функция ПолучитьСтатусШагаПоСтраницеНаСервере(ТекущаяСтраница)

	Номер = 0;

	Если ТекущаяСтраница = "СтраницаСопоставления" Тогда
		Номер = 1;
	ИначеЕсли ТекущаяСтраница = "СтраницаСверка" Тогда
		Номер = 2;
	ИначеЕсли ТекущаяСтраница = "СтраницаФормирование" Тогда
		Номер = 3;
	ИначеЕсли ТекущаяСтраница = "СтраницаОстатки" Тогда
		Номер = 4;
	КонецЕсли;

	Для Каждого Строка Из СтатусыШагов Цикл
		Если Строка.Номер = Номер Тогда
			Возврат Строка.Статус;
		КонецЕсли;
	КонецЦикла;

	Возврат "";

КонецФункции

