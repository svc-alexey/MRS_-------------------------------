#Область ОбработчикиСобытийФормы

// Выполняется при открытии формы.
// Инициализирует страницу параметров: заполняет список складов, вычисляет рекомендуемый день.
//
&НаКлиенте
Процедура ПриОткрытии(Отказ)

	Элементы.ГруппаОсновная.ТекущаяСтраница = Элементы.СтраницаПараметров;

	ЗаполнитьСкладыВыборНаСервере();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

// Обработчик активизации страницы в группе шагов.
// Пересчитывает статус текущего шага и обновляет содержимое таблиц на странице.
//
&НаКлиенте
Процедура ГруппаШаговПриАктивизации(Элемент)

	ОбновитьСтатусТекущегоШага();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

// Команда «Начать работу» — валидирует выбор дня и складов, переходит к шагам.
//
&НаКлиенте
Процедура НачатьРаботу(Команда)

	Если НЕ ЗначениеЗаполнено(ВыбранныйДень) Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Выберите день для работы.'"));
		Возврат;
	КонецЕсли;

	// Проверяем, что выбран хотя бы один склад
	МассивСкладов = ПолучитьОтмеченныеСклады();
	Если МассивСкладов.Количество() = 0 Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Отметьте хотя бы один склад.'"));
		Возврат;
	КонецЕсли;

	// Сохраняем массив складов на форме
	СохранитьМассивСкладовНаСервере(МассивСкладов);

	// Инициализируем статусы шагов
	ИнициализироватьСтатусыШаговНаСервере();

	// Переходим на страницу шагов — первый шаг
	Элементы.ГруппаОсновная.ТекущаяСтраница = Элементы.СтраницаШагов;
	Элементы.ГруппаШагов.ТекущаяСтраница = Элементы.СтраницаСопоставления;

	// Обновляем статус первого шага
	ОбновитьСтатусТекущегоШага();

КонецПроцедуры

// Команда «Далее» — проверяет статус текущего шага и переходит к следующему.
//
&НаКлиенте
Процедура Далее(Команда)

	ТекущаяСтраница = Элементы.ГруппаШагов.ТекущаяСтраница.Имя;

	// Проверяем статус текущего шага
	Статус = ПолучитьСтатусШагаПоСтранице(ТекущаяСтраница);

	Если Статус <> "Пройден" Тогда
		ПоказатьПредупреждение(,
			НСтр("ru = 'Текущий шаг не завершён. Выполните необходимые действия перед переходом дальше.'"));
		Возврат;
	КонецЕсли;

	// Переход на следующую страницу
	Если ТекущаяСтраница = "СтраницаСопоставление" Тогда
		Элементы.ГруппаШагов.ТекущаяСтраница = Элементы.СтраницаСверка;
	ИначеЕсли ТекущаяСтраница = "СтраницаСверка" Тогда
		Элементы.ГруппаШагов.ТекущаяСтраница = Элементы.СтраницаФормирование;
	ИначеЕсли ТекущаяСтраница = "СтраницаФормирование" Тогда
		Элементы.ГруппаШагов.ТекущаяСтраница = Элементы.СтраницаОстатки;
	ИначеЕсли ТекущаяСтраница = "СтраницаОстатки" Тогда
		// Все шаги пройдены — показываем готовность
		ОбновитьИндикациюГотовности();
	КонецЕсли;

	ОбновитьСтатусТекущегоШага();

КонецПроцедуры

// Команда «Назад» — возвращает к предыдущему шагу без проверки статуса.
//
&НаКлиенте
Процедура Назад(Команда)

	ТекущаяСтраница = Элементы.ГруппаШагов.ТекущаяСтраница.Имя;

	Если ТекущаяСтраница = "СтраницаСверка" Тогда
		Элементы.ГруппаШагов.ТекущаяСтраница = Элементы.СтраницаСопоставление;
	ИначеЕсли ТекущаяСтраница = "СтраницаФормирование" Тогда
		Элементы.ГруппаШагов.ТекущаяСтраница = Элементы.СтраницаСверка;
	ИначеЕсли ТекущаяСтраница = "СтраницаОстатки" Тогда
		Элементы.ГруппаШагов.ТекущаяСтраница = Элементы.СтраницаФормирование;
	КонецЕсли;

	ОбновитьСтатусТекущегоШага();

КонецПроцедуры

// Команда «Сопоставить» — сопоставляет выбранные объекты фронта с объектами 1С.
//
&НаКлиенте
Процедура Сопоставить(Команда)

	СопоставитьНаСервере();

КонецПроцедуры

// Команда «(Пере)загрузить чеки за день» — запускает фоновую перезагрузку чеков.
//
&НаКлиенте
Процедура ПерезагрузитьЧекиЗаДень(Команда)

	ПерезагрузитьЧекиЗаДеньНаСервере();

КонецПроцедуры

// Команда «Переформировать выпуска» — запускает фоновое формирование целевых документов.
//
&НаКлиенте
Процедура ПереформироватьВыпуска(Команда)

	ПереформироватьВыпускаНаСервере();

КонецПроцедуры

// Команда «Открыть документ выпуска» — открывает сформированный документ.
//
&НаКлиенте
Процедура ОткрытьДокументВыпуска(Команда)

	ОткрытьДокументВыпускаНаСервере();

КонецПроцедуры

// Команда «Выбрать другой день» — возвращает на страницу выбора параметров.
//
&НаКлиенте
Процедура ВыбратьДругойДень(Команда)

	Элементы.ГруппаОсновная.ТекущаяСтраница = Элементы.СтраницаПараметров;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Заполняет таблицу выбора складов на сервере.
//
&НаСервере
Процедура ЗаполнитьСкладыВыборНаСервере()

	СкладыВыбор.Очистить();

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Склады.Ссылка КАК Склад,
	|	Склады.Наименование КАК Наименование
	|ИЗ
	|	Справочник.Склады КАК Склады
	|ГДЕ
	|	НЕ Склады.ПометкаУдаления
	|УПОРЯДОЧИТЬ ПО Наименование";

	Выборка = Запрос.Выполнить().Выбрать();

	Пока Выборка.Следующий() Цикл
		НоваяСтрока = СкладыВыбор.Добавить();
		НоваяСтрока.Склад  = Выборка.Склад;
		НоваяСтрока.Отмечен = Ложь;
	КонецЦикла;

КонецПроцедуры

// Возвращает массив отмеченных складов из таблицы выбора.
//
&НаКлиенте
Функция ПолучитьОтмеченныеСклады()

	Массив = Новый Массив;

	Для Каждого Строка Из СкладыВыбор Цикл
		Если Строка.Отмечен Тогда
			Массив.Добавить(Строка.Склад);
		КонецЕсли;
	КонецЦикла;

	Возврат Массив;

КонецФункции

// Сохраняет массив выбранных складов в переменную формы на сервере.
//
&НаСервере
Процедура СохранитьМассивСкладовНаСервере(Знач МассивСкладов)

	// Сохраняем через параметры сеанса или реквизит формы
	// Временное решение: сохраняем в ТекущийСклад первый склад для складо-специфичных шагов
	Если МассивСкладов.Количество() > 0 Тогда
		ТекущийСклад = МассивСкладов[0];
	КонецЕсли;

КонецПроцедуры

// Инициализирует таблицу статусов шагов.
//
&НаСервере
Процедура ИнициализироватьСтатусыШаговНаСервере()

	СтатусыШагов.Очистить();

	НоваяСтрока = СтатусыШагов.Добавить();
	НоваяСтрока.Номер = 1;
	НоваяСтрока.Наименование = НСтр("ru = 'Сопоставление объектов фронта'");
	НоваяСтрока.Статус = "";

	НоваяСтрока = СтатусыШагов.Добавить();
	НоваяСтрока.Номер = 2;
	НоваяСтрока.Наименование = НСтр("ru = 'Сверка чеков'");
	НоваяСтрока.Статус = "";

	НоваяСтрока = СтатусыШагов.Добавить();
	НоваяСтрока.Номер = 3;
	НоваяСтрока.Наименование = НСтр("ru = 'Формирование целевых документов'");
	НоваяСтрока.Статус = "";

	НоваяСтрока = СтатусыШагов.Добавить();
	НоваяСтрока.Номер = 4;
	НоваяСтрока.Наименование = НСтр("ru = 'Анализ отрицательных остатков'");
	НоваяСтрока.Статус = "";

КонецПроцедуры

// Обновляет статус текущего шага и данные на активной странице.
//
&НаКлиенте
Процедура ОбновитьСтатусТекущегоШага()

	ТекущаяСтраница = Элементы.ГруппаШагов.ТекущаяСтраница;

	Если ТекущаяСтраница = "СтраницаСопоставление" Тогда
		ОбновитьСтатусСопоставленияНаСервере();
	ИначеЕсли ТекущаяСтраница = "СтраницаСверка" Тогда
		ОбновитьСтатусСверкиНаСервере();
	ИначеЕсли ТекущаяСтраница = "СтраницаФормирование" Тогда
		НуженДиалог = ОбновитьСтатусФормированияНаСервере();
		Если НуженДиалог Тогда
			ПоказатьДиалогАктуальности();
		КонецЕсли;
	ИначеЕсли ТекущаяСтраница = "СтраницаОстатки" Тогда
		ОбновитьСтатусОстатковНаСервере();
	КонецЕсли;

КонецПроцедуры

// Возвращает текущий статус шага по элементу страницы.
//
&НаСервере
Функция ПолучитьСтатусШагаПоСтранице(ТекущаяСтраница)

	// Возвращаем статус из ранее обновлённой таблицы статусов
	// Определяем номер шага по имени страницы
	Номер = 0;

	Если ТекущаяСтраница = "СтраницаСопоставление" Тогда
		Номер = 1;
	ИначеЕсли ТекущаяСтраница = "СтраницаСверка" Тогда
		Номер = 2;
	ИначеЕсли ТекущаяСтраница = "СтраницаФормирование" Тогда
		Номер = 3;
	ИначеЕсли ТекущаяСтраница = "СтраницаОстатки" Тогда
		Номер = 4;
	КонецЕсли;

	Для Каждого Строка Из СтатусыШагов Цикл
		Если Строка.Номер = Номер Тогда
			Возврат Строка.Статус;
		КонецЕсли;
	КонецЦикла;

	Возврат "";

КонецФункции

// Вычисляет и обновляет статус шага «Сопоставление объектов фронта».
//
&НаСервере
Процедура ОбновитьСтатусСопоставленияНаСервере()

	МассивСкладов = ПолучитьМассивСкладовСессии();

	Результат = MRS_ПомощникЗакрытияСменыСервер.СтатусШагаСопоставление(ВыбранныйДень, МассивСкладов);

	// Обновляем статус в таблице
	Для Каждого СтрокаСтатуса Из СтатусыШагов Цикл
		Если СтрокаСтатуса.Номер = 1 Тогда
			СтрокаСтатуса.Статус = Результат.Статус;
		КонецЕсли;
	КонецЦикла;

	// Обновляем таблицу несопоставленных объектов
	НесопоставленныеОбъекты.Очистить();

	Для Каждого Строка Из Результат.Строки Цикл
		Новая = НесопоставленныеОбъекты.Добавить();
		Новая.ТипОбъекта          = Строка.ТипОбъекта;
		Новая.ФронтСистема        = Строка.ФронтСистема;
		Новая.Код                 = Строка.Код;
		Новая.НаименованиеНаФронте = Строка.НаименованиеНаФронте;
	КонецЦикла;

КонецПроцедуры

// Вычисляет и обновляет статус шага «Сверка чеков».
//
&НаСервере
Процедура ОбновитьСтатусСверкиНаСервере()

	МассивСкладов = ПолучитьМассивСкладовСессии();

	Результат = MRS_ПомощникЗакрытияСменыСервер.СтатусШагаСверка(ВыбранныйДень, МассивСкладов);

	Для Каждого СтрокаСтатуса Из СтатусыШагов Цикл
		Если СтрокаСтатуса.Номер = 2 Тогда
			СтрокаСтатуса.Статус = Результат.Статус;
		КонецЕсли;
	КонецЦикла;

	ОтклоненияСверки.Очистить();

	Для Каждого Строка Из Результат.Строки Цикл
		Новая = ОтклоненияСверки.Добавить();
		ЗаполнитьЗначенияСвойств(Новая, Строка);
	КонецЦикла;

КонецПроцедуры

// Вычисляет и обновляет статус шага «Формирование целевых документов».
//
&НаСервере
Функция ОбновитьСтатусФормированияНаСервере()

	МассивСкладов = ПолучитьМассивСкладовСессии();

	// Для каждого склада проверяем статус
	// В MVP показываем статус по первому складу
	Если МассивСкладов.Количество() > 0 Тогда
		ТекущийСклад = МассивСкладов[0];
	КонецЕсли;

	Результат = MRS_ПомощникЗакрытияСменыСервер.СтатусШагаФормирование(ВыбранныйДень, ТекущийСклад);

	Для Каждого СтрокаСтатуса Из СтатусыШагов Цикл
		Если СтрокаСтатуса.Номер = 3 Тогда
			СтрокаСтатуса.Статус = Результат.Статус;
		КонецЕсли;
	КонецЦикла;

	// Заполняем таблицы
	ОтклоненияВыпуска.Очистить();

	Для Каждого Строка Из Результат.ОтклоненияВыпуска Цикл
		Новая = ОтклоненияВыпуска.Добавить();
		ЗаполнитьЗначенияСвойств(Новая, Строка);
	КонецЦикла;

	ОшибкиФормирования.Очистить();

	Для Каждого Строка Из Результат.ОшибкиФормирования Цикл
		Новая = ОшибкиФормирования.Добавить();
		ЗаполнитьЗначенияСвойств(Новая, Строка);
	КонецЦикла;

	ДокументыОткрытыеЦены.Очистить();

	Для Каждого Строка Из Результат.ДокументыОткрытыеЦены Цикл
		Новая = ДокументыОткрытыеЦены.Добавить();
		ЗаполнитьЗначенияСвойств(Новая, Строка);
	КонецЦикла;

	// Если нужен диалог актуальности — показываем вопрос
	Возврат Результат.НуженДиалогАктуальности;

КонецФункции

// Вычисляет и обновляет статус шага «Анализ отрицательных остатков».
//
&НаСервере
Процедура ОбновитьСтатусОстатковНаСервере()

	МассивСкладов = ПолучитьМассивСкладовСессии();

	Если МассивСкладов.Количество() > 0 Тогда
		ТекущийСклад = МассивСкладов[0];
	КонецЕсли;

	Результат = MRS_ПомощникЗакрытияСменыСервер.СтатусШагаОстатки(ВыбранныйДень, ТекущийСклад);

	Для Каждого СтрокаСтатуса Из СтатусыШагов Цикл
		Если СтрокаСтатуса.Номер = 4 Тогда
			СтрокаСтатуса.Статус = Результат.Статус;
		КонецЕсли;
	КонецЦикла;

	ОтрицательныеОстатки.Очистить();

	Для Каждого Строка Из Результат.Строки Цикл
		Новая = ОтрицательныеОстатки.Добавить();
		ЗаполнитьЗначенияСвойств(Новая, Строка);
	КонецЦикла;

КонецПроцедуры

// Показывает диалог подтверждения пересоздания выпусков.
//
&НаКлиенте
Процедура ПоказатьДиалогАктуальности()

	ТекстВопроса = НСтр("ru = 'Рекомендуется пересоздание выпусков блюд для обновления. Выполнить сейчас?'");

	Оповещение = Новый ОписаниеОповещения("ПослеДиалогаАктуальности", ЭтотОбъект);

	ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет);

КонецПроцедуры

// Обработчик результата диалога актуальности.
//
&НаКлиенте
Процедура ПослеДиалогаАктуальности(РезультатВопроса, ДополнительныеПараметры) Экспорт

	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		ПереформироватьВыпускаНаСервере();
	КонецЕсли;

КонецПроцедуры

// Запускает фоновую перезагрузку чеков через БСП ДлительныеОперации.
//
&НаСервере
Процедура ПерезагрузитьЧекиЗаДеньНаСервере()

	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияПроцедуры(
		НСтр("ru = 'Перезагрузка чеков за выбранный день...'"));

	ДлительныеОперации.ВыполнитьПроцедуру(
		ПараметрыВыполнения,
		"MRS_ПомощникЗакрытияСменыСервер.ПерезагрузитьЧекиЗаДень",
		ВыбранныйДень);

КонецПроцедуры

// Запускает фоновое формирование целевых документов через БСП ДлительныеОперации.
//
&НаСервере
Процедура ПереформироватьВыпускаНаСервере()

	МассивСкладов = ПолучитьМассивСкладовСессии();

	Если МассивСкладов.Количество() > 0 Тогда
		ТекущийСклад = МассивСкладов[0];
	Иначе
		Возврат;
	КонецЕсли;

	АдресРезультата = ПоместитьВоВременноеХранилище(Новый Структура);

	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияПроцедуры(
		НСтр("ru = 'Формирование целевых документов...'"));

	ДлительныеОперации.ВыполнитьПроцедуру(
		ПараметрыВыполнения,
		"MRS_ПомощникЗакрытияСменыСервер.СформироватьЦелевыеДокументы",
		ВыбранныйДень,
		ТекущийСклад,
		АдресРезультата);

КонецПроцедуры

// Запускает фоновое сопоставление объектов фронта с последующей пропагацией.
//
&НаСервере
Процедура СопоставитьНаСервере()

	// Собираем уникальные значения ФронтСистема из отмеченных строк
	ФронтСистемы = Новый Соответствие;

	Для Каждого Строка Из НесопоставленныеОбъекты Цикл
		Если Строка.Отмечен И ЗначениеЗаполнено(Строка.ОбъектДляСопоставления) Тогда
			// Сопоставляем
			MRS_ПомощникЗакрытияСменыСервер.СопоставитьОбъектФронта(
				Строка.ТипОбъекта,
				Строка.ФронтСистема,
				Строка.Код,
				Строка.ОбъектДляСопоставления);

			// Запоминаем фронт-систему для последующей пропагации
			Если НЕ ФронтСистемы.Получить(Строка.ФронтСистема) <> Неопределено Тогда
				ФронтСистемы.Вставить(Строка.ФронтСистема, Истина);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;

	// Для каждой фронт-системы запускаем пропагацию сопоставления на уже загруженные чеки
	Для Каждого КлючЗначение Из ФронтСистемы Цикл
		ФронтСистема = КлючЗначение.Ключ;

		ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияПроцедуры(
			НСтр("ru = 'Обновление ссылок в загруженных чеках...'"));

		ДлительныеОперации.ВыполнитьПроцедуру(
			ПараметрыВыполнения,
			"РегистрыСведений.ПЛ_СоответствиеСФронтСистемами.ЗаполнитьСсылкиПоКодамПослеЗагрузки",
			Новый Структура("ФронтСистема", ФронтСистема));
	КонецЦикла;

КонецПроцедуры

