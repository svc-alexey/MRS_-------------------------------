// Применяет результат фонового расчета статуса шага к данным формы.
//
&НаСервере
Функция ПрименитьРезультатСтатусаНаСервере()

	Если НЕ ЗначениеЗаполнено(АдресРезультатаСтатуса) Тогда
		Возврат Ложь;
	КонецЕсли;

	РезультатСтатуса = ПолучитьИзВременногоХранилища(АдресРезультатаСтатуса);

	Если ТипЗнч(РезультатСтатуса) <> Тип("Структура") Тогда
		Возврат Ложь;
	КонецЕсли;

	Если НЕ РезультатСтатуса.Свойство("ТекущаяСтраница")
		ИЛИ НЕ РезультатСтатуса.Свойство("Результат") Тогда
		Возврат Ложь;
	КонецЕсли;

	ТекущаяСтраница = РезультатСтатуса.ТекущаяСтраница;
	Результат = РезультатСтатуса.Результат;

	Если ТекущаяСтраница = "СтраницаСопоставления" Тогда
		ПрименитьРезультатСопоставления(Результат);
	ИначеЕсли ТекущаяСтраница = "СтраницаСверка" Тогда
		ПрименитьРезультатСверки(Результат);
	ИначеЕсли ТекущаяСтраница = "СтраницаФормирование" Тогда
		Возврат ПрименитьРезультатФормирования(Результат, РезультатСтатуса);
	ИначеЕсли ТекущаяСтраница = "СтраницаОстатки" Тогда
		ПрименитьРезультатОстатков(Результат, РезультатСтатуса);
	КонецЕсли;

	Возврат Ложь;

КонецФункции

