// Обновляет индикацию готовности к продвижению даты запрета.
//
&НаСервере
Процедура ОбновитьИндикациюГотовностиНаСервере()

	Если СтатусыШагов.Количество() = 0 Тогда
		НадписьГотовность = "";
		Возврат;
	КонецЕсли;

	ВсеПройдены = Истина;

	Для Каждого СтрокаСтатуса Из СтатусыШагов Цикл
		Если СтрокаСтатуса.Статус <> "Пройден" Тогда
			ВсеПройдены = Ложь;
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Если ВсеПройдены Тогда
		МассивСкладов = ПолучитьМассивСкладовСессии();
		ПараметрыКасс = ПолучитьПараметрыКассСессии();

		Если ПолучитьОбщийСтатусПоСкладам(МассивСкладов, "Формирование", ПараметрыКасс) <> "Пройден"
			ИЛИ ПолучитьОбщийСтатусПоСкладам(МассивСкладов, "Остатки") <> "Пройден" Тогда

			ВсеПройдены = Ложь;
		КонецЕсли;
	КонецЕсли;

	Если ВсеПройдены Тогда
		НадписьГотовность = НСтр("ru = 'День чист по выбранным складам. Дату запрета редактирования можно продвигать.'");
	Иначе
		НадписьГотовность = "";
	КонецЕсли;

КонецПроцедуры

// Обновляет компактное представление статусов шагов.
//
&НаСервере
Процедура ОбновитьПредставлениеСтатусовШаговНаСервере()

	ТекстСтатусов = "";

	Для Каждого СтрокаСтатуса Из СтатусыШагов Цикл

		ФрагментСтатуса = СтрШаблон(
			"%1: %2",
			СтрокаСтатуса.Наименование,
			ПредставлениеСтатусаШага(СтрокаСтатуса.Статус));

		Если ТекстСтатусов = "" Тогда
			ТекстСтатусов = ФрагментСтатуса;
		Иначе
			ТекстСтатусов = СтрШаблон("%1 | %2", ТекстСтатусов, ФрагментСтатуса);
		КонецЕсли;

	КонецЦикла;

	ПредставлениеСтатусовШагов = ТекстСтатусов;

КонецПроцедуры

// Возвращает пользовательское представление статуса шага.
//
// Параметры:
//  Статус - Строка
//
// Возвращаемое значение:
//  Строка
//
&НаСервере
Функция ПредставлениеСтатусаШага(Статус)

	Если Статус = "" Тогда
		Возврат НСтр("ru = 'Ожидает'");
	КонецЕсли;

	Если Статус = "Пройден" Тогда
		Возврат НСтр("ru = 'Пройден'");
	КонецЕсли;

	Если Статус = "НетДанных" Тогда
		Возврат НСтр("ru = 'Нет данных'");
	КонецЕсли;

	Возврат НСтр("ru = 'Требует внимания'");

КонецФункции

// Возвращает массив складов, выбранных в текущей сессии.
//
&НаСервере
Функция ПолучитьМассивСкладовСессии()

	Массив = Новый Массив;
	ИндексСкладов = Новый Соответствие;

	Для Каждого Строка Из МассивСкладовСессии Цикл
		Если ЗначениеЗаполнено(Строка.Склад) И ИндексСкладов.Получить(Строка.Склад) = Неопределено Тогда
			ИндексСкладов.Вставить(Строка.Склад, Истина);
			Массив.Добавить(Строка.Склад);
		КонецЕсли;
	КонецЦикла;

	Если Массив.Количество() = 0 Тогда
		Для Каждого Строка Из СкладыВыбор Цикл
			Если Строка.Отмечен
				И ЗначениеЗаполнено(Строка.Склад)
				И ИндексСкладов.Получить(Строка.Склад) = Неопределено Тогда

				ИндексСкладов.Вставить(Строка.Склад, Истина);
				Массив.Добавить(Строка.Склад);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	Если Массив.Количество() = 0 И ЗначениеЗаполнено(ТекущийСклад) Тогда
		Массив.Добавить(ТекущийСклад);
	КонецЕсли;

	Возврат Массив;

КонецФункции

// Возвращает параметры касс по выбранным точкам продаж текущей сессии.
//
&НаСервере
Функция ПолучитьПараметрыКассСессии()

	ПараметрыКасс = НоваяТаблицаПараметровКасс();

	Для Каждого Строка Из МассивСкладовСессии Цикл
		ДобавитьСтрокуПараметровКасс(ПараметрыКасс, Строка);
	КонецЦикла;

	Если ПараметрыКасс.Количество() = 0 Тогда
		Для Каждого Строка Из СкладыВыбор Цикл
			Если Строка.Отмечен Тогда
				ДобавитьСтрокуПараметровКасс(ПараметрыКасс, Строка);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	Возврат ПараметрыКасс;

КонецФункции

// Создает таблицу параметров касс в формате обработки MRS_ЗагрузкаДанныхИзФронтСистем.
//
&НаСервере
Функция НоваяТаблицаПараметровКасс()

	ПараметрыКасс = Новый ТаблицаЗначений;
	ПараметрыКасс.Колонки.Добавить("Использовать", Новый ОписаниеТипов("Булево"));
	ПараметрыКасс.Колонки.Добавить("КассаККМ", Новый ОписаниеТипов("СправочникСсылка.КассыККМ"));
	ПараметрыКасс.Колонки.Добавить("ФронтСистема", Новый ОписаниеТипов("ПеречислениеСсылка.ПЛ_ТипыФронтСистем"));
	ПараметрыКасс.Колонки.Добавить(
		"КодТочкиПродаж",
		Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(10)));
	ПараметрыКасс.Колонки.Добавить(
		"НаименованиеТочкиПродаж",
		Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(20)));

	Возврат ПараметрыКасс;

КонецФункции

// Добавляет выбранную точку продаж в таблицу параметров касс.
//
&НаСервере
Процедура ДобавитьСтрокуПараметровКасс(ПараметрыКасс, СтрокаИсточник)

	Если НЕ ЗначениеЗаполнено(СтрокаИсточник.КодТочкиПродаж) Тогда
		Возврат;
	КонецЕсли;

	НоваяСтрока = ПараметрыКасс.Добавить();
	НоваяСтрока.Использовать             = Истина;
	НоваяСтрока.КассаККМ                 = СтрокаИсточник.КассаККМ;
	НоваяСтрока.ФронтСистема             = СтрокаИсточник.ФронтСистема;
	НоваяСтрока.КодТочкиПродаж           = СтрокаИсточник.КодТочкиПродаж;
	НоваяСтрока.НаименованиеТочкиПродаж  = СтрокаИсточник.НаименованиеТочкиПродаж;

КонецПроцедуры

// Устанавливает текущий склад, если он не выбран.
//
&НаСервере
Процедура УстановитьТекущийСкладПоУмолчанию(МассивСкладов)

	Если НЕ ЗначениеЗаполнено(ТекущийСклад) И МассивСкладов.Количество() > 0 Тогда
		ТекущийСклад = МассивСкладов[0];
	КонецЕсли;

КонецПроцедуры

// Возвращает агрегированный статус складо-специфичного шага.
//
&НаСервере
Функция ПолучитьОбщийСтатусПоСкладам(МассивСкладов, ИмяШага, ПараметрыКасс = Неопределено)

	Если ИмяШага = "Формирование" Тогда
		РезультатФормирования = MRS_ПомощникЗакрытияСменыСервер.СтатусШагаФормированиеПоСкладам(
			ВыбранныйДень,
			МассивСкладов,
			ПараметрыКасс);

		Возврат РезультатФормирования.Статус;
	КонецЕсли;

	ОбщийСтатус = "Пройден";

	Для Каждого Склад Из МассивСкладов Цикл

		Результат = MRS_ПомощникЗакрытияСменыСервер.СтатусШагаОстатки(ВыбранныйДень, Склад);

		Если Результат.Статус <> "Пройден" Тогда
			ОбщийСтатус = "Не Пройден";
			Прервать;
		КонецЕсли;

	КонецЦикла;

	Возврат ОбщийСтатус;

КонецФункции

// Управляет видимостью поля выбора склада на шагах 3/4.
//
&НаКлиенте
Процедура ОбновитьВидимостьТекущегоСклада()

	МассивСкладов = ПолучитьМассивСкладовСессииНаКлиенте();
	НесколькоСкладов = МассивСкладов.Количество() > 1;

	Элементы.ТекущийСклад.Видимость = НесколькоСкладов
		И (Элементы.ГруппаШагов.ТекущаяСтраница = Элементы.СтраницаФормирование
			ИЛИ Элементы.ГруппаШагов.ТекущаяСтраница = Элементы.СтраницаОстатки);

КонецПроцедуры

// Управляет видимостью команд формы по текущему этапу помощника.
//
&НаКлиенте
Процедура ОбновитьВидимостьКомандФормы()

	СтраницаПараметровАктивна = Элементы.ГруппаОсновная.ТекущаяСтраница = Элементы.СтраницаПараметров;
	СтраницаШаговАктивна = НЕ СтраницаПараметровАктивна;
	ТекущаяСтраницаШага = Элементы.ГруппаШагов.ТекущаяСтраница;
	ИтоговыйШагАктивен = СтраницаШаговАктивна
		И ТекущаяСтраницаШага = Элементы.СтраницаИтоговыйОтчет;

	Элементы.НачатьРаботу.Видимость = СтраницаПараметровАктивна;
	Элементы.ПолучитьРекомендуемыйДеньОтработки.Видимость = СтраницаПараметровАктивна;
	Элементы.НавигацияШагов.Видимость = СтраницаШаговАктивна;
	Элементы.ФормаНазад.Видимость = Ложь;
	Элементы.ФормаДалее.Видимость = Ложь;
	Элементы.ФормаВыбратьДругойДень.Видимость = Ложь;
	Элементы.ФормаПерезагрузитьЧекиЗаДень.Видимость = Ложь;
	Элементы.КнопкаНазад.Видимость = СтраницаШаговАктивна
		И ТекущаяСтраницаШага <> Элементы.СтраницаСопоставления;
	Элементы.КнопкаПерепроверитьТекущийШаг.Видимость = СтраницаШаговАктивна;
	Элементы.КнопкаДалее.Видимость = СтраницаШаговАктивна;
	Элементы.КнопкаВыбратьДругойДень.Видимость = СтраницаШаговАктивна;
	Элементы.КнопкаПерезагрузитьЧекиЗаДень.Видимость = СтраницаШаговАктивна
		И (ТекущаяСтраницаШага = Элементы.СтраницаСопоставления
			ИЛИ ТекущаяСтраницаШага = Элементы.СтраницаСверка);
	Элементы.КнопкаДалее.Заголовок = НСтр("ru = 'Далее'");
	Если ИтоговыйШагАктивен Тогда
		Элементы.КнопкаДалее.Заголовок = НСтр("ru = 'Завершить'");
	КонецЕсли;

	Элементы.НадписьГотовность.Видимость = ИтоговыйШагАктивен
		И ЗначениеЗаполнено(НадписьГотовность);
	Элементы.ИтоговыйОтчет.Видимость = ИтоговыйШагАктивен;

КонецПроцедуры

// Открывает типовой отчет «Ведомость по товарам на складах» по строке расшифровки.
//
// Параметры:
//  Расшифровка - Произвольный
//
&НаКлиенте
Процедура ОткрытьВедомостьПоРасшифровке(Расшифровка)

	Данные = ДанныеЭлементаРасшифровкиВедомости(Расшифровка);
	Если Данные = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Номенклатура = Неопределено;
	Если НЕ Данные.Свойство("Номенклатура", Номенклатура)
		ИЛИ НЕ ЗначениеЗаполнено(Номенклатура) Тогда
		Возврат;
	КонецЕсли;

	ФормаОтчета = ПолучитьФорму("Отчет.ВедомостьПоТоварамНаСкладах.Форма");
	КомпоновщикНастроек = ФормаОтчета.Отчет.КомпоновщикНастроек;

	Период = Новый СтандартныйПериод;
	Период.ДатаНачала = НачалоДня(ВыбранныйДень);
	Период.ДатаОкончания = КонецДня(ВыбранныйДень);

	УстановитьПользовательскийПараметрСКД(КомпоновщикНастроек, "Период", Период);
	УстановитьПользовательскийОтборСКД(
		КомпоновщикНастроек,
		"Номенклатура",
		Номенклатура,
		ВидСравненияКомпоновкиДанных.Равно);
	УстановитьПользовательскийОтборСКД(
		КомпоновщикНастроек,
		"Склад",
		СписокСкладовДляВедомости(),
		ВидСравненияКомпоновкиДанных.ВСписке);

	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("СформироватьПриОткрытии", Истина);
	ПараметрыФормы.Вставить("КлючВарианта", "ВедомостьПоТоварамНаСкладах");
	ПараметрыФормы.Вставить("ПользовательскиеНастройки", КомпоновщикНастроек.ПользовательскиеНастройки);

	ОткрытьФорму("Отчет.ВедомостьПоТоварамНаСкладах.Форма", ПараметрыФормы, ЭтотОбъект);

КонецПроцедуры

// Возвращает список складов для отбора типовой ведомости.
//
// Возвращаемое значение:
//  СписокЗначений
//
&НаКлиенте
Функция СписокСкладовДляВедомости()

	СписокСкладов = Новый СписокЗначений;
	Для Каждого Склад Из ПолучитьМассивСкладовСессииНаКлиенте() Цикл
		СписокСкладов.Добавить(Склад);
	КонецЦикла;

	Возврат СписокСкладов;

КонецФункции

// Устанавливает пользовательский параметр СКД в форме отчета.
//
// Параметры:
//  КомпоновщикНастроек - КомпоновщикНастроекКомпоновкиДанных
//  ИмяПараметра        - Строка
//  Значение            - Произвольный
//
&НаКлиенте
Процедура УстановитьПользовательскийПараметрСКД(КомпоновщикНастроек, ИмяПараметра, Значение)

	ПараметрДанных = КомпоновщикНастроек.Настройки.ПараметрыДанных.Элементы.Найти(ИмяПараметра);
	Если ПараметрДанных = Неопределено
		ИЛИ НЕ ЗначениеЗаполнено(ПараметрДанных.ИдентификаторПользовательскойНастройки) Тогда

		Возврат;
	КонецЕсли;

	ПользовательскийПараметр = КомпоновщикНастроек.ПользовательскиеНастройки.Элементы.Найти(
		ПараметрДанных.ИдентификаторПользовательскойНастройки);
	Если ПользовательскийПараметр = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ПользовательскийПараметр.Использование = Истина;
	ПользовательскийПараметр.Значение = Значение;

КонецПроцедуры

// Устанавливает пользовательский отбор СКД в форме отчета.
//
// Параметры:
//  КомпоновщикНастроек - КомпоновщикНастроекКомпоновкиДанных
//  ИмяОтбора           - Строка
//  Значение            - Произвольный
//  ВидСравнения        - ВидСравненияКомпоновкиДанных
//
&НаКлиенте
Процедура УстановитьПользовательскийОтборСКД(КомпоновщикНастроек, ИмяОтбора, Значение, ВидСравнения)

	ПолеКомпоновки = Новый ПолеКомпоновкиДанных(ИмяОтбора);
	ЭлементОтбора = Неопределено;

	Для Каждого ЭлементНастройки Из КомпоновщикНастроек.Настройки.Отбор.Элементы Цикл
		Если ЭлементНастройки.ЛевоеЗначение = ПолеКомпоновки Тогда
			ЭлементОтбора = ЭлементНастройки;
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Если ЭлементОтбора = Неопределено
		ИЛИ НЕ ЗначениеЗаполнено(ЭлементОтбора.ИдентификаторПользовательскойНастройки) Тогда

		Возврат;
	КонецЕсли;

	ПользовательскийОтбор = КомпоновщикНастроек.ПользовательскиеНастройки.Элементы.Найти(
		ЭлементОтбора.ИдентификаторПользовательскойНастройки);
	Если ПользовательскийОтбор = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ПользовательскийОтбор.Использование = Значение <> Неопределено;
	ПользовательскийОтбор.ВидСравнения = ВидСравнения;
	ПользовательскийОтбор.ПравоеЗначение = Значение;

КонецПроцедуры

// Переводит форму со страницы параметров на первый рабочий шаг.
//
&НаКлиенте
Процедура ПерейтиКШагамРаботы()

	ИнициализироватьСтатусыШаговНаСервере();

	Элементы.ГруппаОсновная.ТекущаяСтраница = Элементы.СтраницаШагов;
	Элементы.ГруппаШагов.ТекущаяСтраница = Элементы.СтраницаСопоставления;

	ОбновитьВидимостьТекущегоСклада();
	ОбновитьВидимостьКомандФормы();
	ОбновитьСтатусТекущегоШага();

КонецПроцедуры

// Возвращает массив складов сессии на клиенте.
//
&НаСервере
Функция ПолучитьМассивСкладовСессииНаКлиенте()

	Возврат ПолучитьМассивСкладовСессии();

КонецФункции

// Возвращает данные строки расшифровки ведомости отрицательных остатков.
//
// Параметры:
//  Расшифровка - Произвольный
//
// Возвращаемое значение:
//  Структура, Неопределено
//
&НаСервере
Функция ДанныеЭлементаРасшифровкиВедомости(Знач Расшифровка)

	Если НЕ ЗначениеЗаполнено(АдресДанныхРасшифровкиВедомости) Тогда
		Возврат Неопределено;
	КонецЕсли;

	ДанныеРасшифровки = ПолучитьИзВременногоХранилища(АдресДанныхРасшифровкиВедомости);
	Если ДанныеРасшифровки = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Попытка
		ЭлементРасшифровки = ДанныеРасшифровки.Элементы[Расшифровка];
	Исключение
		ЗаписьЖурналаРегистрации(
			НСтр("ru = 'MRS.Расшифровка отрицательных остатков'"),
			УровеньЖурналаРегистрации.Ошибка,
			,
			,
			ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		Возврат Неопределено;
	КонецПопытки;

	Если ЭлементРасшифровки = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	ПолеНоменклатуры = ПолеНоменклатурыРасшифровки(ДанныеРасшифровки, ЭлементРасшифровки);
	Если ПолеНоменклатуры = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Результат = Новый Структура;
	Результат.Вставить("Номенклатура", ПолеНоменклатуры.Значение);

	Возврат Результат;

КонецФункции

// Возвращает поле «Номенклатура» из элемента расшифровки или его родителя.
//
// Параметры:
//  ДанныеРасшифровки - ДанныеРасшифровкиКомпоновкиДанных
//  ЭлементРасшифровки - ЭлементДанныхРасшифровкиКомпоновкиДанных
//
// Возвращаемое значение:
//  ПолеДанныхРасшифровкиКомпоновкиДанных, Неопределено
//
&НаСервере
Функция ПолеНоменклатурыРасшифровки(ДанныеРасшифровки, ЭлементРасшифровки)

	ПолеНоменклатуры = ЭлементРасшифровки.ПолучитьПоля().Найти("Номенклатура");
	Если ПолеНоменклатуры <> Неопределено И ЗначениеЗаполнено(ПолеНоменклатуры.Значение) Тогда
		Возврат ПолеНоменклатуры;
	КонецЕсли;

	Родители = ЭлементРасшифровки.ПолучитьРодителей();
	Если Родители.Количество() = 0 Тогда
		Возврат ПолеНоменклатуры;
	КонецЕсли;

	Попытка
		Родитель = ДанныеРасшифровки.Элементы[Родители[0].Идентификатор];
	Исключение
		ЗаписьЖурналаРегистрации(
			НСтр("ru = 'MRS.Расшифровка отрицательных остатков'"),
			УровеньЖурналаРегистрации.Ошибка,
			,
			,
			ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		Возврат ПолеНоменклатуры;
	КонецПопытки;

	Если Родитель = Неопределено Тогда
		Возврат ПолеНоменклатуры;
	КонецЕсли;

	Возврат Родитель.ПолучитьПоля().Найти("Номенклатура");

КонецФункции

// Скрывает статусные декорации перед обновлением шага.
//
&НаКлиенте
Процедура СкрытьДекорацииСтатусовШагов()

	Элементы.НадписьВсеЧистоСопоставление.Видимость = Ложь;
	Элементы.НадписьВсеЧистоСверка.Видимость = Ложь;
	Элементы.НадписьВсеЧистоФормирование.Видимость = Ложь;
	Элементы.НадписьВсеЧистоОстатки.Видимость = Ложь;

	Элементы.ГруппаСостояниеСопоставлениеУспешно.Видимость = Ложь;
	Элементы.ГруппаСостояниеСопоставлениеПроблема.Видимость = Ложь;
	Элементы.ГруппаСостояниеСверкаУспешно.Видимость = Ложь;
	Элементы.ГруппаСостояниеСверкаПроблема.Видимость = Ложь;
	Элементы.ГруппаПояснениеОтчетСверкиЧеков.Видимость = Ложь;
	Элементы.ГруппаСостояниеОтклоненияВыпускаУспешно.Видимость = Ложь;
	Элементы.ГруппаСостояниеОтклоненияВыпускаПроблема.Видимость = Ложь;
	Элементы.ГруппаСостояниеОшибкиФормированияУспешно.Видимость = Ложь;
	Элементы.ГруппаСостояниеОшибкиФормированияПроблема.Видимость = Ложь;
	Элементы.ГруппаСостояниеДокументыОткрытыеЦеныУспешно.Видимость = Ложь;
	Элементы.ГруппаСостояниеДокументыОткрытыеЦеныПроблема.Видимость = Ложь;
	Элементы.ГруппаПояснениеОтчетСверкиВыпусков.Видимость = Ложь;
	Элементы.ГруппаСостояниеОтрицательныеОстаткиУспешно.Видимость = Ложь;
	Элементы.ГруппаСостояниеОтрицательныеОстаткиПроблема.Видимость = Ложь;
	Элементы.ГруппаПояснениеВедомостьОтрицательныхОстатков.Видимость = Ложь;
	Элементы.ГруппаПояснениеАнализОтрицательныхОстатков.Видимость = Ложь;

КонецПроцедуры

// Управляет видимостью надписей «все чисто» на страницах шагов.
//
&НаКлиенте
Процедура ОбновитьВидимостьНадписейВсеЧисто()

	ЕстьНесопоставленныеОбъекты = НесопоставленныеОбъекты.Количество() > 0;
	ЕстьОтклоненияСверки = ОтклоненияСверки.Количество() > 0;
	ЕстьОтклоненияВыпуска = ОтклоненияВыпуска.Количество() > 0;
	ЕстьОшибкиФормирования = ОшибкиФормирования.Количество() > 0;
	ЕстьДокументыОткрытыеЦены = ДокументыОткрытыеЦены.Количество() > 0;
	ЕстьОтрицательныеОстатки = ОтрицательныеОстатки.Количество() > 0;

	СкрытьДекорацииСтатусовШагов();

	Элементы.ГруппаСостояниеСопоставлениеУспешно.Видимость = НЕ ЕстьНесопоставленныеОбъекты;
	Элементы.ГруппаСостояниеСопоставлениеПроблема.Видимость = ЕстьНесопоставленныеОбъекты;

	Элементы.ГруппаСостояниеСверкаУспешно.Видимость = НЕ ЕстьОтклоненияСверки;
	Элементы.ГруппаСостояниеСверкаПроблема.Видимость = ЕстьОтклоненияСверки;
	Элементы.ГруппаПояснениеОтчетСверкиЧеков.Видимость = ЕстьОтклоненияСверки;

	Элементы.ГруппаСостояниеОтклоненияВыпускаУспешно.Видимость = НЕ ЕстьОтклоненияВыпуска;
	Элементы.ГруппаСостояниеОтклоненияВыпускаПроблема.Видимость = ЕстьОтклоненияВыпуска;
	Элементы.ГруппаСостояниеОшибкиФормированияУспешно.Видимость = НЕ ЕстьОшибкиФормирования;
	Элементы.ГруппаСостояниеОшибкиФормированияПроблема.Видимость = ЕстьОшибкиФормирования;
	Элементы.ГруппаСостояниеДокументыОткрытыеЦеныУспешно.Видимость = НЕ ЕстьДокументыОткрытыеЦены;
	Элементы.ГруппаСостояниеДокументыОткрытыеЦеныПроблема.Видимость = ЕстьДокументыОткрытыеЦены;
	Элементы.ГруппаПояснениеОтчетСверкиВыпусков.Видимость =
		ЕстьОтклоненияВыпуска
		ИЛИ ЕстьОшибкиФормирования;

	Элементы.ГруппаСостояниеОтрицательныеОстаткиУспешно.Видимость = НЕ ЕстьОтрицательныеОстатки;
	Элементы.ГруппаСостояниеОтрицательныеОстаткиПроблема.Видимость = ЕстьОтрицательныеОстатки;
	Элементы.ГруппаПояснениеВедомостьОтрицательныхОстатков.Видимость = ЕстьОтрицательныеОстатки;
	Элементы.ГруппаПояснениеАнализОтрицательныхОстатков.Видимость = ЕстьОтрицательныеОстатки;

КонецПроцедуры

// Возвращает параметры запуска длительной операции с обязательной постановкой в фон.
//
// Параметры:
//  НаименованиеФоновогоЗадания - Строка - текст фонового задания для стандартного окна ожидания
//
// Возвращаемое значение:
//  Структура - параметры выполнения для ДлительныеОперации.ВыполнитьПроцедуру
//
&НаСервере
Функция ПараметрыФоновогоЗапуска(НаименованиеФоновогоЗадания)

	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияПроцедуры();
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НаименованиеФоновогоЗадания;
	ПараметрыВыполнения.ЗапуститьВФоне = Истина;
	ПараметрыВыполнения.СРасширениямиБазыДанных = Истина;
	ПараметрыВыполнения.ОжидатьЗавершение = 0;

	Возврат ПараметрыВыполнения;

КонецФункции

// Ожидает завершения одной длительной операции.
//
&НаКлиенте
Процедура ОжидатьДлительнуюОперацию(ДлительнаяОперация, ТекстОжидания, ИмяОбработчика)

	Если ДлительнаяОперация = Неопределено Тогда
		СообщитьОбОшибкеЗапускаДлительнойОперации();
		Возврат;
	КонецЕсли;

	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
	ПараметрыОжидания.ТекстСообщения = ТекстОжидания;

	Оповещение = Новый ОписаниеОповещения(ИмяОбработчика, ЭтотОбъект);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);

КонецПроцедуры

// Ожидает завершения нескольких длительных операций последовательно.
//
&НаКлиенте
Процедура ОжидатьДлительныеОперации(ДлительныеОперации, ТекстОжидания, ИмяОбработчика)

	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Операции", ДлительныеОперации);
	ДополнительныеПараметры.Вставить("Индекс", 0);
	ДополнительныеПараметры.Вставить("ТекстОжидания", ТекстОжидания);
	ДополнительныеПараметры.Вставить("ИмяОбработчика", ИмяОбработчика);

	ОжидатьСледующуюДлительнуюОперацию(Неопределено, ДополнительныеПараметры);

КонецПроцедуры

// Обработчик цепочки ожидания длительных операций.
//
&НаКлиенте
Процедура ОжидатьСледующуюДлительнуюОперацию(Результат, ДополнительныеПараметры) Экспорт

	Если ДлительнаяОперацияЗавершиласьСОшибкой(Результат) Тогда
		Возврат;
	КонецЕсли;

	Индекс = ДополнительныеПараметры.Индекс;
	Операции = ДополнительныеПараметры.Операции;

	Если Индекс >= Операции.Количество() Тогда
		ИмяОбработчика = ДополнительныеПараметры.ИмяОбработчика;
		Оповещение = Новый ОписаниеОповещения(ИмяОбработчика, ЭтотОбъект);
		ВыполнитьОбработкуОповещения(Оповещение, Неопределено);
		Возврат;
	КонецЕсли;

	ДополнительныеПараметры.Индекс = Индекс + 1;

	Если Операции[Индекс] = Неопределено Тогда
		СообщитьОбОшибкеЗапускаДлительнойОперации();
		Возврат;
	КонецЕсли;

	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
	ПараметрыОжидания.ТекстСообщения = ДополнительныеПараметры.ТекстОжидания;

	Оповещение = Новый ОписаниеОповещения("ОжидатьСледующуюДлительнуюОперацию", ЭтотОбъект, ДополнительныеПараметры);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(Операции[Индекс], Оповещение, ПараметрыОжидания);

КонецПроцедуры

// Сообщает пользователю, что фоновая операция не была запущена.
//
&НаКлиенте
Процедура СообщитьОбОшибкеЗапускаДлительнойОперации()

	ОбщегоНазначенияКлиент.СообщитьПользователю(
		НСтр("ru = 'Не удалось запустить фоновую операцию. Повторите действие или проверьте журнал регистрации.'"));

КонецПроцедуры

// Обработчик завершения старта работы.
//
&НаКлиенте
Процедура ПослеНачалаРаботы(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если ДлительнаяОперацияЗавершиласьСОшибкой(Результат) Тогда
		Возврат;
	КонецЕсли;

	ПрименитьРекомендуемыйДеньНаСервере();
	ПерейтиКШагамРаботы();

КонецПроцедуры

// Обработчик завершения фонового обновления статуса шага.
//
&НаКлиенте
Процедура ПослеОбновленияСтатусаТекущегоШага(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если ДлительнаяОперацияЗавершиласьСОшибкой(Результат) Тогда
		Возврат;
	КонецЕсли;

	НуженДиалог = ПрименитьРезультатСтатусаНаСервере();
	ОбновитьВидимостьНадписейВсеЧисто();

	Если НуженДиалог Тогда
		Если Элементы.ГруппаШагов.ТекущаяСтраница = Элементы.СтраницаСверка Тогда
			ПоказатьДиалогПерезагрузкиЧеков();
		Иначе
			ПоказатьДиалогАктуальности();
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

// Обработчик завершения перезагрузки чеков.
//
&НаКлиенте
Процедура ПослеПерезагрузкиЧеков(Результат, ДополнительныеПараметры) Экспорт

	Если ДлительнаяОперацияЗавершиласьСОшибкой(Результат) Тогда
		Возврат;
	КонецЕсли;

	ОбновитьСтатусТекущегоШага();

КонецПроцедуры

// Обработчик завершения переформирования выпусков.
//
&НаКлиенте
Процедура ПослеПереформированияВыпусков(Результат, ДополнительныеПараметры) Экспорт

	Если ДлительнаяОперацияЗавершиласьСОшибкой(Результат) Тогда
		Возврат;
	КонецЕсли;

	ОбработатьРезультатФормированияНаСервере();
	ОбновитьСтатусТекущегоШага();

КонецПроцедуры

// Обработчик завершения сопоставления.
//
&НаКлиенте
Процедура ПослеСопоставления(Результат, ДополнительныеПараметры) Экспорт

	Если ДлительнаяОперацияЗавершиласьСОшибкой(Результат) Тогда
		Возврат;
	КонецЕсли;

	ОбновитьСтатусТекущегоШага();

КонецПроцедуры

// Обработчик завершения расчета рекомендуемого дня.
//
&НаКлиенте
Процедура ПослеРасчетаРекомендуемогоДня(Результат, ДополнительныеПараметры) Экспорт

	Если ДлительнаяОперацияЗавершиласьСОшибкой(Результат) Тогда
		Возврат;
	КонецЕсли;

	ПрименитьРекомендуемыйДеньНаСервере();

КонецПроцедуры

// Показывает ошибку завершения фоновой операции БСП.
//
// Параметры:
//  Результат - Структура, Неопределено - результат ДлительныеОперацииКлиент.ОжидатьЗавершение
//
// Возвращаемое значение:
//  Булево - Истина, если операция завершилась ошибкой
//
&НаКлиенте
Функция ДлительнаяОперацияЗавершиласьСОшибкой(Результат)

	Если Результат = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;

	ТипРезультата = ТипЗнч(Результат);
	Если ТипРезультата <> Тип("Структура")
		И ТипРезультата <> Тип("ФиксированнаяСтруктура") Тогда
		Возврат Ложь;
	КонецЕсли;

	СтатусОперации = "";
	Если НЕ Результат.Свойство("Статус", СтатусОперации)
		ИЛИ СтатусОперации <> "Ошибка" Тогда
		Возврат Ложь;
	КонецЕсли;

	ИнформацияОбОшибке = Неопределено;
	Если Результат.Свойство("ИнформацияОбОшибке", ИнформацияОбОшибке)
		И ИнформацияОбОшибке <> Неопределено Тогда

		СтандартныеПодсистемыКлиент.ВывестиИнформациюОбОшибке(ИнформацияОбОшибке);
	Иначе
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстОшибкиДлительнойОперации(Результат));
	КонецЕсли;

	Возврат Истина;

КонецФункции

// Возвращает текст ошибки фоновой операции БСП.
//
// Параметры:
//  Результат - Структура - результат ДлительныеОперацииКлиент.ОжидатьЗавершение
//
// Возвращаемое значение:
//  Строка
//
&НаКлиенте
Функция ТекстОшибкиДлительнойОперации(Результат)

	ТекстОшибки = "";

	Если Результат.Свойство("ПодробноеПредставлениеОшибки", ТекстОшибки)
		И ЗначениеЗаполнено(ТекстОшибки) Тогда
		Возврат ТекстОшибки;
	КонецЕсли;

	Если Результат.Свойство("КраткоеПредставлениеОшибки", ТекстОшибки)
		И ЗначениеЗаполнено(ТекстОшибки) Тогда
		Возврат ТекстОшибки;
	КонецЕсли;

	Если Результат.Свойство("ОписаниеОшибки", ТекстОшибки)
		И ЗначениеЗаполнено(ТекстОшибки) Тогда
		Возврат ТекстОшибки;
	КонецЕсли;

	Возврат НСтр("ru = 'Фоновая операция завершилась с ошибкой. Подробности см. в журнале регистрации.'");

КонецФункции

// Сохраняет адрес результата формирования и показывает сообщения об ошибках.
//
&НаСервере
Процедура ОбработатьРезультатФормированияНаСервере()

	Если НЕ ЗначениеЗаполнено(АдресРезультатаФормирования) Тогда
		Возврат;
	КонецЕсли;

	Результат = ПолучитьИзВременногоХранилища(АдресРезультатаФормирования);

	Если ТипЗнч(Результат) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;

	Если Результат.Свойство("СообщенияОбОшибках") И ЗначениеЗаполнено(Результат.СообщенияОбОшибках) Тогда
		ОбщегоНазначения.СообщитьПользователю(Результат.СообщенияОбОшибках);
	КонецЕсли;

КонецПроцедуры

// Читает рассчитанный рекомендуемый день из временного хранилища.
//
&НаСервере
Процедура ПрименитьРекомендуемыйДеньНаСервере()

	Если НЕ ЗначениеЗаполнено(АдресРезультатаРекомендуемогоДня) Тогда
		Возврат;
	КонецЕсли;

	РекомендуемыйДень = ПолучитьИзВременногоХранилища(АдресРезультатаРекомендуемогоДня);
	Если ЗначениеЗаполнено(РекомендуемыйДень) Тогда
		ВыбранныйДень = РекомендуемыйДень;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти
