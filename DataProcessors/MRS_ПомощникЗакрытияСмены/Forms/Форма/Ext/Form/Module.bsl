// Обработчик завершения расчёта рекомендуемого дня.
//
&НаКлиенте
Процедура ПослеРасчетаРекомендуемогоДня(Результат, ДополнительныеПараметры) Экспорт

	ПрименитьРекомендуемыйДеньНаСервере();

КонецПроцедуры

// Сохраняет адрес результата формирования и показывает сообщения об ошибках.
//
&НаСервере
Процедура ОбработатьРезультатФормированияНаСервере()

	Если НЕ ЗначениеЗаполнено(АдресРезультатаФормирования) Тогда
		Возврат;
	КонецЕсли;

	Результат = ПолучитьИзВременногоХранилища(АдресРезультатаФормирования);

	Если ТипЗнч(Результат) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;

	Если Результат.Свойство("СообщенияОбОшибках") И ЗначениеЗаполнено(Результат.СообщенияОбОшибках) Тогда
		ОбщегоНазначения.СообщитьПользователю(Результат.СообщенияОбОшибках);
	КонецЕсли;

КонецПроцедуры

// Читает рассчитанный рекомендуемый день из временного хранилища.
//
&НаСервере
Процедура ПрименитьРекомендуемыйДеньНаСервере()

	Если НЕ ЗначениеЗаполнено(АдресРезультатаРекомендуемогоДня) Тогда
		Возврат;
	КонецЕсли;

	РекомендуемыйДень = ПолучитьИзВременногоХранилища(АдресРезультатаРекомендуемогоДня);

КонецПроцедуры

#КонецОбласти
