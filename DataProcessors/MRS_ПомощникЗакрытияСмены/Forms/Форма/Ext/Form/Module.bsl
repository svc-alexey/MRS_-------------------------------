КонецФункции

// Сопоставляет объекты и запускает пропагацию ссылок в фоне.
//
&НаСервере
Функция СопоставитьНаСервере()

	МассивДлительныхОпераций = Новый Массив;
	ФронтСистемы = Новый Соответствие;

	Для Каждого Строка Из НесопоставленныеОбъекты Цикл

		Если НЕ Строка.Отмечен ИЛИ НЕ ЗначениеЗаполнено(Строка.ОбъектДляСопоставления) Тогда
			Продолжить;
		КонецЕсли;

		MRS_ПомощникЗакрытияСменыСервер.СопоставитьОбъектФронта(
			Строка.ТипОбъекта,
			Строка.ФронтСистема,
			Строка.Код,
			Строка.ОбъектДляСопоставления,
			Строка.Количество);

		Если ФронтСистемы.Получить(Строка.ФронтСистема) = Неопределено Тогда
			ФронтСистемы.Вставить(Строка.ФронтСистема, Истина);
		КонецЕсли;

	КонецЦикла;

	Для Каждого КлючЗначение Из ФронтСистемы Цикл

		ФронтСистема = КлючЗначение.Ключ;
		АдресРезультата = ПоместитьВоВременноеХранилище(Неопределено, УникальныйИдентификатор);

		ПараметрыВыполнения = ПараметрыФоновогоЗапуска(НСтр("ru = 'Обновление ссылок в загруженных чеках...'"));

		ДлительнаяОперация = ДлительныеОперации.ВыполнитьПроцедуру(
			ПараметрыВыполнения,
			"РегистрыСведений.ПЛ_СоответствиеСФронтСистемами.ЗаполнитьСсылкиПоКодамПослеЗагрузки",
			Новый Структура("ФронтСистема", ФронтСистема),
			АдресРезультата);

		МассивДлительныхОпераций.Добавить(ДлительнаяОперация);

	КонецЦикла;

	Возврат МассивДлительныхОпераций;

КонецФункции

// Возвращает документ выпуска из временного хранилища.
//
&НаСервере
Функция ПолучитьДокументВыпускаНаСервере()

	Если НЕ ЗначениеЗаполнено(АдресРезультатаФормирования) Тогда
		Возврат Неопределено;
	КонецЕсли;

	Результат = ПолучитьИзВременногоХранилища(АдресРезультатаФормирования);

	Если ТипЗнч(Результат) = Тип("Структура") И Результат.Свойство("ДокументВыпуска") Тогда
		Возврат Результат.ДокументВыпуска;
	КонецЕсли;

	Возврат Неопределено;

КонецФункции

