// Обновляет индикацию готовности к продвижению даты запрета.
//
&НаСервере
Процедура ОбновитьИндикациюГотовности()

	// Проверяем, что все шаги по всем складам пройдены
	МассивСкладов = ПолучитьМассивСкладовСессии();

	ВсеПройдены = Истина;

	Для Каждого СтрокаСтатуса Из СтатусыШагов Цикл
		Если СтрокаСтатуса.Статус <> "Пройден" Тогда
			ВсеПройдены = Ложь;
			Прервать;
		КонецЕсли;
	КонецЦикла;

	// Для складо-специфичных шагов проверяем по каждому складу
	Если ВсеПройдены Тогда
		Для Каждого Склад Из МассивСкладов Цикл
			СтатусФормирования = MRS_ПомощникЗакрытияСменыСервер.СтатусШагаФормирование(ВыбранныйДень, Склад);
			Если СтатусФормирования.Статус <> "Пройден" Тогда
				ВсеПройдены = Ложь;
				Прервать;
			КонецЕсли;

			СтатусОстатки = MRS_ПомощникЗакрытияСменыСервер.СтатусШагаОстатки(ВыбранныйДень, Склад);
			Если СтатусОстатки.Статус <> "Пройден" Тогда
				ВсеПройдены = Ложь;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	Если ВсеПройдены Тогда
		НадписьГотовность = НСтр("ru = 'День чист по выбранным складам. Дату запрета редактирования можно продвигать.'");
	Иначе
		НадписьГотовность = "";
	КонецЕсли;

КонецПроцедуры

// Возвращает массив складов, выбранных в текущей сессии.
// В MVP используем ТекущийСклад как единственный склад.
//
&НаСервере
Функция ПолучитьМассивСкладовСессии()

	Массив = Новый Массив;

	Для Каждого Строка Из СкладыВыбор Цикл
		Если Строка.Отмечен Тогда
			Массив.Добавить(Строка.Склад);
		КонецЕсли;
	КонецЦикла;

	Если Массив.Количество() = 0 И ЗначениеЗаполнено(ТекущийСклад) Тогда
		Массив.Добавить(ТекущийСклад);
	КонецЕсли;

	Возврат Массив;

КонецФункции

#КонецОбласти
