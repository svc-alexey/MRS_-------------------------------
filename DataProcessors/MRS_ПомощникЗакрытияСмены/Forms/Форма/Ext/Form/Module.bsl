КонецПроцедуры

// Применяет данные шага формирования к таблицам формы.
//
&НаСервере
Функция ПрименитьРезультатФормирования(Результат, РезультатСтатуса)

	ОбщийСтатус = Результат.Статус;
	Если РезультатСтатуса.Свойство("ОбщийСтатус") Тогда
		ОбщийСтатус = РезультатСтатуса.ОбщийСтатус;
	КонецЕсли;

	Для Каждого СтрокаСтатуса Из СтатусыШагов Цикл
		Если СтрокаСтатуса.Номер = 3 Тогда
			СтрокаСтатуса.Статус = ОбщийСтатус;
		КонецЕсли;
	КонецЦикла;

	ОтклоненияВыпуска.Очистить();

	Для Каждого Строка Из Результат.ОтклоненияВыпуска Цикл
		Новая = ОтклоненияВыпуска.Добавить();
		ЗаполнитьЗначенияСвойств(Новая, Строка);
	КонецЦикла;

	ОшибкиФормирования.Очистить();

	Для Каждого Строка Из Результат.ОшибкиФормирования Цикл
		Новая = ОшибкиФормирования.Добавить();
		ЗаполнитьЗначенияСвойств(Новая, Строка);
	КонецЦикла;

	ДокументыОткрытыеЦены.Очистить();

	Для Каждого Строка Из Результат.ДокументыОткрытыеЦены Цикл
		Новая = ДокументыОткрытыеЦены.Добавить();
		ЗаполнитьЗначенияСвойств(Новая, Строка);
	КонецЦикла;

	Возврат Результат.НуженДиалогАктуальности;

КонецФункции

