		ВыбранныйДень);

КонецФункции

// Запускает фоновое формирование целевых документов через БСП ДлительныеОперации.
//
&НаСервере
Функция ПереформироватьВыпускаНаСервере()

	МассивСкладов = ПолучитьМассивСкладовСессии();
	УстановитьТекущийСкладПоУмолчанию(МассивСкладов);

	Если НЕ ЗначениеЗаполнено(ТекущийСклад) Тогда
		Возврат Неопределено;
	КонецЕсли;

	АдресРезультатаФормирования = ПоместитьВоВременноеХранилище(Новый Структура, УникальныйИдентификатор);

	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияПроцедуры(
		НСтр("ru = 'Формирование целевых документов...'"));

	Возврат ДлительныеОперации.ВыполнитьПроцедуру(
		ПараметрыВыполнения,
		"MRS_ПомощникЗакрытияСменыСервер.СформироватьЦелевыеДокументы",
		ВыбранныйДень,
		ТекущийСклад,
		АдресРезультатаФормирования);

КонецФункции

// Запускает фоновый расчёт рекомендуемого дня.
//
&НаСервере
Функция РассчитатьРекомендуемыйДеньНаСервере(Знач МассивСкладов)

	АдресРезультатаРекомендуемогоДня = ПоместитьВоВременноеХранилище(Неопределено, УникальныйИдентификатор);

	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияПроцедуры(
