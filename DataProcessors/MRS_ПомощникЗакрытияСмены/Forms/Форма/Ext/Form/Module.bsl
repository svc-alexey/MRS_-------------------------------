КонецФункции

// Вычисляет и обновляет статус шага «Анализ отрицательных остатков».
//
&НаСервере
Процедура ОбновитьСтатусОстатковНаСервере()

	МассивСкладов = ПолучитьМассивСкладовСессии();
	УстановитьТекущийСкладПоУмолчанию(МассивСкладов);

	Результат = MRS_ПомощникЗакрытияСменыСервер.СтатусШагаОстатки(ВыбранныйДень, ТекущийСклад);
	ОбщийСтатус = ПолучитьОбщийСтатусПоСкладам(МассивСкладов, "Остатки");

	Для Каждого СтрокаСтатуса Из СтатусыШагов Цикл
		Если СтрокаСтатуса.Номер = 4 Тогда
			СтрокаСтатуса.Статус = ОбщийСтатус;
		КонецЕсли;
	КонецЦикла;

	ОтрицательныеОстатки.Очистить();

	Для Каждого Строка Из Результат.Строки Цикл
		Новая = ОтрицательныеОстатки.Добавить();
		ЗаполнитьЗначенияСвойств(Новая, Строка);
	КонецЦикла;

	ОбновитьПредставлениеСтатусовШаговНаСервере();

КонецПроцедуры

// Применяет результат фонового расчета статуса шага к данным формы.
//
&НаСервере
Функция ПрименитьРезультатСтатусаНаСервере()

	Если НЕ ЗначениеЗаполнено(АдресРезультатаСтатуса) Тогда
		Возврат Ложь;
	КонецЕсли;

	РезультатСтатуса = ПолучитьИзВременногоХранилища(АдресРезультатаСтатуса);

	Если ТипЗнч(РезультатСтатуса) <> Тип("Структура") Тогда
		Возврат Ложь;
	КонецЕсли;

	Если НЕ РезультатСтатуса.Свойство("ТекущаяСтраница")
		ИЛИ НЕ РезультатСтатуса.Свойство("Результат") Тогда
		Возврат Ложь;
	КонецЕсли;

	ТекущаяСтраница = РезультатСтатуса.ТекущаяСтраница;
	Результат = РезультатСтатуса.Результат;

	НуженДиалог = Ложь;

	Если ТекущаяСтраница = "СтраницаСопоставления" Тогда
		ПрименитьРезультатСопоставления(Результат);
	ИначеЕсли ТекущаяСтраница = "СтраницаСверка" Тогда
		ПрименитьРезультатСверки(Результат);
		НуженДиалог = НуженДиалогПерезагрузкиЧеков(Результат);
	ИначеЕсли ТекущаяСтраница = "СтраницаФормирование" Тогда
		НуженДиалог = ПрименитьРезультатФормирования(Результат, РезультатСтатуса);
	ИначеЕсли ТекущаяСтраница = "СтраницаОстатки" Тогда
		ПрименитьРезультатОстатков(Результат, РезультатСтатуса);
	КонецЕсли;

	ОбновитьПредставлениеСтатусовШаговНаСервере();

	Возврат НуженДиалог;

КонецФункции

// Определяет, нужно ли предложить перезагрузку чеков после сверки.
//
// Параметры:
//  Результат - Структура - результат шага сверки
//
// Возвращаемое значение:
//  Булево - Истина, если есть отклонения, не связанные с ошибкой фронта
//
&НаСервере
Функция НуженДиалогПерезагрузкиЧеков(Результат)

	Если Результат.Статус <> "НеПройден" Тогда
		Возврат Ложь;
	КонецЕсли;

	Для Каждого Строка Из Результат.Строки Цикл
		Если Строка.КатегорияОтклонения <> "ОшибкаФронта" Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;

	Возврат Ложь;

КонецФункции

// Применяет данные шага сопоставления к таблицам формы.
//
&НаСервере
Процедура ПрименитьРезультатСопоставления(Результат)

	Для Каждого СтрокаСтатуса Из СтатусыШагов Цикл
		Если СтрокаСтатуса.Номер = 1 Тогда
			СтрокаСтатуса.Статус = Результат.Статус;
		КонецЕсли;
	КонецЦикла;

	НесопоставленныеОбъекты.Очистить();

	Для Каждого Строка Из Результат.Строки Цикл
		Новая = НесопоставленныеОбъекты.Добавить();
		Новая.ТипОбъекта           = Строка.ТипОбъекта;
		Новая.ФронтСистема         = Строка.ФронтСистема;
		Новая.Код                  = Строка.Код;
		Новая.НаименованиеНаФронте = Строка.НаименованиеНаФронте;
		Новая.ОбъектДляСопоставления = Строка.ОбъектДляСопоставления;
		Новая.Количество           = Строка.Количество;
		Новая.Отмечен              = Ложь;
	КонецЦикла;

КонецПроцедуры

